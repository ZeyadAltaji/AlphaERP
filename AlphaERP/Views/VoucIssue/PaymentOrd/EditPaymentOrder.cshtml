        $('#Model_ePaymentOrd_InvItemsMF_' + srl).modal('show');
    }

    function LoadItemRawMaterial(r) {
        if (frmSatus == 1) {
            $('#ePaymentOrdDFTBody_' + srls).append(r);
        }
        else {
            $('#ePaymentOrdDFTBody_' + srls).append(r);
        }
