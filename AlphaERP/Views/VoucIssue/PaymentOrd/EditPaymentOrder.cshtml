                                        </td>
                                        <td>
                                            <input type="text" style="width: 115px !important; text-align: center !important" id="ePaymentOrd_DocumentArchive_Description_@Count" value="@row["Description"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="ePaymentOrd_DocumentArchive_File_@Count" onchange="uploadFile(this,@Count,@VouNo)" /></div>
                                        </td>
                                        <td></td>
                                        <td>
                                            <a id="ePaymentOrd_DownloadFile_@Count" onclick="DownloadFile('@row["FileName"].ToString()','@Convert.ToBase64String((byte[])row["ArchiveData"])')"><span class="glyphicon glyphicon-download"></span></a>
                                        </td>
                                        <td>
                                            <input id="ePaymentOrd_DocumentArchive_FileName_@Count" type="text" style="text-align: center !important" value="@row["FileName"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="ePaymentOrd_DocumentArchive_UploadDate_@Count" type="text" style="width: 95px; text-align: center !important" value="@date.ToShortDateString()" disabled />
                                        </td>
                                        <td>
                                            <input id="ePaymentOrd_DocumentArchive_FileSize_@Count" type="text" style="width: 70px; text-align: center !important" value="@row["FileSize"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="ePaymentOrd_DocumentArchive_FileType_@Count" type="text" style="width: 55px; text-align: center !important" value="@row["ContentType"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <button class="btn-de" onclick="RemoveRowUpload(this,@Count,@VouNo)" type="button"><i class="fa fa-trash-alt"></i></button>
                                            <input type="hidden" id="InputSerial" value="@(Count++)" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="EditPaymentOrdDocumentArchive(@VouNo)" class="btn btn-primary">@Resources.Resource.Save</button>
            </div>
        </form>
    </div>
</div>
<script>
    var Count = 0;
    
    function EditPaymentOrdDocuments(Srl) {
        $('#Model_ePaymentOrd_DocumentsArchive_' + Srl).draggable({
            handle: ".modal-header",
        });
        $('#Model_ePaymentOrd_DocumentsArchive_' + Srl).modal('show');
        var table = $("#ePaymentOrd_DocumentArchiveTbody_" + Srl);
        var trs = table.find('tr');
        Count = trs.length;
    }
    function Add_ePaymentOrd_DocumentArchive(Srl) {
        var table = $("#ePaymentOrd_DocumentArchiveTbody_" + Srl);

        Count++;
        var newarray = [];
        newarray.push('<input id="ePaymentOrd_DocumentArchive_FileId" type="hidden" value="' + Count + '" />')
        newarray.push('<input id="ePaymentOrd_DocumentArchive_Description_' + Count + '" type="text" style="width: 115px !important;text-align: center !important" />')
        newarray.push('<div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="ePaymentOrd_DocumentArchive_File_' + Count + '" onchange="uploadFile(this,' + Count + ',' + Srl + ')" /></div>')
        newarray.push('')
        newarray.push('<a id="ePaymentOrd_DownloadFile_' + Count + '" onclick="DownloadFile()"><span class="glyphicon glyphicon-download"></span></a>')
        newarray.push('<input id="ePaymentOrd_DocumentArchive_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="ePaymentOrd_DocumentArchive_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="ePaymentOrd_DocumentArchive_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="ePaymentOrd_DocumentArchive_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ',' + Srl + ')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $(table).append(
            GenRowDocumentArchive(newarray, 'ePaymentOrd_DocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        var $td = $(ID).closest("td");
        $($td).find("input[type=file]").click();
    }
    function uploadFile(Elem, Count, srl) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;

        var table = $("#ePaymentOrd_DocumentArchiveTbody_" + srl);
        var tr = table.find('#ePaymentOrd_DocumentArchive_' + Count);

        var fileName = tr.find("#ePaymentOrd_DocumentArchive_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        tr.find('#ePaymentOrd_DocumentArchive_FileName_' + Count)[0].value = fileName;
        tr.find('#ePaymentOrd_DocumentArchive_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#ePaymentOrd_DocumentArchive_FileSize_' + Count)[0].value = file_size;
        tr.find('#ePaymentOrd_DocumentArchive_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }

            var OrderYear = $('#Ord_ePaymentOrder_OrdYear_' + srl).val();
            var OrderNo = $('#Ord_ePaymentOrder_OrderNo_' + srl).val();
            var TawreedNo = $('#Ord_ePaymentOrder_TawreedNo_' + srl).val();
            var VouNo = $('#Ord_ePaymentOrder_PayOrderNo_' + srl).val();

            $formData.append('Id', Count);
            $formData.append('OrderYear', OrderYear);
            $formData.append('OrderNo', OrderNo);
            $formData.append('TawreedNo', TawreedNo);
            $formData.append('VouNo', VouNo);
            $formData.append('VouType', 11);
        }

        $.ajax({
            url: '@Url.Action("InsertFile", "VoucIssue")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function (r) {
                var table = $("#ePaymentOrd_DocumentArchiveTbody_" + srl);
                var tr = table.find('#ePaymentOrd_DocumentArchive_' + Count);
                tr.find('#ePaymentOrd_DownloadFile_' + Count)[0].setAttribute('onclick', 'DownloadFile("' + fileName + '","' + r + '")')
            },
            error: function (error) {
            }
        });
    }
    function RemoveRowUpload(e, Count, srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            var OrderYear = $('#Ord_ePaymentOrder_OrdYear_' + srl).val();
            var OrderNo = $('#Ord_ePaymentOrder_OrderNo_' + srl).val();
            var TawreedNo = $('#Ord_ePaymentOrder_TawreedNo_' + srl).val();
            var VouNo = $('#Ord_ePaymentOrder_PayOrderNo_' + srl).val();

            $.ajax({
                type: "POST",
                url:'@Url.Action("RemoveFile", "VoucIssue")',
                data: { Id: Count, OrderYear: OrderYear, OrderNo: OrderNo, TawreedNo: TawreedNo, VouNo: VouNo, VouType: 11 },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function EditPaymentOrdDocumentArchive(srl) {
        $('#Model_ePaymentOrd_DocumentsArchive_' + srl).modal('hide')
    }
</script>
