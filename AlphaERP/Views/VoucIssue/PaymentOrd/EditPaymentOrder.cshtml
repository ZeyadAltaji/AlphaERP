    }
    function RemoveRowePayment(e, srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            SumTotalQty(srl)
            return true;
        }
        return false;
    }
    SumTotalQty(@VouNo)
    function SumTotalQty(id) {
        var table = $("#ePaymentOrdDFTBody_" + id);
        var trs = table.find('tr');

        var TotalQty = 0
        var TotalQty2 = 0
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            TotalQty += Number($(trs[i]).closest('tr').find('#eOrderItems_Qty_' + InputSerial)[0].value);
            TotalQty2 += Number($(trs[i]).closest('tr').find('#eOrderItems_Qty2_' + InputSerial)[0].value);
        }

        $('#eTotalQty1_' + id).html(Number(TotalQty).toFixed(3));
        $('#eTotalQty2_' + id).html(Number(TotalQty2).toFixed(3));
    }
    function CheckValueGrid(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt == 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
        else {
            if (Amt == '' || Amt == null) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function ExcuteEdit_PaymentOrdInfo(id) {
        var table = $("#ePaymentOrdDFTBody_" + id);
        var trs = table.find('tr');


        var OrdVoucIssueHF = {
            CompNo: '@company.comp_num',
            OrderYear: $('#Ord_ePaymentOrder_OrdYear_' + id).val(),
            OrderNo: $('#Ord_ePaymentOrder_OrderNo_' + id).val(),
            TawreedNo: $('#Ord_ePaymentOrder_TawreedNo_' + id).val(),
            VouType: 11,
            VouNo: $('#Ord_ePaymentOrder_PayOrderNo_' + id).val(),
            ShipSer: "",
            DocType: $('#Ord_ePaymentOrder_CboDocType_' + id).val(),
            StoreNo: $('#Ord_ePaymentOrder_CboStoreNo_' + id).val(),
            VouDate: $('#Ord_ePaymentOrder_PayOrderDate_' + id).val(),
            Notes: $('#Ord_ePaymentOrder_Notes_' + id).val()
        }

        var OrdVoucIssueDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            if ($(trs[i]).closest('tr').find('#eOrderItems_Qty_' + InputSerial)[0].value > 0) {
                OrdVoucIssueDF.push({
                    CompNo: '@company.comp_num',
                    OrderYear: $('#Ord_ePaymentOrder_OrdYear_' + id).val(),
                    OrderNo: $('#Ord_ePaymentOrder_OrderNo_' + id).val(),
                    TawreedNo: $('#Ord_ePaymentOrder_TawreedNo_' + id).val(),
                    VouType: 11,
                    VouNo: $('#Ord_ePaymentOrder_PayOrderNo_' + id).val(),
                    ItemNo: $(trs[i]).closest('tr').find('#eOrderItems_ItemNo')[0].innerHTML,
                    ShipSer: "",
                    Qty: $(trs[i]).closest('tr').find('#eOrderItems_Qty_' + InputSerial)[0].value,
                    TUnit: $(trs[i]).closest('tr').find('.eOrderItems_Unit option:Selected')[0].getAttribute('unitCode'),
                    UnitSerial: $(trs[i]).closest('tr').find('.eOrderItems_Unit')[0].value,
                    Qty2: $(trs[i]).closest('tr').find('#eOrderItems_Qty2_' + InputSerial)[0].value
                })
            }
        }

        if (OrdVoucIssueDF.length == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        var DocumentArchivetable = $("#ePaymentOrd_DocumentArchiveTbody_" + id);
        var trsDocumentArchive = DocumentArchivetable.find('tr');
        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#ePaymentOrd_DocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                OrderYear: $('#Ord_ePaymentOrder_OrdYear_' + id).val(),
                OrderNo: $('#Ord_ePaymentOrder_OrderNo_' + id).val(),
                TawreedNo: $('#Ord_ePaymentOrder_TawreedNo_' + id).val(),
                VouType: 11,
                VouNo: $('#Ord_ePaymentOrder_PayOrderNo_' + id).val(),
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#ePaymentOrd_DocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#ePaymentOrd_DocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#ePaymentOrd_DocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ OrdVoucIssueHF: OrdVoucIssueHF, OrdVoucIssueDF: OrdVoucIssueDF, FileArchive: DocumentArchive }, '../../../VoucIssue/Edit_PaymentOrder', '', ReloadePaymentOrderInfo, false);
    }
    function ReloadePaymentOrderInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#VoucIssueInfoTBody').empty();
        var TawreedNo = r.TawreedNo;
        CloseWindow('/VoucIssue/EditPaymentOrder?OrdYear=' + r.OrdYear + '&OrderNo=' + r.OrderNo + '&TawreedNo=' + TawreedNo + '&VouNo=' + r.VouNo + '&VouType=' + r.VouType + '')
        var table = $("#OrdVoucIssueTable tbody");
        var trs = table.find('tr');
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrderNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');

                $.get("../../../../VoucIssue/DetailsPaymentOrderRec?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo, function (data) {
                    OrdVoucIssueTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }
</script>