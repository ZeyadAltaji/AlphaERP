    var itemType = 0;
    var srls = 0;
    var frmSatus = 1;

    function Add_InvItemsMF(type, srl) {
        itemType = type;
        srls = srl;
        frmSatus = 1;
        var table = $("#SelectPaymentOrdItemTable_" + srl);
        table.find('tr').removeClass("selected");
        var StoreNo = $('#Ord_PaymentOrder_CboStoreNo_' + srl).val();

        var Tbody = $("#PaymentOrdItemTbody_" + srl);
        Tbody.innerHTML = "";
        $(Tbody).load('../../../VoucIssue/PaymentOrdItemsList?StoreNo=' + StoreNo + '&srl=' + srl);
        $('#Model_PaymentOrd_InvItemsMF_' + srl).draggable({
            handle: ".modal-header",
        });

        $('#Model_PaymentOrd_InvItemsMF_' + srl).modal('show');
    }
    function LoadItemRawMaterial(r) {
        if (frmSatus == 1) {
            $('#PaymentOrdDFTBody_' + srls).append(r);
        }
        else {
            $('#PaymentOrdDFTBody_' + srls).append(r);
        }
        $('#Model_PaymentOrd_InvItemsMF_' + srls).modal('hide')
    }
    function RemoveRowPayment(e,srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            SumTotalQty(srl)
            return true;
        }
        return false;
    }
    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#PaymentOrdDFTBody_" + id);
        var trs = table.find('tr');

        var TotalQty = 0
        var TotalQty2 = 0
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            TotalQty += Number($(trs[i]).closest('tr').find('#OrderItems_Qty_' + InputSerial)[0].value);
            TotalQty2 += Number($(trs[i]).closest('tr').find('#OrderItems_Qty2_' + InputSerial)[0].value);
        }

        $('#TotalQty1_' + id).html(Number(TotalQty).toFixed(3));
        $('#TotalQty2_' + id).html(Number(TotalQty2).toFixed(3));
    }
    function CheckValueGrid(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt == 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
        else {
            if (Amt == '' || Amt == null) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function ExcuteSave_PaymentOrdInfo(id) {
        var table = $("#PaymentOrdDFTBody_" + id);
        var trs = table.find('tr');

        var OrdVoucIssueHF = {
            CompNo: '@company.comp_num',
            OrderYear: $('#Ord_PaymentOrder_OrdYear_' + id).val(),
            OrderNo: $('#Ord_PaymentOrder_OrderNo_' + id).val(),
            TawreedNo: $('#Ord_PaymentOrder_TawreedNo_' + id).val(),
            VouType: 11,
            VouNo: $('#Ord_PaymentOrder_PayOrderNo_' + id).val(),
            ShipSer: "",
            DocType: $('#Ord_PaymentOrder_CboDocType_' + id).val(),
            StoreNo: $('#Ord_PaymentOrder_CboStoreNo_' + id).val(),
            VouDate: $('#Ord_PaymentOrder_PayOrderDate_' + id).val(),
            Notes: $('#Ord_PaymentOrder_Notes_' + id).val(),
        }

        var OrdVoucIssueDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            if ($(trs[i]).closest('tr').find('#OrderItems_Qty_' + InputSerial)[0].value > 0) {
                OrdVoucIssueDF.push({
                    CompNo: '@company.comp_num',
                    OrderYear: $('#Ord_PaymentOrder_OrdYear_' + id).val(),
                    OrderNo: $('#Ord_PaymentOrder_OrderNo_' + id).val(),
                    TawreedNo: $('#Ord_PaymentOrder_TawreedNo_' + id).val(),
                    VouType: 11,
                    VouNo: $('#Ord_PaymentOrder_PayOrderNo_' + id).val(),
                    ItemNo: $(trs[i]).closest('tr').find('#OrderItems_ItemNo')[0].innerHTML,
                    ShipSer: "",
                    Qty: $(trs[i]).closest('tr').find('#OrderItems_Qty_' + InputSerial)[0].value,
                    TUnit: $(trs[i]).closest('tr').find('.OrderItems_Unit option:Selected')[0].getAttribute('unitCode'),
                    UnitSerial: $(trs[i]).closest('tr').find('.OrderItems_Unit')[0].value,
                    Qty2: $(trs[i]).closest('tr').find('#OrderItems_Qty2_' + InputSerial)[0].value
                })
            }
        }

        if (OrdVoucIssueDF.length == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        var DocumentArchivetable = $("#PaymentOrd_DocumentArchiveTbody_" + id);
        var trsDocumentArchive = DocumentArchivetable.find('tr');


        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#PaymentOrd_DocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                OrderYear: $('#Ord_PaymentOrder_OrdYear_' + id).val(),
                OrderNo: $('#Ord_PaymentOrder_OrderNo_' + id).val(),
                TawreedNo: $('#Ord_PaymentOrder_TawreedNo_' + id).val(),
                VouType: 11,
                VouNo: $('#Ord_PaymentOrder_PayOrderNo_' + id).val(),
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#PaymentOrd_DocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#PaymentOrd_DocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#PaymentOrd_DocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ OrdVoucIssueHF: OrdVoucIssueHF, OrdVoucIssueDF: OrdVoucIssueDF, FileArchive: DocumentArchive }, '../../../VoucIssue/Save_PaymentOrder', '', ReloadPaymentOrderInfo, false);
    }
    function ReloadPaymentOrderInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#VoucIssueInfoTBody').empty();
        var TawreedNo = r.TawreedNo;
        CloseWindow('/VoucIssue/AddPaymentOrder?OrdYear=' + r.OrdYear + '&OrderNo=' + r.OrderNo + '&TawreedNo=' + TawreedNo + '')

        var table = $("#OrdVoucIssueTable tbody");
        var trs = table.find('tr');
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrderNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');

                $.get("../../../../VoucIssue/DetailsPaymentOrderRec?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo, function (data) {
                    OrdVoucIssueTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }
</script>