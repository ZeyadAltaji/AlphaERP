                                string UnitSerial = DF.UnitSerial.Value.ToString();

                                <tr id="ViewOrderItems_Serial_@Srial">
                                    <td style="width: 10%; word-wrap: break-word; white-space: normal;" id="ViewOrderItems_ItemNo">@DF.ItemNo</td>
