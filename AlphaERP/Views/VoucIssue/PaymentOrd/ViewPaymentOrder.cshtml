            <hr />
            <div class="form-group" style="display: block; height: 225px;">
                <div class="col-md-12 wrapperx" id="ViewPaymentOrd_DIV">
                    <table class="table table-hover ViewPaymentOrdDF_Info" id="ViewPaymentOrdDF_Info">
                        <thead>
                            <tr>
                                <th style="text-align: center; width: 350px; word-wrap: break-word; white-space: normal;">@Html.Recource(44)</th>
                                <th style="text-align: center; width: 990px; word-wrap: break-word; white-space: normal;">@Html.Recource(74)</th>
                                <th style="width: 205px; word-wrap: break-word; white-space: normal;">@Html.Recource(67)</th>
                                @if (CActive.ClientNo == 335)
                                {
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(5693)</th>
                                }
                                else
                                {
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(49)</th>
                                }
                                @if (compMF.UseQty2 == true)
                                {
                                    if (CActive.ClientNo == 335)
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(442)</th>
                                    }
                                    else
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(72)</th>
                                    }
                                }
                                else
                                {
                                    <th hidden>@Html.Recource(72)</th>
                                }
                                <th></th>
                            </tr>
                        </thead>
                        <tfoot>
                            <tr>
                                <th style="text-align: center;" colspan="3">@Html.Translate("الاجمالي", "Total")</th>
                                <th style="text-align:center;" id="vTotalQty1">0</th>
                                @if (compMF.UseQty2 == true)
                                {
                                    <th style="text-align:center;" id="vTotalQty2">0</th>
                                }
                                else
                                {
                                    <th hidden id="vTotalQty2">0</th>
                                }
                                <th></th>
