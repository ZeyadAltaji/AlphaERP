                                    <td style="text-align: center; width: 10%;">
                                        <select style="width:100%" class="ViewOrderItems_Unit" disabled>
                                            @{
                                                using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                                {
                                                    Dt = new DataTable();
                                                    cn.Open();
                                                    using (SqlCommand cmd = new SqlCommand())
                                                    {
                                                        cmd.Connection = cn;
                                                        cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                        cmd.CommandText = "InvT_LoadItemUnits";
                                                        cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                        cmd.Parameters.Add(new SqlParameter("@ItemCode", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                        using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                        {
                                                            DA.Fill(Dt);
                                                        }
                                                    }
                                                }
                                            }
                                            @foreach (DataRow row in Dt.Rows)
                                            {
                                                if (UnitSerial == row["UnitSerial"].ToString())
                                                {
                                                    <option value="@row["UnitSerial"].ToString()" selected>
                                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option value="@row["UnitSerial"].ToString()">
                                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                    </option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td style="text-align: center;">
                                        <input id="ViewOrderItems_Qty_@Srial" value="@DF.Qty" type="number" style="width:75px !important" disabled />
                                    </td>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <td style="text-align: center;">
                                            <input id="ViewOrderItems_Qty2_@Srial" value="@DF.Qty2" type="number" style="width:75px !important" disabled />
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="text-align: center;" hidden>
                                            <input id="ViewOrderItems_Qty2_@Srial" value="@DF.Qty2" type="number" style="width:75px !important" disabled />
                                        </td>
                                    }
                                <td>
                                    <input type="hidden" id="InputSerial" value="@(Srial++)" />
                                </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@*-----------------------------Model PaymentOrd_Documents-------------------------------------*@
<div class="modal fade" id="Model_ViewPaymentOrd_DocumentsArchive">
    <div class="modal-dialog" style="width:800px; ">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Translate("أرشفة الوثائق", "Archive Documents")</label>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-12" style="overflow-y:auto">
                        <table class="table table-hover" id="VPaymentOrd_DocumentArchiveTable">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(66)</th>
                                    <th style="text-align: center !important">@Html.Recource(5629)</th>
                                    <th style="text-align: center !important">@Html.Recource(5630)</th>
                                    <th style="text-align: center !important">@Html.Recource(5631)</th>
                                    <th style="text-align: center !important">@Html.Recource(5632)</th>
                                    <th style="text-align: center !important">@Html.Recource(5633)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="VPaymentOrd_DocumentArchiveTbody" style="border-top: 1px solid #ddd;">
                                @foreach (DataRow row in DtAttachment.Rows)
                                {
                                    DateTime date = Convert.ToDateTime(row["DataUpload"].ToString());
                                    <tr id="ePaymentOrd_DocumentArchive_@Count">
                                        <td>
                                            <input  type="hidden" value="@Count" />
                                        </td>
                                        <td>
                                            <input type="text" style="width: 115px !important; text-align: center !important" id="ePaymentOrd_DocumentArchive_Description_@Count" value="@row["Description"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <a  onclick="DownloadFile('@row["FileName"].ToString()','@Convert.ToBase64String((byte[])row["ArchiveData"])')"><span class="glyphicon glyphicon-download"></span></a>
                                        </td>
                                        <td>
                                            <input type="text" style="text-align: center !important" value="@row["FileName"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input type="text" style="width: 95px; text-align: center !important" value="@date.ToShortDateString()" disabled />
                                        </td>
                                        <td>
                                            <input type="text" style="width: 70px; text-align: center !important" value="@row["FileSize"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input type="text" style="width: 55px; text-align: center !important" value="@row["ContentType"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input type="hidden" id="InputSerial" value="@(Count++)" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="VPaymentOrdDocumentArchive()" class="btn btn-primary">@Resources.Resource.Save</button>
            </div>
        </form>
    </div>
</div>
<script>
    var DocumentsArchiveValue = 0;
    var Count = 0;
    $('#Model_ViewPaymentOrd_DocumentsArchive').draggable({
        handle: ".modal-header",
    });
    function ViewPaymentOrdDocuments(val) {
        DocumentsArchiveValue = val;
        $('#Model_ViewPaymentOrd_DocumentsArchive').modal('show')
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function VPaymentOrdDocumentArchive() {
        $('#Model_ViewPaymentOrd_DocumentsArchive').modal('hide')
    }
</script>
@*--------------------------------END Model PaymentOrd_Documents -----------------------------*@


<script>
    $('#Ord_VPaymentOrder_CboDocType').select2();
    $('#Ord_VPaymentOrder_CboStoreNo').select2();
    $('.ViewOrderItems_Unit').select2();
    SumTotalQty()
    function SumTotalQty() {
        var table = $('#ViewPaymentOrdDFTBody tr');
        var trs = table;
        var TotalQty = 0
        var TotalQty2 = 0
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            TotalQty += Number($(trs[i]).closest('tr').find('#ViewOrderItems_Qty_' + InputSerial)[0].value);
            TotalQty2 += Number($(trs[i]).closest('tr').find('#ViewOrderItems_Qty2_' + InputSerial)[0].value);
        }

        $('#vTotalQty1').html(Number(TotalQty).toFixed(3));
        $('#vTotalQty2').html(Number(TotalQty2).toFixed(3));
    }
</script>