<div class="modal fade" id="Model_WriteOff_DocumentsArchive_@srl">
    <div class="modal-dialog" style="width:800px; ">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Translate("أرشفة الوثائق", "Archive Documents")</label>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-12">
                        <button onclick="Add_WriteOff_DocumentArchive(@srl)" type="button" class="btn btn-primary">@Html.Recource(32)</button>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-12" style="overflow-y:auto">
                        <table class="table table-hover" id="WriteOff_DocumentArchiveTable">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(66)</th>
                                    <th style="text-align: center !important">@Html.Recource(5628)</th>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(5629)</th>
                                    <th style="text-align: center !important">@Html.Recource(5630)</th>
                                    <th style="text-align: center !important">@Html.Recource(5631)</th>
                                    <th style="text-align: center !important">@Html.Recource(5632)</th>
                                    <th style="text-align: center !important">@Html.Recource(5633)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="WriteOff_DocumentArchiveTbody_@srl" style="border-top: 1px solid #ddd;">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="SaveWriteOffDocumentArchive(@srl)" class="btn btn-primary">@Resources.Resource.Save</button>
            </div>
        </form>
    </div>
</div>
<script>
    var Count = 0;
   
    function AddWriteOffDocuments(Srl) {
        $('#Model_WriteOff_DocumentsArchive_' + Srl).draggable({
            handle: ".modal-header",
        });
        $('#Model_WriteOff_DocumentsArchive_' + Srl).modal('show')
    }
    function Add_WriteOff_DocumentArchive(srl) {
        var table = $("#WriteOff_DocumentArchiveTbody_" + srl);
        Count++;
        var newarray = [];
        newarray.push('<input id="WriteOff_DocumentArchive_FileId" type="hidden" value="' + Count + '" />')
        newarray.push('<input id="WriteOff_DocumentArchive_Description_' + Count + '" type="text" style="width: 115px !important;text-align: center !important" />')
        newarray.push('<div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="WriteOff_DocumentArchive_File_' + Count + '" onchange="uploadFile(this,' + Count + ',' + srl +')" /></div>')
        newarray.push('')
        newarray.push('<a id="WriteOff_DownloadFile_' + Count + '" onclick="DownloadFile()"><span class="glyphicon glyphicon-download"></span></a>')
        newarray.push('<input id="WriteOff_DocumentArchive_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="WriteOff_DocumentArchive_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="WriteOff_DocumentArchive_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="WriteOff_DocumentArchive_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ',' + srl +')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $(table).append(
            GenRowDocumentArchive(newarray, 'WriteOff_DocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        var $td = $(ID).closest("td");
        $($td).find("input[type=file]").click();
    }
    function uploadFile(Elem, Count, srl) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;

        var table = $("#WriteOff_DocumentArchiveTbody_" + srl);
        var tr = table.find('#WriteOff_DocumentArchive_' + Count);

        var fileName = tr.find("#WriteOff_DocumentArchive_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        tr.find('#WriteOff_DocumentArchive_FileName_' + Count)[0].value = fileName;
        tr.find('#WriteOff_DocumentArchive_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#WriteOff_DocumentArchive_FileSize_' + Count)[0].value = file_size;
        tr.find('#WriteOff_DocumentArchive_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }

            var OrderYear = $('#Ord_WriteOff_OrdYear_' + srl).val();
            var OrderNo = $('#Ord_WriteOff_OrderNo_' + srl).val();
            var TawreedNo = $('#Ord_WriteOff_TawreedNo_' + srl).val();
            var ShipSer = $('#Ord_WriteOff_ShipSer_' + srl).val();

            $formData.append('Id', Count);
            $formData.append('OrderYear', OrderYear);
            $formData.append('OrderNo', OrderNo);
            $formData.append('TawreedNo', TawreedNo);
            $formData.append('ShipSer', ShipSer);
            $formData.append('VouNo', 0);
            $formData.append('VouType', 13);
        }

        $.ajax({
            url: '@Url.Action("InsertFileWriteOff", "VoucIssue")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function (r) {
                var table = $("#WriteOff_DocumentArchiveTbody_" + srl);
                var tr = table.find('#WriteOff_DocumentArchive_' + Count);
                tr.find('#WriteOff_DownloadFile_' + Count)[0].setAttribute('onclick', 'DownloadFile("' + fileName + '","' + r + '")')
            },
            error: function (error) {
            }
        });
    }
    function RemoveRowUpload(e, Count, srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            var OrderYear = $('#Ord_WriteOff_OrdYear_' + srl).val();
            var OrderNo = $('#Ord_WriteOff_OrderNo_' + srl).val();
            var TawreedNo = $('#Ord_WriteOff_TawreedNo_' + srl).val();
            var ShipSer = $('#Ord_WriteOff_ShipSer_' + srl).val();
            $.ajax({
                type: "POST",
                url:'@Url.Action("RemoveFileWriteOff", "VoucIssue")',
                data: { Id: Count, OrderYear: OrderYear, OrderNo: OrderNo, TawreedNo: TawreedNo, ShipSer: ShipSer, VouNo: 0, VouType: 13 },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function SaveWriteOffDocumentArchive(srl) {
        $('#Model_WriteOff_DocumentsArchive_' + srl).modal('hide')
    }
</script>
@*--------------------------------END Model WriteOff_Documents -----------------------------*@

@*-----------------------------Model WriteOff_InvItemsMF-------------------------------------*@
<div class="modal fade wide" id="Model_WriteOff_InvItemsMF_@srl">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(4756)</label>
            </div>
            <div class="box-body box-profile" id="eWriteOffItemTbody">
                <div class="modal-body row">
                    <div class="form-group">
                        <div class="col-md-12">
                            <table class="table table-hover" id="SelectWriteOffItemTable_@srl">
                                <thead>
                                    <tr>
                                        <th>@Html.Recource(44)</th>
                                        <th>@Html.Recource(74)</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (Ord_PortInfoDF item in PortInfoDF)
                                    {
                                        InvItemsMF M = new MDB().InvItemsMFs.Where(x => x.CompNo == company.comp_num && x.ItemNo == item.ItemNo).FirstOrDefault();
                                        string Desc = Html.Translate(M.ItemDesc, M.ItemDesc_Ara).ToString();
                                        <tr onclick="$(this).toggleClass('selected');">
                                            <td id="ItemNo">@item.ItemNo</td>
                                            <td id="ItemDesca" title="@Desc">@Html.Trim(Desc, 50)</td>
                                            <td></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" onclick="Selecting_WriteOff_InvItemsMF(@srl)" class="btn btn-primary">@Html.Recource(4599)</button>
                    <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
                </div>
            </div>
        </form>
    </div>
</div>
<script>
    var Items = $('#SelectWriteOffItemTable_' + @srl).DataTable({
        "scrollY": TableHeight2(350),
        "paging": true,
        "pageLength": 25,
        "scrollX": true,
        "autoWidth": false
    });

    var itemType = 0;
    var srls = 0;
    var frmSatus = 1;
    function Add_InvItemsMF(type, srl) {
        itemType = type;
        srls = srl;
        frmSatus = 1;
        var table = $("#SelectWriteOffItemTable_" + srl);
        table.find('tr').removeClass("selected");

        $('#Model_WriteOff_InvItemsMF_' + srl).draggable({
            handle: ".modal-header",
        });
        $('#Model_WriteOff_InvItemsMF_' + srl).modal('show');
    }
    function Selecting_WriteOff_InvItemsMF(id) {
        var data = Items.rows('.selected').data();

        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة واحدة على الاقل", "Select one item at least")');
            return;
        }
        if (frmSatus == 1) {
            if (itemType == 1) {
                var table_ = $("#WriteOffOrdDFTBody_" + id);
                var item = new Array();
                for (var i = 0; i < data.length; i++) {
                    var Added = false;
                    if (table_.find("tr").length != 0) {
                        table_.find("tr").each(function () {
                            var ItemNo_ = $(this).find("td:first-child").text();
                            if (ItemNo_ == data[i][0]) {
                                Added = true;
                                return false;
                            }
                            else {
                                Added = false;
                            }
                        });
                        if (!Added) {
                            item.push({
                                ItemNo: data[i][0],
                                ItemDesc: data[i][1]
                            });
                        }
                    }
                    else {
                        item.push({
                            ItemNo: data[i][0],
                            ItemDesc: data[i][1]
                        });
                    }
                }
                if (item.length != 0) {
                    burn({ items: item, srl: table_.find("tr").length, id: id }, '../../../VoucIssue/ChooseWriteOffOrdItems', '', LoadItemRawMaterial, true);
                }
                else {
                    $('#Model_WriteOff_InvItemsMF_' + srl).modal('hide')
                }
            }
        }
    }
    function LoadItemRawMaterial(r) {
        if (frmSatus == 1) {
            $('#WriteOffOrdDFTBody_' + srls).append(r);
        }
        else {
            $('#WriteOffOrdDFTBody_' + srls).append(r);
        }
        $('#Model_WriteOff_InvItemsMF_' + srls).modal('hide')
    }
</script>
@*--------------------------------END Model WriteOff_InvItemsMF -----------------------------*@

<script>
    $('#Ord_WriteOff_CboDocType_' + @srl).select2();
    $('#Ord_WriteOff_CboStoreNo_' + @srl).select2();
    $('.WriteOff_Unit').select2();
    function GetValueqty(e, srl) {
        if (e.value < 0) {
            alert('@Html.Translate("لا يجوز ان تكون الكمية اقل من 0", "The value of the Qty may not be less than 0")');
            e.value = 0;
            e.focus()
            return false;
        }
        SumTotalQty(srl)
    }
    function GetValueqty2(e, srl) {
        if (e.value < 0) {
            alert('@Html.Translate("لا يجوز ان تكون الكمية 2 اقل من 0", "The value of the Qty 2 may not be less than 0")');
            e.value = 0;
            e.focus()
            return false;
        }
        SumTotalQty(srl)
    }
    function RemoveRowWriteOff(e, srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            SumTotalQty(srl)
            return true;
        }
        return false;
    }
    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#WriteOffOrdDFTBody_" + id);
        var trs = table.find('tr');

        var TotalQty = 0
        var TotalQty2 = 0
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            TotalQty += Number($(trs[i]).closest('tr').find('#WriteOff_Qty_' + InputSerial)[0].value);
            TotalQty2 += Number($(trs[i]).closest('tr').find('#WriteOff_Qty2_' + InputSerial)[0].value);
        }

        $('#TotalQty1_' + id).html(Number(TotalQty).toFixed(3));
        $('#TotalQty2_' + id).html(Number(TotalQty2).toFixed(3));
    }
    function CheckValueGrid(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt == 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
        else {
            if (Amt == '' || Amt == null) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function ExcuteSave_WriteOffInfo(id) {
        var table = $("#WriteOffOrdDFTBody_" + id);
        var trs = table.find('tr');

        var OrdVoucIssueHF = {
            CompNo: '@company.comp_num',
            OrderYear: $('#Ord_WriteOff_OrdYear_' + id).val(),
            OrderNo: $('#Ord_WriteOff_OrderNo_' + id).val(),
            TawreedNo: $('#Ord_WriteOff_TawreedNo_' + id).val(),
            VouType: 13,
            VouNo: $('#Ord_WriteOff_PayOrderNo_' + id).val(),
            ShipSer: $('#Ord_WriteOff_ShipSer_' + id).val(),
            DocType: $('#Ord_WriteOff_CboDocType_' + id).val(),
            StoreNo: $('#Ord_WriteOff_CboStoreNo_' + id).val(),
            VouDate: $('#Ord_WriteOff_PayOrderDate_' + id).val(),
            Notes: $('#Ord_WriteOff_Notes_' + id).val()
        }

        var OrdVoucIssueDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            if ($(trs[i]).closest('tr').find('#WriteOff_Qty_' + InputSerial)[0].value > 0) {
                OrdVoucIssueDF.push({
                    CompNo: '@company.comp_num',
                    OrderYear: $('#Ord_WriteOff_OrdYear_' + id).val(),
                    OrderNo: $('#Ord_WriteOff_OrderNo_' + id).val(),
                    TawreedNo: $('#Ord_WriteOff_TawreedNo_' + id).val(),
                    VouType: 13,
                    VouNo: $('#Ord_WriteOff_PayOrderNo_' + id).val(),
                    ItemNo: $(trs[i]).closest('tr').find('#WriteOff_ItemNo')[0].innerHTML,
                    ShipSer: $('#Ord_WriteOff_ShipSer_' + id).val(),
                    Qty: $(trs[i]).closest('tr').find('#WriteOff_Qty_' + InputSerial)[0].value,
                    TUnit: $(trs[i]).closest('tr').find('.WriteOff_Unit option:Selected')[0].getAttribute('unitCode'),
                    UnitSerial: $(trs[i]).closest('tr').find('.WriteOff_Unit')[0].value,
                    Qty2: $(trs[i]).closest('tr').find('#WriteOff_Qty2_' + InputSerial)[0].value
                })
            }
        }

        if (OrdVoucIssueDF.length == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        var DocumentArchivetable = $("#WriteOff_DocumentArchiveTbody_" + id);
        var trsDocumentArchive = DocumentArchivetable.find('tr');

        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#WriteOff_DocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                OrderYear: $('#Ord_WriteOff_OrdYear_' + id).val(),
                OrderNo: $('#Ord_WriteOff_OrderNo_' + id).val(),
                TawreedNo: $('#Ord_WriteOff_TawreedNo_' + id).val(),
                ShipSer: $('#Ord_WriteOff_ShipSer_' + id).val(),
                VouType: 13,
                VouNo: $('#Ord_WriteOff_PayOrderNo_' + id).val(),
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#WriteOff_DocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#WriteOff_DocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#WriteOff_DocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ OrdVoucIssueHF: OrdVoucIssueHF, OrdVoucIssueDF: OrdVoucIssueDF, FileArchive: DocumentArchive }, '../../../VoucIssue/Save_WriteOff', '', ReloadWriteOffInfo, false);
    }
    function ReloadWriteOffInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#VoucIssueInfoTBody').empty();
        var TawreedNo = r.TawreedNo;
        var ShipSer = r.ShipSer;
        CloseWindow('/VoucIssue/AddWriteOff?OrdYear=' + r.OrdYear + '&OrderNo=' + r.OrderNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer + '');

        var table = $("#OrdWriteOffTable tbody");
        var trs = table.find('tr');
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrderNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo && $(trs[i])[0].getAttribute('ShipSer') == ShipSer) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');
                var ShipSer = $(trs[i])[0].getAttribute('ShipSer');

                $.get("../../../../VoucIssue/DetailsWriteOffRec?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer, function (data) {
                    OrdWriteOffTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }
</script>