            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-12">
                        <button onclick="AddWithoutAcountDocumentArchive()" type="button" class="btn btn-primary">@Html.Recource(32)</button>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-12" style="overflow-y:auto">
                        <table class="table table-hover" id="WithoutAcountDocumentArchiveTable">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(66)</th>
                                    <th style="text-align: center !important">@Html.Recource(5628)</th>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(5629)</th>
                                    <th style="text-align: center !important">@Html.Recource(5630)</th>
                                    <th style="text-align: center !important">@Html.Recource(5631)</th>
                                    <th style="text-align: center !important">@Html.Recource(5632)</th>
                                    <th style="text-align: center !important">@Html.Recource(5633)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="VendorWithoutAcountDocumentArchiveTbody" style="border-top: 1px solid #ddd;">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="SaveVendorWithoutAcountDocumentArchive()" class="btn btn-primary">@Resources.Resource.Save</button>
            </div>
        </form>
    </div>
</div>
<script>
    var DocumentsArchiveValue = 0;
    var Count = 0;
    $('#Model_VendorWithoutAcount_DocumentsArchive').draggable({
        handle: ".modal-header",
    });
    function AddWithoutAcountDocuments(val) {
        DocumentsArchiveValue = val;
        $('#Model_VendorWithoutAcount_DocumentsArchive').modal('show')
    }
    function AddWithoutAcountDocumentArchive() {
        Count++;
        var newarray = [];
        newarray.push('<input id="VendorWithoutAcount_DocumentArchive_FileId" type="hidden" value="' + Count + '" />')
        newarray.push('<input id="VendorWithoutAcount_DocumentArchive_Description_' + Count + '" type="text" style="width: 115px !important;text-align: center !important" />')
        newarray.push('<div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="VendorWithoutAcount_DocumentArchive_File_' + Count + '" onchange="uploadFile(this,' + Count + ')" /></div>')
        newarray.push('')
        newarray.push('<a id="VendorWithoutAcount_DownloadFile_' + Count + '" onclick="DownloadFile()"><span class="glyphicon glyphicon-download"></span></a>')
        newarray.push('<input id="VendorWithoutAcount_DocumentArchive_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="VendorWithoutAcount_DocumentArchive_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="VendorWithoutAcount_DocumentArchive_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="VendorWithoutAcount_DocumentArchive_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $("#VendorWithoutAcountDocumentArchiveTbody").append(
            GenRowDocumentArchive(newarray, 'VendorWithoutAcount_DocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        if (VendorWithoutAcount_save_VendorNo.value == "") {
            alert('@Html.Translate("يجب ادخال رقم المورد", "You Must Enter Vendor Number")');
        }
        else {
            var $td = $(ID).closest("td");
            $($td).find("input[type=file]").click();
        }
    }
    function uploadFile(Elem, Count) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;
        var fileName = $("#VendorWithoutAcount_DocumentArchive_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        var tr = $("#VendorWithoutAcountDocumentArchiveTbody #VendorWithoutAcount_DocumentArchive_" + Count + "");
        tr.find('#VendorWithoutAcount_DocumentArchive_FileName_' + Count)[0].value = fileName;
        tr.find('#VendorWithoutAcount_DocumentArchive_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#VendorWithoutAcount_DocumentArchive_FileSize_' + Count)[0].value = file_size;
        tr.find('#VendorWithoutAcount_DocumentArchive_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }
            $formData.append('Id', Count);
            $formData.append('VendorNo', VendorWithoutAcount_save_VendorNo.value);
        }

        $.ajax({
            url: '@Url.Action("InsertFile", "VendorsInfo")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function (r) {
                var tr = $("#VendorWithoutAcountDocumentArchiveTbody #VendorWithoutAcount_DocumentArchive_" + Count + "");
                tr.find('#VendorWithoutAcount_DownloadFile_' + Count)[0].setAttribute('onclick', 'DownloadFile("' + fileName + '","' + r + '")')
            },
            error: function (error) {
            }
        });
    }
    function RemoveRowUpload(e, Count) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            $.ajax({
                type: "POST",
                url:'@Url.Action("RemoveFile", "VendorsInfo")',
                data: { Id: Count, VendorNo: VendorWithoutAcount_save_VendorNo.value },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function SaveVendorWithoutAcountDocumentArchive() {
        $('#Model_VendorWithoutAcount_DocumentsArchive').modal('hide')
    }
</script>
@*--------------------------------END Model Documents -----------------------------*@


