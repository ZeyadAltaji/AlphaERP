                    DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#VendorWithoutAcount_DocumentArchive_UploadDate_' + InputSerial)[0].value,
                    ContentType: $(trsDocumentArchive[i]).closest('tr').find('#VendorWithoutAcount_DocumentArchive_FileType_' + InputSerial)[0].value
                })
            }


            wait();
            burn({ AccGroups: VendorWithoutAcount_save_CboAccGroups.value, Vendors: Vendors, GLCRs: GLCR, VenContact: Ven_Contact, VenbankInfo: Ven_bankInfo, FileArchive: DocumentArchive }, '../../../VendorsInfo/CreateWithoutVendorsInfo', '', ReloadWithoutVendorsInfo, true);
        }
    function ReloadWithoutVendorsInfo(r) {
            done();
            MsgBox('@Html.Recource(475)', 'green');
            CloseWindow('/VendorsInfo/AddWithoutAcount');
            $('#Ord_VendorsInfoListDiv').load('../../../VendorsInfo/VendorsInfoList');
        }
</script>
