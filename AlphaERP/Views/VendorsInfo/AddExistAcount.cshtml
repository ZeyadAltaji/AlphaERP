        var trsDocumentArchive = DocumentArchivetable;
        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#VendorExistAcount_DocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                VendorNo: VendorExistAcount_save_VendorNo.value,
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#VendorExistAcount_DocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#VendorExistAcount_DocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#VendorExistAcount_DocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ Vendors: Vendors, GLCRs: GLCR, VenContact: Ven_Contact, VenbankInfo: Ven_bankInfo, FileArchive: DocumentArchive }, '../../../VendorsInfo/CreateVendorsInfo', '', ReloadVendorsInfo, true);
    }
    function ReloadVendorsInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        CloseWindow('/VendorsInfo/AddExistAcount');
        $('#Ord_VendorsInfoListDiv').load('../../../VendorsInfo/VendorsInfoList');
    }
</script>
