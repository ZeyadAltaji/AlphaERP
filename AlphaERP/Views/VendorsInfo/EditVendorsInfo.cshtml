        newarray.push('<a id="AddDownloadFile_' + Count +'" onclick="DownloadFile()"><span class="glyphicon glyphicon-download"></span></a>')
        newarray.push('<input id="VendorExistAcount_EditAttachmentFiles_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="VendorExistAcount_EditDocumentArchive_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="VendorExistAcount_EditDocumentArchive_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="VendorExistAcount_EditDocumentArchive_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ',' + srl + ')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $(table).append(
            GenRowDocumentArchive(newarray, 'EditDocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        var $td = $(ID).closest("td");
        $($td).find("input[type=file]").click();
    }
    function uploadFile(Elem, Count, srl) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;

        var table = $("#VendorExistAcount_EditDocumentArchiveTbody_" + srl);
        var tr = table.find('#EditDocumentArchive_' + Count);


        var fileName = tr.find("#VendorExistAcount_EditDocumentArchive_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        tr.find('#VendorExistAcount_EditAttachmentFiles_FileName_' + Count)[0].value = fileName;
        tr.find('#VendorExistAcount_EditDocumentArchive_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#VendorExistAcount_EditDocumentArchive_FileSize_' + Count)[0].value = file_size;
        tr.find('#VendorExistAcount_EditDocumentArchive_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }

            var VendorNo = $('#VendorExistAcount_Edit_VendorNo_' + srl).val();

            $formData.append('Id', Count);
            $formData.append('VendorNo', VendorNo);
        }

        $.ajax({
            url: '@Url.Action("InsertFile", "VendorsInfo")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function (r) {
                var table = $("#VendorExistAcount_EditDocumentArchiveTbody_" + srl);
                var tr = table.find('#EditDocumentArchive_' + Count);
                tr.find('#AddDownloadFile_' + Count)[0].setAttribute('onclick', 'DownloadFile("' + fileName + '","' + r +'")')
            },
            error: function (error) {
            }
        });
    }
    function RemoveRowUpload(e, Count, srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            var Vendor = $('#VendorExistAcount_Edit_VendorNo_' + srl).val();
            $.ajax({
                type: "POST",
                url:'@Url.Action("RemoveFile", "VendorsInfo")',
                data: { Id: Count, VendorNo: Vendor },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    };
    function CloseDocumentArchive(srl) {
        $('#Model_VendorExistAcount_EditDocumentsArchive_' + srl).modal('hide');
    }
</script>
