<script>
    var CountContactPersons = 0;

    function EditContactPersons(srl) {
        $('#Model_VendorExistAcount_Edit_ContactPersons_' + srl).draggable({
            handle: ".modal-header",
        });
        $('#Model_VendorExistAcount_Edit_ContactPersons_' + srl).modal('show');

        var table = $("#VendorExistAcount_Edit_ContactPersonsTable_" + srl);
        var trs = table.find('Tbody tr');
        CountContactPersons = trs.length;
    }
    function EditContactPersonsModel(srl) {
        var table = $("#VendorExistAcount_Edit_ContactPersonsTable_" + srl).find('Tbody');
        CountContactPersons++;
        ststaus = 1;
        var newarray = [];
        newarray.push('<input id="VendorExistAcount_EditContactPersons_SupervisorNo" onblur="CheckEditValueSupervisorNo(' + CountContactPersons + ',' + srl +' )" type="number" style="width: 90px !important;" />')
        newarray.push('<input id="VendorExistAcount_EditContactPersons_SupervisorName" type="text" style="width: 95%  !important;" />')
        newarray.push('<button class="btn-de" onclick="RemoveRowContactPersons(this,' + srl +')" type="button"><i class= "fa fa-trash-alt"></i ></button> <input id="VendorExistAcount_EditContactPersons_InputSerial" type="hidden" value="' + CountContactPersons + '"  />')
        $(table).append(
            GenRowMas(newarray, 'EditContactPersons_' + CountContactPersons)
        );
    }
    function GenRowMas(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function CheckEditValueSupervisorNo(val, srl) {
        var table = $("#VendorExistAcount_Edit_ContactPersonsTable_" + srl).find('Tbody');
        var tr = $(table).find("#EditContactPersons_" + val + "");
        if (tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].value != '') {
            if (tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].value < 0) {
                MsgBox('@Html.Translate("لا يجوز ان يكون رقم المسؤول بالسالب", "The Supervisor number should not be negative")', 'red');
                tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].focus();
                return false;
            }
        }
        if (tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].value == '') {
            MsgBox('@Html.Translate("لا يجوز ان يكون رقم المسؤول فارغ", "The Supervisor number should not be Empty")', 'red');
            tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].focus();
            return false;
        }
        var ContactPersons = $("#VendorExistAcount_Edit_ContactPersonsTable_" + srl).find('Tbody tr');
        var trsContactPersons = ContactPersons;
        for (var i = 0; i < trsContactPersons.length; i++) {
            if ($(trsContactPersons[i]).closest('tr').find('#VendorExistAcount_EditContactPersons_InputSerial')[0].value != tr.find('#VendorExistAcount_EditContactPersons_InputSerial')[0].value) {
                if ($(trsContactPersons[i]).closest('tr').find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].value == tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].value) {
                    alert('@Html.Translate("رقم المسؤول مكرر", "Duplicate Supervisor number")');
                    tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].value = ""
                    tr.find('#VendorExistAcount_EditContactPersons_SupervisorNo')[0].focus();
                    return false;
                }
            }
        }
    }
    function RemoveRowContactPersons(e,srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            return true;
            CountContactPersons++;
        }
        return false;
    }
    function Edit_VendorExistAcount_ContactPersons(srl) {
        $('#Model_VendorExistAcount_Edit_ContactPersons_' + srl).modal('hide');
    }
</script>
@*--------------------------------END Model EditContactPersons -------------------------------------------*@

