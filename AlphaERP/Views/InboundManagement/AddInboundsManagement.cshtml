@using AlphaERP.Models
@using System.Data.SqlClient;
@using System.Data;
@using System.Collections.Generic;
@{
    User me = (User)Session["me"];
    Company company = (Company)Session["company"];
    int OrdYear = ViewBag.OrdYear;
    int OrderNo = ViewBag.OrderNo;
    string TawreedNo = ViewBag.TawreedNo;
    string InboundSer = ViewBag.InboundSer;
    string InboundGRN = ViewBag.InboundGRN;
    string srl = ViewBag.srl;
    Ord_InboundsInfoHF InboundsInfoHF = new MDB().Ord_InboundsInfoHF.Where(x => x.CompNo == company.comp_num && x.OrderYear == OrdYear &&
    x.OrderNo == OrderNo && x.TawreedNo == TawreedNo && x.InboundSer == InboundSer).FirstOrDefault();

    List<Ord_InboundsInfoDF> InboundsInfoDF = new MDB().Ord_InboundsInfoDF.Where(x => x.CompNo == company.comp_num
    && x.OrderYear == OrdYear && x.OrderNo == OrderNo && x.TawreedNo == TawreedNo && x.InboundSer == InboundSer).ToList();

    OrderHF ordhf = new MDB().OrderHFs.Where(x => x.CompNo == InboundsInfoHF.CompNo && x.OrdYear == InboundsInfoHF.OrderYear && x.OrderNo == InboundsInfoHF.OrderNo && x.TawreedNo == InboundsInfoHF.TawreedNo).FirstOrDefault();
    List<InvItemsMF> Mf = new MDB().InvItemsMFs.Where(x => x.CompNo == company.comp_num).ToList();
 DataTable Dt = new DataTable();
    InvCompMF compMF = new MDB().InvCompMFs.Where(x => x.CompNo == company.comp_num).FirstOrDefault();
    if (compMF.UseQty2 == null)
    {
        compMF.UseQty2 = false;
    }
    int Srial = 1;
    InvStoresMF store = new MDB().InvStoresMFs.Where(x => x.CompNo == company.comp_num && x.StoreNo == InboundsInfoHF.InboundStoreNo).FirstOrDefault();
}

