                                @foreach (Ord_InboundsInfoDF DF in InboundsInfoDF)
                                {
                                    double POQty = new MDB().OrderDFs.Where(x => x.CompNo == company.comp_num && x.OrdYear == OrdYear && x.OrderNo == OrderNo && x.TawreedNo == TawreedNo && x.ItemNo == DF.ItemNo).Sum(x => x.Qty).Value;
