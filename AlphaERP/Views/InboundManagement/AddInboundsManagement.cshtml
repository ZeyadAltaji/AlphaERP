    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#OrdInboundManagementTBody_" + id);
        var trs = table.find('tr');

        var TotalInboundPOQty = 0;
        var TotalInboundPOBounsQty = 0;

        var TotalInboundRecipientQty = 0;
        var TotalInboundQty1 = 0;
        var TotalInboundBounsQty = 0;
        var TotalInboundQty2 = 0;
        var TotalInboundRemainingQty = 0;

        var TotalInboundGRNQty1 = 0;
        var TotalInboundGRNBounsQty = 0;
        var TotalInboundGRNQty2 = 0;
        var TotalDiffQty1 = 0;
        var TotalDiffQty2 = 0;
        var Total1 = 0
        var Total2 = 0

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            TotalInboundPOQty += Number($(trs[i]).closest('tr').find('#InboundManagement_POQty_' + InputSerial)[0].value);
            TotalInboundPOBounsQty += Number($(trs[i]).closest('tr').find('#InboundManagement_POBounsQty_' + InputSerial)[0].value);

            TotalInboundRecipientQty += Number($(trs[i]).closest('tr').find('#InboundManagement_RecipientQty_' + InputSerial)[0].value);

            TotalInboundQty1 += Number($(trs[i]).closest('tr').find('#InboundManagement_Qty_' + InputSerial)[0].value);
            TotalInboundBounsQty += Number($(trs[i]).closest('tr').find('#InboundManagement_BounsQty_' + InputSerial)[0].value);
            TotalInboundQty2 += Number($(trs[i]).closest('tr').find('#InboundManagement_Qty2_' + InputSerial)[0].value);
            TotalInboundRemainingQty += Number($(trs[i]).closest('tr').find('#InboundManagement_RemainingQty_' + InputSerial)[0].value);

            TotalInboundGRNQty1 += Number($(trs[i]).closest('tr').find('#InboundManagement_GRNQty_' + InputSerial)[0].value);
            TotalInboundGRNBounsQty += Number($(trs[i]).closest('tr').find('#InboundManagement_GRNBounsQty_' + InputSerial)[0].value);
            TotalInboundGRNQty2 += Number($(trs[i]).closest('tr').find('#InboundManagement_GRNQty2_' + InputSerial)[0].value);

            TotalDiffQty1 = Number($(trs[i]).closest('tr').find('#InboundManagement_Qty_' + InputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#InboundManagement_GRNQty_' + InputSerial)[0].value);
            TotalDiffQty2 = Number($(trs[i]).closest('tr').find('#InboundManagement_Qty2_' + InputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#InboundManagement_GRNQty2_' + InputSerial)[0].value);

            $(trs[i]).closest('tr').find('#InboundManagement_GRNDifference1_' + InputSerial)[0].value = Number(TotalDiffQty1);
            $(trs[i]).closest('tr').find('#InboundManagement_GRNDifference2_' + InputSerial)[0].value = Number(TotalDiffQty2);

            Total1 = Number(Total1) + Number(TotalDiffQty1);
            Total2 = Number(Total2) + Number(TotalDiffQty2);
        }
        
        $('#TotalInboundPOQty_' + id).html(Number(TotalInboundPOQty));
        $('#TotalInboundPOBounsQty_' + id).html(Number(TotalInboundPOBounsQty));

        $('#TotalInboundRecipientQty_' + id).html(Number(TotalInboundRecipientQty));
        $('#TotalInboundQty1_' + id).html(Number(TotalInboundBounsQty));
        $('#TotalInboundBounsQty_' + id).html(Number(TotalInboundQty1));

        $('#TotalInboundQty2_' + id).html(Number(TotalInboundQty2));
        $('#TotalInboundRemainingQty_' + id).html(Number(TotalInboundRemainingQty));
        $('#TotalInboundGRNQty1_' + id).html(Number(TotalInboundGRNQty1));
        $('#TotalInboundGRNBounsQty_' + id).html(Number(TotalInboundGRNBounsQty));

        $('#TotalInboundGRNQty2_' + id).html(Number(TotalInboundGRNQty2));
        $('#TotalInboundDifferenceQty1_' + id).html(Number(Total1));
        $('#TotalInboundDifferenceQty2_' + id).html(Number(Total2));
    }

