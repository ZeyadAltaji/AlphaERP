<script>
    function CheckValueQty(e,srl) {
         if (e.value < 0) {
             e.value = 0;
             e.focus();
             alert('@Html.Translate("يجب أن تكون الكمية أكبر من صفر", "The Qty Must be Greater Than Zero")');
        }
         if (e.value == "") {
             e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueQty2(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
             alert('@Html.Translate("يجب أن تكون الكمية 2 أكبر من صفر", "The Qty 2 Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#VOrdInboundManagementTBody_" + id);
        var trs = table.find('tr');

        var TotalInboundQty1 = 0;

        var TotalInboundBounsQty = 0;

        var TotalInboundQty2 = 0;

        var TotalInboundGRNQty1 = 0;

        var TotalInboundGRNBounsQty = 0;

        var TotalInboundGRNQty2 = 0;
        var TotalDiffQty1 = 0;
        var TotalDiffQty2 = 0;
        var Total1 = 0
        var Total2 = 0

        for (var i = 0; i < trs.length; i++) {
            var VInputSerial = $(trs[i]).closest('tr').find('#VInputSerial')[0].value
            TotalInboundQty1 += Number($(trs[i]).closest('tr').find('#VInboundManagement_Qty_' + VInputSerial)[0].value);

            TotalInboundBounsQty += Number($(trs[i]).closest('tr').find('#VInboundManagement_BounsQty_' + VInputSerial)[0].value);

            TotalInboundQty2 += Number($(trs[i]).closest('tr').find('#VInboundManagement_Qty2_' + VInputSerial)[0].value);

            TotalInboundGRNQty1 += Number($(trs[i]).closest('tr').find('#VInboundManagement_GRNQty_' + VInputSerial)[0].value);
            TotalInboundGRNBounsQty += Number($(trs[i]).closest('tr').find('#VInboundManagement_GRNBounsQty_' + VInputSerial)[0].value);

            TotalInboundGRNQty2 += Number($(trs[i]).closest('tr').find('#VInboundManagement_GRNQty2_' + VInputSerial)[0].value);

            TotalDiffQty1 = Number($(trs[i]).closest('tr').find('#VInboundManagement_Qty_' + VInputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#VInboundManagement_GRNQty_' + VInputSerial)[0].value);
            TotalDiffQty2 = Number($(trs[i]).closest('tr').find('#VInboundManagement_Qty2_' + VInputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#VInboundManagement_GRNQty2_' + VInputSerial)[0].value);

            $(trs[i]).closest('tr').find('#VInboundManagement_GRNDifference1_' + VInputSerial)[0].value = Number(TotalDiffQty1);
            $(trs[i]).closest('tr').find('#VInboundManagement_GRNDifference2_' + VInputSerial)[0].value = Number(TotalDiffQty2);

            Total1 = Number(Total1) + Number(TotalDiffQty1);
            Total2 = Number(Total2) + Number(TotalDiffQty2);
        }

        $('#VTotalInboundQty1_' + id).html(Number(TotalInboundQty1));
        $('#VTotalInboundBounsQty_' + id).html(Number(TotalInboundBounsQty));
        $('#VTotalInboundQty2_' + id).html(Number(TotalInboundQty2));
        $('#VTotalInboundGRNQty1_' + id).html(Number(TotalInboundGRNQty1));
        $('#VTotalInboundGRNBounsQty_' + id).html(Number(TotalInboundGRNBounsQty));
        $('#VTotalInboundGRNQty2_' + id).html(Number(TotalInboundGRNQty2));
        $('#VTotalInboundDifferenceQty1_' + id).html(Number(Total1));
        $('#VTotalInboundDifferenceQty2_' + id).html(Number(Total2));
    }
</script>

