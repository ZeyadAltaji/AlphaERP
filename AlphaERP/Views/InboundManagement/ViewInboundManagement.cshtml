                                        <th colspan="3" style="text-align: center; width: 350px; border-left: 1px solid;">@Html.Translate("المعلومات الوارده", "Inbounds Info")</th>
                                        <th colspan="4" style="text-align: center; width: 350px; border-left: 1px solid;">@Html.Translate("معلومات محضر الاستلام", "Goods Receipt Information")</th>
