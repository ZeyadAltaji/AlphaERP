                                </tr>
                            </tfoot>
                            <tbody style="text-align: center;" id="VOrdInboundManagementTBody_@srl">
                                @foreach (Ord_InboundManagementDF DF in InboundManagementDF)
                                {
                                    string ItemDesc = Mf.Where(x => x.ItemNo == DF.ItemNo).Select(O => Html.Translate(O.ItemDesc, O.ItemDesc_Ara)).FirstOrDefault().ToString();
                                    string UnitSerial = DF.UnitSerial.Value.ToString();
                                    string UnitSerialGRN = DF.InboundGRNUnitSerial.Value.ToString();

                                    <tr style="height: 25px;" id="VInboundManagement_@Srial">
                                        <td class="second-col" style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="VInboundManagement_ItemNo_@Srial">@DF.ItemNo</td>
                                        <td class="third-col" style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="VInboundManagement_ItemDesc">@ItemDesc</td>
