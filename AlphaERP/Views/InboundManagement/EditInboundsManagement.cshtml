@using AlphaERP.Models
@using System.Data.SqlClient;
@using System.Data;
@using System.Collections.Generic;
@{
    User me = (User)Session["me"];
    Company company = (Company)Session["company"];
    int OrdYear = ViewBag.OrdYear;
    int OrderNo = ViewBag.OrderNo;
    string TawreedNo = ViewBag.TawreedNo;
    string InboundSer = ViewBag.InboundSer;
    string InboundGRN = ViewBag.InboundGRN;
    string srl = ViewBag.srl;
    Ord_InboundManagementHF InboundManagementHF = new MDB().Ord_InboundManagementHF.Where(x => x.CompNo == company.comp_num && x.OrderYear == OrdYear &&
    x.OrderNo == OrderNo && x.TawreedNo == TawreedNo && x.InboundSer == InboundSer && x.InboundGRN == InboundGRN).FirstOrDefault();

    List<Ord_InboundManagementDF> InboundManagementDF = new MDB().Ord_InboundManagementDF.Where(x => x.CompNo == company.comp_num
    && x.OrderYear == OrdYear && x.OrderNo == OrderNo && x.TawreedNo == TawreedNo
    && x.InboundSer == InboundSer && x.InboundGRN == InboundGRN).ToList();

    List<InvItemsMF> Mf = new MDB().InvItemsMFs.Where(x => x.CompNo == company.comp_num).ToList();
    DataTable Dt = new DataTable();
    InvCompMF compMF = new MDB().InvCompMFs.Where(x => x.CompNo == company.comp_num).FirstOrDefault();
    if (compMF.UseQty2 == null)
    {
        compMF.UseQty2 = false;
    }
    int Srial = 1;
    InvStoresMF store = new MDB().InvStoresMFs.Where(x => x.CompNo == company.comp_num && x.StoreNo == InboundManagementHF.InboundGRNStoreNo).FirstOrDefault();

    var Count = 1;

    DataTable DtAttachment = new DataTable();
    using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
    {
        DtAttachment = new DataTable();
        cn.Open();
        using (SqlCommand cmd = new SqlCommand())
        {
            cmd.Connection = cn;
            cmd.CommandType = CommandType.StoredProcedure;
            cmd.CommandText = "Ord_GetInboundManagementArchiveInfo";
            cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
            cmd.Parameters.Add(new SqlParameter("@OrderYear", SqlDbType.SmallInt)).Value = OrdYear;
            cmd.Parameters.Add(new SqlParameter("@OrderNo", SqlDbType.NVarChar)).Value = OrderNo;
            cmd.Parameters.Add(new SqlParameter("@TawreedNo", SqlDbType.NVarChar)).Value = TawreedNo;
            cmd.Parameters.Add(new SqlParameter("@InboundSer", SqlDbType.NVarChar)).Value = InboundSer;
            cmd.Parameters.Add(new SqlParameter("@InboundGRN", SqlDbType.NVarChar)).Value = InboundGRN;

            using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
            {
                DA.Fill(DtAttachment);
            }
        }
    }
}

