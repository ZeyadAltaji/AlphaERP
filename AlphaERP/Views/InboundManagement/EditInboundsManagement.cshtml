            }*@

            if (CheckValueGrid(0, $(trs[i]).closest('tr').find('#eInboundManagement_Batch_' + eInputSerial)[0].value.trim())) {
                alert('@Html.Translate("يجب إدخال الحزمة", "You Must Enter Batch")');
                $(trs[i]).closest('tr').find('#eInboundManagement_Batch_' + eInputSerial)[0].value = '';
                $(trs[i]).closest('tr').find('#eInboundManagement_Batch_' + eInputSerial)[0].focus();
                return;
            }

            InboundManagementDF.push({
                CompNo: '@company.comp_num',
                InboundSer: $('#Ord_eInboundManagement_InboundSer_' + id).val(),
                InboundGRN: $('#Ord_eInboundManagement_ReceiptNo_' + id).val(),
                ItemSrl: $(trs[i]).closest('tr').find('#eInboundManagement_ItemSrl')[0].value,
                ItemNo: $(trs[i]).closest('tr').find('#eInboundManagement_ItemNo_' + eInputSerial)[0].innerHTML,
                batchNo: $(trs[i]).closest('tr').find('#eInboundManagement_Batch_' + eInputSerial)[0].value.trim(),
                ManfDate: $(trs[i]).closest('tr').find('#eInboundManagement_ManfDate_' + eInputSerial)[0].value,
                EndDate: $(trs[i]).closest('tr').find('#eInboundManagement_EndDate_' + eInputSerial)[0].value,
                Qty: $(trs[i]).closest('tr').find('#eInboundManagement_Qty_' + eInputSerial)[0].value,
                BounsQty: $(trs[i]).closest('tr').find('#eInboundManagement_BonusQty_' + eInputSerial)[0].value,
                TUnit: $(trs[i]).closest('tr').find('.eInboundManagement_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                UnitSerial: $(trs[i]).closest('tr').find('.eInboundManagement_ItemNo_Unit')[0].value,
                Qty2: $(trs[i]).closest('tr').find('#eInboundManagement_Qty2_' + eInputSerial)[0].value,
                InboundGRNQty: $(trs[i]).closest('tr').find('#eInboundManagement_GRNQty_' + eInputSerial)[0].value,
                InboundGRNBounsQty: $(trs[i]).closest('tr').find('#eInboundManagement_GRNBonusQty_' + eInputSerial)[0].value,
                InboundGRNTUnit: $(trs[i]).closest('tr').find('.eInboundManagement_ItemNo_GRNUnit option:Selected')[0].getAttribute('unitCode'),
                InboundGRNUnitSerial: $(trs[i]).closest('tr').find('.eInboundManagement_ItemNo_GRNUnit')[0].value,
                InboundGRNQty2: $(trs[i]).closest('tr').find('#eInboundManagement_GRNQty2_' + eInputSerial)[0].value,
                ReqDeliveryDate: $(trs[i]).closest('tr').find('#eInboundManagement_ReqDeliveryDate_' + eInputSerial)[0].value
            });
        }

        if (InboundManagementDF.length == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        var DocumentArchivetable = $("#eInboundManagement_DocumentArchiveTbody");
        var trsDocumentArchive = DocumentArchivetable.find('tr');

        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#InboundManagement_EditDocumentArchive_FileId')[0].value;
            DocumentArchive.push({
            OrderYear: $('#Ord_eInboundManagement_OrdYear_' + id).val(),
            OrderNo: $('#Ord_eInboundManagement_OrderNo_' + id).val(),
            TawreedNo: $('#Ord_eInboundManagement_TawreedNo_' + id).val(),
            InboundSer: $('#Ord_eInboundManagement_InboundSer_' + id).val(),
            InboundGRN: $('#Ord_eInboundManagement_ReceiptNo_' + id).val(),
            FileId: InputSerial,
            Description: $(trsDocumentArchive[i]).closest('tr').find('#InboundManagement_EditDocumentArchive_Description_' + InputSerial)[0].value,
            DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#InboundManagement_EditDocumentArchive_UploadDate_' + InputSerial)[0].value,
            ContentType: $(trsDocumentArchive[i]).closest('tr').find('#InboundManagement_EditDocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ InboundManagementHF: InboundManagementHF, InboundManagementDF: InboundManagementDF, FileArchive: DocumentArchive }, '../../../InboundManagement/Edit_InboundManagement', '', eReloadOrdInboundManagement, false);
    }
