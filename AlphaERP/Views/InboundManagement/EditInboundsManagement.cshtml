<script>
    function Edit_OrdInboundManagementDocuments() {
        $('#Model_eInboundManagement_DocumentsArchive').draggable({
            handle: ".modal-header",
        });
        $('#Model_eInboundManagement_DocumentsArchive').modal('show');

        var table = $("#eInboundManagement_DocumentArchiveTbody");
        var trs = table.find('tr');
        Count = trs.length;
    }
    function eInboundManagement_DocumentsArchive() {
        var table = $("#eInboundManagement_DocumentArchiveTbody");
        Count++;
        var newarray = [];
        newarray.push('<input id="InboundManagement_EditDocumentArchive_FileId" type="hidden" value="' + Count + '" />')
        newarray.push('<input id="InboundManagement_EditDocumentArchive_Description_' + Count + '" type="text" style="width: 115px !important;text-align: center !important" />')
        newarray.push('<div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="InboundManagement_EditDocumentArchive_File_' + Count + '" onchange="uploadFile(this,' + Count + ')" /></div>')
        newarray.push('')
        newarray.push('<a id="InboundManagement_AddDownloadFile_' + Count + '" onclick="DownloadFile()"><span class="glyphicon glyphicon-download"></span></a>')
        newarray.push('<input id="InboundManagement_EditAttachmentFiles_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="InboundManagement_EditDocumentArchive_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="InboundManagement_EditDocumentArchive_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="InboundManagement_EditDocumentArchive_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $(table).append(
            GenRowDocumentArchive(newarray, 'eInboundManagementDocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        var $td = $(ID).closest("td");
        $($td).find("input[type=file]").click();
    }
    function uploadFile(Elem, Count) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;

        var table = $("#eInboundManagement_DocumentArchiveTbody");
        var tr = table.find('#eInboundManagementDocumentArchive_' + Count);

        var fileName = tr.find("#InboundManagement_EditDocumentArchive_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        tr.find('#InboundManagement_EditAttachmentFiles_FileName_' + Count)[0].value = fileName;
        tr.find('#InboundManagement_EditDocumentArchive_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#InboundManagement_EditDocumentArchive_FileSize_' + Count)[0].value = file_size;
        tr.find('#InboundManagement_EditDocumentArchive_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }

            $formData.append('Id', Count);
            $formData.append('OrderYear', @OrdYear);
            $formData.append('OrderNo', '@OrderNo');
            $formData.append('TawreedNo', '@TawreedNo');
            $formData.append('InboundSer', '@InboundSer');
            $formData.append('InboundGRN', '@InboundGRN');

        }

        $.ajax({
            url: '@Url.Action("InsertFile", "InboundManagement")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function (r) {
                var table = $("#eInboundManagement_DocumentArchiveTbody");
                var tr = table.find('#eInboundManagementDocumentArchive_' + Count);
                tr.find('#InboundManagement_AddDownloadFile_' + Count)[0].setAttribute('onclick', 'DownloadFile("' + fileName + '","' + r + '")')
            },
            error: function (error) {
            }
        });
    }
    function RemoveRowUpload(e, Count, srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);

            $.ajax({
                type: "POST",
                url: '@Url.Action("RemoveFile", "InboundManagement")',
                data: { Id: Count, OrdYear: @OrdYear, OrderNo: '@OrderNo', TawreedNo: '@TawreedNo', InboundSer: '@InboundSer', InboundGRN: '@InboundGRN' },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function EditInboundManagementDocumentArchive() {
        $('#Model_eInboundManagement_DocumentsArchive').modal('hide')
    }
</script>
@*--------------------------------END Model Documents -----------------------------*@




<script>
    function CheckValueQty(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
            alert('@Html.Translate("يجب أن تكون الكمية أكبر من صفر", "The Qty Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueBonusQty(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
            alert('@Html.Translate("يجب أن تكون الكمية الاضافية أكبر من صفر", "The Bonus Qty Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueQty2(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
            alert('@Html.Translate("يجب أن تكون الكمية 2 أكبر من صفر", "The Qty 2 Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#eOrdInboundManagementTBody_" + id);
        var trs = table.find('tr');

        var TotalInboundPOQty = 0;
        var TotalInboundPOBonusQty = 0;

        var TotalInboundRecipientQty = 0;
        var TotalInboundQty1 = 0;
        var TotalInboundBonusQty = 0;
        var TotalInboundQty2 = 0;
        var TotalInboundRemainingQty = 0;

        var TotalInboundGRNQty1 = 0;

        var TotalInboundGRNBonusQty = 0;

        var TotalInboundGRNQty2 = 0;
        var TotalDiffQty1 = 0;
        var TotalDiffQty2 = 0;
        var Total1 = 0
        var Total2 = 0

        for (var i = 0; i < trs.length; i++) {
            var eInputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value
            TotalInboundPOQty += Number($(trs[i]).closest('tr').find('#eInboundManagement_POQty_' + eInputSerial)[0].value);
            TotalInboundPOBonusQty += Number($(trs[i]).closest('tr').find('#eInboundManagement_POBonusQty_' + eInputSerial)[0].value);

            TotalInboundRecipientQty += Number($(trs[i]).closest('tr').find('#eInboundManagement_RecipientQty_' + eInputSerial)[0].value);
            TotalInboundQty1 += Number($(trs[i]).closest('tr').find('#eInboundManagement_Qty_' + eInputSerial)[0].value);
            TotalInboundBonusQty += Number($(trs[i]).closest('tr').find('#eInboundManagement_BonusQty_' + eInputSerial)[0].value);

            TotalInboundQty2 += Number($(trs[i]).closest('tr').find('#eInboundManagement_Qty2_' + eInputSerial)[0].value);
            TotalInboundRemainingQty += Number($(trs[i]).closest('tr').find('#eInboundManagement_RemainingQty_' + eInputSerial)[0].value);

            TotalInboundGRNQty1 += Number($(trs[i]).closest('tr').find('#eInboundManagement_GRNQty_' + eInputSerial)[0].value);
            TotalInboundGRNBonusQty += Number($(trs[i]).closest('tr').find('#eInboundManagement_GRNBonusQty_' + eInputSerial)[0].value);

            TotalInboundGRNQty2 += Number($(trs[i]).closest('tr').find('#eInboundManagement_GRNQty2_' + eInputSerial)[0].value);

            TotalDiffQty1 = Number($(trs[i]).closest('tr').find('#eInboundManagement_Qty_' + eInputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#eInboundManagement_GRNQty_' + eInputSerial)[0].value);
            TotalDiffQty2 = Number($(trs[i]).closest('tr').find('#eInboundManagement_Qty2_' + eInputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#eInboundManagement_GRNQty2_' + eInputSerial)[0].value);

            $(trs[i]).closest('tr').find('#eInboundManagement_GRNDifference1_' + eInputSerial)[0].value = Number(TotalDiffQty1);
            $(trs[i]).closest('tr').find('#eInboundManagement_GRNDifference2_' + eInputSerial)[0].value = Number(TotalDiffQty2);

            Total1 = Number(Total1) + Number(TotalDiffQty1);
            Total2 = Number(Total2) + Number(TotalDiffQty2);
        }

        $('#eTotalInboundPOQty_' + id).html(Number(TotalInboundPOQty));
        $('#eTotalInboundPOBounsQty_' + id).html(Number(TotalInboundPOBonusQty));

        $('#eTotalInboundRecipientQty_' + id).html(Number(TotalInboundRecipientQty));
        $('#eTotalInboundQty1_' + id).html(Number(TotalInboundQty1));
        $('#eTotalInboundBounsQty_' + id).html(Number(TotalInboundBonusQty));

        $('#eTotalInboundQty2_' + id).html(Number(TotalInboundQty2));
        $('#eTotalInboundRemainingQty_' + id).html(Number(TotalInboundRemainingQty));

        $('#eTotalInboundGRNQty1_' + id).html(Number(TotalInboundGRNQty1));
        $('#eTotalInboundGRNBounsQty_' + id).html(Number(TotalInboundGRNBonusQty));

        $('#eTotalInboundGRNQty2_' + id).html(Number(TotalInboundGRNQty2));
        $('#eTotalInboundDifferenceQty1_' + id).html(Number(Total1));
        $('#eTotalInboundDifferenceQty2_' + id).html(Number(Total2));
    }

