@* Modal list *@


<div class="modal fade wideBom ui-draggable in" id="ProdCost_QAEventModal" style="left: 20.5rem;top: 11.4rem;">
    <div class="modal-dialog">
        <form class="modal-content">
            <div class="modal-header">
                <button type="button" class="close btn-close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(475)</label>
            </div>
            <div class="modal-body row">

                <table class="table " style="width:100%">
                    <thead>
                        <tr>
                            <th>@Html.Translate("تسلسل", "Ser")</th>
                            <th>@Html.Translate("عنصر", "Item")</th>
                            <th>@Html.Translate("صانع", "Maker") </th>
                            <th></th>
                            <th> @Html.Translate("المدقق", "Checker")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="EevetBody"></tbody>
                </table>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-close" data-dismiss="modal">@Html.Translate("اغلق", "Close")</button>
                <button type="button" class="btn btn-primary btn-Save"> @Html.Translate("حفظ", "Save") </button>
            </div>
        </form>
    </div>
</div>

