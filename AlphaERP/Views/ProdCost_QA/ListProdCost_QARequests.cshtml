<table class="table table-hover dataTable" style="width:100%" id="RequestsTB">
    <thead>
        <tr>
            <th>@Html.Translate("رقم الطلب", "Order Number")</th>
            <th>@Html.Translate("تاريخ الطلب", "Request Date")</th>
            <th>@Html.Translate("المنتج النهائي", "Finished Product")</th>
            <th>@Html.Translate("المعادلة", "Formula")</th>
            <th>@Html.Translate("الوحدة", "Unit")</th>
            <th>@Html.Translate("الكمية", "Quantity")</th>
            <th>@Html.Translate("تسلسل المراحل", "Stage Serial")</th>
            <th>@Html.Translate("ترتيب المرحلة", "Stage Desc ")</th>

        </tr>
    </thead>
    <tbody id="TableProdCostQA_Req">
        @foreach (var item in Model)
        {
            <tr  compno="@item.OrderNo" orderno="@item.OrderNo" orderyear="@item.OrderYear" reqno="@item.ReqNo" qa-procno="@item.QA_ProcNo">
                <td>@item.OrderNo</td>
                <td>@item.ReqDate.ToString("yyyy-MM-dd")</td>
                <td>@item.ItemDesc_Ara</td>
                <td>@item.formula_desc</td>
                <td>@item.unitName</td>
                <td>@item.qty_prepare</td>
                <td>@item.QA_ProcNo</td>
                <td>@item.stage_desc</td>
            </tr>
        }
    </tbody>
</table>
<div id="ListReqQA">
</div>
