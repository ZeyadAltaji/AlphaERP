<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-10">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-block" onclick="ClearInqItemBalance()">
                    @Resources.Resource.Clear
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="Invt_InqItemBalanceDiv">

    </div>
</div>

<script>
    ClearInqItemBalance()
    function ClearInqItemBalance() {
        wait();
        burn({}, '../../../InqItemBalance/InqItemBal', '', LoadInqItemBalance, true);
    }
    function LoadInqItemBalance(r) {
        Invt_InqItemBalanceDiv.innerHTML = "";
        $('#Invt_InqItemBalanceDiv').html(r);
        done();
    }
</script>