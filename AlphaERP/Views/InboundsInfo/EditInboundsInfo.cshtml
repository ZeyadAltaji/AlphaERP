<script>
    $('#Ord_eInboundsInfo_CboStoreNo_' + @srl).select2();
    $('#eSelectInboundsInfoBatchTable_' + @srl).DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25
    });
    var srlId = 0;
    var ethisValue = 0;
    function AddBatchNo(e, srl, Id) {
        srlId = Id;
        ethisValue = srl;
        var table = $("#eInboundsInfoDFTBody_" + Id);
        var trs = table.find('#eInboundsInfo_' + srl);

        $('#eSelectInboundsInfoBatchTable_' + Id).find('tr').removeClass("selected");
        $('#eSelectInboundsInfoBatchTbody_' + Id).empty();
        $('#eSelectInboundsInfoBatchTbody_' + Id).load('../../../InboundsInfo/LoadItemBatch?ItemNo=' + trs.find('#InboundsInfo_ItemNo_' + srl)[0].innerHTML + '&storeNo=' + $('#Ord_InboundsInfo_CboStoreNo_' + Id).val());
        $('#Model_eInboundsInfo_Batch_' + @srl).draggable({
            handle: ".modal-header",
        });
        $('#Model_eInboundsInfo_Batch_'+ @srl).modal('show');
    }
    function SelectInboundsInfo_BatchNo(e) {
        var trs = $('#eSelectInboundsInfoBatchTable_' + srlId).find('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function eSelectingInboundsInfoBatch(id) {
        var table = $("#eSelectInboundsInfoBatchTable_" + id);
        var trs = table.find('tr[name=selected]');

        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حزمة", "Select one Batch")');
            return;
        }


        var table = $("#eInboundsInfoDFTBody_" + id);
        var tr = table.find('#eInboundsInfo_' + ethisValue);

        tr.find('#eInboundsInfo_Batch_' + ethisValue)[0].value = trs[0].getAttribute('BatchNo');

        $('#Model_eInboundsInfo_Batch_' + @srl).modal('hide');
    }
    function CheckValueQty(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
            alert('@Html.Translate("يجب أن تكون الكمية أكبر من صفر", "The Qty Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueBounsQty(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
            alert('@Html.Translate("يجب أن تكون الكمية الاضافية أكبر من صفر", "The Bouns Qty Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueQty2(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
            alert('@Html.Translate("يجب أن تكون الكمية 2 أكبر من صفر", "The Qty 2 Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }

    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#eInboundsInfoDFTBody_" + id);
        var trs = table.find('tr');
        var eTotalPOQty1 = 0
        var eTotalPOBounsQty = 0
        var eTotalPOQty2 = 0

        var eTotalRemainingQty = 0
        var eTotalReceivedQty = 0

        var eTotalQty1 = 0
        var eTotalBounsQty = 0
        var eTotalQty2 = 0


        for (var i = 0; i < trs.length; i++) {
            var eInputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value
            eTotalPOQty1 += Number($(trs[i]).closest('tr').find('#eInboundsInfo_POQty_' + eInputSerial)[0].value);
            eTotalPOBounsQty += Number($(trs[i]).closest('tr').find('#eInboundsInfo_POBonusQty_' + eInputSerial)[0].value);
            eTotalPOQty2 += Number($(trs[i]).closest('tr').find('#eInboundsInfo_POQty2_' + eInputSerial)[0].value);

            eTotalRemainingQty += Number($(trs[i]).closest('tr').find('#eInboundsInfo_RemainingQty_' + eInputSerial)[0].value);
            eTotalReceivedQty += Number($(trs[i]).closest('tr').find('#eInboundsInfo_ReceivedQty_' + eInputSerial)[0].value);

            eTotalQty1 += Number($(trs[i]).closest('tr').find('#eInboundsInfo_Qty_' + eInputSerial)[0].value);
            eTotalBounsQty += Number($(trs[i]).closest('tr').find('#eInboundsInfo_BonusQty_' + eInputSerial)[0].value);
            eTotalQty2 += Number($(trs[i]).closest('tr').find('#eInboundsInfo_Qty2_' + eInputSerial)[0].value);
        }

        $('#eTotalPOQty1_' + id).html(Number(eTotalPOQty1));
        $('#eTotalPOBounsQty_' + id).html(Number(eTotalPOBounsQty));
        $('#eTotalPOQty2_' + id).html(Number(eTotalPOQty2));

        $('#eTotalRemainingQty_' + id).html(Number(eTotalRemainingQty));
        $('#eTotalReceivedQty_' + id).html(Number(eTotalReceivedQty));

        $('#eTotalQty_' + id).html(Number(eTotalQty1).toFixed(3));
        $('#eTotalBounsQty_' + id).html(Number(eTotalBounsQty).toFixed(3));

        $('#eTotalQty2_' + id).html(Number(eTotalQty2).toFixed(3));
    }
    function CheckValueGrid(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt == 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
        else {
            if (Amt == '' || Amt == null) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function ExcuteEdit_OrdInboundsInfo(id) {

        var table = $("#eInboundsInfoDFTBody_" + id);
        var trs = table.find('tr');

        var InboundsInfoHF = {
            CompNo: '@company.comp_num',
            OrderYear: $('#Ord_eInboundsInfo_OrdYear_' + id).val(),
            OrderNo: $('#Ord_eInboundsInfo_OrderNo_' + id).val(),
            TawreedNo: $('#Ord_eInboundsInfo_TawreedNo_' + id).val(),
            InboundSer: $('#Ord_eInboundsInfo_InboundSer_' + id).val(),
            InboundDate: $('#Ord_eInboundsInfo_InboundDate_' + id).val(),
            CarNo: $('#Ord_eOrdReceipt_CarNo_' + id).val(),
            InboundStoreNo: $('#Ord_eInboundsInfo_CboStoreNo_' + id).val(),
            InboundNotes: $('#Ord_eInboundsInfo_Notes_' + id).val(),
        }

        var InboundsInfoDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var eInputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value
            if ($(trs[i]).closest('tr').find('#eInboundsInfo_Qty_' + eInputSerial)[0].value > $(trs[i]).closest('tr').find('#eInboundsInfo_RemainingQty_' + eInputSerial)[0].value) {
                if (confirm('@Resources.Resource.ConfirmPurchaseOrderQty')) {
                    if ($(trs[i]).closest('tr').find('#eInboundsInfo_Qty_' + eInputSerial)[0].value > 0) {
                        InboundsInfoDF.push({
                            CompNo: '@company.comp_num',
                            InboundSer: $('#Ord_eInboundsInfo_InboundSer_' + id).val(),
                            ItemSrl: $(trs[i]).closest('tr').find('#eInboundsInfo_ItemSrl')[0].value,
                            ItemNo: $(trs[i]).closest('tr').find('#eInboundsInfo_ItemNo_' + eInputSerial)[0].innerHTML,
                            batchNo: $(trs[i]).closest('tr').find('#eInboundsInfo_Batch_' + eInputSerial)[0].value.trim(),
                            Qty: $(trs[i]).closest('tr').find('#eInboundsInfo_Qty_' + eInputSerial)[0].value,
                            BounsQty: $(trs[i]).closest('tr').find('#eInboundsInfo_BonusQty_' + eInputSerial)[0].value,
                            TUnit: $(trs[i]).closest('tr').find('.eInboundsInfo_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                            UnitSerial: $(trs[i]).closest('tr').find('.eInboundsInfo_ItemNo_Unit')[0].value,
                            Qty2: $(trs[i]).closest('tr').find('#eInboundsInfo_Qty2_' + eInputSerial)[0].value,
                            ReqDeliveryDate: $(trs[i]).closest('tr').find('#eInboundsInfo_ReqDeliveryDate_' + eInputSerial)[0].value
                        })
                    }
                }
                else {
                    return false;
                }
            }
            else {
                if ($(trs[i]).closest('tr').find('#eInboundsInfo_Qty_' + eInputSerial)[0].value > 0) {
                    InboundsInfoDF.push({
                        CompNo: '@company.comp_num',
                        InboundSer: $('#Ord_eInboundsInfo_InboundSer_' + id).val(),
                        ItemSrl: $(trs[i]).closest('tr').find('#eInboundsInfo_ItemSrl')[0].value,
                        ItemNo: $(trs[i]).closest('tr').find('#eInboundsInfo_ItemNo_' + eInputSerial)[0].innerHTML,
                        batchNo: $(trs[i]).closest('tr').find('#eInboundsInfo_Batch_' + eInputSerial)[0].value.trim(),
                        Qty: $(trs[i]).closest('tr').find('#eInboundsInfo_Qty_' + eInputSerial)[0].value,
                        BounsQty: $(trs[i]).closest('tr').find('#eInboundsInfo_BonusQty_' + eInputSerial)[0].value,
                        TUnit: $(trs[i]).closest('tr').find('.eInboundsInfo_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                        UnitSerial: $(trs[i]).closest('tr').find('.eInboundsInfo_ItemNo_Unit')[0].value,
                        Qty2: $(trs[i]).closest('tr').find('#eInboundsInfo_Qty2_' + eInputSerial)[0].value,
                        ReqDeliveryDate: $(trs[i]).closest('tr').find('#eInboundsInfo_ReqDeliveryDate_' + eInputSerial)[0].value
                    })
                }
            }
        }

        if (InboundsInfoDF.length == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        wait();
        burn({ InboundsInfoHF: InboundsInfoHF, InboundsInfoDF: InboundsInfoDF }, '../../../InboundsInfo/Edit_InboundsInfo', '', ReloadeOrdInboundsInfo, false);
    }
    function ReloadeOrdInboundsInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        var TawreedNo = r.TawreedNo;
        var InboundSer = r.InboundSer;
        CloseWindow('/InboundsInfo/EditInboundsInfo?OrdYear=' + r.OrdYear + '&OrderNo=' + r.OrdNo + '&TawreedNo=' + TawreedNo + '&InboundSer=' + InboundSer + '')
        var table = $("#InboundsInfoTable tbody");
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrdNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');

                $.get("../../../../InboundsInfo/DetailsInboundsInfo?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo, function (data) {
                    InboundsInfoTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }
</script>