                                </tr>
                            </thead>
                            <thead>
                                <tr>
                                    <th style="text-align: center; width: 350px; word-wrap: break-word; white-space: normal;">@Html.Recource(44)</th>
                                    <th style="text-align: center; width: 990px; word-wrap: break-word; white-space: normal; border-right: 1px solid;">@Html.Recource(74)</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(49)</th>
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(3200)</th>
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal; border-right: 1px solid;">@Html.Recource(72)</th>
                                    }
                                    else
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(49)</th>
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;border-right: 1px solid;">@Html.Recource(3200)</th>
                                         <th hidden style="width: 165px; word-wrap: break-word; white-space: normal; ">@Html.Recource(72)</th>
                                    }
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(243)</th>
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal; border-right: 1px solid;">@Html.Recource(5533)</th>
                                    <th style="width: 205px; text-align: center !important; word-wrap: break-word; white-space: normal;">@Html.Recource(45)</th>
                                    <th style="width: 205px; word-wrap: break-word; white-space: normal;">@Html.Recource(67)</th>
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(49)</th>
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(3200)</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(72)</th>
                                    }
                                    else
                                    {
                                        <th hidden>@Html.Recource(72)</th>
                                    }
