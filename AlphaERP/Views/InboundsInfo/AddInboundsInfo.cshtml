                                    <th></th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <th style="text-align: center; border-right: 1px solid;" colspan="2">@Html.Translate("الاجمالي", "Total")</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="text-align:center;" id="TotalPOQty1_@srl">0</th>
                                        <th style="text-align:center;" id="TotalPOBounsQty_@srl">0</th>
                                        <th style="text-align: center; border-right: 1px solid;" id="TotalPOQty2_@srl">0</th>
                                    }
                                    else
                                    {
                                        <th style="text-align: center;" id="TotalPOQty1_@srl">0</th>
                                        <th style="text-align:center; border-right: 1px solid;" id="TotalPOBounsQty_@srl">0</th>
                                        <th hidden id="TotalPOQty2_@srl">0</th>
                                    }
                                    <th style="text-align:center;" id="TotalRemainingQty_@srl">0</th>
                                    <th style="text-align: center; border-right: 1px solid;" id="TotalReceivedQty_@srl">0</th>
                                    <th></th>
                                    <th></th>
                                    <th style="text-align:center;" id="TotalPortQty1_@srl">0</th>
                                    <th style="text-align:center;" id="TotalPortBounsQty_@srl">0</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="text-align:center;" id="TotalPortQty2_@srl">0</th>
                                    }
                                    else
                                    {
                                        <th hidden id="TotalPortQty2_@srl">0</th>
                                    }
                                    <th></th>
                                    <th></th>
                                </tr>
                            </tfoot>
                            <tbody style="text-align: center;" id="OrdInboundsInfoTBody_@srl">
                                @foreach (OrderDF DF in OrdDF)
                                {
                                    RemainingQty = 0;
                                    ReceivedQty = 0;
                                    double Qty = 0;
                                    double GRNQty = 0;

                                    {
                                        using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                        {
                                            Dt = new DataTable();
                                            cn.Open();
                                            using (SqlCommand cmd = new SqlCommand())
                                            {
                                                cmd.Connection = cn;
                                                cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                cmd.CommandText = "Ord_GetInvDaily";
                                                cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                cmd.Parameters.Add(new SqlParameter("@OrdYear", System.Data.SqlDbType.Int)).Value = DF.OrdYear;
                                                cmd.Parameters.Add(new SqlParameter("@OrderNo", System.Data.SqlDbType.Int)).Value = DF.OrderNo;
                                                cmd.Parameters.Add(new SqlParameter("@TawreedNo", System.Data.SqlDbType.VarChar, 20)).Value = DF.TawreedNo;
                                                cmd.Parameters.Add(new SqlParameter("@ItemNo", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                {
                                                    DA.Fill(Dt);
                                                }
                                            }
                                        }
                                        foreach (DataRow row in Dt.Rows)
                                        {
                                            ReceivedQty = Convert.ToDouble(row["ReceivedQty"]);
                                            GRNQty = Convert.ToDouble(row["GRNQty"]);
                                        }
                                    }
                                    Qty = Math.Abs(ReceivedQty - RemainingQty);
                                    RemainingQty = Math.Abs((DF.Qty.Value - GRNQty));
                                    string ItemDesc = Mf.Where(x => x.ItemNo == DF.ItemNo).Select(O => Html.Translate(O.ItemDesc, O.ItemDesc_Ara)).FirstOrDefault().ToString();
                                    string UnitSerial = DF.UnitSerial.Value.ToString();
                                <tr style="height: 25px;" id="InboundsInfo_@Srial">
                                    <td class="second-col" style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="InboundsInfo_ItemNo_@Srial">@DF.ItemNo</td>
                                    <td class="third-col" style="text-align: center !important; word-wrap: break-word; white-space: normal; border-right: 1px solid; " id="InboundsInfo_ItemDesc">@ItemDesc</td>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <td style="text-align:center !important">
                                            <input id="InboundsInfo_POQty_@Srial" value="@DF.Qty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                        </td>
                                        <td style="text-align:center !important">
                                            <input id="InboundsInfo_POBonusQty_@Srial" value="@DF.Bonus" type="number" style="width: 75px !important; text-align: center !important" disabled />
                                        </td>
                                        <td style="text-align: center !important; border-right: 1px solid;">
                                            <input id="InboundsInfo_POQty2_@Srial" value="@DF.Qty2" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty2(this,@srl)" disabled />
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="text-align: center !important;">
                                            <input id="InboundsInfo_POQty_@Srial" value="@DF.Qty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                        </td>
                                        <td style="text-align:center !important;border-right: 1px solid;">
                                            <input id="InboundsInfo_POBonusQty_@Srial" value="@DF.Bonus" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                        </td>
                                        <td style="text-align:center !important" hidden>
                                            <input id="InboundsInfo_POQty2_@Srial" value="@DF.Qty2" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty2(this,@srl)" disabled />
                                        </td>
                                    }
                                    <td style="text-align:center !important">
                                        <input id="InboundsInfo_RemainingQty_@Srial" value="@RemainingQty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                    </td>
                                    <td style="text-align: center !important; border-right: 1px solid;">
                                        <input id="InboundsInfo_ReceivedQty_@Srial" value="@GRNQty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty2(this,@srl)" disabled />
                                    </td>
                                    <td style="text-align: center; width: 10%;">
                                        <input id="InboundsInfo_Batch_@Srial" value="" type="text" style="width: 115px !important" maxlength="16" />
                                    </td>
                                    <td style="text-align: center;">
                                        <select class="InboundsInfo_ItemNo_Unit">
                                            @{
                                                using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                                {
                                                    Dt = new DataTable();
                                                    cn.Open();
                                                    using (SqlCommand cmd = new SqlCommand())
                                                    {
                                                        cmd.Connection = cn;
                                                        cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                        cmd.CommandText = "InvT_LoadItemUnits";
                                                        cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                        cmd.Parameters.Add(new SqlParameter("@ItemCode", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                        using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                        {
                                                            DA.Fill(Dt);
                                                        }
                                                    }
                                                }
                                            }
                                            @foreach (DataRow row in Dt.Rows)
                                            {
                                                if (UnitSerial == row["UnitSerial"].ToString())
                                                {
                                                    <option value="@row["UnitSerial"].ToString()" unitCode="@row["UnitCode"].ToString()" selected>
                                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option value="@row["UnitSerial"].ToString()" unitCode="@row["UnitCode"].ToString()">
                                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                    </option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td style="text-align:center !important">
                                        <input id="InboundsInfo_Qty_@Srial" value="0" type="number" style="width:75px !important" onblur="CheckValueQty(this,@srl)" />
                                    </td>
                                    <td style="text-align:center !important">
                                        <input id="InboundsInfo_BonusQty_@Srial" value="0" type="number" style="width:75px !important" onblur="CheckValueBonusQty(this,@srl)" />
                                    </td>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <td style="text-align:center !important">
                                            <input id="InboundsInfo_Qty2_@Srial" value="@DF.Qty2" type="number" style="width:75px !important" onblur="CheckValueQty2(this,@srl)" />
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="text-align:center !important" hidden>
                                            <input id="InboundsInfo_Qty2_@Srial" value="@DF.Qty2" type="number" style="width:75px !important" onblur="CheckValueQty2(this,@srl)" />
                                        </td>
                                    }
                                    <td style="width: 45%;text-align: center;">
                                        <input style="width: 115px !important;" type="date" id="InboundsInfo_ReqDeliveryDate_@Srial" value="@DF.ReqDeliveryDate.Value.ToString("yyyy-MM-dd")" />
                                    </td>
                                    <td>
                                        <input type="hidden" id="InboundsInfo_ItemSrl" value="@Srial" />
                                        <input type="hidden" id="InputSerial" value="@(Srial++)" />
                                    </td>
                                </tr>
                                }
                            </tbody>
                        }
                        else
                        {
                            <thead style="background-color: lightblue">
                                <tr>
                                    <th colspan="2" style="text-align: center; width: 350px; border-left: 1px solid;">@Html.Translate("المواد", "Items")</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th colspan="3" style="text-align: center; width: 350px; border-left: 1px solid;">@Html.Translate("امر الشراء", "Purchase Order")</th>
                                    }
