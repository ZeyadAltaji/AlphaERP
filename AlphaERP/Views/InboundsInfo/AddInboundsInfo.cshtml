                                    <th colspan="6" style="text-align: center; width: 350px;">@Html.Translate("المعلومات الوارده", "Inbounds Info")</th>
                                </tr>
                            </thead>
                            <thead>
                                <tr>
                                    <th style="text-align: center; width: 350px; word-wrap: break-word; white-space: normal;">@Html.Recource(44)</th>
                                    <th style="text-align: center; width: 990px; word-wrap: break-word; white-space: normal; border-left: 1px solid;">@Html.Recource(74)</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(49)</th>
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(3200)</th>
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal; border-left: 1px solid;">@Html.Recource(72)</th>
                                    }
                                    else
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(49)</th>
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;border-left: 1px solid;">@Html.Recource(3200)</th>
                                        <th hidden style="width: 165px; word-wrap: break-word; white-space: normal; ">@Html.Recource(72)</th>
                                    }
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(243)</th>
                                     <th style="width: 165px; word-wrap: break-word; white-space: normal; border-left: 1px solid;">@Html.Recource(5533)</th>
                                    <th style="width: 205px; text-align: center !important; word-wrap: break-word; white-space: normal;">@Html.Recource(45)</th>
                                    <th style="width: 205px; word-wrap: break-word; white-space: normal;">@Html.Recource(67)</th>
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(49)</th>
                                    <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(3200)</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="width: 165px; word-wrap: break-word; white-space: normal;">@Html.Recource(72)</th>
                                    }
                                    else
                                    {
                                        <th hidden>@Html.Recource(72)</th>
                                    }
                                    <th>@Html.Translate("تاريخ التسليم المطلوب", "Requested Delivery Date")</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <th style="text-align: center; border-left: 1px solid;" colspan="2">@Html.Translate("الاجمالي", "Total")</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="text-align:center;" id="TotalPOQty1_@srl">0</th>
                                        <th style="text-align:center;" id="TotalPOBounsQty_@srl">0</th>
                                        <th style="text-align: center; border-left: 1px solid;" id="TotalPOQty2_@srl">0</th>
                                    }
                                    else
                                    {
                                        <th style="text-align: center;" id="TotalPOQty1_@srl">0</th>
                                        <th style="text-align:center;border-left: 1px solid;" id="TotalPOBounsQty_@srl">0</th>
                                        <th hidden id="TotalPOQty2_@srl">0</th>
                                    }
                                    <th style="text-align:center;" id="TotalRemainingQty_@srl">0</th>
                                    <th style="text-align: center; border-left: 1px solid;" id="TotalReceivedQty_@srl">0</th>
                                    <th></th>
                                    <th></th>
                                    <th style="text-align:center;" id="TotalPortQty1_@srl">0</th>
                                    <th style="text-align:center;" id="TotalPortBounsQty_@srl">0</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th style="text-align:center;" id="TotalPortQty2_@srl">0</th>
                                    }
                                    else
                                    {
                                        <th hidden id="TotalPortQty2_@srl">0</th>
                                    }
                                    <th></th>
                                    <th></th>
                                </tr>
                            </tfoot>
                            <tbody style="text-align: center;" id="OrdInboundsInfoTBody_@srl">
                                @foreach (OrderDF DF in OrdDF)
                                {
                                    RemainingQty = 0;
                                    ReceivedQty = 0;
                                    double Qty = 0;
                                    double GRNQty = 0;
                                    {
                                        using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                        {
                                            Dt = new DataTable();
                                            cn.Open();
                                            using (SqlCommand cmd = new SqlCommand())
                                            {
                                                cmd.Connection = cn;
                                                cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                cmd.CommandText = "Ord_GetInvDaily";
                                                cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                cmd.Parameters.Add(new SqlParameter("@OrdYear", System.Data.SqlDbType.Int)).Value = DF.OrdYear;
                                                cmd.Parameters.Add(new SqlParameter("@OrderNo", System.Data.SqlDbType.Int)).Value = DF.OrderNo;
                                                cmd.Parameters.Add(new SqlParameter("@TawreedNo", System.Data.SqlDbType.VarChar, 20)).Value = DF.TawreedNo;
                                                cmd.Parameters.Add(new SqlParameter("@ItemNo", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                {
                                                    DA.Fill(Dt);
                                                }
                                            }
                                        }
                                        foreach (DataRow row in Dt.Rows)
                                        {
                                            ReceivedQty = Convert.ToDouble(row["ReceivedQty"]);
                                            RemainingQty = Convert.ToDouble(row["RemainingQty"]);
                                            GRNQty = Convert.ToDouble(row["GRNQty"]);
                                        }
                                    }
                                    Qty = Math.Abs(ReceivedQty - RemainingQty);
                                    RemainingQty =Math.Abs((DF.Qty.Value - GRNQty));
                                    string ItemDesc = Mf.Where(x => x.ItemNo == DF.ItemNo).Select(O => Html.Translate(O.ItemDesc, O.ItemDesc_Ara)).FirstOrDefault().ToString();
                                    string UnitSerial = DF.UnitSerial.Value.ToString();
                                <tr style="height: 25px;" id="InboundsInfo_@Srial">
                                    <td class="second-col" style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="InboundsInfo_ItemNo_@Srial">@DF.ItemNo</td>
                                    <td class="third-col" style="text-align: center !important; word-wrap: break-word; white-space: normal; border-left: 1px solid; " id="InboundsInfo_ItemDesc">@ItemDesc</td>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <td style="text-align:center !important">
                                            <input id="InboundsInfo_POQty_@Srial" value="@DF.Qty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                        </td>
                                        <td style="text-align:center !important">
                                            <input id="InboundsInfo_POBonusQty_@Srial" value="@DF.Bonus" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                        </td>
                                        <td style="text-align: center !important; border-left: 1px solid;">
                                            <input id="InboundsInfo_POQty2_@Srial" value="@DF.Qty2" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty2(this,@srl)" disabled />
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="text-align: center !important;">
                                            <input id="InboundsInfo_POQty_@Srial" value="@DF.Qty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                        </td>
                                        <td style="text-align:center !important;border-left: 1px solid;">
                                            <input id="InboundsInfo_POBonusQty_@Srial" value="@DF.Bonus" type="number" style="width: 75px !important; text-align: center !important" disabled />
                                        </td>
                                        <td style="text-align:center !important" hidden>
                                            <input id="InboundsInfo_POQty2_@Srial" value="@DF.Qty2" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty2(this,@srl)" disabled />
                                        </td>
                                    }
                                    <td style="text-align:center !important">
                                        <input id="InboundsInfo_RemainingQty_@Srial" value="@RemainingQty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty(this,@srl)" disabled />
                                    </td>
                                    <td style="text-align: center !important; border-left: 1px solid;">
                                        <input id="InboundsInfo_ReceivedQty_@Srial" value="@GRNQty" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueQty2(this,@srl)" disabled />
                                    </td>
                                    <td style="text-align: center; width: 10%;">
                                        <input id="InboundsInfo_Batch_@Srial" value="" type="text" style="width: 115px !important" maxlength="16" />
                                    </td>
                                    <td style="text-align: center;">
                                        <select class="InboundsInfo_ItemNo_Unit">
                                            @{
                                                using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                                {
                                                    Dt = new DataTable();
                                                    cn.Open();
                                                    using (SqlCommand cmd = new SqlCommand())
                                                    {
                                                        cmd.Connection = cn;
                                                        cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                        cmd.CommandText = "InvT_LoadItemUnits";
                                                        cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                        cmd.Parameters.Add(new SqlParameter("@ItemCode", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                        using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                        {
                                                            DA.Fill(Dt);
                                                        }
                                                    }
                                                }
                                            }
                                            @foreach (DataRow row in Dt.Rows)
                                            {
                                                if (UnitSerial == row["UnitSerial"].ToString())
                                                {
                                                    <option value="@row["UnitSerial"].ToString()" unitCode="@row["UnitCode"].ToString()" selected>
                                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option value="@row["UnitSerial"].ToString()" unitCode="@row["UnitCode"].ToString()">
                                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                    </option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td style="text-align:center !important">
                                        <input id="InboundsInfo_Qty_@Srial" value="0" type="number" style="width:75px !important" onblur="CheckValueQty(this,@srl)" />
                                    </td>
                                    <td style="text-align:center !important">
                                        <input id="InboundsInfo_BonusQty_@Srial" value="0" type="number" style="width: 75px !important; text-align: center !important" onblur="CheckValueBonusQty(this,@srl)" />
                                    </td>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <td style="text-align:center !important">
                                            <input id="InboundsInfo_Qty2_@Srial" value="0" type="number" style="width:75px !important" onblur="CheckValueQty2(this,@srl)" />
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="text-align:center !important" hidden>
                                            <input id="InboundsInfo_Qty2_@Srial" value="0" type="number" style="width:75px !important" onblur="CheckValueQty2(this,@srl)" />
                                        </td>
                                    }
                                    <td style="width: 45%;text-align: center;">
                                        <input style="width: 115px !important;" type="date" id="InboundsInfo_ReqDeliveryDate_@Srial" value="@DF.ReqDeliveryDate.Value.ToString("yyyy-MM-dd")" />
                                    </td>
                                    <td>
                                        <input type="hidden" id="InboundsInfo_ItemSrl" value="@Srial" />
                                        <input type="hidden" id="InputSerial" value="@(Srial++)" />
                                    </td>
                                </tr>
                                }
                            </tbody>
                        }
                    </table>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" onclick="ExcuteSave_OrdInboundsInfo(@srl)" class="btn btn-primary">@Resources.Resource.Save</button>
        </div>
    </div>
</div>

<div class="modal fade" id="Model_InboundsInfo_Batch">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(45)</label>
            </div>
            <div class="box-body box-profile">
                <div class="modal-body row">
                    <div class="form-group">
                        <div class="col-md-12">
                            <table class="table table-hover" id="SelectInboundsInfoBatchTable_@srl">
                                <thead>
                                    <tr>
                                        <th>@Html.Recource(102)</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="SelectInboundsInfoBatchTbody_@srl">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" onclick="SelectingInboundsInfoBatch(@srl)" class="btn btn-primary">@Html.Recource(4599)</button>
                    <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
                </div>
            </div>
        </form>
    </div>
</div>


<script>
    $('#Ord_InboundsInfo_CboStoreNo_' + @srl).select2();
    function CheckValueQty(e,srl) {
         if (e.value < 0) {
             e.value = 0;
             e.focus();
             alert('@Html.Translate("يجب أن تكون الكمية أكبر من صفر", "The Qty Must be Greater Than Zero")');
        }
         if (e.value == "") {
             e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueBonusQty(e,srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
            alert('@Html.Translate("يجب أن تكون الكمية الاضافية أكبر من صفر", "The Bouns Qty Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueQty2(e, srl) {
        if (e.value < 0) {
            e.value = 0;
            e.focus();
             alert('@Html.Translate("يجب أن تكون الكمية 2 أكبر من صفر", "The Qty 2 Must be Greater Than Zero")');
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#OrdInboundsInfoTBody_" + id);
        var trs = table.find('tr');
        var TotalPOQty1 = 0
        var TotalPOBounsQty = 0
        var TotalPOQty2 = 0

        var TotalRemainingQty = 0
        var TotalReceivedQty = 0

        var TotalPortQty1 = 0
        var TotalPortBounsQty = 0
        var TotalPortQty2 = 0

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            TotalPOQty1 += Number($(trs[i]).closest('tr').find('#InboundsInfo_POQty_' + InputSerial)[0].value);
            TotalPOBounsQty += Number($(trs[i]).closest('tr').find('#InboundsInfo_POBonusQty_' + InputSerial)[0].value);
            TotalPOQty2 += Number($(trs[i]).closest('tr').find('#InboundsInfo_POQty2_' + InputSerial)[0].value);

            TotalRemainingQty += Number($(trs[i]).closest('tr').find('#InboundsInfo_RemainingQty_' + InputSerial)[0].value);
            TotalReceivedQty += Number($(trs[i]).closest('tr').find('#InboundsInfo_ReceivedQty_' + InputSerial)[0].value);

            TotalPortQty1 += Number($(trs[i]).closest('tr').find('#InboundsInfo_Qty_' + InputSerial)[0].value);
            TotalPortBounsQty += Number($(trs[i]).closest('tr').find('#InboundsInfo_BonusQty_' + InputSerial)[0].value);
            TotalPortQty2 += Number($(trs[i]).closest('tr').find('#InboundsInfo_Qty2_' + InputSerial)[0].value);
        }

        $('#TotalPOQty1_' + id).html(Number(TotalPOQty1));
        $('#TotalPOBounsQty_' + id).html(Number(TotalPOBounsQty));
        $('#TotalPOQty2_' + id).html(Number(TotalPOQty2));

        $('#TotalRemainingQty_' + id).html(Number(TotalRemainingQty));
        $('#TotalReceivedQty_' + id).html(Number(TotalReceivedQty));

        $('#TotalPortQty1_' + id).html(Number(TotalPortQty1));
        $('#TotalPortBounsQty_' + id).html(Number(TotalPortBounsQty));
        $('#TotalPortQty2_' + id).html(Number(TotalPortQty2));
    }

    $('#SelectInboundsInfoBatchTable_' + @srl).DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25
    });
    var srlId = 0;
    function AddBatchNo(e, srl, Id) {
        srlId = Id;
        thisValue = srl;
        var table = $("#OrdInboundsInfoTBody_" + Id);
        var trs = table.find('#InboundsInfo_' + srl);

        $('#SelectInboundsInfoBatchTable_' + Id).find('tr').removeClass("selected");
        $('#SelectInboundsInfoBatchTbody_' + Id).empty();
        $('#SelectInboundsInfoBatchTbody_' + Id).load('../../../InboundsInfo/LoadItemBatch?ItemNo=' + trs.find('#InboundsInfo_ItemNo_' + srl)[0].innerHTML + '&storeNo=' + $('#Ord_InboundsInfo_CboStoreNo_' + Id).val());
        $('#Model_InboundsInfo_Batch').draggable({
            handle: ".modal-header",
        });
        $('#Model_InboundsInfo_Batch').modal('show');
    }
    function SelectInboundsInfo_BatchNo(e) {
        var trs = $('#SelectInboundsInfoBatchTable_' + srlId).find('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function SelectingInboundsInfoBatch(id) {
        var table = $("#SelectInboundsInfoBatchTable_" + id);
        var trs = table.find('tr[name=selected]');

        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حزمة", "Select one Batch")');
            return;
        }


        var table = $("#OrdInboundsInfoTBody_" + id);
        var tr = table.find('#InboundsInfo_' + thisValue);

        tr.find('#InboundsInfo_Batch_' + thisValue)[0].value = trs[0].getAttribute('BatchNo');

        $('#Model_InboundsInfo_Batch').modal('hide');
    }
    function CheckValueGrid(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt == 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
        else {
            if (Amt == '' || Amt == null) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function ExcuteSave_OrdInboundsInfo(id) {


        var table = $("#OrdInboundsInfoTBody_" + id);
        var trs = table.find('tr');


        var InboundsInfoHF = {
            CompNo: '@company.comp_num',
            OrderYear: $('#Ord_InboundsInfo_OrdYear_' + id).val(),
            OrderNo: $('#Ord_InboundsInfo_OrderNo_' + id).val(),
            TawreedNo: $('#Ord_InboundsInfo_TawreedNo_' + id).val(),
            InboundSer: $('#Ord_InboundsInfo_InboundSer_' + id).val(),
            InboundDate: $('#Ord_InboundsInfo_RecDate_' + id).val(),
            InboundStoreNo: $('#Ord_InboundsInfo_CboStoreNo_' + id).val(),
            InboundNotes: $('#Ord_InboundsInfo_Notes_' + id).val(),
            IsApproval:0
        }

        var InboundsInfoDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value;
            if (Number($(trs[i]).closest('tr').find('#InboundsInfo_Qty_' + InputSerial)[0].value) > Number($(trs[i]).closest('tr').find('#InboundsInfo_RemainingQty_' + InputSerial)[0].value)) {
                if (confirm('@Resources.Resource.ConfirmPurchaseOrderQty')) {
                    if ($(trs[i]).closest('tr').find('#InboundsInfo_Qty_' + InputSerial)[0].value > 0) {
                        InboundsInfoDF.push({
                            CompNo: '@company.comp_num',
                            InboundSer: $('#Ord_InboundsInfo_InboundSer_' + id).val(),
                            ItemSrl: $(trs[i]).closest('tr').find('#InboundsInfo_ItemSrl')[0].value,
                            ItemNo: $(trs[i]).closest('tr').find('#InboundsInfo_ItemNo_' + InputSerial)[0].innerHTML,
                            batchNo: $(trs[i]).closest('tr').find('#InboundsInfo_Batch_' + InputSerial)[0].value.trim(),
                            Qty: $(trs[i]).closest('tr').find('#InboundsInfo_Qty_' + InputSerial)[0].value,
                            BounsQty :$(trs[i]).closest('tr').find('#InboundsInfo_BonusQty_' + InputSerial)[0].value,
                            TUnit: $(trs[i]).closest('tr').find('.InboundsInfo_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                            UnitSerial: $(trs[i]).closest('tr').find('.InboundsInfo_ItemNo_Unit')[0].value,
                            Qty2: $(trs[i]).closest('tr').find('#InboundsInfo_Qty2_' + InputSerial)[0].value,
                            ReqDeliveryDate: $(trs[i]).closest('tr').find('#InboundsInfo_ReqDeliveryDate_' + InputSerial)[0].value
                        })
                    }
                }
                else {
                    return false;
                }
            }
            else {
                if (Number($(trs[i]).closest('tr').find('#InboundsInfo_Qty_' + InputSerial)[0].value) > 0) {
                    InboundsInfoDF.push({
                        CompNo: '@company.comp_num',
                        InboundSer: $('#Ord_InboundsInfo_InboundSer_' + id).val(),
                        ItemSrl: $(trs[i]).closest('tr').find('#InboundsInfo_ItemSrl')[0].value,
                        ItemNo: $(trs[i]).closest('tr').find('#InboundsInfo_ItemNo_' + InputSerial)[0].innerHTML,
                        batchNo: $(trs[i]).closest('tr').find('#InboundsInfo_Batch_' + InputSerial)[0].value.trim(),
                        Qty: $(trs[i]).closest('tr').find('#InboundsInfo_Qty_' + InputSerial)[0].value,
                        BounsQty :$(trs[i]).closest('tr').find('#InboundsInfo_BonusQty_' + InputSerial)[0].value,
                        TUnit: $(trs[i]).closest('tr').find('.InboundsInfo_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                        UnitSerial: $(trs[i]).closest('tr').find('.InboundsInfo_ItemNo_Unit')[0].value,
                        Qty2: $(trs[i]).closest('tr').find('#InboundsInfo_Qty2_' + InputSerial)[0].value,
                        ReqDeliveryDate: $(trs[i]).closest('tr').find('#InboundsInfo_ReqDeliveryDate_' + InputSerial)[0].value
                    })
                }
            }
        }

        if (InboundsInfoDF.length == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        wait();
        burn({ InboundsInfoHF: InboundsInfoHF, InboundsInfoDF: InboundsInfoDF }, '../../../InboundsInfo/Save_InboundsInfo', '', ReloadOrdInboundsInfo, false);
    }
    function ReloadOrdInboundsInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        var TawreedNo = r.TawreedNo;
        CloseWindow('/InboundsInfo/AddInboundsInfo?OrdYear=' + r.OrdYear + '&OrderNo=' + r.OrdNo + '&TawreedNo=' + TawreedNo + '');

        var table = $("#InboundsInfoTable tbody");
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrdNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');

                $.get("../../../../InboundsInfo/DetailsInboundsInfo?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo, function (data) {
                    InboundsInfoTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }
</script>