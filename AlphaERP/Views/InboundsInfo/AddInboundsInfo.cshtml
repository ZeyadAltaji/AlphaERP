                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="col-md-12">
                    <div class="col-md-2">
                        <label class="unselectable" for="Ord_InboundsInfo_StoreNo">@Html.Recource(1)</label>
                    </div>
                    <div class="col-md-4" style="margin-bottom: 5px;">
                        <select style="width: 85%" id="Ord_InboundsInfo_CboStoreNo_@srl">
                            @foreach (var v in lStores)
                            {
                                if (v.StoreNo == lStores.Select(o => o.StoreNo).FirstOrDefault())
                                {
                                    <option value="@v.StoreNo" selected>@Html.Translate(v.StoreName, v.StoreNameEng)</option>
                                }
                                else
                                {
                                    <option value="@v.StoreNo">@Html.Translate(v.StoreName, v.StoreNameEng)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="col-md-12">
                    <div class="col-md-2">
                        <label class="unselectable" for="Ord_InboundsInfo_Notes">@Html.Recource(70)</label>
                    </div>
                    <div class="col-md-10">
                        <textarea required="true" style="width: 96%; height: 25px !important; " id="Ord_InboundsInfo_Notes_@srl" />
                    </div>
                </div>
            </div>
            <hr />
            <div class="form-group" style="display: block; height: 125px;">
                <div class="col-md-12 wrapperx" id="OrdInboundsInfo_DIV">
                    <table class="table table-hover OrdInboundsInfoDF_Info" id="OrdInboundsInfoDFTable">
                        @if (Session["language"].ToString() == "en")
                        {
                            <thead style="background-color: lightblue">
                                <tr>
                                    <th colspan="2" style="text-align: center; width: 350px; border-right: 1px solid;">@Html.Translate("المواد", "Items")</th>
                                    @if (compMF.UseQty2 == true)
                                    {
                                        <th colspan="3" style="text-align: center; width: 350px; border-right: 1px solid;">@Html.Translate("امر الشراء", "Purchase Order")</th>
                                    }
