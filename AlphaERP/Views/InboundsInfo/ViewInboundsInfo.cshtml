                        <tbody style="text-align: center;" id="vInboundsInfoDFTBody_@srl">
                            @if (Session["language"].ToString() == "en")
                            {
                                foreach (Ord_InboundsInfoDF DF in InboundInfoDF)
                                {
                                    RemainingQty = 0;
                                    ReceivedQty = 0;
                                    double Qty = 0;
                                    {
                                        using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                        {
                                            Dt = new DataTable();
                                            cn.Open();
                                            using (SqlCommand cmd = new SqlCommand())
                                            {
                                                cmd.Connection = cn;
                                                cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                cmd.CommandText = "Ord_GetInvDaily";
                                                cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                cmd.Parameters.Add(new SqlParameter("@OrdYear", System.Data.SqlDbType.Int)).Value = OrdYear;
                                                cmd.Parameters.Add(new SqlParameter("@OrderNo", System.Data.SqlDbType.Int)).Value = OrderNo;
                                                cmd.Parameters.Add(new SqlParameter("@TawreedNo", System.Data.SqlDbType.VarChar, 20)).Value = TawreedNo;
                                                cmd.Parameters.Add(new SqlParameter("@ItemNo", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                {
                                                    DA.Fill(Dt);
                                                }
                                            }
                                        }
                                        foreach (DataRow row in Dt.Rows)
                                        {
                                            ReceivedQty = Convert.ToDouble(row["ReceivedQty"]);
                                            RemainingQty = Convert.ToDouble(row["RemainingQty"]);
                                        }
                                    }
                                    string ItemDesc = Mf.Where(x => x.ItemNo == DF.ItemNo).Select(O => Html.Translate(O.ItemDesc, O.ItemDesc_Ara)).FirstOrDefault().ToString();
                                    string UnitSerial = DF.UnitSerial.Value.ToString();
                                    OrderDF OrdDF = new MDB().OrderDFs.Where(x => x.CompNo == company.comp_num && x.OrdYear == OrdYear && x.OrderNo == OrderNo && x.TawreedNo == TawreedNo && x.ItemNo == DF.ItemNo).FirstOrDefault();
                                    Qty = Math.Abs(RemainingQty - ReceivedQty);
                                    RemainingQty = Math.Abs((OrdDF.Qty.Value - RemainingQty) + Qty);
                                    <tr style="height: 25px;" id="eInboundInfoDF_@Srial">
                                        <td class="second-col" style="text-align: center !important;word-wrap: break-word; white-space: normal;" id="vInboundsInfo_ItemNo_@Srial">@DF.ItemNo</td>
                                        <td class="third-col" style="text-align: center !important; word-wrap: break-word; white-space: normal; border-right: 1px solid;" id="vInboundsInfo_ItemDesc">@ItemDesc</td>
