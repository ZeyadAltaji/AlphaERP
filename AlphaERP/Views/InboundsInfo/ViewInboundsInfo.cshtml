<script>
    $('#Ord_VInboundsInfo_CboStoreNo_' + @srl).select2();
   
    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#vInboundsInfoDFTBody_" + id);
        var trs = table.find('tr');

        var vTotalPOQty1 = 0
        var vTotalPOBounsQty = 0
        var vTotalPOQty2 = 0

        var vTotalRemainingQty = 0
        var vTotalReceivedQty = 0

        var vTotalQty1 = 0
        var vTotalBounsQty = 0
        var vTotalQty2 = 0


        for (var i = 0; i < trs.length; i++) {
            var vInputSerial = $(trs[i]).closest('tr').find('#vInputSerial')[0].value
            vTotalPOQty1 += Number($(trs[i]).closest('tr').find('#vInboundsInfo_POQty_' + vInputSerial)[0].value);
            vTotalPOBounsQty += Number($(trs[i]).closest('tr').find('#vInboundsInfo_POBounsQty_' + vInputSerial)[0].value);
            vTotalPOQty2 += Number($(trs[i]).closest('tr').find('#vInboundsInfo_POQty2_' + vInputSerial)[0].value);

            vTotalRemainingQty += Number($(trs[i]).closest('tr').find('#vInboundsInfo_RemainingQty_' + vInputSerial)[0].value);
            vTotalReceivedQty += Number($(trs[i]).closest('tr').find('#vInboundsInfo_ReceivedQty_' + vInputSerial)[0].value);

            vTotalQty1 += Number($(trs[i]).closest('tr').find('#vInboundsInfo_Qty_' + vInputSerial)[0].value);
            vTotalBounsQty += Number($(trs[i]).closest('tr').find('#vInboundsInfo_BounsQty_' + vInputSerial)[0].value);
            vTotalQty2 += Number($(trs[i]).closest('tr').find('#vInboundsInfo_Qty2_' + vInputSerial)[0].value);
        }

        $('#vTotalPOQty1_' + id).html(Number(vTotalPOQty1).toFixed(3));
        $('#vTotalBounsQty_' + id).html(Number(vTotalPOBounsQty).toFixed(3));

        $('#vTotalPOQty2_' + id).html(Number(vTotalPOQty2).toFixed(3));

        $('#vTotalRemainingQty_' + id).html(Number(vTotalRemainingQty).toFixed(3));
        $('#vTotalReceivedQty_' + id).html(Number(vTotalReceivedQty).toFixed(3));

        $('#vTotalQty_' + id).html(Number(vTotalQty1).toFixed(3));
        $('#vTotalBounsQty_' + id).html(Number(vTotalBounsQty).toFixed(3));
        $('#vTotalQty2_' + id).html(Number(vTotalQty2).toFixed(3));
    }
   
</script>