@using AlphaERP.Models

@{
    Company company = (Company)Session["company"];
    User Me = (User)Session["me"];
    List<UserPermission> permissions = new MDB().UserPermissions.Where(x => x.UserID == Me.UserID && x.CompNo == company.comp_num && x.ProgAccess == true).ToList();

    List<Menu> mm = permissions.Where(x => x.Menu != null).Select(x => x.Menu).ToList();
    List<Menu> mm2 = new List<Menu>();
    List<Menu> mm3 = new List<Menu>();
    List<Menu> mm4 = new List<Menu>();
    List<Menu> mm5 = new List<Menu>();
    List<Menu> mm6 = new List<Menu>();

    foreach (var m in mm)
    {
        if (m._parent != null)
        {
            AddToMenu(m._parent, mm2);
        }
    }


    foreach (var m in mm2)
    {
        if (m._parent != null)
        {
            AddToMenu(m._parent, mm3);
        }
    }



    foreach (var m in mm3)
    {
        if (m._parent != null)
        {
            AddToMenu(m._parent, mm4);
        }
    }

    foreach (var m in mm4)
    {
        if (m._parent != null)
        {
            AddToMenu(m._parent, mm5);
        }
    }

    foreach (var m in mm5)
    {
        if (m._parent != null)
        {
            AddToMenu(m._parent, mm6);
        }
    }

    mm.AddRange(mm2);

    mm.AddRange(mm3);

    mm.AddRange(mm4);

    mm.AddRange(mm5);

    mm.AddRange(mm6);

    mm = mm.GroupBy(x => x.ProgID).Select(x => x.FirstOrDefault()).ToList();

    mm = mm.OrderBy(x => x.sort).ToList();



    Session["menu"] = mm;
    Session["permissions"] = permissions;
}
@functions{
    int Childs(int? ProgID, List<Menu> ListMenu)
    {
        int count = ListMenu.Where(x => x.ParentID == ProgID).Count();
        return count;
    }

    string Ex(int ProgId, List<Menu> mm)
    {
        if (mm.Where(x => x.ProgID == ProgId).FirstOrDefault() == null)
        {
            return "hidden";
        }
        else
        {
            return "";
        }
    }

    void AddToMenu(Menu m, List<Menu> mm)
    {

        Menu ex = mm.Where(x => x.ProgID == m.ProgID).FirstOrDefault();
        if (ex == null)
        {

            if (m.ProgID == 200100)
            {

            }

            mm.Add(m);
        }
    }

    bool Drow(Menu m, List<Menu> mm, List<UserPermission> permissions)
    {
        if (m.SourceForm != "1")
        {
            UserPermission ex = permissions.Where(x => x.Menu.ProgID == m.ProgID).FirstOrDefault();
            if (ex == null)
            {
                return false;
            }
            else
            {
                return true;
            }
        }




        return true;
    }
}
