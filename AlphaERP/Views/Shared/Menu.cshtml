</div>
<script>
    $('#search-input').keyup(function () {
        if (this.value.length > 0) {
            debugger
            $("#mmenu li").hide().filter(function () {
                return $(this).attr('prog').toLowerCase().indexOf($("#search-input").val().toLowerCase()) != -1 || $(this).text().toLowerCase().indexOf($("#search-input").val().toLowerCase()) != -1;
            }).show();


            if (Number($("#search-input").val()) > 0) {
                $("#mmenu li").filter(function () {
                    if (Number($(this).attr('prog')) == Number($("#search-input").val())) {
                        if ($(this).parent().is("li")) {
                            $(this).parent().show()
                        }
                        if ($(this).parent().parent().is("li")) {
                            $(this).parent().parent().show()
                        }
                        if ($(this).parent().parent().parent().is("li")) {
                            $(this).parent().parent().parent().show()
                        }
                        if ($(this).parent().parent().parent().parent().is("li")) {
                            $(this).parent().parent().parent().parent().show()
                        }
                        return true
                    } else {
                        return false
                    }
                }).show();
            }




        }
        else {
            $("#mmenu li").show();
        }
    });
    function GtTitle(e) {

    }
</script>
