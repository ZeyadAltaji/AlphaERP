function LinkRequested(e) {
    debugger
	$("title").html('@Resources.Resource.title - ' + e.text);
	var lisx = document.getElementById("mmenu").getElementsByTagName("li");
	for (var i = 0; i < lisx.length; i++) {
		lisx[i].children[0].className = '';
	}
	e.className = "active"
	var lis = document.getElementById("MainUL").getElementsByTagName("li");
	for (var i = 0; i < lis.length; i++) {
		if ('/' + lis[i].getAttribute('orginal') == e.getAttribute('href')) {
			lis[i].children[0].click();
		}
	}
}

function GeneralSearch(e) {
	//$('#GeneralUL').empty();
	$('#SearchResults').fadeIn(500, function () {});
	burn({
		s: e.value
	}, 'Home/GeneralSearch', '', GeneralSearchResult, true);
}

function GeneralSearchResult(F) {
	var ul = document.getElementById("GeneralUL");
	$(ul).empty();
	for (var i = 0; i < F.F.length; i++) {
		var li = document.createElement("li");
		var a = document.createElement("a");
		a.href = '#/' + F.F[i].Link;
		a.text = F.F[i].Caption;
		li.appendChild(a);
		ul.appendChild(li);
	}
}

function GetBadges() {
	$.getJSON('../../../Home/Badges', function (response) {
		if (response != null) {
			$.each(response, function (i, item) {
				if (item.count == 0) {
					$('#badge-' + item.prog).addClass("badge-0");
				} else {
					$('#badge-' + item.prog).text(item.count);
					$('#badge-' + item.prog).removeClass("badge-0");
				}
			});
		}
	});
}

