                function burn(data, url, modalName, callBack, Silent) {

            var token = $('[name=__RequestVerificationToken]').val();
            data.__RequestVerificationToken = token;
            var settings = {
                'async': true,
                'crossDomain': true,
                'url': '../../../' + url,
                'method': 'POST',
                'data': data,
                beforeSend: function() {

                },
                complete: function() {
                    if (!modalName == '') {
                        HideModal(modalName)
                    }
                }
            }
            $.ajax(settings)
                .done(function(response) {
                    if (response) {
                        if (!response.error == "") {
                            alert(response.error)
                        }
                        if (!modalName == '') {
                            HideModal(modalName)
                        }
                        done();
                        if (isFunction(callBack)) {
                            if (!response.error == "") {} else {

                                callBack(response)
                            }
                        }

                    } else {
                        alert('error');
                    }
                });

        }

