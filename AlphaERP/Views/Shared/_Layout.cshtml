    <script>
        function EditTable(e,TableID) {
          if (cntrlIsPressed) {
            EditTablePermission(TableID)
           }
         }
        function ColumnV(MYtable, c, v) {
            if (v == true || v == false) {
            var column = MYtable.column(c);
            column.visible(v);
            }
        }
        function EditTablePermission(e) {

            document.getElementById('ThisTableID').value = e;
            burn({ id: e }, '../../../Home/GetTableColumns', '', xxxxx, true);


        }
        function xxxxx(p) {
            $('#ColumnsCheckBoxes').empty();
            var table = document.getElementById('MyColumsTable')
            for (var i = 0; i < p.p.length; i++) {
                var att = "";
                if (p.p[i].Visible.toString().toLowerCase() == 'true') {
                    att =' checked = "true" ';
                }
                $(table).find('tbody').append("<tr>" +
                    '<td style="text-align:@Html.Translate("right","left") !important ; direction:@Html.Translate("rtl","ltr")"><label>' +
                    '<input type="checkbox" ColumnID="' + p.p[i].ColumnID + '" ' + att + '>' +
                    p.p[i].DescAr +
                    '</label></td></tr> ');
            }
            $('#SetTablePermission').modal('show')
        }
        function SaveTablePermission() {
            var xtrS = ColumnsCheckBoxes.getElementsByTagName("tr");
            var TablePermissions = new Array();
            for (var i = 0; i < xtrS.length; i++) {
                var TablePermission = {
                        ComID: 1,
                    TableID: document.getElementById('ThisTableID').value,
                    ColumnID: xtrS[i].cells[0].children[0].children[0].getAttribute('ColumnID'),
                        Visible : xtrS[i].cells[0].children[0].children[0].checked
                    };
                    TablePermissions.push(TablePermission);
            }
            burn({ PS: TablePermissions }, '../../../Home/SaveTablePermissions', 'SetTablePermission', ReLoAdPaGe, true)
        }
        function ReLoAdPaGe() {
            window.location.reload();
        }
    </script>
