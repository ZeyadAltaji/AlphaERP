    function OrderSatgesGrdView(__gu, __OrderYear, __OrderNo, formula_code, _sser, _year, _code, _FormDesc, _FinItem, _stage_code, stage_desc, _stat, _date) {
        gu__ = __gu;
        OrderYear__ = __OrderYear;
        OrderNo__ = __OrderNo;
        FormCode__ = formula_code;
        ItemDesc__ = _FinItem;

        document.getElementById('Mrp_YearPlanDetlsD_save_TxtYear').value = _year;
        document.getElementById('Mrp_YearPlanDetlsD_save_TxtOrderNo').value = _code;
        document.getElementById('Mrp_YearPlanDetlsD_save_LblFormDesc').value = _FormDesc;
        document.getElementById('Mrp_YearPlanDetlsD_save_LblFinItem').value = _FinItem;
        document.getElementById('Mrp_YearPlanDetlsD_save_TxtStageDesc').value = _stage_code + "  >> " + stage_desc;
        document.getElementById('Mrp_YearPlanDetlsD_save_TxtOrderNo').setAttribute('code', _stage_code)
        document.getElementById('Mrp_YearPlanDetlsD_save_TxtOrderNo').setAttribute('ser', _sser)
        document.getElementById('Mrp_YearPlanDetlsD_save_TxtOrderNo').setAttribute('formula_code', formula_code)

        document.getElementById('Mrp_YearPlanDetlsD_save_TxtStageStat').value = _stat;
        document.getElementById('Mrp_YearPlanDetlsD_save_TxtDate').value = _date;
        document.getElementById('Mrp_YearPlanDetlsD_save_txtTotalHrs').value = '';
        document.getElementById('Mrp_YearPlanDetlsD_save_txtTotalSetUP').value = '';
        document.getElementById('Mrp_YearPlanDetlsD_save_TxtTotalStopage').value = '';
        if (_stat == 'In Process') {
            $('#ProductionOrdersInProgressOPN').hide();
            $('#ProductionOrdersInProgressCLS').show();
        }
        if (_stat == 'Not Started') {
            $('#ProductionOrdersInProgressCLS').hide();
            $('#ProductionOrdersInProgressOPN').show();
        }
        if (_stat == 'Closed') {
            $('#ProductionOrdersInProgressCLS').hide();
            $('#ProductionOrdersInProgressOPN').hide();
        }
        $('#Mrp_YearPlanDetlsD_save_Mrp_YearPlanDetlsD').modal('show')
    }
