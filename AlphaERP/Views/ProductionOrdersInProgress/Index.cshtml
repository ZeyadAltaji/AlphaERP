<script>



    var openedRow = null;


    $('#Mrp_YearPlanDetlsD_save_Mrp_YearPlanDetlsD').draggable({
        handle: '.modal-header'
    });
    $('#ModalListAllDailyProduction').draggable({
        handle: '.modal-header'
    });
    $('#ModalDailyProdListView').draggable({
        handle: '.modal-header'
    });
    $('#Mrp_YearPlanDetlsD_save_Mrp_YearPlanDetlsD').on('shown.bs.modal', function () {
        $('#Mrp_YearPlanDetlsD_save_TxtYear').focus();
        $('#Mrp_YearPlanDetlsD_save_TxtYear').select();
    });
    $(document).ready(function() {
        var rowMatNavItem = $("#rowMatNavItem");
        var IssuedQtylbl = $("#IssuedQtylbl");
        var issuedQtyVal = $("#issuedQtyVal");

        var StdQtylbl = $("#StdQtylbl");
        var StdQtyVal = $("#StdQtyVal");

        var QtyVarlbl = $("#QtyVarlbl");
        var QtyVarVal = $("#QtyVarVal");
        var IssueCostlbl = $("#IssueCostlbl");
        var IssueCostVal = $("#IssueCostVal");

        // Add a click event handler to rowMatNavItem
        rowMatNavItem.click(function() {
            // Check if rowMatNavItem is active
            if (rowMatNavItem.hasClass("active")) {
                IssuedQtylbl.show();
                issuedQtyVal.show();

                StdQtylbl.show();
                StdQtyVal.show();

                QtyVarlbl.show();
                QtyVarVal.show();

                IssueCostlbl.show();
                IssueCostVal.show();
