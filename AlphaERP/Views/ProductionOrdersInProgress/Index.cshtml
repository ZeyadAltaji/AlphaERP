    function ProductionOrdersInProgressDoStage(OpID) {

        if (OpID == 1) {
            $('#Mrp_YearPlanDetlsD_save_txtTotalHrs').val('00:00')
            $('#Mrp_YearPlanDetlsD_save_txtTotalSetUP').val('00:00')
            $('#Mrp_YearPlanDetlsD_save_TxtTotalStopage').val('00:00')
        } else {
            if ($('#Mrp_YearPlanDetlsD_save_txtTotalHrs').val() == '') {
                $('#Mrp_YearPlanDetlsD_save_txtTotalHrs').focus();
                return;
            }
            if ($('#Mrp_YearPlanDetlsD_save_txtTotalSetUP').val() == '') {
                $('#Mrp_YearPlanDetlsD_save_txtTotalSetUP').focus();
                return;
            }
            if ($('#Mrp_YearPlanDetlsD_save_TxtTotalStopage').val() == '') {
                $('#Mrp_YearPlanDetlsD_save_TxtTotalStopage').focus();
                return;
            }
        }

        burn({
            OpID: OpID,
            FormCode: $('#Mrp_YearPlanDetlsD_save_TxtOrderNo').attr('formula_code'),
            year: $('#Mrp_YearPlanDetlsD_save_TxtYear').val(),
            OrderNo: $('#Mrp_YearPlanDetlsD_save_TxtOrderNo').val(),
            StageCode: $('#Mrp_YearPlanDetlsD_save_TxtOrderNo').attr('code'),
            StageSer: $('#Mrp_YearPlanDetlsD_save_TxtOrderNo').attr('ser'),
            date: $('#Mrp_YearPlanDetlsD_save_TxtDate').val(),
            hrs: $('#Mrp_YearPlanDetlsD_save_txtTotalHrs').val(),
            setuphrs: $('#Mrp_YearPlanDetlsD_save_txtTotalSetUP').val(),
            stophrs: $('#Mrp_YearPlanDetlsD_save_TxtTotalStopage').val()
        }, '../../../ProductionOrdersInProgress/UpdateStage', '', ProductionOrdersInProgressUpdated, false)

    }
