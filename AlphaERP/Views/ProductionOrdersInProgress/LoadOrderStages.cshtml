@using AlphaERP.Models;
@using System.Data
@model System.Data.DataSet
@{
    string gu = "div___" + Guid.NewGuid().ToString();
    string lang = Session["language"].ToString();
    Company company = (Company)Session["company"];
    int OrderNo = ViewBag.OrderNo;
    string ItemDesc = ViewBag.ItemDesc;
    int OrderYear = ViewBag.OrderYear;
    int RTestOptionQC = 1;
    int RTestOptionQA = 2;
    int ViewRawMateria = 1;
    int RFI = 2;
    int Viewproduction = 1;
    int Receiving = 2;
    string FormCode = ViewBag.FormCode;
 }
<style>
    .highlights {
        background-color: #cfcfcf !important;
     
    }

    .gu {
         transform: scale(1.00); 
        box-shadow: 2px 2px 12px rgba(0, 0, 0, 0.2), 3px 9px 8px rgba(0, 0, 0, 0.2);
        margin-bottom: 3rem;
        max-height: 89vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .btn-View {
        border: none;
        background: transparent;
        position: relative;
        top: 3px;
    }

        .btn-View:hover {
            background: transparent;
            border: none;
        }

        .btn-View .fa-eye {
            font-weight: 100 !important;
            color: #3c8dbc;
            font-size: 16px;
        }

    #table {
        flex-grow: 1;
        text-align: left !important;
    }

    .table-wrapper {
        position: relative;
        width: 100%;
        overflow: auto;
        max-height: 100vh;
        display: flex;
    }

    .sticky-thead {
        position: sticky;
        top: 30px;
        background: lavender;
        z-index: 1;
    }

    .QAtable, .QCtable {
        border-collapse: collapse !important;
    }

    .tableInfo caption {
        height: 3rem;
        position: sticky;
        top: 0rem;
        background: whitesmoke;
    }

    .QAtable caption, .QCtable caption {
        width: 100%;
        height: 3rem;
        font-size: 14px;
        bottom: 33px;
        background: yellow;
        position: sticky;
        z-index: 2;
        top: 0;
    }
    /*testing*/
    .progress-wrapper {
    position: relative;
    top: 1px;
    width: 100%;
}

.progress-bar-container {
    position: relative;
    width: 100%;
    height: 20px;
    background-color: #ddd;
}

.progress-bar-green {
    height: 100%;
    background-color: green;
    transition: width 1s linear; 
}

.progress-bar-red {
    height: 100%;
    background-color: red;
    transition: width 1s linear; 
}
   
</style>
@if (lang == "en")
{
    <style>
        .QAtable caption, .QCtable caption {
            text-align: center;
        }

        .table-detailsInfo th:nth-child(10),
        .QA td:nth-child(4),
        .table-detailsInfo td:nth-child(10),
        .QA td:nth-child(4) {
            border-right: 1px solid #ccc;
        }

        .QAtable caption {
            border-right: 1px solid black !important;
        }
    </style>
}
else
{
    <style>
        .QAtable caption, .QCtable caption {
            text-align: center;
        }

        .QAtable caption {
            border-left: 1px solid black !important;
        }

        .tableInfo thead tr .arSer {
            width: 5rem !important;
        }

        .QAtable thead tr .arStatus,
        .QCtable thead tr .arStatus {
            width: 11rem !important;
        }

        .table-detailsInfo th:nth-child(10),
        .QA td:nth-child(4),
        .table-detailsInfo td:nth-child(10),
        .QA td:nth-child(4) {
            border-left: 1px solid #ccc;
        }
    </style>
}
<div class="form-group" style="margin-bottom: 2rem;">
    <div class="col-md-2">
        <label class="unselectable" for="Prod_DailyProd_Edit_Year">@Html.Translate("رقم الطلب", "Order No.") </label>
    </div>
    <div class="col-md-2">
        <input required="true" type="number" id="Prod_DailyProd_Edit_Year" value="@OrderNo" disabled />
    </div>
    <div class="col-md-2">
        <label class="unselectable" for="Prod_DailyProd_Edit_DailyProdNo">@Html.Translate("المنتج النهائي", "Finished Product.") </label>
    </div>
    <div class="col-md-2" style="margin-bottom: 5px;">
        <input style="width:100%;" type="text" id="Prod_DailyProd_Edit_DailyProdNo" value="@ItemDesc" disabled />
    </div>
</div>
<div id="@gu" class="gu" style="width: 100%; overflow-x: auto;"">
  
        <div class="table-wrapper" id="alltable">
            <table style="width: 64%; margin: 0;" id="table tableinfos" class="tableInfo" >
                <caption></caption>
                <thead style="background: lavender; " class="sticky-thead">
                    <tr>
                        <th style="width:1px"></th>
                        <th class="arSer" style="width: 4rem;">@Html.Recource(309)</th>
                        <th>@Html.Recource(2559)</th>
                        <th>@Html.Translate("الحالة", "Status")</th>
                        <th>@Html.Translate("التاريخ", "Date")</th>
                        <th style="align-items: baseline;display: flex;position: relative;top: 2px;">@Html.Translate("تحديث الحالة", "Update Status")</th>
                        <th></th>
                        <th></th>
                        <th>@Html.Translate("عدد الساعات", "Total Hrs")</th>
                        <th>@Html.Translate("تفاصيل العمل", "D.Labor Edit")</th>
                        <th></th>


                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow Dr in Model.Tables["OrderStages"].Rows)
                    {
                        var begindates = Dr["begin_date"];
                        var end_date = Dr["end_date"];
                        var Closed_Date = Dr["Closed_Date"];

                        <tr class="table-detailsInfo" style="text-align:left;height: 2.4rem !important;" CompNo="@company.comp_num" OrderYear="@Dr["prepare_year"]" OrderNo="@Dr["prepare_code"]" StageSer="@Dr["StageSer"]" stage_code="@Dr["stage_code"]">

                            <td></td>
                            <td>@Dr["StageSer"]</td>
                            <td>@Dr["stage_desc"]</td>
                            <td>@Dr["StageStat"]</td>

 
                            @if (Dr["StageStat"].ToString().Trim() == "Closed")
                            {
                                <td>@Convert.ToDateTime(Dr["Closed_Date"].ToString()).ToString("yyyy/MM/dd")</td>
                            }
                            else if (Dr["StageStat"].ToString().Trim() == "In Process")
                            {
                                <td>@Convert.ToDateTime(begindates.ToString()).ToString("yyyy/MM/dd")</td>
                            }
                            else if (Dr["StageStat"].ToString().Trim() == "Not Started")
                            {
                                <td>Not Date</td>
                            }

                            @if (Convert.ToBoolean(Dr["Stage_Status"].ToString()) == true && Convert.ToBoolean(Dr["BeginFlag"].ToString()) == true)
                            {
                                <td></td>
                            }
                            else if (Convert.ToBoolean(Dr["Stage_Status"].ToString()) == false && Convert.ToBoolean(Dr["BeginFlag"].ToString()) == true)
                            {
                                <td id="btn-close-stage-cell"><button class="btn-de btn-close-stage" onclick="CloseStageModel(@company.comp_num,@Dr["prepare_year"],@Dr["prepare_code"],@Dr["StageSer"],@Dr["stage_code"])"><i class="fa fa-stop-circle"></i></button></td>
                            }
                            else if (Convert.ToBoolean(Dr["Stage_Status"].ToString()) == false && Convert.ToBoolean(Dr["BeginFlag"].ToString()) == false)
                            {
                                <td id="btn-open-stage-cell"><button class="btn-ed btn-open-stage" onclick="StartStageModel(@company.comp_num,@Dr["prepare_year"],@Dr["prepare_code"],@Dr["StageSer"],@Dr["stage_code"])"><i class="fa fa-play-circle" style="font-weight:100 !important;"></i></button></td>
                            }
                            else
                            {
                                <td></td>

                            }

                            <td style="width: 25%;">
                                <div class="progress-wrapper">
                                    <div class="progress-bar-container" data-begin-date="@begindates" data-end-date="@end_date" data-Closed_Date="@Closed_Date">
                                        <div class="progress-bar progress-bar-green" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                                            <span class="texttimeprogress"></span>
                                        </div>
                                        <div class="progress-bar progress-bar-red" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                                            <span class="texttimeprogress"></span>
                                        </div>
                                    </div>

                                </div>
                            </td>
                            <td></td>
                            <td><input style="width: 7rem; type="text" value="@Dr["TotalHours"]" disabled /></td>

                            <td><button class="btn btn-ed" type="button" onclick="EditLoadWorkHrsClick('@company.comp_num', '@Dr["prepare_year"]', '@Dr["prepare_code"]', '@Dr["StageSer"]', '@Dr["stage_code"]','@Dr["begin_date"]')" @(Dr["StageStat"].ToString().Trim() == "Closed" || Convert.ToBoolean(Dr["Stage_Status"].ToString()) == false && Convert.ToBoolean(Dr["BeginFlag"].ToString()) == false ? "disabled" : "")  ><i class="fa fa-pencil-alt"></i></button></td>
                            <td></td>

                        </tr>
                    }
                </tbody>
                <tfoot style="background: lavender; ">
                    <tr style="height: 2rem !important;"><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
                </tfoot>
            </table>
            <table style="width: 17%; margin: 0;" id="table" class="QAtable">
