        //This function to Calculate time and transfers from time from data base , to time loacl such as 12/12/2021 12:12:12 AM , and move ProgressBars
        function updateAllProgressBars() {
            const progressBarContainers = document.querySelectorAll('.progress-bar-container');
            progressBarContainers.forEach(progressBarContainer => {
                const beginDateStr = progressBarContainer.getAttribute('data-begin-date');
                const endDateStr = progressBarContainer.getAttribute('data-end-date');
                const closedDateStr = progressBarContainer.getAttribute('data-Closed_Date');
                const currentDate = new Date();
                const beginDate = moment(beginDateStr, 'DD/MM/YYYY hh:mm:ss A');
                const endDate = moment(endDateStr, 'DD/MM/YYYY hh:mm:ss A');
                const closedDate = moment(closedDateStr, 'DD/MM/YYYY hh:mm:ss A');
                const timeDifference = endDate - beginDate;
                const hoursDifference = timeDifference / (1000 * 60 * 60);
                const elapsedTime = (currentDate - beginDate) / (1000 * 60 * 60);
                let progressPercentage;
                if (closedDate < endDate) {
                    progressPercentage = 90;
                    progressBarColorClass = 'progress-bar-red';
                } else {
                    progressPercentage = Math.min((elapsedTime / hoursDifference) * 100, 100);
                }
                const progressBar = progressBarContainer.querySelector('.progress-bar');
                progressBar.style.width = progressPercentage + '%';


                if (progressPercentage === 90) {
                    progressBar.classList.remove('progress-bar-green');
                    progressBar.classList.add('progress-bar-red');
                } else if (currentDate < endDate) {
                    progressBar.classList.remove('progress-bar-red');
                    progressBar.classList.add('progress-bar-green');
                } else {
                    progressBar.classList.remove('progress-bar-green');
                    progressBar.classList.add('progress-bar-red');
                }


            });
        }
