                                    @*<button onclick="ProductionOrdersInProgressQCQA_ReTest('@Dr["prepare_year"]','@Dr["prepare_code"]','@Dr["stage_code"]','@Dr["StageSer"]','@RTestOptionQA')" class="btn-ed" style="margin-left: 7px;"><img src="~/Images/menu/Retest.png" width="18rem" height="18rem" /></button>*@


                                </div>
                            </td>

                        </tr>
                    }
                </tbody>
                <tfoot style="background: lavender; ">
                    <tr style="height: 2rem !important;"><td></td><td></td><td></td><td></td></tr>
                </tfoot>
            </table>
            <table style="width: 17%; margin: 0;" id="table" class="QCtable">
                <caption>@Html.Translate("ضبط الجودة", "Quality Control")</caption>
                <thead style="background: lavender; " class="sticky-thead">
                    <tr style="text-align:left">
                        <th></th>
                        <th class="arStatus" style="width: 7rem;">@Html.Translate("الحالة", "Status")</th>
                        <th>@Html.Translate("النتيجة", "Result")</th>
                        <th style="width: auto;max-width: 30%;"></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow Dr in Model.Tables["OrderStages"].Rows)
            {
                <tr class="table-detailsQC">
                    <td></td>
                    <td>@Dr["QCStat"]</td>
                    <td>@Dr["QCValue"]</td>

                    <td>
                        <div style="display:flex">
                            <button class="btn btn-View" onclick="ViewQCResult(@company.comp_num,@Dr["prepare_year"],@Dr["prepare_code"],@Dr["StageSer"],@Dr["stage_code"])" @(Convert.ToString(Dr["QCStat"]) == "-" && Convert.ToString(Dr["QCValue"]) == "-" ? "disabled" : "") ><i class="fa fa-eye" ></i></button>
                            <button onclick="ProductionOrdersInProgressQCQA_ReTest('@Dr["prepare_year"]','@Dr["prepare_code"]','@Dr["stage_code"]','@Dr["StageSer"]','@RTestOptionQC')"  class="btn-ed" style="margin-left: 7px;" @(Convert.ToString( Dr["QCValue"]) == "Faild" ? "" : "disabled") ><img src="~/Images/menu/Retest.png" width="18rem" height="18rem" style="cursor:@(Convert.ToString(Dr["QCValue"]) == "Faild"  ? "" : "no-drop;")" /></button>
                            @*<button onclick="ProductionOrdersInProgressQCQA_ReTest('@Dr["prepare_year"]','@Dr["prepare_code"]','@Dr["stage_code"]','@Dr["StageSer"]','@RTestOptionQC')" class="btn-ed" style="margin-left: 7px;"><img src="~/Images/menu/Retest.png" width="18rem" height="18rem" /></button>*@


                        </div>
                    </td>
                </tr>
                }
                </tbody>
                <tfoot style="background: lavender; ">
                    <tr style="height: 2rem !important;"><td></td><td></td><td></td><td></td></tr>
                </tfoot>
            </table>
         
        </div>
    </div>
