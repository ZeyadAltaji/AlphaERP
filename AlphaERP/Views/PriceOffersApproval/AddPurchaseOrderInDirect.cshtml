                                <td>
                                    <input id="PurchaseOrderInDirect_Qty_@Srial" value="@OrdDF.Qty" type="number" style="width:75px !important" onblur="CheckValueQty(@Srial)" />
                                </td>
                                @if (compMF.UseQty2 == true)
                                {
                                    <td>
                                        <input id="PurchaseOrderInDirect_Qty2_@Srial" value="@OrdDF.Qty2" type="number" style="width:75px !important" onblur="CheckValueQty2(@Srial)" />
                                    </td>
                                }
                                else
                                {
                                    <td hidden>
                                        <input id="PurchaseOrderInDirect_Qty2_@Srial" value="@OrdDF.Qty2" type="number" style="width:75px !important" onblur="CheckValueQty2(@Srial)" />
                                    </td>
                                }
                                <td>
                                    <input id="PurchaseOrderInDirect_Bouns_@Srial" value="@OrdDF.Bonus" type="number" style="width:75px !important" onblur="CheckValueBonus(@Srial)" />
                                </td>
                                <td>
                                    <input id="PurchaseOrderInDirect_DiscPer_@Srial" value="0" type="number" style="width:75px !important" onblur="CheckValuePerDiscount(@Srial)" />
                                </td>
                                <td>
                                    <input id="PurchaseOrderInDirect_SellPrice_@Srial" value="@OrdDF.Price" type="number" style="width:75px !important" onblur="CheckValuePrice(@Srial)" />
                                </td>
                                <td>
                                    <input id="PurchaseOrderInDirect_STax_Perc_@Srial" value="@MFItem.STax_Perc" type="number" style="width:75px !important" onblur="CheckValueSTaxPerc(@Srial)" />
                                </td>
                                <td>
                                    <input id="PurchaseOrderInDirect_RefNo_@Srial" value="0" type="text" style="width:75px !important" />
                                </td>
                                <td style="width: 8%;" id="PurchaseOrderInDirect_Total_@Srial">@Total</td>
                                <td style="text-align: center;">
                                    <textarea required="true" id="PurchaseOrderInDirect_ReqNotes_@Srial" placeholder="@Html.Recource(70)" />
                                </td>
                                <td>
                                    <input type="hidden" id="InputSerial" value="@(Srial++)" />
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
