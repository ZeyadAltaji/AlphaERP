                                <th style="text-align: center !important;">@Html.Recource(70)</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody style="text-align: center;" id="PurchaseOrderInDirectTBody">
                            @foreach (OrderDF OrdDF in OrdDFs)
                            {
                                InvItemsMF MFItem = MF.Where(x => x.ItemNo == OrdDF.ItemNo).FirstOrDefault();
                                InvUnitCode UCItem = UC.Where(x => x.UnitCode == MFItem.UnitC4).FirstOrDefault();
                                double Total = OrdDF.Qty.Value * Convert.ToDouble(OrdDF.Price.Value);
                            <tr style="height: 25px;" itemNo="@OrdDF.ItemNo" id="PurchaseOrderInDirect_Serial_@Srial">
                                <td class="second-col" style="text-align: center !important" id="PurchaseOrderInDirect_ItemNo">@OrdDF.ItemNo</td>
                                <td class="third-col" style="text-align: center !important" id="PurchaseOrderInDirect_ItemDesc">@Html.Translate(MFItem.ItemDesc, MFItem.ItemDesc_Ara)</td>
