    sumTotalAll()
    function sumTotalAll() {
        var table = $('#PurchaseOrderInDirectTBody tr');
        var trs = table;
        var totalAmount = 0;
        var itemDiscVal = 0;
        var totalDiscVal = 0;
        var totalTaxVal = 0;
        var itemTaxPer = 0;
        var TotalNetAmount = 0;
        var TotalAmnt = 0;
        var Total = 0;
        var FreightCost = 0;
        var ExtraExp = 0;

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value;
            itemTaxPer = Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_STax_Perc_' + InputSerial)[0].value);
            itemDiscVal = Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_Qty_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_SellPrice_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_DiscPer_' + InputSerial)[0].value) / 100;
            ItemTaxVal = (Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_Qty_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_SellPrice_' + InputSerial)[0].value) - Number(itemDiscVal)) * (Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_STax_Perc_' + InputSerial)[0].value) / 100);


            Total = (Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_SellPrice_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_Qty_' + InputSerial)[0].value)) - ((Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_SellPrice_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_Qty_' + InputSerial)[0].value)) * Number($(trs[i]).closest('tr').find('#PurchaseOrderInDirect_DiscPer_' + InputSerial)[0].value)) / 100;
            $(trs[i]).closest('tr').find('#PurchaseOrderInDirect_Total_' + InputSerial)[0].innerHTML = Number(Total).toFixed(3)

            totalAmount = Number(totalAmount) + Number(Total);
            totalTaxVal = Number(totalTaxVal) + Number(Total) * (itemTaxPer / 100);
            totalDiscVal = Number(totalDiscVal) + itemDiscVal
        }

        FreightCost = Number($('#MRP_PurchaseOrderInDirect_FreightCost').val())
        ExtraExp = Number($('#MRP_PurchaseOrderInDirect_ExtraExp').val())


        TotalAmnt = Number(totalAmount) + Number(totalDiscVal)
        TotalNetAmount = (Number(TotalAmnt) + Number(totalTaxVal)) - Number(totalDiscVal);
        TotalNetAmount = Number(TotalNetAmount) + Number(FreightCost) + Number(ExtraExp);
        $('#MRP_PurchaseOrderInDirect_Amount').val(Number(TotalAmnt).toFixed(3));
        $('#MRP_PurchaseOrderInDirect_Discount').val(Number(totalDiscVal).toFixed(3));
        $('#MRP_PurchaseOrderInDirect_TaxAmount').val(Number(totalTaxVal).toFixed(3));
        $('#MRP_PurchaseOrderInDirect_NetAmount').val(Number(TotalNetAmount).toFixed(3));

    }

    function CheckValueGrid(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt == 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
        else {
            if (Amt == '' || Amt == null) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
