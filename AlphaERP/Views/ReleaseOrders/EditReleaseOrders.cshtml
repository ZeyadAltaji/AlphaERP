    function ExcuteEdit_ReleaseOrderInfo(id) {

        var table = $("#eOrdReleaseOrdersDFTBody_" + id);
        var trs = table.find('tr');


        var ReleaseOrdersHF = {
            CompNo: '@company.comp_num',
            OrderYear: '@OrdYear',
            OrderNo: '@OrderNo',
            TawreedNo: '@TawreedNo',
            InboundSer: '@InboundSer',
            InboundGRN: '@InboundGRN',
            ReleaseOrdId: '@ReleaseOrdId',
            DocType: $('#Ord_eReleaseOrders_CboDocType_' + id).val(),
            StoreNo: $('#Ord_eReleaseOrders_StoreNo_' + id).val(),
            Notes: $('#Ord_eReleaseOrders_Notes_' + id).val(),
            IsApproval: false
        }
        var count = 0
        var ReleaseOrdersDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value;

            if (Number($(trs[i]).closest('tr').find('#eOrdRelease_FreeQty_' + InputSerial)[0].value) > Number($(trs[i]).closest('tr').find('#eOrdRelease_RemainingQty_' + InputSerial)[0].value)) {
                alert('@Html.Translate("لا يجوز ان تكون الكمية المحررة اكبر من الكميات المتبقية", "The Free Qty may not be greater than the Remaining Qty")');
                $(trs[i]).closest('tr').find('#eOrdRelease_FreeQty_' + InputSerial)[0].focus();
                return;
            }

            if ($(trs[i]).closest('tr').find('#eOrdRelease_FreeQty_' + InputSerial)[0].value > 0) {
                count = count + 1;
            }

            ReleaseOrdersDF.push({
                CompNo: '@company.comp_num',
                ReleaseOrdId: '@ReleaseOrdId',
                ItemSrl: $(trs[i]).closest('tr').find('#eOrdRelease_ItemSrl')[0].innerHTML,
                ItemNo: $(trs[i]).closest('tr').find('#eOrdRelease_ItemNo')[0].innerHTML,
                //batchNo: $(trs[i]).closest('tr').find('#eOrdRelease_batchNo')[0].innerHTML,
                batchNo:$(trs[i]).closest('tr').find('#eOrdRelease_batch_' + InputSerial)[0].value,
                TUnit: $(trs[i]).closest('tr').find('#eOrdRelease_TUnit')[0].innerHTML,
                UnitSerial: $(trs[i]).closest('tr').find('#eOrdRelease_TUnit')[0].getAttribute('unitSerial'),
                ReservedQty: $(trs[i]).closest('tr').find('#eOrdRelease_ReservedQty_' + InputSerial)[0].value,
                FreeQty: $(trs[i]).closest('tr').find('#eOrdRelease_FreeQty_' + InputSerial)[0].value
            })
        }

        var DocumentArchivetable = $("#eReleaseOrder_DocumentArchiveTbody");
        var trsDocumentArchive = DocumentArchivetable.find('tr');

        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#eReleaseOrder_EditDocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                OrderYear: '@OrdYear',
                OrderNo: '@OrderNo',
                TawreedNo: '@TawreedNo',
                InboundSer: '@InboundSer',
                InboundGRN: '@InboundGRN',
                ReleaseOrdId: '@ReleaseOrdId',
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#eReleaseOrder_EditDocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#eReleaseOrder_EditDocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#eReleaseOrder_EditDocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        if (count == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        wait();
        burn({ ReleaseOrdersHF: ReleaseOrdersHF, ReleaseOrdersDF: ReleaseOrdersDF, FileArchive: DocumentArchive }, '../../../ReleaseOrders/Edit_ReleaseOrders', '', ReloadeReleaseOrdersInfo, false);
    }
    function ReloadeReleaseOrdersInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        var TawreedNo = r.TawreedNo;
        var InboundSer = r.InboundSer;
        var InboundGRN = r.InboundGRN;

        CloseWindow('../../../ReleaseOrders/EditReleaseOrders?OrdYear=' + r.OrdYear + '&OrderNo= ' + r.OrdNo + '&TawreedNo=' + TawreedNo + '&InboundSer=' + InboundSer + '&InboundGRN=' + InboundGRN + '&ReleaseOrdId=' + r.ReleaseOrdId + '');

        var table = $("#ReleaseOrdersHFTable tbody");
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrdNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo && $(trs[i])[0].getAttribute('InboundSer') == InboundSer && $(trs[i])[0].getAttribute('InboundGRN') == InboundGRN) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");

                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');
                var InboundSer = $(trs[i])[0].getAttribute('InboundSer');
                var InboundGRN = $(trs[i])[0].getAttribute('InboundGRN');

                $.get("../../../../ReleaseOrders/DetailsReleaseOrders?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo + '&InboundSer=' + InboundSer + '&InboundGRN=' + InboundGRN, function (data) {
                    ReleaseOrdersHFTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }

</script>

