@model AlphaERP.Models.YearPlanDetlsH
@using System.Data.SqlClient
@using AlphaERP.Models
@{

}

<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-10" style="padding:0">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-1">
                <label for="AnnualProductionPlanYear" class="unselectable">@Html.Recource(59)</label>
            </div>
            <div class="col-md-1">
                <input onblur="AnnualProductionPlanSerach()" type="number" maxlength="4" max="2099" id="AnnualProductionPlanYear" value="@Model.PlanYear" style="width:100%" />
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="AnnualProductionPlanListTableDiv">
        @Html.Partial("~/Views/AnnualProductionPlan/List.cshtml")
    </div>
</div>



<div class="modal fade wide" id="AnnualProductionPlan_InvItemsMF">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(4756)</label>
            </div>
            <div class="modal-body row">

                <div class="form-group">
                    <div class="col-md-12">
                        <table class="table table-hover" id="AnnualProductionPlanSelectItemTable">
                            <thead>
                                <tr>
                                    <th>@Html.Recource(44)</th>
                                    <th>@Html.Recource(74)</th>
                                    <th>@Html.Recource(4286)</th>
                                    <th>@Html.Recource(360)</th>
                                    <th>@Html.Recource(67)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int Comp_num = Convert.ToInt16(Html.CompNo().ToString());
                                    string query = string.Format("exec SP_Search {0},'WHERE (prod_formula_header_info.comp_no = {0}) AND (prod_formula_header_info.SusFlag = 0)',392", Comp_num);
                                    using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                    {
                                        SqlCommand cmd = new SqlCommand(query, cn);
                                        cn.Open();
                                        SqlDataReader rdr = cmd.ExecuteReader();
                                        if (rdr.HasRows)
                                        {
                                            while (rdr.Read())
                                            {
                                                <tr onclick="$(this).toggleClass('selected');">
                                                    <td>@rdr["ItemNofin"]</td>
                                                    <td title="@rdr["ItemDescfin"].ToString()">@Html.Trim(rdr["ItemDescfin"].ToString(), 30)</td>
                                                    <td>@rdr["formula_code"]</td>
                                                    <td>@rdr["formula_desc"]</td>
                                                    <td>@rdr["UnitCode"]</td>
                                                    <td></td>
                                                </tr>
                                            }
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="AnnualProductionPlanDOK();" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>


<script>
    function AnnualProductionPlanSerach() {
        wait();
        $('#AnnualProductionPlanListTableDiv').load('../../../AnnualProductionPlan/List?Year=' + input.value, function () {
            done();
        })
    }
    var input = document.getElementById("AnnualProductionPlanYear");
    input.addEventListener("keyup", function (event) {
        if (event.keyCode === 13) {
            event.preventDefault();
            if (input.value < 2099 && input.value > 2000) {
                AnnualProductionPlanSerach();
            } else {
                MsgBox('@Html.Translate("سنة خاطئة","Wrong year")','red')
                input.focus();
            }

        }
    });

    $('#AnnualProductionPlan_InvItemsMF').draggable({
        handle: '.modal-header'
    });

    function AnnualProductionPlan_AddItem() {
        $('#AnnualProductionPlanSelectItemTable tr').removeClass("selected");
        $('#AnnualProductionPlan_InvItemsMF').modal('show')
    }

    var APPitemsTable = $('#AnnualProductionPlanSelectItemTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });

    function AnnualProductionPlanDOK() {
        var data = APPitemsTable.rows('.selected').data();
        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة واحدة على الاقل", "Select one item at least")');
            return;
        }
        var table_ = $("#AnnualProductionPlanDataTable > tbody");

        for (var i = 0; i < data.length; i++) {
            var Added = false;
            table_.find("tr").each(function () {
                var ItemNo_ = $(this).find("td:first-child").text();
                var ItemName_ = $(this).find("td:nth-child(2)").text();
                var PlanNo_ = $(this).find("td:nth-child(3)").text();
                if (ItemNo_ == data[i][0] && ItemName_ == data[i][1] && PlanNo_ == data[i][2]) {
                    Added = true;
                }
            });

            if (!Added) {
                APPTable.row.add([
                    data[i][0],
                    data[i][1],
                    data[i][2],
                    data[i][3],
                    data[i][4],
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<input type="number" style="width:50px !important" />',
                    '<button class="btn-de" onclick="RemoveRow(this)"><i class= "fa fa-trash-alt"></i ></button>'
                ]).draw(false);
            }

        }

        $('#AnnualProductionPlan_InvItemsMF').modal('hide')

    }

    function AnnualProductionPlanUpdateClick() {
        var Dts = new Array();
        var trs = document.getElementById('AnnualProductionPlanDataTableTB').getElementsByTagName("tr");

        for (var i = 0; i < trs.length; i++) {
            Dts.push
                ({
                    ItemNo: trs[i].cells[0].innerHTML,
                    FormCode: trs[i].cells[2].innerHTML,
                    MQty1: trs[i].cells[5].children[0].value,
                    MQty2: trs[i].cells[6].children[0].value,
                    MQty3: trs[i].cells[7].children[0].value,
                    MQty4: trs[i].cells[8].children[0].value,
                    MQty5: trs[i].cells[9].children[0].value,
                    MQty6: trs[i].cells[10].children[0].value,
                    MQty7: trs[i].cells[11].children[0].value,
                    MQty8: trs[i].cells[12].children[0].value,
                    MQty9: trs[i].cells[13].children[0].value,
                    MQty10: trs[i].cells[14].children[0].value,
                    MQty11: trs[i].cells[15].children[0].value,
                    MQty12: trs[i].cells[16].children[0].value
                });
        }
        burn({ Dts: Dts, Year: $('#AnnualProductionPlanYear').val() }, '../../../AnnualProductionPlan/Action', '', APPSaved, false)
    }

    function APPSaved() {
        MsgBox('@Html.Translate("حفظ ناجح", "Saved successfully")','green');
    }

</script>