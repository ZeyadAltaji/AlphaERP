                    <div class="col-md-2">
                        <label class="unselectable" for="ProdCost_PurchaseReqHF_v_ReqDate">@Html.Recource(58) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        @OrdRequestHF.ReqDate.Value.ToShortDateString()
                    </div>
                    <div class="col-md-2">
                        <label class="unselectable" for="ProdCost_PurchaseReqHF_v_ReqDeliveryDate">@Html.Translate("تاريخ التسليم المطلوب", "Requested Delivery Date")</label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        @OrdRequestHF.ReqDeliveryDate.Value.ToShortDateString()
                    </div>
                    <div class="col-md-2">
                        <label class="unselectable" for="ProdCost_PurchaseReqHF_v_ReferenceNo">@Html.Recource(96) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <input required="false" style="width: 150px !important; " type="text" id="ProdCost_PurchaseReqHF_v_ReferenceNo" value="@OrdRequestHF.RefNo" disabled />
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="col-md-12">
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <label class="unselectable">@Html.Recource(9700) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <input disabled style="width:100%" type="text" id="ProdCost_PurchaseReqHF_v_txtReqBUName" value="@RBBDesc" />
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <label class="unselectable">@Html.Recource(9701) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <input disabled style="width:100%" type="text" id="ProdCost_PurchaseReqHF_v_txtAuthBUName" value="@ABBDesc" />
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <label class="unselectable">@Html.Recource(3242) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <select style="width:100%" id="ProdCost_PurchaseReqHF_Edit_CboPurpose" disabled>
                            @foreach (var v in Purpose)
                            {
                                if (v.Id == OrdRequestHF.Purpose.Value)
                                {
                                    <option value="@v.Id" selected>@Html.Translate(v.DescAr, v.DescEn)</option>
                                }
                                else
                                {
                                    <option value="@v.Id">@Html.Translate(v.DescAr, v.DescEn)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="col-md-12">
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <label class="unselectable">@Html.Recource(9704) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <input disabled style="width:100%" type="text" id="ProdCost_PurchaseReqHF_v_txtOrderPriorityName" value="@OrderPriortyDesc" />
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <label class="unselectable">@Html.Recource(1671) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <select style="width:100%" id="ProdCost_PurchaseReqHF_v_CboCurrCode" disabled>
                            @foreach (var v in Currency)
                            {
                                if (v.Id == OrdRequestHF.CurrNo.Value)
                                {
                                    <option value="@v.Id" selected>@Html.Translate(v.DescAr, v.DescEn)</option>
                                }
                                else
                                {
                                    <option value="@v.Id">@Html.Translate(v.DescAr, v.DescEn)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <label class="unselectable">@Html.Recource(3265) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <select style="width:100%" id="ProdCost_PurchaseReqHF_Edit_CboOrderType" disabled>
