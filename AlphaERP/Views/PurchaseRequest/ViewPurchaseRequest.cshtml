@using AlphaERP.Models
@using System.Data.SqlClient;
@using System.Data;
@using System.Collections.Generic;
@{
    string ReqNo = ViewBag.ReqNo;
    int ReqYear = ViewBag.ReqYear;
    Company company = (Company)Session["company"];

    List<BusunisUnit> BU = ViewBag.BusunisUnit;

    Ord_RequestHF OrdRequestHF = new MDB().Ord_RequestHF.Where(x => x.CompNo == company.comp_num && x.ReqYear == ReqYear && x.ReqNo == ReqNo).FirstOrDefault();
    List<Ord_RequestDF> OrdRequestDF = new MDB().Ord_RequestDF.Where(x => x.CompNo == company.comp_num && x.ReqYear == ReqYear && x.ReqNo == ReqNo).ToList();
    string RBBDesc = BU.Where(x => x.Id == OrdRequestHF.ReqBU).Select(O => Html.Translate(O.DescAr, O.DescEn)).FirstOrDefault().ToString();
    string ABBDesc = BU.Where(x => x.Id == OrdRequestHF.AuthBU).Select(O => Html.Translate(O.DescAr, O.DescEn)).FirstOrDefault().ToString();
    List<InvItemsMF> Mf = new MDB().InvItemsMFs.Where(x => x.CompNo == company.comp_num).ToList();
    double TotalAll = new MDB().Ord_RequestDF.Where(x => x.CompNo == company.comp_num && x.ReqYear == ReqYear && x.ReqNo == ReqNo).Sum(o => o.TotalValue).Value;
    string OrderPriortyDesc = "";
    if (OrdRequestHF.OrderPriority == 0)
    {
        OrderPriortyDesc = Html.Translate("عادي", "Normal").ToString();
    }
    else if (OrdRequestHF.OrderPriority == 1)
    {
        OrderPriortyDesc = Html.Translate("متوسط", "Medium").ToString();
    }
    else if (OrdRequestHF.OrderPriority == 2)
    {
        OrderPriortyDesc = Html.Translate("عاجل", "Urgently").ToString();
    }
    InvCompMF compMF = new MDB().InvCompMFs.Where(x => x.CompNo == company.comp_num).FirstOrDefault();
    if (compMF.UseQty2 == null)
    {
        compMF.UseQty2 = false;
    }

    List<PayCodes> Currency = ViewBag.Currency;
    List<PayCodes> PrdType = ViewBag.PrdType;
    List<PayCodes> Purpose = ViewBag.Purpose;

    double QtyOH = 0;
    double ResQty = 0;
    DataTable Dt = new DataTable();

    DataTable DtAttachment = new DataTable();
    DtAttachment = ViewBag.Arch;
    
    ClientsActive CActive = new MDB().ClientsActives.Where(x => x.CompNo == company.comp_num).FirstOrDefault();

    var Count = 1;
}

<div class="box box-primary">
