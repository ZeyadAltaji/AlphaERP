            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#PurchaseRequest_Price_' + InputSerial)[0].value)) {
                alert('@Html.Translate("يجب إدخال السعر", "ou Must Enter Price")');
                return;
            }

            if (ProdCost_PurchaseReqHF_save_CboOrderType.value == 1) {
                OrdReqDF.push({
                    CompNo: '@company.comp_num',
                    ItemNo: $(trs[i]).closest('tr').find('#PurchaseRequest_ItemNo')[0].innerHTML,
                    TUnit: $(trs[i]).closest('tr').find('.PurchaseRequest_Item_Unit option:Selected')[0].getAttribute('unitCode'),
                    Qty: $(trs[i]).closest('tr').find('#PurchaseRequest_Qty_' + InputSerial)[0].value,
                    Qty2: $(trs[i]).closest('tr').find('#PurchaseRequest_Qty2_' + InputSerial)[0].value,
                    Price: $(trs[i]).closest('tr').find('#PurchaseRequest_Price_' + InputSerial)[0].value,
                    TotalValue: $(trs[i]).closest('tr').find('#PurchaseReques_Total_' + InputSerial)[0].value,
                    Note: $(trs[i]).closest('tr').find('#PurchaseReques_Notes_' + InputSerial)[0].value,
                    UnitSerial: $(trs[i]).closest('tr').find('.PurchaseRequest_Item_Unit')[0].value,
                    ReqDeliveryDate: $(trs[i]).closest('tr').find('#PurchaseReques_RequestedDeliveryDate_' + InputSerial)[0].value,
                    QtyStock: $(trs[i]).closest('tr').find('#PurchaseRequest_QtyOH_' + InputSerial)[0].value
                });
            }
            else {
                OrdReqDF.push({
                    CompNo: '@company.comp_num',
                    ItemNo: $(trs[i]).closest('tr').find('#PurchaseRequest_ItemNo')[0].value,
                    TUnit: 'Meter',
                    Qty: $(trs[i]).closest('tr').find('#PurchaseRequest_Qty_' + InputSerial)[0].value,
                    Qty2: 0,
                    Price: $(trs[i]).closest('tr').find('#PurchaseRequest_Price_' + InputSerial)[0].value,
                    TotalValue: $(trs[i]).closest('tr').find('#PurchaseReques_Total_' + InputSerial)[0].value,
                    Note: $(trs[i]).closest('tr').find('#PurchaseReques_Notes_' + InputSerial)[0].value,
                    UnitSerial: 4,
                    ReqDeliveryDate: $(trs[i]).closest('tr').find('#PurchaseReques_RequestedDeliveryDate_' + InputSerial)[0].value,
                    QtyStock: 0
                });
            }
        }

        var DocumentArchivetable = $("#Ord_PR_DocumentArchiveTbody");
        var trsDocumentArchive = DocumentArchivetable.find('tr');

        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#Ord_PR_DocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                OrderYear:0,
                OrderNo: 0,
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#Ord_PR_DocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#Ord_PR_DocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#Ord_PR_DocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        if (confirm('@Resources.Resource.ConfirmCreatePurchaseOrders')) {
            burn({ OrdReqHF: OrdReqHF, OrdReqDF: OrdReqDF, FileArchive: DocumentArchive }, '../../../PurchaseRequest/Save_PurchaseRequest', '', ReloadPurchaseRequest, false);
        }
        else {
            done();
        }
    }
    function ReloadPurchaseRequest() {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#PurchaseReqItemKasihTBody').empty();
        $('#PurchaseRequest').modal('hide');
        CloseWindow('/PurchaseRequest/AddPurchaseRequestKasih');
        $('#Prod_PurchaseRequestListDiv').load('../../../PurchaseRequest/PurchaseRequestList?ReqStatus=0');
    }

</script>