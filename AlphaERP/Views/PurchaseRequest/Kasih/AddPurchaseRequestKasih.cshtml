    });

    GetDataByOrderType();

    function GetDataByOrderType() {
        if (ProdCost_PurchaseReqHF_save_CboOrderType.value == 1) {
            PurchaseReqItemDiv.innerHTML = "";
            $('#PurchaseReqItemDiv').load('../../../PurchaseRequest/PurchaseReqItemDiv');
        }
        else {
            PurchaseReqItemDiv.innerHTML = "";
            $('#PurchaseReqItemDiv').load('../../../PurchaseRequest/PurchaseReqItemDivKasih');
        }
    }
    function addPurchaseRequest() {
        ProdCost_PurchaseReqHF_save_ReqDate.value = '@DateTime.Now.ToString("yyyy-MM-dd")';
        ProdCost_PurchaseReqHF_save_ReqNotes.value = '';
        $('#PurchaseRequest').modal('show');
    }
    var RawMaterial = $('#SelectPurchaseReqItemTable').DataTable({
        "scrollY": 200,
