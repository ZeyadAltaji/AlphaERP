<div class="modal fade" id="Model_ePR_DocumentsArchive">
    <div class="modal-dialog" style="width:800px; ">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Translate("أرشفة الوثائق", "Archive Documents")</label>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-12">
                        <button onclick="ePR_DocumentsArchive()" type="button" class="btn btn-primary">@Html.Recource(32)</button>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-12" style="overflow-y:auto">
                        <table class="table table-hover" id="ePR_DocumentArchiveTable">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(66)</th>
                                    <th style="text-align: center !important">@Html.Recource(5628)</th>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(5629)</th>
                                    <th style="text-align: center !important">@Html.Recource(5630)</th>
                                    <th style="text-align: center !important">@Html.Recource(5631)</th>
                                    <th style="text-align: center !important">@Html.Recource(5632)</th>
                                    <th style="text-align: center !important">@Html.Recource(5633)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="eOrdPR_DocumentArchiveTbody" style="border-top: 1px solid #ddd;">
                                @foreach (DataRow row in DtAttachment.Rows)
                                {
                                    DateTime date = Convert.ToDateTime(row["DataUpload"].ToString());
                                    <tr id="EditOrdPRDocumentArchive_@Count">
                                        <td>
                                            <input id="OrdPR_EditDocumentArchive_FileId" type="hidden" value="@Count" />
                                        </td>
                                        <td>
                                            <input type="text" style="width: 115px !important; text-align: center !important" id="OrdPR_EditDocumentArchive_Description_@Count" value="@row["Description"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="OrdPR_EditDocumentArchive_File_@Count" onchange="uploadFile(this,@Count)" /></div>
                                        </td>
                                        <td></td>
                                        <td>
                                            <a id="OrdPR_AddDownloadFile_@Count" onclick="DownloadFile('@row["FileName"].ToString()','@Convert.ToBase64String((byte[])row["ArchiveData"])')"><span class="glyphicon glyphicon-download"></span></a>
                                        </td>
                                        <td>
                                            <input id="OrdPR_EditAttachmentFiles_FileName_@Count" type="text" style="text-align: center !important" value="@row["FileName"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="OrdPR_EditDocumentArchive_UploadDate_@Count" type="text" style="width: 95px; text-align: center !important" value="@date.ToShortDateString()" disabled />
                                        </td>
                                        <td>
                                            <input id="OrdPR_EditDocumentArchive_FileSize_@Count" type="text" style="width: 70px; text-align: center !important" value="@row["FileSize"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="OrdPR_EditDocumentArchive_FileType_@Count" type="text" style="width: 55px; text-align: center !important" value="@row["ContentType"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <button class="btn-de" onclick="RemoveRowUpload(this,@Count)" type="button"><i class="fa fa-trash-alt"></i></button>
                                            <input type="hidden" id="InputSerial" value="@(Count++)" />
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="EditOrdPRDocumentArchive()" class="btn btn-primary">@Resources.Resource.Save</button>
            </div>
        </form>
    </div>
</div>
<script>
    function Edit_OrdPRDocuments() {
        $('#Model_ePR_DocumentsArchive').draggable({
            handle: ".modal-header",
        });
        $('#Model_ePR_DocumentsArchive').modal('show');

        var table = $("#eOrdPR_DocumentArchiveTbody");
        var trs = table.find('tr');
        Count = trs.length;
    }
    function ePR_DocumentsArchive() {
        var table = $("#eOrdPR_DocumentArchiveTbody");
        Count++;
        var newarray = [];
        newarray.push('<input id="OrdPR_EditDocumentArchive_FileId" type="hidden" value="' + Count + '" />')
        newarray.push('<input id="OrdPR_EditDocumentArchive_Description_' + Count + '" type="text" style="width: 115px !important;text-align: center !important" />')
        newarray.push('<div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="OrdPR_EditDocumentArchive_File_' + Count + '" onchange="uploadFile(this,' + Count + ')" /></div>')
        newarray.push('')
        newarray.push('<a id="OrdPR_AddDownloadFile_' + Count + '" onclick="DownloadFile()"><span class="glyphicon glyphicon-download"></span></a>')
        newarray.push('<input id="OrdPR_EditAttachmentFiles_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="OrdPR_EditDocumentArchive_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="OrdPR_EditDocumentArchive_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="OrdPR_EditDocumentArchive_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $(table).append(
            GenRowDocumentArchive(newarray, 'EditOrdPRDocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        var $td = $(ID).closest("td");
        $($td).find("input[type=file]").click();
    }
    function uploadFile(Elem, Count) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;

        var table = $("#eOrdPR_DocumentArchiveTbody");
        var tr = table.find('#EditOrdPRDocumentArchive_' + Count);

        var fileName = tr.find("#OrdPR_EditDocumentArchive_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        tr.find('#OrdPR_EditAttachmentFiles_FileName_' + Count)[0].value = fileName;
        tr.find('#OrdPR_EditDocumentArchive_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#OrdPR_EditDocumentArchive_FileSize_' + Count)[0].value = file_size;
        tr.find('#OrdPR_EditDocumentArchive_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }

            var OrderYear = '@ReqYear';
            var OrderNo = '@ReqNo';

            $formData.append('Id', Count);
            $formData.append('OrderYear', OrderYear);
            $formData.append('OrderNo', OrderNo);
        }

        $.ajax({
            url: '@Url.Action("InsertFile", "PurchaseRequest")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function (r) {
                var table = $("#eOrdPR_DocumentArchiveTbody");
                var tr = table.find('#EditOrdPRDocumentArchive_' + Count);
                tr.find('#OrdPR_AddDownloadFile_' + Count)[0].setAttribute('onclick', 'DownloadFile("' + fileName + '","' + r + '")')
            },
            error: function (error) {
            }
        });
    }
    function RemoveRowUpload(e, Count, srl) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
             var OrderYear = '@ReqYear';
            var OrderNo = '@ReqNo';

            $.ajax({
                type: "POST",
                url:'@Url.Action("RemoveFile", "OrdReceipt")',
                data: { Id: Count, OrderYear: OrderYear, OrderNo: OrderNo },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function EditOrdPRDocumentArchive() {
        $('#Model_ePR_DocumentsArchive').modal('hide')
    }
</script>
@*--------------------------------END Model Documents -----------------------------*@

<script>
    $('.ePurchaseRequest_Item_Unit').select2();
    $('#ProdCost_PurchaseReqHF_Edit_CboOrderPriority').select2();
    $('#ProdCost_PurchaseReqHF_Edit_CboCurrCode').select2();
    $('#ProdCost_PurchaseReqHF_Edit_CboOrderType').select2();
    $('#ProdCost_PurchaseReqHF_Edit_CboPurpose').select2();

    $('#ProdCost_PurchaseReqHF_Edit_CboReqBU').val(@OrdRequestHF.ReqBU);
    $('#ProdCost_PurchaseReqHF_Edit_CboAuthBU').val(@OrdRequestHF.AuthBU);
    $('#ProdCost_PurchaseReqHF_Edit_CboReqBU').select2();
    $('#ProdCost_PurchaseReqHF_Edit_CboAuthBU').select2();


    $('#Model_eInvItemsMF').draggable({
        handle: ".modal-header",
    });

    var RawMaterial = $('#eSelectPurchaseReqItemTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25,
        "language": {
            search: ' <i class="fa fa-search" aria-hidden="true"></i> '
        }
    });

    function Edit_InvItemsMF(type) {
        itemType = type;
        frmSatus = 1;
        $('#eSelectPurchaseReqItemTable tr').removeClass("selected");
        $('#Model_eInvItemsMF').modal('show');
    }
    function eSelectingItemMaterial_InvItemsMF() {
        var data = RawMaterial.rows('.selected').data();
        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة واحدة على الاقل", "Select one item at least")');
            return;
        }
        if (frmSatus == 1) {
            if (itemType == 1) {
                var table_ = $("#ePurchaseReqItemTBody");
                var item = new Array();
                for (var i = 0; i < data.length; i++) {
                    var Added = false;
                    if (table_.find("tr").length != 0) {
                        table_.find("tr").each(function () {
                            var ItemNo_ = $(this).find("td #ePurchaseRequest_ItemNo")[0].value;
                            if (ItemNo_ == data[i][0]) {
                                Added = true;
                                return false;
                            }
                            else {
                                Added = false;
                            }
                        });
                        if (!Added) {
                            item.push({
                                ItemNo: data[i][0],
                                ItemDesc: data[i][1]
                            });
                        }
                    }
                    else {
                        item.push({
                            ItemNo: data[i][0],
                            ItemDesc: data[i][1]
                        });
                    }
                }
                if (item.length != 0) {
                    burn({ items: item, srl: table_.find("tr").length }, '../../../PurchaseRequest/ePurchaseRequestItems', '', LoadItemRawMaterial, true);
                }
                else {
                    $('#Model_eInvItemsMF').modal('hide')
                }
            }
        }
    }
    function LoadItemRawMaterial(r) {
        if (frmSatus == 1) {
            $('#ePurchaseReqItemTBody').append(r);
        }
        else {
            $('#ePurchaseReqItemTBody').append(r);
        }
        $('#Model_eInvItemsMF').modal('hide')
    }
    function eGetItemNo(e) {
       var data = RawMaterial.rows('.selected').data();
        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة واحدة على الاقل", "Select one item at least")');
            return;
        }
        if (frmSatus == 1) {
            if (itemType == 1) {
                var table_ = $("#ePurchaseReqItemTBody");
                var item = new Array();
                for (var i = 0; i < data.length; i++) {
                    var Added = false;
                    if (table_.find("tr").length != 0) {
                        table_.find("tr").each(function () {
                            var ItemNo_ = $(this).find("td:first-child").text();
                            if (ItemNo_ == data[i][0]) {
                                Added = true;
                                return false;
                            }
                            else {
                                Added = false;
                            }
                        });
                        if (!Added) {
                            item.push({
                                ItemNo: data[i][0],
                                ItemDesc: data[i][1]
                            });
                        }
                    }
                    else {
                        item.push({
                            ItemNo: data[i][0],
                            ItemDesc: data[i][1]
                        });
                    }
                }
                if (item.length != 0) {
                    burn({ items: item, srl: table_.find("tr").length }, '../../../PurchaseRequest/ePurchaseRequestItems', '', LoadItemRawMaterial, true);
                }
                else {
                    $('#Model_InvItemsMF').modal('hide')
                }
            }
        }
    }

    function eGetchangeCost(item, e, srl) {

        burn({ itemNo: item, Unitserial: e, srl: srl }, '../../../PurchaseRequest/LoadUnitCost', '', LoadCost, true);
    }

    function LoadCost(r) {
        var tr = $('#ePurchaseReqItemTBody #ePurchaseRequest_Serial_' + r.srl);
        tr.find('#ePurchaseRequest_QtyOH_' + r.srl)[0].value = r.QtyOH;
        tr.find('#ePurchaseRequest_ResQty_' + r.srl)[0].value = r.ResQty;
    }

