    function ExcuteEditProd_PurchaseRequest() {

        var table = $('#ePurchaseReqItemTBody tr');
        var trs = table;
        if (trs.length == 0) {
            alert('@Html.Translate("يجب إدخال المواد", "Raw Items must be entered")');
            return false;
        }

        var OrdReqHF = {
            CompNo: '@company.comp_num',
            ReqYear: '@ReqYear',
            ReqNo: '@ReqNo',
            ReqDate: ProdCost_PurchaseReqHF_Edit_ReqDate.value,
            ReqDeliveryDate: ProdCost_PurchaseReqHF_Edit_ReqDeliveryDate.value,
            ReqBU: ProdCost_PurchaseReqHF_Edit_CboReqBU.value,
            AuthBU: ProdCost_PurchaseReqHF_Edit_CboAuthBU.value,
            Note: ProdCost_PurchaseReqHF_Edit_ReqNotes.value,
            OrderPriority: ProdCost_PurchaseReqHF_Edit_CboOrderPriority.value,
            CurrNo: ProdCost_PurchaseReqHF_Edit_CboCurrCode.value,
            RefNo: ProdCost_PurchaseReqHF_Edit_RefNo.value,
            OrderType: ProdCost_PurchaseReqHF_Edit_CboOrderType.value,
            Purpose: ProdCost_PurchaseReqHF_Edit_CboPurpose.value
        };
        var OrdReqDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#ePurchaseRequest_Qty_' + InputSerial)[0].value)) {
                $(trs[i]).closest('tr').find('#ePurchaseRequest_Qty_' + InputSerial)[0].focus();
                alert('@Html.Translate("يجب إدخال الكمية", "You Must Enter Qty")');
                return;
            }
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#ePurchaseRequest_Price_' + InputSerial)[0].value)) {
                $(trs[i]).closest('tr').find('#ePurchaseRequest_Price_' + InputSerial)[0].focus();
                alert('@Html.Translate("يجب إدخال السعر", "ou Must Enter Price")');
                return;
            }

            if (ProdCost_PurchaseReqHF_Edit_CboOrderType.value == 1) {
                OrdReqDF.push({
                    CompNo: '@company.comp_num',
                    ItemNo: $(trs[i]).closest('tr').find('#ePurchaseRequest_ItemNo')[0].value,
                    TUnit: $(trs[i]).closest('tr').find('.ePurchaseRequest_Item_Unit option:Selected')[0].getAttribute('unitCode'),
                    Qty: $(trs[i]).closest('tr').find('#ePurchaseRequest_Qtyth_' + InputSerial)[0].value,
                    Qty2: $(trs[i]).closest('tr').find('#ePurchaseRequest_Qty2_' + InputSerial)[0].value,
                    Price: $(trs[i]).closest('tr').find('#ePurchaseRequest_Priceth_' + InputSerial)[0].value,
                    TotalValue: $(trs[i]).closest('tr').find('#ePurchaseReques_Totalth_' + InputSerial)[0].value,
                    Note: $(trs[i]).closest('tr').find('#ePurchaseReques_Notes_' + InputSerial)[0].value,
                    UnitSerial: $(trs[i]).closest('tr').find('.ePurchaseRequest_Item_Unit')[0].value,
                    ReqDeliveryDate: $(trs[i]).closest('tr').find('#ePurchaseRequest_RequestedDeliveryDate_' + InputSerial)[0].value,
                    QtyStock: $(trs[i]).closest('tr').find('#ePurchaseRequest_QtyOH_' + InputSerial)[0].value,
                });
            }
            else {
                OrdReqDF.push({
                    CompNo: '@company.comp_num',
                    ItemNo: $(trs[i]).closest('tr').find('#ePurchaseRequest_ItemNo')[0].value,
                    TUnit: 'Meter',
                    Qty: $(trs[i]).closest('tr').find('#ePurchaseRequest_Qty_' + InputSerial)[0].value,
                    Qty2: 0,
                    Price: $(trs[i]).closest('tr').find('#ePurchaseRequest_Price_' + InputSerial)[0].value,
                    TotalValue: $(trs[i]).closest('tr').find('#ePurchaseReques_Total_' + InputSerial)[0].value,
                    Note: $(trs[i]).closest('tr').find('#ePurchaseReques_Notes_' + InputSerial)[0].value,
                    UnitSerial: 4,
                    ReqDeliveryDate: $(trs[i]).closest('tr').find('#ePurchaseRequest_RequestedDeliveryDate_' + InputSerial)[0].value,
                    QtyStock: 0,
                });
            }
            
        }

        var DocumentArchivetable = $("#eOrdPR_DocumentArchiveTbody");
        var trsDocumentArchive = DocumentArchivetable.find('tr');

        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#OrdPR_EditDocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                ReqYear: '@ReqYear',
            ReqNo: '@ReqNo',
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#OrdPR_EditDocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#OrdPR_EditDocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#OrdPR_EditDocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        if (confirm('@Resources.Resource.ConfirmEditPurchaseOrders')) {
            burn({ OrdReqHF: OrdReqHF, OrdReqDF: OrdReqDF, FileArchive: DocumentArchive }, '../../../PurchaseRequest/Edit_PurchaseRequest', '', ReloadPurchaseRequest, false);
        }
        else {
            done();
        }
    }
    function ReloadPurchaseRequest(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        if(@CActive.ClientNo == 239){
            CloseWindow('/PurchaseRequest/EditPurchaseRequestKasih?ReqYear=' + r.ReqYear + '&ReqNo=' + r.ReqNo + '');
        }
        else{
            CloseWindow('/PurchaseRequest/EditPurchaseRequest?ReqYear=' + r.ReqYear + '&ReqNo=' + r.ReqNo + '');
        }
        $('#Prod_PurchaseRequestListDiv').load('../../../PurchaseRequest/PurchaseRequestList?ReqStatus=0');
    }
</script>