@*----------------------Dept-----------------------*@
<div class="modal fade" id="Model_eOrdPOExpenses_GLDEPMFs_@TransNo">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(1867)</label>
            </div>
            <div class="modal-body row">

                <div class="form-group">
                    <div class="col-md-12">
                        <table class="table table-hover" id="Select_eOrdExpenses_GLDEPMFsTable_@TransNo">
                            <thead>
                                <tr>
                                    <th style="width: 20%;">@Html.Recource(110)</th>
                                    <th style="width: 55%;">@Html.Recource(109)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    foreach (var item in GLDEPMFs)
                                    {
                                        <tr onclick="eSelect_finGLDEPMFs(this)" ondblclick="eSelect_GLDEPMFs(this)" DEP_NUM="@item.DEP_NUM" DepDesc="@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()">
                                            <td style="width: 20%;" id="eOrdExpenses_DEPNUM">@item.DEP_NUM</td>
                                            <td style="width: 55%;" id="eOrdExpenses_DEPNAME">@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()</td>
                                            <td></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Selecting_eOrdPOExpenses_GLDEPMFs(@TransNo)" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    var Serial = 0;
    var deptId = 0;
    var GLDEPMFs = $('#Select_eOrdExpenses_GLDEPMFsTable_'+ @TransNo).DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    function eSerach_Dept(Id) {
        Serial = Id;
        var table = $("#Select_eOrdExpenses_GLDEPMFsTable_" + Id);
        table.find('tr').removeClass("selected");

        $('#Model_eOrdPOExpenses_GLDEPMFs_' + Id).draggable({
            handle: ".modal-header",
        });

        $('#Model_eOrdPOExpenses_GLDEPMFs_' + Id).modal('show');
    }
    function eSelect_finGLDEPMFs(e) {
        var table = $('#Select_eOrdExpenses_GLDEPMFsTable_' + Serial);
        var oTable = table.dataTable();
        var trs = oTable.$('tr');

        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function eSelect_GLDEPMFs(e) {
        var table = $('#Select_eOrdExpenses_GLDEPMFsTable_' + Serial);
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');

        $('#eOrd_PurchaseOrderExpenses_DeptNo_' + Serial).val(e.getAttribute('DEP_NUM'));
        $('#eOrd_PurchaseOrderExpenses_DeptName_' + Serial).val(e.getAttribute('DepDesc'));

        $('#eOrd_PurchaseOrderExpenses_OldDeptNo_' + Serial).val(e.getAttribute('DEP_NUM'));
        deptId = trs[0].getAttribute('DEP_NUM');

        $('#eOrd_PurchaseOrderExpenses_AccNo_' + Serial).val(null)
        $('#eOrd_PurchaseOrderExpenses_AccName_' + Serial).val(null)

        $('#Model_eOrdPOExpenses_GLDEPMFs_' + Serial).modal('hide')
    }
    function Selecting_eOrdPOExpenses_GLDEPMFs(Id) {
        var table = $('#Select_eOrdExpenses_GLDEPMFsTable_' + Serial);
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');

        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار دائرة", "Select one Dept")');
            return;
        }

        $('#eOrd_PurchaseOrderExpenses_DeptNo_' + Serial).val(trs[0].getAttribute('DEP_NUM'));
        $('#eOrd_PurchaseOrderExpenses_DeptName_' + Serial).val(trs[0].getAttribute('DepDesc'));

        $('#eOrd_PurchaseOrderExpenses_OldDeptNo_' + Serial).val(trs[0].getAttribute('DEP_NUM'));
        deptId = trs[0].getAttribute('DEP_NUM');

        $('#eOrd_PurchaseOrderExpenses_AccNo_' + Serial).val(null)
        $('#eOrd_PurchaseOrderExpenses_AccName_' + Serial).val(null)


        $('#Model_eOrdPOExpenses_GLDEPMFs_' + Serial).modal('hide')
    }
    function GetDeptName(e,id) {
        Serial = id;
        if (CheckValue('eOrd_PurchaseOrderExpenses_DeptNo_' + id)) {
            $('#eOrd_PurchaseOrderExpenses_DeptNo_' + id).val(null);
            $('#eOrd_PurchaseOrderExpenses_DeptName_' + id).val(null);
            $('#eOrd_PurchaseOrderExpenses_AccNo_' + id).val(null);
            $('#eOrd_PurchaseOrderExpenses_AccName_' + id).val(null);
            return;
        }
        if ($('#eOrd_PurchaseOrderExpenses_OldDeptNo_' + id).val() != e) {
            $('#eOrd_PurchaseOrderExpenses_OldDeptNo_' + id).val(e);
            burn({ DeptNo: e }, '../../../PurchaseOrder/GetDeptName', '', LoadDeptName, true);
        }
    }
    function LoadDeptName(r) {
        if (r.DeptName == "") {
