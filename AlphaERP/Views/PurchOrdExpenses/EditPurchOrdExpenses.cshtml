            return;
        }

        var table = $("#eOrd_PurchOrdExpensesTBody_" + Id);
        var trs = table.find('tr');

        if (trs.length == 0) {
            alert('@Html.Translate("يجب إدخال المصاريف", "Raw Expenses must be entered")');
            return false;
        }

        if (Number($('#eOrd_PurchaseOrderExpenses_TotalAmount_' + Id).val()).toFixed(3) != Number($('#eOrd_PurchaseOrderExpenses_TotalExpenses_' + Id).val()).toFixed(3)) {
            alert('@Html.Translate("يجب ان تكون القيمة الاجمالية تساوي قيمة المصاريف", "The total value must be equal to the value of the expenses")');
            return false;
        }

        var POExpensesHF = {
            CompNo: '@company.comp_num',
            TransYear: $('#eOrd_PurchaseOrderExpenses_TransYear_' + Id).val(),
            TransNo: $('#eOrd_PurchaseOrderExpenses_TransNo_' + Id).val(),
            TransDate: $('#eOrd_PurchaseOrderExpenses_TransDate_' + Id).val(),
            DeptNo: $('#eOrd_PurchaseOrderExpenses_DeptNo_' + Id).val(),
            AccNo: $('#eOrd_PurchaseOrderExpenses_AccNo_' + Id).val(),
            CurrCode:$('#eOrd_PurchaseOrderExpenses_CboCurrCode_' + Id).val(),
            ExRate: $('#eOrd_PurchaseOrderExpenses_ConvertRate_' + Id).val(),
            TotalAmount: $('#eOrd_PurchaseOrderExpenses_TotalAmount_' + Id).val(),
            FrAmount: $('#eOrd_PurchaseOrderExpenses_TotalFrAmount_' + Id).val(),
            Note: $('#eOrd_PurchaseOrderExpenses_Notes_' + Id).val(),
            IsPosted: false
        };

        var POExpensesDF = new Array();

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value;

            POExpensesDF.push({
                CompNo: '@company.comp_num',
                TransYear: $('#eOrd_PurchaseOrderExpenses_TransYear_' + Id).val(),
                TransNo: $('#eOrd_PurchaseOrderExpenses_TransNo_' + Id).val(),
                OrderYear: $(trs[i]).closest('tr').find('#ePOExpenses_OrdYear')[0].innerHTML,
                OrderNo: $(trs[i]).closest('tr').find('#ePOExpenses_OrderNo')[0].innerHTML,
                TawreedNo: $(trs[i]).closest('tr').find('#ePOExpenses_TawreedNo')[0].innerHTML,
                ExpID: $(trs[i]).closest('tr').find('#ePOExpenses_ExpID')[0].innerHTML,
                Amount: $(trs[i]).closest('tr').find('#ePODF_Amount_' + InputSerial)[0].value,
                FrAmount: $(trs[i]).closest('tr').find('#ePODF_FrAmount_' + InputSerial)[0].value,
                SalesTaxAmount: $(trs[i]).closest('tr').find('#ePODF_SalesTaxAmount_' + InputSerial)[0].value,
                SalesTaxAmountFr: $(trs[i]).closest('tr').find('#ePODF_SalesTaxAmountFr_' + InputSerial)[0].value,
                IncomeTaxAmount: $(trs[i]).closest('tr').find('#ePODF_IncomeTaxAmount_' + InputSerial)[0].value,
                IncomeTaxAmountFr: $(trs[i]).closest('tr').find('#ePODF_IncomeTaxAmountFr_' + InputSerial)[0].value,
                CustomtaxAmount: $(trs[i]).closest('tr').find('#ePODF_CustomtaxAmount_' + InputSerial)[0].value,
                CustomtaxAmountFr: $(trs[i]).closest('tr').find('#ePODF_CustomtaxAmountFr_' + InputSerial)[0].value
            });
        }

        wait();
        burn({ POExpensesHF: POExpensesHF, POExpensesDF: POExpensesDF }, '../../../PurchOrdExpenses/EditPurchOrdExp', '', ReloadePurchaseOrderExpenses, false);
    }
    function ReloadePurchaseOrderExpenses(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        CloseWindow('/PurchOrdExpenses/EditPurchOrdExpenses?TransYear=' + r.TransYear + '&TransNo=' + r.TransNo + '');
        SerachPurchOrdExpensesInfo();
    }

</script>
