<div class="modal fade" id="Model_OrdPOExpenses_GLDEPMFs">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(1867)</label>
            </div>
            <div class="modal-body row">

                <div class="form-group">
                    <div class="col-md-12">
                        <table class="table table-hover" id="Select_OrdExpenses_GLDEPMFsTable">
                            <thead>
                                <tr>
                                    <th style="width: 20%;">@Html.Recource(110)</th>
                                    <th style="width: 55%;">@Html.Recource(109)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    foreach (var item in GLDEPMFs)
                                    {
                                        <tr onclick="Select_finGLDEPMFs(this)" ondblclick="Select_GLDEPMFs(this)" DEP_NUM="@item.DEP_NUM" DepDesc="@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()">
                                            <td style="width: 20%;" id="OrdExpenses_DEPNUM">@item.DEP_NUM</td>
                                            <td style="width: 55%;" id="OrdExpenses_DEPNAME">@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()</td>
                                            <td></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Selecting_OrdPOExpenses_GLDEPMFs()" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_OrdPOExpenses_GLDEPMFs').draggable({
        handle: ".modal-header",
    });
    var deptId = 0;
    var GLDEPMFs = $('#Select_OrdExpenses_GLDEPMFsTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    function Serach_Dept() {
        $('#Select_OrdExpenses_GLDEPMFsTable tr').removeClass("selected");
        $('#Model_OrdPOExpenses_GLDEPMFs').modal('show');
    }
    function Select_finGLDEPMFs(e) {
        var trs = GLDEPMFs.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Select_GLDEPMFs(e) {
        var trs = GLDEPMFs.$('tr[name=selected]');
        Ord_PurchaseOrderExpenses_DeptNo.value = trs[0].getAttribute('DEP_NUM');
        Ord_PurchaseOrderExpenses_DeptName.value = trs[0].getAttribute('DepDesc');

        deptId = trs[0].getAttribute('DEP_NUM')
        Ord_PurchaseOrderExpenses_AccNo.value = null;
        Ord_PurchaseOrderExpenses_AccName.value = null;

        $('#Model_OrdPOExpenses_GLDEPMFs').modal('hide')
    }
    function Selecting_OrdPOExpenses_GLDEPMFs() {
        var trs = GLDEPMFs.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار دائرة", "Select one Dept")');
            return;
        }

        Ord_PurchaseOrderExpenses_DeptNo.value = trs[0].getAttribute('DEP_NUM');
        Ord_PurchaseOrderExpenses_DeptName.value = trs[0].getAttribute('DepDesc');

        deptId = trs[0].getAttribute('DEP_NUM')

        Ord_PurchaseOrderExpenses_AccNo.value = null;
        Ord_PurchaseOrderExpenses_AccName.value = null;

        $('#Model_OrdPOExpenses_GLDEPMFs').modal('hide')
    }
    function GetDeptName(e) {
        
        if (deptId != e) {
            deptId = e;
            burn({ DeptNo: e }, '../../../PurchOrdExpenses/GetDeptName', '', LoadDeptName, true);
        }
    }
    function LoadDeptName(r) {
        if (r.DeptName == "") {
            Ord_PurchaseOrderExpenses_DeptNo.value = null;
            Ord_PurchaseOrderExpenses_DeptName.value = null;
        }
        else {
            Ord_PurchaseOrderExpenses_DeptName.value = r.DeptName;
        }
        Ord_PurchaseOrderExpenses_AccNo.value = null;
        Ord_PurchaseOrderExpenses_AccName.value = null;
    }
   
</script>
@*----------------------ENDDept-----------------------*@

@*----------------------Acc-----------------------*@
<div class="modal fade" id="Model_OrdPOExpenses_Acc">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(1867)</label>
            </div>
            <div class="modal-body row" id="OrdPOExpenses_Accbody">

            </div>
            <div class="modal-footer">
                <button type="button" onclick="Selecting_OrdPOExpenses_Acc()" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_OrdPOExpenses_Acc').draggable({
        handle: ".modal-header",
    });
    function CheckValue(ID) {
        if (document.getElementById(ID).getAttribute('required') == 'true') {
            if (document.getElementById(ID).value == '') {
                document.getElementById(ID).focus();
                return true;
            } else {
                return false;
            }
        }
        return false;
    }
    function Serach_Acc() {
        if (CheckValue('Ord_PurchaseOrderExpenses_DeptNo')) {
            alert('@Html.Translate("يجب ادخال الدائرة", "You must enter the Dept")');
            return;
        }
        burn({ DeptId: Ord_PurchaseOrderExpenses_DeptNo.value }, '../../../PurchOrdExpenses/Account', '', ReloadtAcc, true);
    }
    function ReloadtAcc(r) {
        OrdPOExpenses_Accbody.innerHTML = "";
        $('#OrdPOExpenses_Accbody').html(r);
        $('#Model_OrdPOExpenses_Acc').modal('show');
    }
    function Select_finAcc(e) {
        var table = $('#OrdPOExpenses_AccTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Selecting_OrdPOExpenses_Acc() {
        var table = $('#OrdPOExpenses_AccTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حساب", "Select one Acc")');
            return;
        }

        Ord_PurchaseOrderExpenses_AccNo.value = trs[0].getAttribute('acc_num');
        Ord_PurchaseOrderExpenses_AccName.value = trs[0].getAttribute('AccDesc');
        $('#Model_OrdPOExpenses_Acc').modal('hide')
    }
    function Select_Acc(e) {
        var table = $('#OrdPOExpenses_AccTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');

        Ord_PurchaseOrderExpenses_AccNo.value = trs[0].getAttribute('acc_num');
        Ord_PurchaseOrderExpenses_AccName.value = trs[0].getAttribute('AccDesc');

        $('#Model_OrdPOExpenses_Acc').modal('hide')
    }

    function GetVendorName(e) {
        burn({ DeptNo: Ord_PurchaseOrderExpenses_DeptNo.value, AccNo: e }, '../../../PurchOrdExpenses/GetVendorName', '', LoadVendorName, true);
    }
    function LoadVendorName(r) {
        if (r.VendorName == "") {
            alert('@Html.Translate("الحساب غير مربوط بالدائرة", "The Account Is Not Linked To The Department")');
            Ord_PurchaseOrderExpenses_AccNo.focus();
            Ord_PurchaseOrderExpenses_AccNo.value = null;
            Ord_PurchaseOrderExpenses_AccName.value = null;
        }
        else {
            Ord_PurchaseOrderExpenses_AccName.value = r.VendorName;
        }
    }
</script>
@*----------------------ENDAcc-----------------------*@

