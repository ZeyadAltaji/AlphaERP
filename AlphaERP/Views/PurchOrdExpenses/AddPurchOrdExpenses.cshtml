<script>
    $('#Ord_PurchaseOrderExpenses_CboCurrCode').select2();
    GetCurrRatio();
    function GetCurrRatio() {
        burn({ CurrCode: Ord_PurchaseOrderExpenses_CboCurrCode.value }, '../../../PurchOrdExpenses/GetCurrRatio', '', LoadCurrRatio, true);
    }
    function LoadCurrRatio(r) {
        Ord_PurchaseOrderExpenses_ConvertRate.value = r.CurrRat;
    }
   
    function CheckAmount(e) {
        if (e < 0) {
            alert('@Html.Translate("لا يجوز ان تكون القيمة اقل من 0", "The value of the Amount may not be less than 0")');
            e.value = 0;
            e.focus();
            return false;
        }

        var TotalFrAmount = (Number(e) / Number(Ord_PurchaseOrderExpenses_ConvertRate.value));
        $('#Ord_PurchaseOrderExpenses_TotalFrAmount').val(Number(TotalFrAmount).toFixed(3));
    }
    function CheckFrAmount(e) {
        Number(Ord_PurchaseOrderExpenses_TotalFrAmount.value).toFixed(3);
        if (e < 0) {
            alert('@Html.Translate("لا يجوز ان تكون القيمة بالاجنبي اقل من 0", "The value of the Fr Amount may not be less than 0")');
            e.value = 0;
            e.focus();
            return false;
        }
        if (e != Number(Ord_PurchaseOrderExpenses_TotalFrAmount.value).toFixed(3)) {
            var TotalAmount = (Number(e) * Number(Ord_PurchaseOrderExpenses_ConvertRate.value));
            $('#Ord_PurchaseOrderExpenses_TotalAmount').val(Number(TotalAmount).toFixed(3));
        }
    }


    function sumTotalAll() {
        var table = $('#Ord_PurchOrdExpensesTBody tr');
        var trs = table;
        var TotalAmount = 0;
        var TotalAmountFr = 0;
        var SalesTaxAmount = 0;
        var SalesTaxAmountFr = 0;
        var IncomeTaxAmount = 0;
        var IncomeTaxAmountFr = 0;
        var CustomtaxAmount = 0;
        var CustomtaxAmountFr = 0;

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            TotalAmount += Number($(trs[i]).closest('tr').find('#PODF_Amount_' + InputSerial)[0].value);
            TotalAmountFr += Number($(trs[i]).closest('tr').find('#PODF_FrAmount_' + InputSerial)[0].value);
            SalesTaxAmount += Number($(trs[i]).closest('tr').find('#PODF_SalesTaxAmount_' + InputSerial)[0].value);
            SalesTaxAmountFr += Number($(trs[i]).closest('tr').find('#PODF_SalesTaxAmountFr_' + InputSerial)[0].value);
            IncomeTaxAmount += Number($(trs[i]).closest('tr').find('#PODF_IncomeTaxAmount_' + InputSerial)[0].value);
            IncomeTaxAmountFr += Number($(trs[i]).closest('tr').find('#PODF_IncomeTaxAmountFr_' + InputSerial)[0].value);
            CustomtaxAmount += Number($(trs[i]).closest('tr').find('#PODF_CustomtaxAmount_' + InputSerial)[0].value);
            CustomtaxAmountFr += Number($(trs[i]).closest('tr').find('#PODF_CustomtaxAmountFr_' + InputSerial)[0].value);
        }

        $('#Ord_PurchaseOrderExpenses_TotalExpenses').val(Number(TotalAmount).toFixed(3));
        $('#Ord_PurchaseOrderExpenses_TotalExpensesFr').val(Number(TotalAmountFr).toFixed(3));
        $('#Ord_PurchaseOrderExpenses_SalesTaxAmount').val(Number(SalesTaxAmount).toFixed(3));
        $('#Ord_PurchaseOrderExpenses_SalesTaxAmountFr').val(Number(SalesTaxAmountFr).toFixed(3));
        $('#Ord_PurchaseOrderExpenses_IncomeTaxAmount').val(Number(IncomeTaxAmount).toFixed(3));
        $('#Ord_PurchaseOrderExpenses_IncomeTaxAmountFr').val(Number(IncomeTaxAmountFr).toFixed(3));
        $('#Ord_PurchaseOrderExpenses_CustomtaxAmount').val(Number(CustomtaxAmount).toFixed(3));
        $('#Ord_PurchaseOrderExpenses_CustomtaxAmountFr').val(Number(CustomtaxAmountFr).toFixed(3));
    }

