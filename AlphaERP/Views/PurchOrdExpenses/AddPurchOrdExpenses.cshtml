        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار مصروف واحدة على الاقل", "Select one ExpCodes at least")');
            return;
        }
        var table_ = $("#Ord_PurchOrdExpensesTBody");
        var item = new Array();
        for (var i = 0; i < data.length; i++) {
            var Added = false;
            if (table_.find("tr").length != 0) {
                table_.find("tr").each(function () {
                    var OrdYear_ = $(this).find("#POExpenses_OrdYear").text();
                    var OrderNo_ = $(this).find("#POExpenses_OrderNo").text();
                    var TawreedNo_ = $(this).find("#POExpenses_TawreedNo").text();
                    var ExpID_ = $(this).find("#POExpenses_ExpID").text();

                    if (OrdYear_ == data[i][0] && OrderNo_ == data[i][1] && TawreedNo_ == data[i][2] && ExpID_ == data[i][3]) {
                        Added = true;
                        return false;
                    }
                    else {
                        Added = false;
                    }
                });
                if (!Added) {
                    item.push({
                        OrdYear: data[i][0],
                        OrderNo: data[i][1],
                        TawreedNo: data[i][2],
                        ExpID: data[i][3],
                        ExpArDesc: data[i][4]
                    });
                }
            }
            else {
                item.push({
                    OrdYear: data[i][0],
                    OrderNo: data[i][1],
                    TawreedNo: data[i][2],
                    ExpID: data[i][3],
                    ExpArDesc: data[i][4]
                });
            }
        }
        if (item.length != 0) {
            burn({ items: item, srl: table_.find("tr").length }, '../../../PurchOrdExpenses/PurchOrdExp', '', LoadItemRawMaterial, true);
        }
        else {
            $('#Model_OrdPOExpenses_ExpCodes').modal('hide')
        }
