    function ExcuteSaveOrd_POExpenses() {

        if (Ord_PurchaseOrderExpenses_DeptNo.value == "") {
            alert('@Html.Translate("يجب إدخال الدائرة", "You Must Enter Dept")');
            return;
        }

        if (Ord_PurchaseOrderExpenses_AccNo.value == "") {
            alert('@Html.Translate("يجب إدخال الحساب الدائن", "You Must Enter Credit Acc.")');
            return;
        }

        if (Ord_PurchaseOrderExpenses_TotalAmount.value == "") {
            alert('@Html.Translate("يجب ان تكون القيمة الاجمالية اكبر من 0", "The total Amount must be greater than 0")');
            return;
        }

        var table = $('#Ord_PurchOrdExpensesTBody tr');
        var trs = table;

        if (trs.length == 0) {
            alert('@Html.Translate("يجب إدخال المصاريف", "Raw Expenses must be entered")');
            return false;
        }

        if (Number(Ord_PurchaseOrderExpenses_TotalAmount.value).toFixed(3) != Number(Ord_PurchaseOrderExpenses_TotalExpenses.value).toFixed(3)) {
            alert('@Html.Translate("يجب ان تكون القيمة الاجمالية تساوي قيمة المصاريف", "The total value must be equal to the value of the expenses")');
            return false;
        }

        var POExpensesHF = {
            CompNo: '@company.comp_num',
            TransYear: Ord_PurchaseOrderExpenses_TransYear.value,
            TransNo: 0,
            TransDate: Ord_PurchaseOrderExpenses_TransDate.value,
            DeptNo: Ord_PurchaseOrderExpenses_DeptNo.value,
            AccNo: Ord_PurchaseOrderExpenses_AccNo.value,
            CurrCode: Ord_PurchaseOrderExpenses_CboCurrCode.value,
            ExRate: Ord_PurchaseOrderExpenses_ConvertRate.value,
            TotalAmount: Ord_PurchaseOrderExpenses_TotalAmount.value,
            FrAmount: Ord_PurchaseOrderExpenses_TotalFrAmount.value,
            Note: Ord_PurchaseOrderExpenses_Notes.value,
            IsPosted: false
        };

        var POExpensesDF = new Array();
        
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value;

            POExpensesDF.push({
                CompNo: '@company.comp_num',
                TransYear: Ord_PurchaseOrderExpenses_TransYear.value,
                TransNo: 0,
                OrderYear: $(trs[i]).closest('tr').find('#POExpenses_OrdYear')[0].innerHTML,
                OrderNo: $(trs[i]).closest('tr').find('#POExpenses_OrderNo')[0].innerHTML,
                TawreedNo: $(trs[i]).closest('tr').find('#POExpenses_TawreedNo')[0].innerHTML,
                ExpID: $(trs[i]).closest('tr').find('#POExpenses_ExpID')[0].innerHTML,
                Amount: $(trs[i]).closest('tr').find('#PODF_Amount_' + InputSerial)[0].value,
                FrAmount: $(trs[i]).closest('tr').find('#PODF_FrAmount_' + InputSerial)[0].value,
                SalesTaxAmount: $(trs[i]).closest('tr').find('#PODF_SalesTaxAmount_' + InputSerial)[0].value,
                SalesTaxAmountFr: $(trs[i]).closest('tr').find('#PODF_SalesTaxAmountFr_' + InputSerial)[0].value,
                IncomeTaxAmount: $(trs[i]).closest('tr').find('#PODF_IncomeTaxAmount_' + InputSerial)[0].value,
                IncomeTaxAmountFr: $(trs[i]).closest('tr').find('#PODF_IncomeTaxAmountFr_' + InputSerial)[0].value,
                CustomtaxAmount: $(trs[i]).closest('tr').find('#PODF_CustomtaxAmount_' + InputSerial)[0].value,
                CustomtaxAmountFr: $(trs[i]).closest('tr').find('#PODF_CustomtaxAmountFr_' + InputSerial)[0].value
            });
        }

        wait();
        burn({ POExpensesHF: POExpensesHF, POExpensesDF: POExpensesDF }, '../../../PurchOrdExpenses/CreatePurchOrdExpenses', '', ReloadPurchaseOrderExpenses, false);
    }
    function ReloadPurchaseOrderExpenses(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        CloseWindow('/PurchOrdExpenses/AddPurchOrdExpenses');
        SerachPurchOrdExpensesInfo();
    }

</script>
