    function Select_ExpCodes(e) {
        var table_ = $("#Ord_PurchOrdExpensesTBody");
        var item = new Array();
        var Added = false;
        if (table_.find("tr").length != 0) {
            table_.find("tr").each(function () {
                var OrdYear_ = $(this).find("#POExpenses_OrdYear").text();
                var OrderNo_ = $(this).find("#POExpenses_OrderNo").text();
                var TawreedNo_ = $(this).find("#POExpenses_TawreedNo").text();
                var ExpID_ = $(this).find("#POExpenses_ExpID").text();

                if (OrdYear_ == e.getAttribute('OrdYear') && OrderNo_ == e.getAttribute('OrderNo') && TawreedNo_ == e.getAttribute('TawreedNo') && ExpID_ == e.getAttribute('ExpID')) {
                    Added = true;
                    return false;
                }
                else {
                    Added = false;
                }
            });
            if (!Added) {
                item.push({
                    OrdYear: e.getAttribute('OrdYear'),
                    OrderNo: e.getAttribute('OrderNo'),
                    TawreedNo: e.getAttribute('TawreedNo'),
                    ExpID: e.getAttribute('ExpID'),
                    ExpArDesc: e.getAttribute('ExpDesc')
                });
            }
        }
        else {
            item.push({
                OrdYear: e.getAttribute('OrdYear'),
                OrderNo: e.getAttribute('OrderNo'),
                TawreedNo: e.getAttribute('TawreedNo'),
                ExpID: e.getAttribute('ExpID'),
                ExpArDesc: e.getAttribute('ExpDesc')
            });
        }

        if (item.length != 0) {
            burn({ items: item, srl: table_.find("tr").length }, '../../../PurchOrdExpenses/PurchOrdExp', '', LoadItemRawMaterial, true);
        }
        else {
            $('#Model_OrdPOExpenses_ExpCodes').modal('hide')
        }
    }
    function SelectingPurchOrdExpenses_ExpCodes(e) {
