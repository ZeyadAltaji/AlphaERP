    }
    function Selecting_StageQCTest() {
        var data = QCTest.rows('.selected').data();
        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار فحص واحدة على الاقل", "Select one Test at least")');
            return;
        }
        var table_ = ""
        var item = new Array();
        table_ = $("#QCStageDetailsTbody");
        for (var i = 0; i < data.length; i++) {
            var Added = false;
            if (table_.find("tr").length != 0) {
                table_.find("tr").each(function () {
                    var TestCode_ = $(this).find("td:first-child").text();
                    if (TestCode_ == data[i][0]) {
                        Added = true;
                        return false;
                    }
                    else {
                        Added = false;
                    }
                });
                if (!Added) {
                     var newarray = [];
                    newarray.push('<label id="QCStageTestCode" style="width:125px !important" >' + data[i][0] +'</label>')
