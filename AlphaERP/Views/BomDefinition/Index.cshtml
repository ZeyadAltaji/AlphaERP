                    newarray.push('<input id="QCFromNo" type="number" style="width:75px !important;text-align: center !important;" value="0" />')
                    newarray.push('<input id="QCToNo" type="number" style="width:75px !important;text-align: center !important;" value="0" />')
                    newarray.push('<button class="btn-de" onclick="RemoveRow(this)"><i class= "fa fa-trash-alt"></i ></button>')
                    $("#QCStageDetailsTbody").append(
                        GenRow(newarray)
                    );
                }
            }
            else {
                var newarray = [];
                newarray.push('<label id="QCStageTestCode" style="width:125px !important" >' + data[i][0] + '</label>')
                newarray.push('<label id="QCStageTestDesc" style="width:125px !important" >' + data[i][1] + '</label>')
                newarray.push('<input id="QCFromNo" type="number" style="width:75px !important;text-align: center !important;" value="0" />')
                newarray.push('<input id="QCToNo" type="number" style="width:75px !important;text-align: center !important;" value="0" />')
                newarray.push('<button class="btn-de" onclick="RemoveRow(this)"><i class= "fa fa-trash-alt"></i ></button>')
                $("#QCStageDetailsTbody").append(
                    GenRow(newarray)
                );
            }
        }
        $('#Model_StageQCTest').modal('hide')
    }
    function Select_FormQCTest(e) {
        var table = $('#SelectFormStageQCTestTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Selecting_FormStageQCTest() {
             var table = $('#SelectFormStageQCTestTable');
            var oTable = table.dataTable();
            var trs = oTable.$('tr[name=selected]');
            if (trs.length == 0) {
                alert('@Html.Translate("يرجى اختيار نموذج واحد على الاقل", "Select one Form at least")');
                return;
            }
        var FormNo = trs[0].getAttribute('FormNo')
        var GetNameTest = trs[0].getAttribute('FormDesc')
        var compNoInput = $("#compNoInput").val();
        var formulaCodeInput = $("#formulaCodeInput").val();
        var stageCodeInput = $("#stageCodeInput").val();
        var matchingRow = $("#eProdItemStagesTBody tr, #ProdItemStagesTBody tr").filter(function () {
            return $(this).find("#ProdItemStages_StageCode").attr("StageCode") === stageCodeInput;
        });
        if (matchingRow.length > 0) {
             //Update the QA Proc No and description
            var qaProcNoInput = matchingRow.find("#QCFromNoInput_" + stageCodeInput);
            qaProcNoInput.val(FormNo);

            var qaButton = matchingRow.find("#NameTest_" + stageCodeInput);
            qaButton.text(GetNameTest);
            var txtpopover = matchingRow.find("#txtpopover_" + stageCodeInput);
            txtpopover.text(GetNameTest);

        }
        doneSelect_FormQCTest()
}

    function doneSelect_FormQCTest() {
        done();

        $('#Model_FormStageQCTest').modal('hide');


    }
