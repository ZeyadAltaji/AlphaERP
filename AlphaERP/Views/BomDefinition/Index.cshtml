    function ExcuteSaveProd_BomDefinition() {
        if (CheckValue('Prod_BOMH_save_formula_code')) { alert('@Html.Translate("يرجى ادخال رمز الصيغة", "Please enter Formula Code")'); return; }
        var Prod_BOMH_save_formula_code = document.getElementById('Prod_BOMH_save_formula_code');
        var formula_code = Prod_BOMH_save_formula_code.value
        if (parseInt(formula_code) === 0 || formula_code === 0) {alert('@Html.Translate("قيمة رمز الصيغة غير صالحة", "Formula Code value is invalid ")'); return;}
        if (CheckValue('Prod_BOMH_save_formula_codeDesc')) { alert('@Html.Translate("يرجى ادخال وصف الصيغة", "Please enter Formula Description")'); return; }
        if (CheckValue('Prod_BOMH_save_item_no')) { alert('@Html.Translate("الرجاء تحديد المنتج النهائي", "Please select the final product")'); return; }
        var formQtyElement = document.getElementById('Prod_BOMH_save_FormQty');
        if (formQtyElement.value == 0 || formQtyElement.value === '') {alert('@Html.Translate("يرجى ادخال الكمية !", "Please enter the quantity!")'); formQtyElement.focus(); return;}
        if (CheckValue('Prod_BOMH_save_FormQty')) { alert('@Html.Translate("الرجاء إدخال القيمة لكمية الصيغة", "Please enter the value for the form quantity")'); return; }
        if (CheckValue('Prod_BOMH_save_Passed')) { alert('@Html.Translate("الرجاء إدخال قيمة تمرير", "Please enter the value for the Passed ")'); return; }
        if (CheckValue('Prod_BOMH_save_Waste')) { alert('@Html.Translate("الرجاء إدخال القيمة للنفايات", "Please enter the value for the Waste")'); return; }
        if (CheckValue('Prod_BOMH_save_Rejected')) { alert('@Html.Translate("الرجاء إدخال القيمة لكمية للرفض", "Please enter the value for the Rejected")'); return; }




        var Total = 0;
        Total = Number(Prod_BOMH_save_Passed.value) + Number(Prod_BOMH_save_Waste.value) + Number(Prod_BOMH_save_Rejected.value);
        Total = Number(Total).toFixed(3);
        if (Total != Number(Prod_BOMH_save_FormQty.value).toFixed(3)) {
            alert('@Html.Translate("يجب ان تكون كمية المعادلة مساوية لمجموع الكمية الموزعة معياريا", "Bom Qty Should Be Equal To the standard Qty Distribution")');
            return false;
        }

        if (Prod_BOMH_save_Date.value > Prod_BOMH_save_ExpiryDate.value) {
            alert('@Html.Translate("لا يجوز ان يكون التاريخ اكبر من تاريخ نهاية صلاحية المعادلة", "The date may not be greater than the date of the end of the equation validity")');
            return false;
        }

        var table = $('#ItemRawMaterialTBody tr');
        var trs = table;
        if (trs.length == 0) {
            alert('@Html.Translate("يجب أدخال المواد الاولية", "Raw materials must be entered")');
            return false;
        }
        var BomDefH = {
            comp_no: '@company.comp_num',
            formula_code: Prod_BOMH_save_formula_code.value,
            formula_desc: Prod_BOMH_save_formula_codeDesc.value,
            FormLevel: 0,
            formula_date: Prod_BOMH_save_Date.value,
            item_no: Prod_BOMH_save_item_no.value,
            UnitSerial: Prod_BOMH_save_UnitCode.value,
            best_qty: Prod_BOMH_save_FormQty.value,
            Qty1: Prod_BOMH_save_Passed.value,
            Qty2: Prod_BOMH_save_Waste.value,
            Qty3: Prod_BOMH_save_Rejected.value,
            GroupId: Prod_BOMH_save_Group.value,
            ExpiryDate: Prod_BOMH_save_ExpiryDate.value,
            StandardCost: Prod_BOMH_save_StdCost.checked,
            SusFlag: Prod_BOMH_save_Hult.checked,
            BomNotes: SAVE_BOMNotes.value
        };
        var BomDefD = new Array();
        for (var i = 0; i < trs.length; i++) {
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#BOMInfo_Qty')[0].value)) {
                alert('@Html.Translate("يجب ادخال الكمية في ملف المواد الاولية ", "You Must Enter Qty in the raw materials file ")');
                return;
            }
            if (CheckValueGrid(0, $(trs[i]).closest('tr').find('#BOMInfo_LossPerc')[0].value)) {
                alert('@Html.Translate("يجب ادخال نسبة الفاقد في ملف المواد الاولية", "The percentage of waste must be entered in the raw materials file")');
                return;
            }

            BomDefD.push({
                comp_no: '@company.comp_num',
                formula_code: Prod_BOMH_save_formula_code.value,
                item_no: Prod_BOMH_save_item_no.value,
                rawmaterial_no: $(trs[i]).closest('tr').find('#BOMInfo_ItemNo')[0].innerHTML,
                best_qty: $(trs[i]).closest('tr').find('#BOMInfo_Qty')[0].value,
                LossPerc: $(trs[i]).closest('tr').find('#BOMInfo_LossPerc')[0].value,
                UnitSerial: $(trs[i]).closest('tr').find('.ItemRawMaterial_Unit')[0].value,
                lowest_qty: ($(trs[i]).closest('tr').find('#BOMInfo_Qty')[0].value) / (Prod_BOMH_save_FormQty.value),
            });
        }
        var BomDefProduct = new Array();
        var BomDefAdditiveItems = new Array();
        var BomDefProperty = new Array();
        var BomDefStage = new Array();
        var table1 = $('#ItemByProductTBody tr');
        var trs1 = table1;
        var PerCostTot = 0;
        if (trs1.length != 0) {
            for (var i = 0; i < trs1.length; i++) {
                if (CheckValueGrid(0, $(trs1[i]).closest('tr').find('#ItemByProduct_PQty')[0].value)) {
                    alert('@Html.Translate("يجب ادخال الكمية  في ملف المنتجات الفرعية ", "You Must Enter quantity in the Sub-products file ")');
                    return;
                }
                if (CheckValueGrid(0, $(trs1[i]).closest('tr').find('#ItemByProduct_WQty')[0].value)) {
                    alert('@Html.Translate("يجب ادخال ك.تالف  في ملف المنتجات الفرعية", "You Must Enter wast quantity in the Sub-products file")');
                    return;
                }
                if (CheckValueGrid(0, $(trs1[i]).closest('tr').find('#ItemByProduct_RQty')[0].value)) {
                    alert('@Html.Translate("يجب ادخال ك.مرفوض  في ملف المنتجات الفرعية", "You Must Enter Reject quantity in the Sub-products file")');
                    return;
                }
                if (CheckValueGrid(0, $(trs1[i]).closest('tr').find('#ItemByProduct_PerCost')[0].value)) {
                    alert('@Html.Translate("يجب ادخال نسبة التحمل%  في ملف المنتجات الفرعية", "You Must Enter Cost Share% in the Sub-products file")');
                    return;
                }
                BomDefProduct.push({
                    comp_no: '@company.comp_num',
                    formula_code: Prod_BOMH_save_formula_code.value,
                    item_no: $(trs1[i]).closest('tr').find('#ItemByProduct_ItemNo')[0].innerHTML,
                    itemdesc: $(trs1[i]).closest('tr').find('#ItemByProduct_ItemDesc')[0].innerHTML,
                    Qty1: $(trs1[i]).closest('tr').find('#ItemByProduct_PQty')[0].value,
                    Qty2: $(trs1[i]).closest('tr').find('#ItemByProduct_WQty')[0].value,
                    Qty3: $(trs1[i]).closest('tr').find('#ItemByProduct_RQty')[0].value,
                    PerCost: $(trs1[i]).closest('tr').find('#ItemByProduct_PerCost')[0].value,
                    UnitSerial: $(trs1[i]).closest('tr').find('.ItemByProduct_Unit')[0].value
                });
                PerCostTot = PerCostTot + Number($(trs1[i]).closest('tr').find('#ItemByProduct_PerCost')[0].value);
            }
            if (PerCostTot > 100) {
                  alert('@Html.Translate(" يجب ادخال نسبة التحمل اقل او تساوي 100  في ملف المنتجات الفرعية", "You Must Enter Cost Share Less than or equal 100 in the Sub-products file")');
                    return;
            }
        }

        var table2 = $('#AdditiveItemsTBody tr');
        var trs2 = table2;
        if (trs2.length != 0) {
            for (var i = 0; i < trs2.length; i++) {
                 if (CheckValueGrid(1,  $(trs2[i]).closest('tr').find('#AdditiveItems_Qty')[0].value)) {
                alert('@Html.Translate("يجب ادخال الكمية  في ملف المواد المضافة ", "You Must Enter quantity in the additional-Items file ")');
                return;
                }
                BomDefAdditiveItems.push({
                    CompNo: '@company.comp_num',
                    BOMCode: Prod_BOMH_save_formula_code.value,
                    RMCode: $(trs2[i]).closest('tr').find('#AdditiveItems_ItemNo')[0].innerHTML,
                    UnitSerial: $(trs2[i]).closest('tr').find('.AdditiveItems_Unit')[0].value,
                    QTY: $(trs2[i]).closest('tr').find('#AdditiveItems_Qty')[0].value,
                    Notes: $(trs2[i]).closest('tr').find('#AdditiveItems_Notes')[0].value
                });
            }
        }

        var table3 = $('#PropertyTBody tr');
        var trs3 = table3;
        if (trs3.length != 0) {
            for (var i = 0; i < trs3.length; i++) {
                var x = i;
                BomDefProperty.push({
                    CompNo: '@company.comp_num',
                    FormulaCode: Prod_BOMH_save_formula_code.value,
                    PropertName: $(trs3[i]).closest('tr').find('#BOMProperty_PropertyName')[0].value,
                    PropertValue: $(trs3[i]).closest('tr').find('#BOMProperty_Qty')[0].value
                });
            }
        }

        var table4 = $('#ProdItemStagesTBody tr');
        var trs4 = table4;
        if (trs4.length != 0) {
            for (var i = 0; i < trs4.length; i++) {
                var stageCode = $(trs4[i]).closest('tr').find('#ProdItemStages_StageCode')[0].innerHTML;
                var qaProcNoInput = $(trs4[i]).find('#qaProcNoInput_' + stageCode).val();
                var QCFromNoInput = $(trs4[i]).find('#QCFromNoInput_' + stageCode).val();

                var hr = $(trs4[i]).closest('tr').find('#ProdItemStages_SatndardTimeHr')[0].value;
                var min = $(trs4[i]).closest('tr').find('#ProdItemStages_SatndardTimeMin')[0].value;
                var fixedTime = $(trs4[i]).closest('tr').find('#ProdItemStages_FixedTime')[0].checked;
                var closePStage = $(trs4[i]).closest('tr').find('#ProdItemStages_ClosePStage')[0].checked;


                BomDefStage.push({
                    Comp_no: '@company.comp_num',
                    Formula_code: Prod_BOMH_save_formula_code.value,
                    Item_no: Prod_BOMH_save_item_no.value,
                    Stage_code:stageCode,
                    Hr: hr,
                    Min: min,
                    FixedTime: fixedTime,
                    ClosePStage: closePStage,
                    QAProc: qaProcNoInput,
                    QCFromNo: QCFromNoInput

                });
            }
            console.log(BomDefStage);
        }

        wait();
        if (confirm('@Resources.Resource.ConfirmBOMDef')) {
             burn({ BomDefH: BomDefH, BomDefD: BomDefD, BomDefProduct: BomDefProduct, BomDefAdditiveItems: BomDefAdditiveItems, Prod_ItemStages: BomDefStage, BomDefProperty: BomDefProperty}, '../../../BomDefinition/Save_BomDefinition', '', ReloadBomDefinition, false);
        }
        else {
            done();
        }
     }
