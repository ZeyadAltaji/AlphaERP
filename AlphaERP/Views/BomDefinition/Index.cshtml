    $('#Model_StageQCTest').draggable({
        handle: ".modal-header",
    });
    $('#Model_FormStageQCTest').draggable({
        handle: ".modal-header",
    });
    $('#Model_ProdstageInfo').draggable({
        handle: ".modal-header",
    });
    $('#Model_InvItemsMF').draggable({
        handle: ".modal-header",
    });
    $('#Model_finItems').draggable({
        handle: ".modal-header",
    });
    $('#BomDefinition_PackingDefention_Model').draggable({
        handle: ".modal-header",
    });
    function AddQCTestProd(Formula_code, Item_no, Stage_code, StageSer) {
         var Item = {
            Formula_code: Formula_code,
            Item_no: Item_no,
            Stage_code: Stage_code,
            StageSer: StageSer
        };
        burn({ SubDetails: Item }, '../../../BomDefinition/ItemStageTestQC', '', LoadItemStageTestQC, true);
    }
    function LoadItemStageTestQC(r) {
        BOMStageQCTestDiv.innerHTML = "";
        $('#BOMStageQCTestDiv').html(r);
        $('#Model_BOMStageQCTest').modal('show');
    }


    function AddQCTestProdnew(Stage_code) {
        var Item = {
            Stage_code: Stage_code,
        };
        burn({ SubDetails: Item }, '../../../BomDefinition/ItemStageTestQC', '', LoadItemStageTestQC, true);
    }

    function GetQASetBystage(Comp_no, Formula_code, Stage_code, StageSer) {

             $('#ProdCost_QASetupHF').load("../../../BomDefinition/GetQASetupHFBystages?Comp_no=" + Comp_no
                                  + "&Formula_code=" + encodeURIComponent(Formula_code)
                                  + "&Stage_code=" + Stage_code
                                  + "&StageSer=" + StageSer);
            $('#Model_getProdCost_QASetupHF').modal('show');



    }
    function GetQASetBystagetoadd(Comp_no,Stage_code) {
        $('#ProdCost_QASetupHFadd').load("../../../BomDefinition/GetQASetupHFBystagesadd?Comp_no=" + Comp_no
                             + "&Stage_code=" + Stage_code
       );
        $('#Model_getProdCost_QASetupHFadd').modal('show');



    }


    function selectbtn() {
          var stageSerInput = $("#stageCodeInput").val();
        var newQAProcNo = $(".selected-row .qaProcNoInput").val();
        var selectedDesc = $("#description").val();
        if (!stageSerInput || !newQAProcNo || !selectedDesc) {
            alert('@Html.Translate("يرجى اختيار أحد إجراءات ضمان الجودة", "Please select one of QA Procedure")');
            return;
        }
        var matchingRow = $("#eProdItemStagesTBody tr, #ProdItemStagesTBody tr").filter(function () {
            return $(this).find("#ProdItemStages_StageCode").attr("StageCode") === stageSerInput;
        });

        if (matchingRow.length > 0) {
            // Update the QA Proc No and description
            var qaProcNoInput = matchingRow.find("#qaProcNoInput_" + stageSerInput);
            qaProcNoInput.val(newQAProcNo);

            var qaButton = matchingRow.find("#qaButton_" + stageSerInput);
            qaButton.text(selectedDesc);
            var txtpopover = matchingRow.find("#txtpopoveer_" + stageSerInput);
            txtpopover.text(selectedDesc);


        }
         doneBomDefinition()
    }
    function doneBomDefinition() {
        done();

        $('#Model_getProdCost_QASetupHF').modal('hide');


    }
    function selectbtnadd() {
         var stageSerInput = $("#stageCodeInput").val();
        var newQAProcNo = $(".selected-row .qaProcNoInput").val();
        var selectedDesc = $("#description").val();
        if (!stageSerInput || !newQAProcNo || !selectedDesc) {
            alert('@Html.Translate("يرجى اختيار أحد إجراءات ضمان الجودة", "Please select one of QA Procedure")');
            return;
        }
        var matchingRow = $("#eProdItemStagesTBody tr, #ProdItemStagesTBody tr").filter(function () {
            return $(this).find("#ProdItemStages_StageCode").attr("StageCode") === stageSerInput;
        });

        if (matchingRow.length > 0) {
            // Update the QA Proc No and description
            var qaProcNoInput = matchingRow.find("#qaProcNoInput_" + stageSerInput);
            qaProcNoInput.val(newQAProcNo);

            var qaButton = matchingRow.find("#qaButton_" + stageSerInput);
            qaButton.text(selectedDesc);
            var txtpopover = matchingRow.find("#txtpopoveer_" + stageSerInput);
            txtpopover.text(selectedDesc);


        }
        doneBomDefinitionadd()
    }
