    function LoadQCTestRelatedToForm(r) {
        $('#QCStageDetailsTbody').empty();
        for (var i = 0; i < r.FormQC.length; i++) {
            var newarray = [];
            newarray.push('<label id="QCStageTestCode" style="width:125px !important" >' + r.FormQC[i].TestNo + '</label>')
            newarray.push('<label id="QCStageTestDesc" style="width:125px !important" >' + @Html.Translate("r.FormQC[i].LocalDesc","r.FormQC[i].EngDesc") + '</label>')
            newarray.push('<input id="QCFromNo" type="number" style="width:75px !important;text-align: center !important;"/ value="' + r.FormQC[i].FromNo + '">')
            newarray.push('<input id="QCToNo" type="number" style="width:75px !important;text-align: center !important;" value="' + r.FormQC[i].ToNo + '">')
            newarray.push('<button class="btn-de" onclick="RemoveRow(this)"><i class= "fa fa-trash-alt"></i ></button>')
            $("#QCStageDetailsTbody").append(
                GenRow(newarray)
            );
        }
        $('#Model_FormStageQCTest').modal('hide')
    }
    function Save_QCTestBOM() {
         var BomQCTest = new Array();
        var table1 = $('#QCStageDetailsTbody tr');
        var trs1 = table1;
        if (trs1.length == 0) {
            alert('@Html.Translate("لم يتم ادخال بيانات الفحص", "No test data was entered")');
            return false;
        }
        for (var i = 0; i < trs1.length; i++) {
            if (CheckValueGrid(0, $(trs1[i]).closest('tr').find('#QCFromNo')[0].value)) {
                alert('@Html.Translate("يجب ان لا تكون بداية الفحص فارغة", "The start of the examination must not be Empty")');
                return;
            }
            if (CheckValueGrid(0, $(trs1[i]).closest('tr').find('#QCToNo')[0].value)) {
                alert('@Html.Translate("يجب ان لا تكون نهاية الفحص فارغة", "The end of the examination must not be Empty")');
                return;
            }
            if (CheckValueGrid(1, $(trs1[i]).closest('tr').find('#QCToNo')[0].value)) {
                alert('@Html.Translate("يحب ان لا تكون نهاية الفحص 0", "It should not be the end of the examination 0")');
                return;
            }
            if (Number($(trs1[i]).closest('tr').find('#QCFromNo')[0].value) >= Number($(trs1[i]).closest('tr').find('#QCToNo')[0].value)) {
                alert('@Html.Translate("يحب ان يكون نهاية الفحص اكبر من بداية الفحص", "The end of the examination should be greater than the beginning of the examination")');
                return;
            }
            var stageSerInput = $('#Prod_BOMH_save_formula_code').val();
            var Prod_BOMH_save_item_no = $('#Prod_BOMH_save_item_no').val();

            if (stageSerInput == "") {
                BomQCTest.push({
                    CompNo: '@company.comp_num',
                    Formula_code: Prod_BOMH_Edit_formula_code.value,
                    Item_no: Prod_BOMH_Edit_item_no.value,
                    Stage_code: SAVE_ItemStage_StageCode.innerHTML,
                    StageSer: SAVE_ItemStage_StageCode.getAttribute('StageSer'),
                    TestNo: $(trs1[i]).closest('tr').find('#QCStageTestCode')[0].innerHTML,
                    FromNo: $(trs1[i]).closest('tr').find('#QCFromNo')[0].value,
                    ToNo: $(trs1[i]).closest('tr').find('#QCToNo')[0].value,
                    Serial1: SAVE_ItemStage_StageCode.getAttribute('StageSer')
                });
                console.log(BomQCTest)
            } else if (stageSerInput != "") {
                BomQCTest.push({
                    CompNo: '@company.comp_num',
                    Formula_code: stageSerInput,
                    Item_no: Prod_BOMH_save_item_no,
                    Stage_code: SAVE_ItemStage_StageCode.innerHTML,
                    StageSer: SAVE_ItemStage_StageCode.getAttribute('StageSer'),
                    TestNo: $(trs1[i]).closest('tr').find('#QCStageTestCode')[0].innerHTML,
                    FromNo: $(trs1[i]).closest('tr').find('#QCFromNo')[0].value,
                    ToNo: $(trs1[i]).closest('tr').find('#QCToNo')[0].value,
                    Serial1: SAVE_ItemStage_StageCode.getAttribute('StageSer')
                });
                console.log(BomQCTest)
            }

        }

        wait();
        if (confirm('@Resources.Resource.ConfirmQCTest')) {
            burn({ BomQCTest: BomQCTest }, '../../../BomDefinition/Save_QCTestBOM', '', ReloadQCTestBOM, false);
        }
        else {
            done();
        }
    }
    function ReloadQCTestBOM() {
        done();
        $('#Model_BOMStageQCTest').modal('hide');
    }
    function RemoveRowQCTest(e, StageCode, StageSer) {
        ethis = e;
        StageCode1 = StageCode;
        StageSer1 = StageSer;
        var item = {
            Formula_code: Prod_BOMH_Edit_formula_code.value,
            Item_no: Prod_BOMH_Edit_item_no.value,
            Stage_code: StageCode,
            StageSer: StageSer,
        }
        burn({ itemQCTest: item }, '../../../BomDefinition/GetDataQCTestBOM', '', RemoveRowQCTestBOM, false);
    }
    function RemoveRowQCTestBOM(r) {
        if (r.d == 'NotDelete') {
            if (confirm('@Resources.Resource.DeleteConfirmQCTest')) {
                var item = {
                    Formula_code: Prod_BOMH_Edit_formula_code.value,
                    Item_no: Prod_BOMH_Edit_item_no.value,
                    Stage_code: StageCode1,
                    StageSer: StageSer1,
                }
                burn({ itemQCTest: item }, '../../../BomDefinition/RemoveDataQCTestBOM', '', RemDataQCTestBOM, false);
            }
        }
        else {
            RemoveRow(ethis);
        }
    }
    function RemDataQCTestBOM() {
        var p = ethis.parentNode.parentNode;
        p.parentNode.parentNode.deleteRow(p.rowIndex);
        return true;
    }
