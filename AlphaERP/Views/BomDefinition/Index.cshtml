<script>
    var groupIDCounter = 1;
    var itemType = 0;
    var StageCode1 = 0;
    var StageSer1 = 0;
    var ethis = '';
    var frmSatus = 1;
    var maxIndex = $("#ProdItemStagesTBody tr").length;

    var QCTest = $('#SelectStageQCTestTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25,
        "scrollX": true,
        "autoWidth": false
    });
    var RawMaterial = $('#SelectItemRawMaterialTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    var ProdstageInfo = $('#SelectProdstageInfoTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    var table = $('#SelectfinItemsTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    $('#Prod_BOMH_save_UnitCode').select2();
    $('#Prod_BOMH_save_Group').select2();
    $('#Prod_BomDefinition_Model').draggable({
        handle: ".modal-header",
    });
    $('#Model_BOMStageQCTest').draggable({
        handle: ".modal-header",
    });
    $('#Model_getProdCost_QASetupHF').draggable({
        handle: ".modal-header",
