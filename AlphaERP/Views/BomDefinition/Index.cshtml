        $('#ProdItemStagesTBody').empty();
        $('#Prod_BomDefinition_Model').modal('hide');
        $('#Prod_BomDefinitionListDiv').load('../../../BomDefinition/BomDefinitionList');
    }
    function SelectQCTest() {
        $('#SelectStageQCTestTable tr').removeClass("selected");
        $('#Model_StageQCTest').modal('show')
    }
    function SelectFormQCTest(Comp_no, Formula_code, Stage_code) {
         $("#compNoInput").val(Comp_no);
        $("#formulaCodeInput").val(Formula_code);
        $("#stageCodeInput").val(Stage_code);
