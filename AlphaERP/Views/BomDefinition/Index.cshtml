    function calculateStartIndex(lastStageSerValue, tageSerValue) {
        if (lastStageSerValue) {
            return parseInt(lastStageSerValue) + 1;
        } else {
            return parseInt(tageSerValue) + 1;
        }
    }
    function HandleSelect(stageCodeToAdd, stageDescToAdd) {
        var lastRowIndex = $("#eProdItemStagesTable tbody tr").length - 1;
        var lastStageSerValue = $("#eProdItemStagesTable tbody tr:eq(" + lastRowIndex + ") td#ProdItemStages_StageSer").attr("StageSer");
        var lastRow = $("#eProdItemStagesTable tbody tr").length - 1;
        var tageSerValue = $("#eProdItemStagesTable tbody tr:eq(" + lastRowIndex + ") td#ProdItemStages_Stag______srl").attr("StageSer");
        if (!tageSerValue || isNaN(parseInt(tageSerValue))) {
            tageSerValue = 0;
        } else {
            tageSerValue = parseInt(tageSerValue);
        }

         var table_;
        if (frmSatus == 1) {
            table_ = $("#ProdItemStagesTBody");
        } else if (frmSatus == 2) {
            table_ = $("#eProdItemStagesTBody");
        }

         var alreadyAdded = false;
        table_.find("tr").each(function () {
            var stageCode_ = $(this).find("td:nth-child(2)").text();
            if (stageCode_ === stageCodeToAdd) {
                alert('@Html.Translate("المرحلة بفعل موجودة مسبقاً ", "Stage by Pre-Existing Action")');
                alreadyAdded = true;
                return false; // Exit the loop
            }
        });


        if (!alreadyAdded) {
            var newIndex = calculateStartIndex(lastStageSerValue, tageSerValue);
            var data = [{
                stage_code: stageCodeToAdd,
                stage_desc: stageDescToAdd,
                GroupID: newIndex  // Set the GroupID to the current value
            }];



            if (data.length !== 0) {
                 burn({ stage: data }, '../../../BomDefinition/ProdstageInfo', '', LoadProdstageInfo, true);
            } else {
                $('#Model_ProdstageInfo').modal('hide');
            }
        }
    }
