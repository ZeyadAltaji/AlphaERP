@model IEnumerable<AlphaERP.Models.prod_extend_item>
@using AlphaERP.Models
@using System.Data.SqlClient;
@using System.Data;
@using System.Collections.Generic;
@{
    Company company = (Company)Session["company"];
    DataTable Dt = new DataTable();
}

<div class="form-group">
    <div class="col-md-12">
        <label class="unselectable">@Html.Recource(2550) :</label>
        <button onclick="Edit_InvItemsMF(2)" type="button" class="btn btn-default">@Html.Recource(2550)</button>
    </div>
    <div class="col-md-12" style="height:200px;max-height:200px;overflow-y:auto">
        <table class="table table-hover" id="eItemByProductTable">
            <thead>
                <tr>
                    <th style="width: 14%;">@Html.Recource(44)</th>
                    <th style="width: 45%;">@Html.Recource(74)</th>
                    <th>@Html.Recource(67)</th>
                    <th>@Html.Recource(3)</th>
                    <th     text-align: center;>@Html.Recource(49)</th>
                    <th>@Html.Recource(2536)</th>
                    @*<th>@Html.Recource(2556)</th>
        <th>@Html.Recource(2557)</th>*@


                    <th></th>
                </tr>
            </thead>
            <tbody id="eItemByProductTBody">
                @foreach (var item in Model)
                {
                    string Catg = new MDB().InvItemsMFs.Where(x => x.CompNo == item.comp_no && x.ItemNo == item.item_no).FirstOrDefault().Categ;
                <tr>
                    <td style="width: 14%;" id="ItemByProduct_ItemNo">@item.item_no</td>
                    <td style="width: 45%;" id="ItemByProduct_ItemDesc">@item.itemdesc</td>
                    <td style="width: 10%;text-align: center;">
                        <select style="width:100%" class="ItemByProduct_Unit">
                            @{
                                using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                {
                                    Dt = new DataTable();
                                    cn.Open();
                                    using (SqlCommand cmd = new SqlCommand())
                                    {
                                        cmd.Connection = cn;
                                        cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                        cmd.CommandText = "InvT_LoadItemUnits";
                                        cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                        cmd.Parameters.Add(new SqlParameter("@ItemCode", System.Data.SqlDbType.VarChar, 20)).Value = item.item_no;
                                        using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                        {
                                            DA.Fill(Dt);
                                        }
                                    }
                                }
                            }
                            @foreach (DataRow row in Dt.Rows)
                            {
                                if (@row["UnitSerial"].ToString() == item.UnitSerial.ToString())
                                {
                                    <option value="@row["UnitSerial"].ToString()" selected>
                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                    </option>
                                }
                                else
                                {
                                    <option value="@row["UnitSerial"].ToString()">
                                        @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                    </option>
                                }
                            }
                        </select>
                    </td>
                    <td style="width: 15%;">@Catg</td>
                    <td style="width: 10%;text-align: center;">
                        <input id="ItemByProduct_PQty" value="@item.Qty1" type="number" required="true" style="width:75px !important" />
                    </td>
                    <td style="width: 10%;text-align: center;">
                        <input id="ItemByProduct_PerCost" value="@item.percost" type="number" required="true" style="width:75px !important" />
                    </td>

                    <td style="width: 10%;text-align: center;">
                        <input id="ItemByProduct_WQty" value="@item.Qty2" type="hidden" required="true" style="width:75px !important" />
                    </td>
                    <td style="width: 10%;text-align: center;">
                        <input id="ItemByProduct_RQty" value="@item.Qty3" type="hidden" required="true" style="width:75px !important" />
                    </td>

                    <td>
                        <button class="btn-de" onclick="RemoveRow(this)"><i class="fa fa-trash-alt"></i></button>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    $('#ItemByProduct_Unit').select2();
</script>