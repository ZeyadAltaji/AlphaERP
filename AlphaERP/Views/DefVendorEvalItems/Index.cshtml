<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-10" style="padding:0">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2 col-sm-2">
                <button class="btn btn-primary btn-block" onclick="CreateDefVendorEvalItems()">
                    <i class="fa fa-plus"></i> @Resources.Resource.Add
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="Ord_VendorEvalItemsDiv">
        @Html.Partial("~/Views/DefVendorEvalItems/DefVendorEvalItemsList.cshtml")
    </div>
</div>

<style>
    .modal-title{
       width: calc(100% - 160px);
    }
</style>

<div class="modal fade" id="Model_Ord_VendorEvalItems">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Resources.Resource.Save >> @Html.Translate("بنود التقييم", "Evaluation Items")</label>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-4">
                        <label class="unselectable" for="Ord_VendorEvalItems_CodeId">@Html.Recource(117) </label>
                    </div>
                    <div class="col-md-8" style="margin-bottom: 5px;">
                        <input required="false" type="text" id="Ord_VendorEvalItems_CodeId" placeholder="@Html.Recource(117)" />
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-4">
                        <label class="unselectable" for="Ord_VendorEvalItems_DescAr">@Html.Recource(66) </label>
                    </div>
                    <div class="col-md-8" style="margin-bottom: 5px;">
                        <input required="false" type="text" id="Ord_VendorEvalItems_DescAr" placeholder="@Html.Recource(66)" />
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-4">
                        <label class="unselectable" for="Ord_VendorEvalItems_DescEn">@Html.Recource(118) </label>
                    </div>
                    <div class="col-md-8" style="margin-bottom: 5px;">
                        <input required="false" type="text" id="Ord_VendorEvalItems_DescEn" placeholder="@Html.Recource(118)" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="ExcuteSave_VendorEvalItems();" class="btn btn-primary">@Resources.Resource.Save</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Resources.Resource.Cancel</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_Ord_VendorEvalItems').draggable({
        handle: '.modal-header'
    });
    $('#Model_Ord_VendorEvalItems').on('shown.bs.modal', function () {
        $('#Ord_VendorEvalItems_CodeId').focus();
        $('#Ord_VendorEvalItems_CodeId').select();
    });

    function CreateDefVendorEvalItems() {
        FormNo_ = 0;
        Ord_VendorEvalItems_CodeId.value = "";
        Ord_VendorEvalItems_DescAr.value = "";
        Ord_VendorEvalItems_DescEn.value = "";
        $('#Model_Ord_VendorEvalItems').modal('show')
    }

    function ExcuteSave_VendorEvalItems() {
        if ($('Ord_VendorEvalItems_CodeId').value == '') {$('Ord_VendorEvalItems_CodeId').focus(); return; }
        if ($('Ord_VendorEvalItems_DescAr').value == '') { $('Ord_VendorEvalItems_DescAr').focus(); return; }
        wait();
        burn({ CodeId: Ord_VendorEvalItems_CodeId.value, DescAr: Ord_VendorEvalItems_DescAr.value, DescEn: Ord_VendorEvalItems_DescEn.value }, '../../../DefVendorEvalItems/Save_VendorEvalItems', '', ReloadVendorEvalItems, false);
    }
    function ReloadVendorEvalItems(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#Ord_VendorEvalItemsDiv').load('../../../DefVendorEvalItems/DefVendorEvalItemsList');
        $('#Model_Ord_VendorEvalItems').modal('hide')
    }
</script>


<div class="modal fade" id="Model_Ord_eVendorEvalItems">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Resources.Resource.Save >> @Html.Translate("بنود التقييم", "Evaluation Items")</label>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-4">
                        <label class="unselectable" for="Ord_eVendorEvalItems_CodeId">@Html.Recource(117) </label>
                    </div>
                    <div class="col-md-8" style="margin-bottom: 5px;">
                        <input required="false" type="text" id="Ord_eVendorEvalItems_CodeId" disabled placeholder="@Html.Recource(117)" />
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-4">
                        <label class="unselectable" for="Ord_eVendorEvalItems_DescAr">@Html.Recource(66) </label>
                    </div>
                    <div class="col-md-8" style="margin-bottom: 5px;">
                        <input required="false" type="text" id="Ord_eVendorEvalItems_DescAr" placeholder="@Html.Recource(66)" />
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-4">
                        <label class="unselectable" for="Ord_eVendorEvalItems_DescEn">@Html.Recource(118) </label>
                    </div>
                    <div class="col-md-8" style="margin-bottom: 5px;">
                        <input required="false" type="text" id="Ord_eVendorEvalItems_DescEn" placeholder="@Html.Recource(118)" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="ExcuteEdit_VendorEvalItems();" class="btn btn-primary">@Resources.Resource.Save</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Resources.Resource.Cancel</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_Ord_eVendorEvalItems').draggable({
        handle: '.modal-header'
    });
    $('#Model_Ord_eVendorEvalItems').on('shown.bs.modal', function () {
        $('#Ord_eVendorEvalItems_DescAr').focus();
        $('#Ord_eVendorEvalItems_DescAr').select();
    });

    function EditEvalItems(CodeId, DescAr, DescEn) {
        Ord_eVendorEvalItems_CodeId.value = "";
        Ord_eVendorEvalItems_DescAr.value = "";
        Ord_eVendorEvalItems_DescEn.value = "";

        Ord_eVendorEvalItems_CodeId.value = CodeId;
        Ord_eVendorEvalItems_DescAr.value = DescAr;
        Ord_eVendorEvalItems_DescEn.value = DescEn;
        $('#Model_Ord_eVendorEvalItems').modal('show')
    }

    function ExcuteEdit_VendorEvalItems() {
        if ($('Ord_eVendorEvalItems_CodeId').value == '') { $('Ord_eVendorEvalItems_CodeId').focus(); return; }
        if ($('Ord_eVendorEvalItems_DescAr').value == '') { $('Ord_eVendorEvalItems_DescAr').focus(); return; }
        wait();
        burn({ CodeId: Ord_eVendorEvalItems_CodeId.value, DescAr: Ord_eVendorEvalItems_DescAr.value, DescEn: Ord_eVendorEvalItems_DescEn.value }, '../../../DefVendorEvalItems/Edit_VendorEvalItems', '', ReloadeVendorEvalItems, false);
    }
    function ReloadeVendorEvalItems(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#Ord_VendorEvalItemsDiv').load('../../../DefVendorEvalItems/DefVendorEvalItemsList');
        $('#Model_Ord_eVendorEvalItems').modal('hide')
    }
</script>


<script>
    function DeleteEvalItems(CodeId) {
        if (confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            burn({ CodeId: CodeId }, '../../../DefVendorEvalItems/Del_VendorEvalItems', '', ReloadDelEvalItems, false);
        }
    }
    function ReloadDelEvalItems(r) {
        MsgBox('@Html.Recource(2598)', 'red');
        $('#Ord_VendorEvalItemsDiv').load('../../../DefVendorEvalItems/DefVendorEvalItemsList');
    }
</script>