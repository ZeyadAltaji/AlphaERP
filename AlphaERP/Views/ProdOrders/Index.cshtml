    $('#Model_ProdOrder_AlternativeItems').draggable({ handle: ".modal-header" });
    $('#Model_ProdOrder_InvItems').draggable({ handle: ".modal-header" });
    $('#Model_ProdOrder_AllStore').draggable({ handle: ".modal-header" });
    $('#Model_ProdOrder_stageInfo').draggable({ handle: ".modal-header" });
    $('#Prod_ProdOrder_Model').draggable({ handle: ".modal-header" });
    $('#Prod_eProdOrder_Model').draggable({ handle: ".modal-header" });
    $('#Model_ProdOrder_Store').draggable({ handle: ".modal-header" });
    $('#Model_ProdOrderFormulaItem').draggable({ handle: ".modal-header" });

    function AddProd_ProdOrderDefinition() {
        CountAdd = 0;
        $('#RMDetailsTbody').empty();
        $('#OrderProdStagesTbody').empty();
        $('#OrderProdByProductsTbody').empty();
        Prod_ProdOrder_Add_OrderYear.value = '@DateTime.Now.Year';
        Prod_ProdOrder_Add_OrderNo.value = "";
        Prod_ProdOrder_Add_OrderDate.value = '@DateTime.Now.ToString("yyyy-MM-dd")';
        Prod_ProdOrder_Add_formulacode.value = "";
        Prod_ProdOrder_Add_formulaDesc.value = "";
        Prod_ProdOrder_Add_ItemNo.value = "";
        Prod_ProdOrder_Add_ItemDesc.value = "";
        Prod_ProdOrder_Add_Qty.value = "";
        Prod_ProdOrder_Add_WasteQty.value = "0";
        Prod_ProdOrder_Add_SQ.value = "0.000";
        Prod_ProdOrder_Add_StoreNo.value = "";
        Prod_ProdOrder_Add_StoreDesc.value = "";
        Prod_ProdOrder_Add_SalesOrderYear.value = '@DateTime.Now.Year';
        Prod_ProdOrder_Add_SalesOrderNo.value = "";
        Prod_ProdOrder_Add_RefNo1.value = "";
        Prod_ProdOrder_Add_RefNo2.value = "";
        Prod_ProdOrder_Add_Notes.value = "";
        Prod_ProdOrder_Add_Year.value = '@DateTime.Now.Year';
        Prod_ProdOrder_Add_Month.value = '@DateTime.Now.Month';
        RMTotalQty.innerHTML = "0.000";

        $('.nav-tabs a[href="#ProdOrderInfo"]').tab('show');
        $('#Prod_ProdOrder_Model').modal('show');
    }

    function SearchProdOrder_FormulaCode(status) {
        thisstatus = status;
        ProdOrderFormulaItemDiv.innerHTML = "";
        $('#ProdOrderFormulaItemDiv').load('../../../ProdOrders/FormulaItem');
        $('#Model_ProdOrderFormulaItem').modal('show');
    }

    function Select_FormulaItems(e) {
        var table = $('#SelectProdOrdFormulaItemsTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }

    function dbclickSelect_FormulaItems(e) {
        var table = $('#SelectProdOrdFormulaItemsTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار معادلة واحدة على الاقل", "Select one Formula at least")');
            return;
        }
        if (thisstatus == 1) {
            Prod_ProdOrder_Add_formulacode.value = trs[0].getAttribute('formula_code');
            Prod_ProdOrder_Add_formulaDesc.value = trs[0].getAttribute('formula_desc');
            Prod_ProdOrder_Add_ItemNo.value = trs[0].getAttribute('item_no');
            Prod_ProdOrder_Add_ItemDesc.value = trs[0].getAttribute('ItemDesc');
        }
        if (thisstatus == 2) {
            Prod_ProdOrder_Edit_formulacode.value = trs[0].getAttribute('formula_code');
            Prod_ProdOrder_Edit_formulaDesc.value = trs[0].getAttribute('formula_desc');
            Prod_ProdOrder_Edit_ItemNo.value = trs[0].getAttribute('item_no');
            Prod_ProdOrder_Edit_ItemDesc.value = trs[0].getAttribute('ItemDesc');
            Prod_ProdOrder_Edit_Qty.focus();
        }
        $('#Model_ProdOrderFormulaItem').modal('hide');
    }

    function SelectingProdOrd_FormulaItems() {
        var table = $('#SelectProdOrdFormulaItemsTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار معادلة واحدة على الاقل", "Select one Formula at least")');
            return;
