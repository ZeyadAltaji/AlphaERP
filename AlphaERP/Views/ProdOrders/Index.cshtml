            PlanYear: Prod_ProdOrder_Edit_Year.value,
            PlanMonth: Prod_ProdOrder_Edit_Month.value,
            waste: Prod_ProdOrder_Edit_WasteQty.value,
            Note: Prod_ProdOrder_Edit_Notes.value,
            BusUnitID: Prod_ProdOrder_Edit_BusUnitID.value,
            StoreNo: Prod_ProdOrder_Edit_StoreNo.value,
            Actual_SG: Prod_ProdOrder_Edit_SQ.value,
            SalesOrderY: Prod_ProdOrder_Edit_SalesOrderYear.value,
            RefNo1: Prod_ProdOrder_Edit_RefNo1.value,
            RefNo2: Prod_ProdOrder_Edit_RefNo2.value
        };

        var ProdInfoDF = new Array();
        var trs = $('#eRMDetailsTbody tr');
        if (trs.length == 0) {
            alert('@Html.Translate("مجموع كميات المواد الخام يجب أن لا يتجاوز كمية أمر التجهيز", "Total RM Qty should not exceed production Order Qty")');
            return false;
        }
        for (var i = 0; i < trs.length; i++) {
            if (CheckValueGrid(0, $(trs[i]).closest('tr').find('#RM_RmQty')[0].value)) {
                alert('@Html.Translate("يجب ادخال الكمية في ملف المواد الاولية ", "You Must Enter Qty in the raw materials file ")');
                return;
            }
            Total = Number(Total) + Number($(trs[i]).closest('tr').find('#RM_RmQty')[0].value);
            Total = Number(Total).toFixed(3);
            ProdInfoDF.push({
                comp_no: '@company.comp_num',
                prepare_year: Prod_ProdOrder_Edit_OrderYear.value,
                prepare_code: Prod_ProdOrder_Edit_OrderNo.value,
                item_no: Prod_ProdOrder_Edit_ItemNo.value,
                RevisionNo: $(trs[i]).closest('tr').find('#RefrenceNo')[0].value,
                rawmaterial_no: $(trs[i]).closest('tr').find('#RM_ItemNo')[0].value,
                UnitSerial: $(trs[i]).closest('tr').find('.RM_Unit')[0].value,
                Iqty: $(trs[i]).closest('tr').find('#RM_RmQty')[0].value,
                RQty: $(trs[i]).closest('tr').find('#RM_RmQty')[0].value,
                NoteDet: $(trs[i]).closest('tr').find('#RM_NoteDet')[0].value,
            });
        }

        if (Total != Number(Prod_ProdOrder_Edit_Qty.value).toFixed(3) && alowValue === "True") {
            alert('@Html.Translate("مجموع كميات المواد الخام يجب أن لا يتجاوز كمية أمر التجهيز", "Total RM Qty should not exceed production Order Qty")');
            return false;
        }

        trs = $('#eOrderProdStagesTbody tr');
        var ProdStages = new Array();
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('#Stages_StartDate')[0].value > $(trs[i]).closest('tr').find('#Stages_EndDate')[0].value) {
                alert('@Html.Translate("لا يجوز ان يكون تاريخ بدا المرحلة اكبر من تاريخ الانتهاء", "The starting date of the stage may not be greater than the end date")');
                return false;
            }
            ProdStages.push({
                comp_no: '@company.comp_num',
                prepare_year: Prod_ProdOrder_Edit_OrderYear.value,
                prepare_code: Prod_ProdOrder_Edit_OrderNo.value,
                item_no: Prod_ProdOrder_Edit_formulacode.value,
                stage_code: $(trs[i]).closest('tr').find('#Stages_StageCode')[0].innerHTML,
                begin_date: $(trs[i]).closest('tr').find('#Stages_StartDate')[0].value,
                Closed_Date: $(trs[i]).closest('tr').find('#Stages_EndDate')[0].value,
                CalcTime: $(trs[i]).closest('tr').find('#Stages_CalcTime')[0].value
            });
        }

        trs = $('#eOrderProdByProductsTbody tr');
        var ProdProducts = new Array();
        for (var i = 0; i < trs.length; i++) {
            ProdProducts.push({
                CompNo: '@company.comp_num',
                OrderYear: Prod_ProdOrder_Edit_OrderYear.value,
                OrderNo: Prod_ProdOrder_Edit_OrderNo.value,
                formula_code: Prod_ProdOrder_Edit_formulacode.value,
                item_no: $(trs[i]).closest('tr').find('#Product_ItemNo')[0].innerHTML,
                Qty: $(trs[i]).closest('tr').find('#Product_Qty')[0].innerHTML,
                CostPrc: $(trs[i]).closest('tr').find('#Product_CostPrc')[0].innerHTML
            });
        }

        wait();
        if (confirm('@Resources.Resource.ConfirmeProdOrder')) {
            burn({ ProdInfoHF: ProdInfoHF, ProdInfoDF: ProdInfoDF, manufacure: ProdStages, OrderExtended: ProdProducts }, '../../../ProdOrders/Edit_ProdOrders', '', eReloadProdOrder, true);
        } else {
            done();
        }
    }

    function eReloadProdOrder() {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#Prod_eProdOrder_Model').modal('hide');
        $('#Prod_ProdOrderListDiv').load('../../../ProdOrders/ProdOrdersList?Year=' + Prod_ProdOrder_Year.value);
    }

    function Del_ProdOrders(CompNo, prepare_year, prepare_code) {
        if (confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            burn({ comp_no: CompNo, prepareyear: prepare_year, preparecode: prepare_code }, '../../../ProdOrders/Delete_ProdOrders', '', DelReloadProdOrder, true);
        }
    }

    function DelReloadProdOrder() {
        MsgBox('@Html.Recource(2598)', 'red');
        $('#Prod_ProdOrderListDiv').load('../../../ProdOrders/ProdOrdersList?Year=' + Prod_ProdOrder_Year.value);
    }

    function ItemQtyInAllStores(item) {
        thisitem = item;
        burn({ Itemno: item, unit: 4 }, '../../../ProdOrders/QtyAllStoer', '', ReloadtStoer, true);
        $('#Model_ProdOrder_AllStore').modal('show');
    }

    function GetDataStoreItem() {
        var unit = 0;
        if (ProdOrder_FirstUnit.checked == true) { unit = 1; }
        if (ProdOrder_SecondUnit.checked == true) { unit = 2; }
        if (ProdOrder_ThirdUnit.checked == true) { unit = 3; }
        if (ProdOrder_FourthUnit.checked == true) { unit = 4; }
        burn({ Itemno: thisitem, unit: unit }, '../../../ProdOrders/QtyAllStoer', '', ReloadtStoer, true);
    }

    function ReloadtStoer(r) {
        ProdOrder_AllStorebody.innerHTML = "";
        $('#ProdOrder_AllStorebody').html(r);
    }

    function Checkyear() {
        if (Prod_ProdOrder_Year.value < 2000) {
            Prod_ProdOrder_Year.value = "@DateTime.Now.Year";
            Prod_ProdOrder_Year.focus();
        }
    }

    function SerachProdOrder() {
        wait();
        $('#Prod_ProdOrderListDiv').load('../../../ProdOrders/ProdOrdersList?Year=' + Prod_ProdOrder_Year.value, function () {
            done();
        });
    }
</script>

<div class="modal fade" id="Model_Revisions" style="left: 47.7rem;top: 25rem;">
    <div class="modal-dialog">
        <div class="modal-content" id="RevisionsModalContent">
        </div>
    </div>
</div>

<script>
    function ShowRevisions(btn, itemNo) {
        var url = '/ProdOrders/GetItemRevisions';
        window.currentRevisionInput = $(btn).closest('div').find('input[type="text"]');
        
        $('#RevisionsModalContent').load(url + '?itemNo=' + encodeURIComponent(itemNo), function() {
            $('#Model_Revisions').modal('show');
        });
    }

    function SelectRevision(revNo) {
        if (window.currentRevisionInput) {
            window.currentRevisionInput.val(revNo);
            window.currentRevisionInput.trigger('change');
        }
        $('#Model_Revisions').modal('hide');
    }
</script>
