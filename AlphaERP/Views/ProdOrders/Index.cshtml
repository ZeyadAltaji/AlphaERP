            if (CountAdd == 0) { CountAdd = tr.length; }
            CountAdd++;
            currentCount = CountAdd;
        }
        if (stsus == 2) {
            var tr = $("#eOrderProdStagesTbody tr");
            if (CountEdit == 0) { CountEdit = tr.length; }
