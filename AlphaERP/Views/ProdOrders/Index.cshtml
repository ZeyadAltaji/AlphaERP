@using AlphaERP.Models
@using System.Data.SqlClient;
@{
    User me = (User)Session["me"];
    Company company = (Company)Session["company"];

    var Alow = new MDB().ProdCost_CompPara
        .Where(x => x.CompNo == company.comp_num)
        .Select(x => x.UsePackItem)
        .FirstOrDefault();

    List<prod_prodstage_info> stage_info = new MDB().prod_prodstage_info
        .Where(x => x.comp_no == company.comp_num).ToList();
}

<div class="box box-primary">
    <div class="box-body box-profile">
        <div>
            <div class="col-md-7" style="padding:0">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="SerachProdOrder_Year">@Resources.Resource.Year </label>
                <input onblur="Checkyear()" type="text" id="Prod_ProdOrder_Year" value="@DateTime.Now.Year"
                       oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);"
                       maxlength="4" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-success btn-block" onclick="SerachProdOrder()">
                    @Html.Recource(975)
                </button>
                <button class="btn btn-primary btn-block" onclick="AddProd_ProdOrderDefinition()">
                    <i class="fa fa-plus"></i> @Html.Recource(32)
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="Prod_ProdOrderListDiv">
        @Html.Partial("~/Views/ProdOrders/ProdOrdersList.cshtml")
    </div>
</div>

