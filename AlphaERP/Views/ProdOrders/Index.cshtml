    }

    function SearchProdOrder_StoreNo() {
        $('#SelectProdOrd_StoreTable tr').removeClass("selected");
        $('#Model_ProdOrder_Store').modal('show');
    }

    function SelectStore(e) {
        var table = $('#SelectProdOrd_StoreTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }

    function SelectingProdOrd_Store() {
        var table = $('#SelectProdOrd_StoreTable');
