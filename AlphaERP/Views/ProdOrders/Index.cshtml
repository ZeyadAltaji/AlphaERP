        newarray.push('<td><button class="btn-de" onclick="RemoveRowOrderProdStages(this)" type="button"><i class="fa fa-trash-alt"></i></button></td>');

        if (stsus == 1) {
            $("#OrderProdStagesTbody").append(GenRowMas(newarray, 'ItemStage_' + currentCount));
