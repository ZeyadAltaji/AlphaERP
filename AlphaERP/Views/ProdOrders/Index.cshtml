    function ExcuteSaveProd_ProdOrders() {
        if (CheckValue('Prod_ProdOrder_Add_formulacode')) {
            alert('@Html.Translate("يجب ادخال رمز المعادلة", "Equation code must be entered")');
            return;
        }
        if (CheckValue('Prod_ProdOrder_Add_ItemNo')) {
            alert('@Html.Translate("يجب ادخال رمز المادة", "The item No must be entered.")');
            return;
        }
        if (CheckValue('Prod_ProdOrder_Add_Qty')) {
            alert('@Html.Translate("يجب ادخال الكمية", "Quantity must be entered")');
            return;
        }
        if (CheckValue('Prod_ProdOrder_Add_Year')) {
            alert('@Html.Translate("يجب ادخال  السنة", " year must be entered")');
            return;
        }
        if (CheckValue('Prod_ProdOrder_Add_Month')) {
            alert('@Html.Translate("يجب ادخال  الشهر", "You must enter the  month.")');
            return;
        }
        if (CheckValue('Prod_ProdOrder_Add_StoreNo')) {
            alert('@Html.Translate("يجب ادخال المستودع", "Store must be entered")');
            return;
        }

        var Total = 0;
        var alowInput = document.getElementById("alowInput_Add");
        var alowValue = alowInput.getAttribute("data-Allow");

        const date = new Date(Prod_ProdOrder_Add_OrderDate.value);
        var year = date.getFullYear();
        if (year != Prod_ProdOrder_Add_OrderYear.value) {
            alert('@Html.Translate("سنة الامر يجب أن تساوي سنة تاريخ الأمر", "Order Year Should Equal Order Date Year")');
            return false;
        }

        var ProdInfoHF = {
            comp_no: '@company.comp_num',
            prepare_year: Prod_ProdOrder_Add_OrderYear.value,
            prepare_date: Prod_ProdOrder_Add_OrderDate.value,
            item_no: Prod_ProdOrder_Add_ItemNo.value,
            formula_code: Prod_ProdOrder_Add_formulacode.value,
            qty_prepare: Prod_ProdOrder_Add_Qty.value,
            PlanYear: Prod_ProdOrder_Add_Year.value,
            PlanMonth: Prod_ProdOrder_Add_Month.value,
            waste: Prod_ProdOrder_Add_WasteQty.value,
            Note: Prod_ProdOrder_Add_Notes.value,
            BusUnitID: Prod_ProdOrder_Add_BusUnitID.value,
            StoreNo: Prod_ProdOrder_Add_StoreNo.value,
            Actual_SG: Prod_ProdOrder_Add_SQ.value,
            SalesOrderY: Prod_ProdOrder_Add_SalesOrderYear.value,
            RefNo1: Prod_ProdOrder_Add_RefNo1.value,
            RefNo2: Prod_ProdOrder_Add_RefNo2.value
        };

        var ProdInfoDF = new Array();
        var trs = $('#RMDetailsTbody tr');
        if (trs.length == 0) {
            alert('@Html.Translate("مجموع كميات المواد الخام يجب أن لا يتجاوز كمية أمر التجهيز", "Total RM Qty should not exceed production Order Qty")');
            return false;
        }
        for (var i = 0; i < trs.length; i++) {
            if (CheckValueGrid(0, $(trs[i]).closest('tr').find('#RM_RmQty')[0].value)) {
                alert('@Html.Translate("يجب ادخال الكمية في ملف المواد الاولية ", "You Must Enter Qty in the raw materials file ")');
                return;
            }
            Total = Number(Total) + Number($(trs[i]).closest('tr').find('#RM_RmQty')[0].value);
            Total = Number(Total).toFixed(3);
            ProdInfoDF.push({
                comp_no: '@company.comp_num',
                prepare_year: Prod_ProdOrder_Add_OrderYear.value,
                item_no: Prod_ProdOrder_Add_ItemNo.value,
                RevisionNo: $(trs[i]).closest('tr').find('#RefrenceNo')[0].value,
                rawmaterial_no: $(trs[i]).closest('tr').find('#RM_ItemNo')[0].value,
                UnitSerial: $(trs[i]).closest('tr').find('.RM_Unit')[0].value,
                Iqty: $(trs[i]).closest('tr').find('#RM_RmQty')[0].value,
                RQty: $(trs[i]).closest('tr').find('#RM_RmQty')[0].value,
                NoteDet: $(trs[i]).closest('tr').find('#RM_NoteDet')[0].value,
            });
        }

        if (Total != Number(Prod_ProdOrder_Add_Qty.value).toFixed(3) && alowValue === "True") {
            alert('@Html.Translate("مجموع كميات المواد الخام يجب أن لا يتجاوز كمية أمر التجهيز", "Total RM Qty should not exceed production Order Qty")');
            return false;
        }

        trs = $('#OrderProdStagesTbody tr');
        var ProdStages = new Array();
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('#Stages_StartDate')[0].value > $(trs[i]).closest('tr').find('#Stages_EndDate')[0].value) {
                alert('@Html.Translate("لا يجوز ان يكون تاريخ بدا المرحلة اكبر من تاريخ الانتهاء", "The starting date of the stage may not be greater than the end date")');
                return false;
            }
            ProdStages.push({
                comp_no: '@company.comp_num',
                prepare_year: Prod_ProdOrder_Add_OrderYear.value,
                item_no: Prod_ProdOrder_Add_formulacode.value,
                stage_code: $(trs[i]).closest('tr').find('#Stages_StageCode')[0].innerHTML,
                begin_date: $(trs[i]).closest('tr').find('#Stages_StartDate')[0].value,
                Closed_Date: $(trs[i]).closest('tr').find('#Stages_EndDate')[0].value,
                CalcTime: $(trs[i]).closest('tr').find('#Stages_CalcTime')[0].value
            });
        }

        trs = $('#OrderProdByProductsTbody tr');
        var ProdProducts = new Array();
        for (var i = 0; i < trs.length; i++) {
            ProdProducts.push({
                CompNo: '@company.comp_num',
                OrderYear: Prod_ProdOrder_Add_OrderYear.value,
                formula_code: Prod_ProdOrder_Add_formulacode.value,
                item_no: $(trs[i]).closest('tr').find('#Product_ItemNo')[0].innerHTML,
                Qty: $(trs[i]).closest('tr').find('#Product_Qty')[0].innerHTML,
                CostPrc: $(trs[i]).closest('tr').find('#Product_CostPrc')[0].innerHTML
            });
        }

        wait();
        if (confirm('@Resources.Resource.ConfirmProdOrder')) {
            burn({ ProdInfoHF: ProdInfoHF, ProdInfoDF: ProdInfoDF, manufacure: ProdStages, OrderExtended: ProdProducts }, '../../../ProdOrders/Save_ProdOrders', '', ReloadProdOrder, true);
        } else {
            done();
        }
    }

