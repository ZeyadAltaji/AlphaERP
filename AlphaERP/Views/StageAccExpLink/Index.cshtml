    function CheckValueCostShare(statusCost,val) {
        if (statusCost == 1) {
            var tr = $("#StageAccExpLinkTBody #StageAccExpLink_" + val + "");
            if (tr.find('#StageAccExpLink_CostShare')[0].value > 100 || tr.find('#StageAccExpLink_CostShare')[0].value < 0) {
                MsgBox('@Html.Translate("النسبة يجب ان تكون بين 0 و 100", "The ratio should be between 0 and 100")', 'red');
                tr.find('#StageAccExpLink_CostShare')[0].value = 0
                tr.find('#StageAccExpLink_CostShare')[0].focus();
                return false;
            }
        }
        if (statusCost == 2) {
            var tr = $("#eStageAccExpLinkTBody #eStageAccExpLink_" + val + "");
            if (tr.find('#StageAccExpLink_eCostShare')[0].value > 100 || tr.find('#StageAccExpLink_eCostShare')[0].value < 0) {
                MsgBox('@Html.Translate("النسبة يجب ان تكون بين 0 و 100", "The ratio should be between 0 and 100")', 'red');
                tr.find('#StageAccExpLink_eCostShare')[0].value = 0
                tr.find('#StageAccExpLink_eCostShare')[0].focus();
                return false;
            }
        }
    }
