    function ExcuteSaveProd_StageAccExpLink() {
        if (CheckValue('Prod_StageAccExpLink_Stagecode')) { return; }
        if (CheckValue('Prod_StageAccExpLink_Deptcode')) { return; }
        if (CheckValue('Prod_StageAccExpLink_Acccode')) { return; }

        var StageAccExpLink = new Array();

        var table = $('#StageAccExpLinkTBody tr');
        var trs = table;

        if (trs.length == 0) {
            alert('@Html.Translate("يجب ادخال بيانات المصاريف", "Must Input Expenses Data")');
            return false;
        }

        for (var i = 0; i < trs.length; i++) {
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#StageAccExpLink_DeptNoDet')[0].value)) {
                alert('@Html.Translate("يجب ادخال الدائرة", "DeptNo must be entered")');
                return false;
            }
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#StageAccExpLink_AccNoDet')[0].value)) {
                alert('@Html.Translate("يجب ادخال الحساب", "AccNo must be entered")');
                return false;
            }
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#StageAccExpLink_CostShare')[0].value)) {
                alert('@Html.Translate("يجب ادخال نسبة التحميل", "Cost Share must be entered")');
                return false;
            }

            StageAccExpLink.push({
                CompNo: '@company.comp_num',
                StageCode: Prod_StageAccExpLink_Stagecode.value,
                CloseDept: Prod_StageAccExpLink_Deptcode.value,
                CloseAcc: Prod_StageAccExpLink_Acccode.value,
                ExpDept: $(trs[i]).closest('tr').find('#StageAccExpLink_DeptNoDet')[0].value,
                ExpAcc: $(trs[i]).closest('tr').find('#StageAccExpLink_AccNoDet')[0].value,
                CostShare: $(trs[i]).closest('tr').find('#StageAccExpLink_CostShare')[0].value
            });
        }
        wait();

        burn({ StageAccExpLink: StageAccExpLink }, '../../../StageAccExpLink/Save_StageAccExpLink', '', ReloadSaveStageAccExpLink, true);
    }
