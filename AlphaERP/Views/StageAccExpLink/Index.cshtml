<script>
    var count = 0;
    var eCount = 0;
    var thisValue = '';
    var ethisValue = '';
    var thisValueAcc = '';
    var ethisValueAcc = '';

    var status = 0;
    var statusacc = 0;

    // تحريك الموديل
    $('#Prod_StageAccExpLink_Model').draggable({
        handle: ".modal-header",
    });
    $('#Model_StageAccExpLink_ProdstageInfo').draggable({
        handle: ".modal-header",
    });
    $('#Model_StageAccExpLink_GLDEPMFs').draggable({
        handle: ".modal-header",
    });
    $('#Model_StageAccExpLink_Acc').draggable({
        handle: ".modal-header",
    });

    $('#Model_StageAccExpLink_DeptMF').draggable({
        handle: ".modal-header",
    });
    $('#Prod_eStageAccExpLink_Model').draggable({
        handle: ".modal-header",
    });

    

    function AddProd_StageAccExpLink() {
        $('#Prod_StageAccExpLink_Model').modal('show')
        Prod_StageAccExpLink_Stagecode.value =null;
        Prod_StageAccExpLink_StageDesc.value = null;
        Prod_StageAccExpLink_Deptcode.value = null;
        Prod_StageAccExpLink_DeptDesc.value = null;
        Prod_StageAccExpLink_Acccode.value = null;
        Prod_StageAccExpLink_AccDesc.value = null;
        $('#StageAccExpLinkTBody').empty();

    }
    var ProdstageInfo = $('#Select_StageAccExpLink_ProdstageInfoTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    var GLDEPMFs = $('#Select_StageAccExpLink_GLDEPMFsTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    function Serach_StageInfo() {
        $('#Select_StageAccExpLink_ProdstageInfoTable tr').removeClass("selected");
        $('#Model_StageAccExpLink_ProdstageInfo').modal('show')
    }
    function Serach_Dept() {
        status = 0;
        $('#Select_StageAccExpLink_GLDEPMFsTable tr').removeClass("selected");
        $('#Model_StageAccExpLink_GLDEPMFs').modal('show')
    }
    function CheckValue(ID) {
        if (document.getElementById(ID).getAttribute('required') == 'true') {
            if (document.getElementById(ID).value == '') {
                document.getElementById(ID).focus();
                return true;
            } else {
                return false;
            }
        }
        return false;
    }
    function Serach_Acc() {
        statusacc = 0;
        if (CheckValue('Prod_StageAccExpLink_Deptcode')) {
            alert('@Html.Translate("يجب ادخال الدائرة", "You must enter the Dept")');
            return;
        }
        wait();
        burn({ DeptId: Prod_StageAccExpLink_Deptcode.value }, '../../../StageAccExpLink/Account', '', ReloadtAcc, true);
    }
    function Select_finItems(e) {
        var trs = ProdstageInfo.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Select_finItemsGLDEPMFs(e) {
        var trs = GLDEPMFs.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function ReloadtAcc(r) {
        StageAccExpLink_Accbody.innerHTML = "";
        $('#StageAccExpLink_Accbody').html(r);
        $('#Model_StageAccExpLink_Acc').modal('show');
    }
    function Select_finItemsAcc(e) {
        var table = $('#StageAccExpLink_AccTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Selecting_StageAccExpLink_ProdstageInfo() {
        var trs = ProdstageInfo.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار مرحلة", "Select one stage ")');
            return;
        }

        Prod_StageAccExpLink_Stagecode.value = trs[0].getAttribute('Stagecode');
        Prod_StageAccExpLink_StageDesc.value = trs[0].getAttribute('StageDesc');
        CheckIsExixts();
        $('#Model_StageAccExpLink_ProdstageInfo').modal('hide')
    }
    function Selecting_StageAccExpLink_GLDEPMFs() {
        if (status == 0) {
            var trs = GLDEPMFs.$('tr[name=selected]');
            if (trs.length == 0) {
                alert('@Html.Translate("يرجى اختيار دائرة", "Select one Dept")');
                return;
            }

            Prod_StageAccExpLink_Deptcode.value = trs[0].getAttribute('DEP_NUM');
            Prod_StageAccExpLink_DeptDesc.value = trs[0].getAttribute('DepDesc');

            Prod_StageAccExpLink_Acccode.value = null;
            Prod_StageAccExpLink_AccDesc.value = null;
        }
        if (status == 1) {
            var trs = GLDEPMFs.$('tr[name=selected]');
            if (trs.length == 0) {
                alert('@Html.Translate("يرجى اختيار دائرة", "Select one Dept")');
                return;
            }

            var tr = $("#StageAccExpLinkTBody #StageAccExpLink_" + thisValue + "");
            tr.find('#StageAccExpLink_DeptNoDet')[0].value = trs[0].getAttribute('DEP_NUM');
            tr.find('#StageAccExpLink_DeptNameDet')[0].value = trs[0].getAttribute('DepDesc');

            tr.find('#StageAccExpLink_AccNoDet')[0].value = null;
            tr.find('#StageAccExpLink_AccNameDet')[0].value = null;
        }
         if (status == 2) {
            var trs = GLDEPMFs.$('tr[name=selected]');
            if (trs.length == 0) {
                alert('@Html.Translate("يرجى اختيار دائرة", "Select one Dept")');
                return;
            }

            var tr = $("#eStageAccExpLinkTBody #eStageAccExpLink_" + ethisValue + "");
            tr.find('#StageAccExpLink_eDeptNoDet')[0].value = trs[0].getAttribute('DEP_NUM');
             tr.find('#StageAccExpLink_eDeptNameDet')[0].value = trs[0].getAttribute('DepDesc');

             tr.find('#StageAccExpLink_eAccNoDet')[0].value = null;
             tr.find('#StageAccExpLink_eAccNameDet')[0].value = null;
        }
        $('#Model_StageAccExpLink_GLDEPMFs').modal('hide')
    }
    function Selecting_StageAccExpLink_Acc() {
        if (statusacc == 0) {
            var table = $('#StageAccExpLink_AccTable');
            var oTable = table.dataTable();
            var trs = oTable.$('tr[name=selected]');
            if (trs.length == 0) {
                alert('@Html.Translate("يرجى اختيار حساب", "Select one Acc")');
                return;
            }
            Prod_StageAccExpLink_Acccode.value = trs[0].getAttribute('acc_num');
            Prod_StageAccExpLink_AccDesc.value = trs[0].getAttribute('AccDesc');
            CheckIsExixts();
        }
        if (statusacc == 1) {
            var table = $('#StageAccExpLink_AccTable');
            var oTable = table.dataTable();
            var trs = oTable.$('tr[name=selected]');

            if (trs.length == 0) {
                alert('@Html.Translate("يرجى اختيار حساب", "Select one Acc")');
                return;
            }

            var tr = $("#StageAccExpLinkTBody #StageAccExpLink_" + thisValueAcc + "");
            var table = $('#StageAccExpLinkTBody tr');
            var trs1 = table;
            for (var i = 0; i < trs1.length; i++) {
                var id = tr[0].getAttribute('id')
                var trid = trs1[i].getAttribute('id')
                if (id != trid) {
                    if ($(trs1[i]).closest('tr').find('#StageAccExpLink_DeptNoDet')[0].value == tr.find('#StageAccExpLink_DeptNoDet')[0].value) {
                        if ($(trs1[i]).closest('tr').find('#StageAccExpLink_AccNoDet')[0].value == trs[0].getAttribute('acc_num')) {
                            alert('@Html.Translate("رقم الحساب مكرر لنفس الدائرة","ACC No Is Duplecated for Dept No")');
                            return false;
                        }
                    }
                }

            }
            tr.find('#StageAccExpLink_AccNoDet')[0].value = trs[0].getAttribute('acc_num');
            tr.find('#StageAccExpLink_AccNameDet')[0].value = trs[0].getAttribute('AccDesc');
        }
        if (statusacc == 2) {
            var table = $('#StageAccExpLink_AccTable');
            var oTable = table.dataTable();
            var trs = oTable.$('tr[name=selected]');

            if (trs.length == 0) {
                alert('@Html.Translate("يرجى اختيار حساب", "Select one Acc")');
                return;
            }

            var tr = $("#eStageAccExpLinkTBody #eStageAccExpLink_" + ethisValueAcc + "");
            var table = $('#eStageAccExpLinkTBody tr');
            var trs1 = table;
            for (var i = 0; i < trs1.length; i++) {
                var id = tr[0].getAttribute('id')
                var trid = trs1[i].getAttribute('id')
                if (id != trid) {
                    if ($(trs1[i]).closest('tr').find('#StageAccExpLink_eDeptNoDet')[0].value == tr.find('#StageAccExpLink_eDeptNoDet')[0].value) {
                        if ($(trs1[i]).closest('tr').find('#StageAccExpLink_eAccNoDet')[0].value == trs[0].getAttribute('acc_num')) {
                            alert('@Html.Translate("رقم الحساب مكرر لنفس الدائرة","ACC No Is Duplecated for Dept No")');
                            return false;
                        }
                    }
                }

            }
            tr.find('#StageAccExpLink_eAccNoDet')[0].value = trs[0].getAttribute('acc_num');
            tr.find('#StageAccExpLink_eAccNameDet')[0].value = trs[0].getAttribute('AccDesc');
        }
        $('#Model_StageAccExpLink_Acc').modal('hide')
    }
    function CheckIsExixts() {
        if (CheckValue('Prod_StageAccExpLink_Stagecode')) { Prod_StageAccExpLink_Stagecode.focus(); return; }
        if (CheckValue('Prod_StageAccExpLink_Deptcode')) { Prod_StageAccExpLink_Deptcode.focus();  return; }
        if (CheckValue('Prod_StageAccExpLink_Acccode')) { Prod_StageAccExpLink_Acccode.focus(); return; }

        burn({ Stagecode: Prod_StageAccExpLink_Stagecode.value, Deptcode: Prod_StageAccExpLink_Deptcode.value, Acccode: Prod_StageAccExpLink_Acccode.value }, '../../../StageAccExpLink/CheckIsExixts', '', ReloadCheckIsExixts, true);
    }
    function ReloadCheckIsExixts(r) {
        if (r.d == "IsExixts") {
            MsgBox('@Html.Translate("البيانات معرفا مسبقا","Data Is Saved ")', 'red');
            Prod_StageAccExpLink_Stagecode.value = '';
            Prod_StageAccExpLink_StageDesc.value = '';
        }
    }
    function GenRowMas(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function eRemoveRow(e) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            return true;
            eCount++;
        }
        return false;
    }
    function Add_DeptDet() {
        ststaus = 1;
        count++;
        var newarray = [];
        newarray.push('<input id="StageAccExpLink_DeptNoDet" type="number" style="width: 40px !important;" disabled />')
        newarray.push('<input id="StageAccExpLink_DeptNameDet" type="text" disabled />')
        newarray.push('<button onclick="AddDeptNo(' + count + ')" type="button" class="btn btn-primary">@Html.Recource(1867)</button>')
        newarray.push('<input id="StageAccExpLink_AccNoDet" type="number" disabled />')
        newarray.push('<input id="StageAccExpLink_AccNameDet" type="text" disabled />')
        newarray.push('<button onclick="AddAccNo(' + count + ')" type="button" class="btn btn-primary">@Html.Recource(219)</button>')
