                    <div class="col-md-2">
                        <label class="unselectable" for="Prod_StageAccExpLink_Deptcode">@Html.Recource(9590) </label>
                    </div>
                    <div class="col-md-2">
                        <input required="true" style="width: 125%;" id="Prod_StageAccExpLink_Deptcode" disabled />
                    </div>
                    <div class="col-md-6">
                        <input style="width: 100%;" id="Prod_StageAccExpLink_DeptDesc" disabled />
                    </div>
                    <div class="col-md-2">
                        <button onclick="Serach_Dept()" type="button" class="btn btn-primary">@Html.Recource(975)</button>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-2">
                        <label class="unselectable" for="Prod_StageAccExpLink_formula_code">@Html.Recource(7473) </label>
                    </div>
                    <div class="col-md-2">
                        <input required="true"  style="width: 125%;" id="Prod_StageAccExpLink_Acccode" disabled />
                    </div>
                    <div class="col-md-6">
                        <input style="width: 100%;" id="Prod_StageAccExpLink_AccDesc" disabled />
                    </div>
                    <div class="col-md-2">
                        <button onclick="Serach_Acc()" type="button" class="btn btn-primary">@Html.Recource(975)</button>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-12">
                        <button   onclick="Add_DeptDet()" type="button" class="btn btn-primary" >@Html.Recource(32)</button>
                    </div>


                    <div class="col-md-12" style="width:872px !important;overflow-y:auto">
                        <table class="table table-hover" id="PackingItemTable">
                            <thead>
                                <tr>

                                    <th style="width: 35px !important; text-align:center">@Html.Recource(110)</th>
                                    <th style=" text-align:center">@Html.Recource(109)</th>
                                    <th></th>
                                    <th style=" text-align:center">@Html.Recource(255)</th>
                                    <th style=" text-align:center">@Html.Recource(256)</th>
                                    <th></th>
                                    <th style="width: 62px !important; text-align:center">@Html.Recource(9586)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="StageAccExpLinkTBody">
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="ExcuteSaveProd_StageAccExpLink()" class="btn btn-primary">@Html.Recource(475)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>

