                        <label class="unselectable" for="Prod_StageAccExpLink_Stagecode">@Html.Recource(4482) </label>
                    </div>
                    <div class="col-md-2">
                        <input required="true"  style="width: 125%;" id="Prod_StageAccExpLink_Stagecode" disabled />
                    </div>
                    <div class="col-md-6">
