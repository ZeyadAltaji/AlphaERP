        var ProdStages = {
            comp_no: '@company.comp_num',
            stage_code: ProdStages_save_StageCode.value,
            stage_desc: ProdStages_save_StageName.value,
            GroupID: ProdStages_save_Group.value,
            no_yearly_daily_work: ProdStages_save_AnualWorkingDays.value,
            notes: ProdStages_save_Notes.value,
            Hr: ProdStages_save_DailyWorkingHours.value,
            SetupTime: ProdStages_save_SetupTime.value,
            SetupTimePrc: ProdStages_save_SetupTimeCost.value,
            StopTimePrc: ProdStages_save_StopTime.value,
            QualityControl: ProdStages_save_QualityStage.checked,
        }

        var MachinesStage = new Array();

        var table = $('#DefineMachinesStageTbody tr');
        var trs = table;
        if (trs.length != 0) {
            for (var i = 0; i < trs.length; i++) {
                if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#DefineMachinesStage_MachineNo')[0].value)) {
                    alert('@Html.Translate("يجب ادخال رقم الماكينة", "Machine No must be entered")');
                    return false;
                }
                if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#DefineMachinesStage_MachineName')[0].value)) {
                    alert('@Html.Translate("يجب ادخال اسم الماكينة", "Machine Name must be entered")');
                    return false;
                }

                MachinesStage.push({
                    CompNo: '@company.comp_num',
                    stage_code: ProdStages_save_StageCode.value,
                    machine_code: $(trs[i]).closest('tr').find('#DefineMachinesStage_MachineNo')[0].value,
                    machine_Desc: $(trs[i]).closest('tr').find('#DefineMachinesStage_MachineName')[0].value,
                    consumption_value: $(trs[i]).closest('tr').find('#DefineMachinesStage_DepreciationValue')[0].value,
                    FACode: $(trs[i]).closest('tr').find('#DefineMachinesStage_FixAssestNo')[0].value,
                    FASr: $(trs[i]).closest('tr').find('#DefineMachinesStage_Serial')[0].value,
                });
            }
        }

        wait();

        burn({ stageinfo: ProdStages, MachineInfo: MachinesStage }, '../../../ProductionStages/Save_ProdStages', '', ReloadProdStages, true);
    }
