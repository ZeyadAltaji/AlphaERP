<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-6">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="Ord_LinkPrchOrdUsers_ByRequest">
                    <input id="Ord_LinkPrchOrdUsers_ByRequest" type="radio" name="Ord_LinkPrchOrdUsersRadio" checked onchange="GetLinkPrchOrdUsers()">
                    @Html.Translate("حسب الطلب","By Request")
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="Ord_LinkPrchOrdUsers_ByItems">
                    <input name="Ord_LinkPrchOrdUsersRadio" type="radio" id="Ord_LinkPrchOrdUsers_ByItems" onchange="GetLinkPrchOrdUsers()" />
                    @Html.Translate("حسب المواد", "By Items")
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable"></label>
                <button class="btn btn-success btn-block" onclick="LinkPrchOrdUsersSerach()">
                    @Resources.Resource.Search
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="LinkPrchOrdUsersRequestDiv" style="display:none">

    </div>
    <div class="box-body box-profile" id="LinkPrchOrdUsersItemsDiv" style="display:none">

    </div>
</div>

<script>
    GetLinkPrchOrdUsers();
    function GetLinkPrchOrdUsers() {
        LinkPrchOrdUsersSerach();
    }
    function LinkPrchOrdUsersSerach() {
        if (Ord_LinkPrchOrdUsers_ByRequest.checked == true) {
            LinkPrchOrdUsersRequestDiv.innerHTML = "";
            LinkPrchOrdUsersItemsDiv.innerHTML = "";
            $("#LinkPrchOrdUsersItemsDiv").css("display", "none");
            $("#LinkPrchOrdUsersRequestDiv").css("display", "block");
            $('#LinkPrchOrdUsersRequestDiv').load('../../../LinkPrchOrdUsers/GetPurchOrd?PurchOrd=0');
        }
        if (Ord_LinkPrchOrdUsers_ByItems.checked == true) {
            $("#LinkPrchOrdUsersRequestDiv").css("display", "none");
            $("#LinkPrchOrdUsersItemsDiv").css("display", "block");
            LinkPrchOrdUsersRequestDiv.innerHTML = "";
            LinkPrchOrdUsersItemsDiv.innerHTML = "";
            $('#LinkPrchOrdUsersItemsDiv').load('../../../LinkPrchOrdUsers/GetPurchOrd?PurchOrd=1');
        }
    }
</script>