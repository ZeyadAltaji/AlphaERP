                <tr id="EnterVendorOffer_@item.VendorNo">
                    <td style="width: 10%; word-wrap: break-word; white-space: normal;" vendor="@item.VendorNo">@Html.Translate(VenderName, VenderNameEn)</td>
                    <td style="width: 20%; word-wrap: break-word; white-space: normal;" id="EnterVendorOffer_ItemNo_@Srial">@item.ItemNo</td>
