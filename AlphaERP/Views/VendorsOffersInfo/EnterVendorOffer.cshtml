                    </td>
                    <td style="text-align: center;">
                        <input id="EnterVendorOffer_Price_@Srial" value="@item.SellPrice" type="number" min="0" style="width:75px !important" onblur="CheckValuePrice(@Srial)" />
                    </td>
                    @if (@item.Curr != 0)
                    {
                        <td style="text-align: center;">
                            <select style="width:100%" class="EnterVendorOffer_CboCurrCode">
                                @foreach (var Curr in Currency)
