<script>
    $('.EnterVendorOffer_CboCurrCode').select2();
    $('.EnterVendorOffer_CboPaymentType').select2();
    $('.EnterVendorOffer_CboDeliveryPlace').select2();

    function CheckValueQty(Serial) {
        if ($('#EnterVendorOffer_Qty_' + Serial)[0].value < 0) {
            $('#EnterVendorOffer_Qty_' + Serial)[0].value = 0;
            $('#EnterVendorOffer_Qty_' + Serial)[0].focus();
            alert('@Html.Translate("يجب أن تكون الكمية أكبر من صفر", "The Qty Must be Greater Than Zero")');
        }
        if ($('#EnterVendorOffer_Qty_' + Serial)[0].value == "") {
            $('#EnterVendorOffer_Qty_' + Serial)[0].value = 0;
        }
    }
    function CheckValueQty2(Serial) {
        if ($('#EnterVendorOffer_Qty2_' + Serial)[0].value < 0) {
            $('#EnterVendorOffer_Qty2_' + Serial)[0].value = 0;
            $('#EnterVendorOffer_Qty2_' + Serial)[0].focus();
            alert('@Html.Translate("يجب أن تكون الكمية 2 أكبر من صفر", "The Qty 2 Must be Greater Than Zero")');
        }
        if ($('#EnterVendorOffer_Qty2_' + Serial)[0].value == "") {
            $('#EnterVendorOffer_Qty2_' + Serial)[0].value = 0;
        }
    }

    
    function CheckValueBouns(Serial) {
        if ($('#EnterVendorOffer_Bonus_' + Serial)[0].value < 0) {
            $('#EnterVendorOffer_Bonus_' + Serial)[0].value = 0;
            $('#EnterVendorOffer_Bonus_' + Serial)[0].focus();
            alert('@Html.Translate("يجب أن تكون الكمية الاضافية أكبر من صفر", "The Bonus Must be Greater Than Zero")');
        }
        if ($('#EnterVendorOffer_Bonus_' + Serial)[0].value == "") {
            $('#EnterVendorOffer_Bonus_' + Serial)[0].value = 0;
        }
    }
    function CheckValuePrice(Serial) {
        if ($('#EnterVendorOffer_Price_' + Serial)[0].value < 0) {
            $('#EnterVendorOffer_Price_' + Serial)[0].value = 0;
            $('#EnterVendorOffer_Price_' + Serial)[0].focus();
            alert('@Html.Translate("يجب أن يكون السعر أكبر من صفر", "The Price Must be Greater Than Zero")');
        }
        if ($('#EnterVendorOffer_Price_' + Serial)[0].value == "") {
            $('#EnterVendorOffer_Price_' + Serial)[0].value = 0;
        }
    }
    function SaveRequestforQuotation() {
        var OrdCopyInfo = new Array();
        var table = $('#EnterVendorOfferTBody tr');
        var ordcopyNo = 0;
        var ordcopyNo1 = 0;
        var bVendore = false;
        var VendoreOld = 0
        var trs = table;

        for (var i = 0; i < trs.length; i++) {
            if (bVendore == true) {
                if (ordcopyNo > 0) {
                    if (ordcopyNo != ordcopyNo1) {
                        alert('@Html.Translate("يجب إدخال عرض المورد لجميع المواد", "Supplier offer must be entered for all item")');
                        return false;
                    }
                }
            }
            bVendore = false;

            VendoreOld = $(trs[i]).closest('tr').find('#EnterVendorOffer_VendorNo')[0].value;
            if (VendorNo == VendoreOld) {
                continue;
            }
            ordcopyNo = 0;
            var VendorNo = $(trs[i]).closest('tr').find('#EnterVendorOffer_VendorNo')[0].value
            var tableVendore = $('#EnterVendorOfferTBody #EnterVendorOffer_' + VendorNo);
            var trsVendore = tableVendore;
            ordcopyNo1 = trsVendore.length;

            for (var z = 0; z < trsVendore.length; z++) {
                var InputSerial = $(trsVendore[z]).closest('tr').find('#InputSerial')[0].value
                if ($(trsVendore[z]).closest('tr').find('#EnterVendorOffer_Qty_' + InputSerial)[0].value > 0 && $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_Price_' + InputSerial)[0].value > 0) {
                    OrdCopyInfo.push({
                        ReqforQuotNo: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_ReqforQuotNo')[0].value,
                        VendorNo: VendorNo,
                        ItemNo: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_ItemNo_' + InputSerial)[0].innerHTML,
                        Qty: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_Qty_' + InputSerial)[0].value,
                        Qty2: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_Qty2_' + InputSerial)[0].value,
                        Bonus: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_Bonus_' + InputSerial)[0].value,
                        SellPrice: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_Price_' + InputSerial)[0].value,
                        DeliveryDate: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_DeliveryDate_' + InputSerial)[0].value,
                        bVendorsOffers: true,
                        Curr: $(trs[i]).closest('tr').find('.EnterVendorOffer_CboCurrCode')[0].value,
                        Pmethod: $(trs[i]).closest('tr').find('.EnterVendorOffer_CboPaymentType')[0].value,
                        DeliveryPlace: $(trs[i]).closest('tr').find('.EnterVendorOffer_CboDeliveryPlace')[0].value,
                        CountryOfOrigin: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_CountryOfOrigin_' + InputSerial)[0].value,
                        ShippingPort: $(trsVendore[z]).closest('tr').find('#EnterVendorOffer_ShippingPort_' + InputSerial)[0].value
                    });
                    ordcopyNo = ordcopyNo + 1;
                }
                bVendore = true
            }
        }

        @*if (OrdCopyInfo.length == 0) {
            alert('@Html.Translate("يجب إدخال الكمية و السعر  لماده واحده على الاقل", "You must enter the quantity and price for at least one item")');
            return false;
        }*@

        wait();
