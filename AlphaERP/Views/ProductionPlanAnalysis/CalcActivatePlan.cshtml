@model IEnumerable<AlphaERP.Models.MRP_Calculation>
@using AlphaERP.Models
@{
    MRP_Calculation MRPCalu = Model.FirstOrDefault();
    Company company = (Company)Session["company"];
    List<BusunisUnit> Venders = new MDB().Database.SqlQuery<BusunisUnit>(string.Format("select VendorNo as VenderId ,name as DescAr,Eng_Name as DescEn from Vendors where (comp = '{0}') AND (IsHalt = 0)", company.comp_num)).ToList();
}
    <style>
        #MRPCalculationTable thead tr th {
            padding: 8px 15px !important;
            text-align: center !important;
        }

        .OrderStat > td {
            color: red !important;
        }

        #MRPCalculationTable thead tr th, td {
            /**/
            white-space: nowrap;
        }

        #MRPCalculationTable thead tr td:last-child {
            text-align: right !important
        }

        .GroupTitle {
            font-size: 14px;
            font-weight: bold;
            margin: 0px -15px;
        }
    </style>

    <link href="~/Content/stickytooltip.css" rel="stylesheet" />
    <script src="~/Scripts/stickytooltip.js?s=12"></script>


    <div class="modal-body row">
        <div class="form-group">
            <div class="col-md-2">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_PlanYear">@Resources.Resource.PlanYear </label>
            </div>
            <div class="col-md-2" style="margin-bottom: 5px;">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_PlanYear">
                    @MRPCalu.PlanYear
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_PlanNo">@Resources.Resource.PlanNo </label>
            </div>
            <div class="col-md-2" style="margin-bottom: 5px;">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_PlanNo">
                    @MRPCalu.PlanNo
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_PlanDuration">@Resources.Resource.PlanDuration </label>
            </div>
            <div class="col-md-2" style="margin-bottom: 5px;">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_PlanDuration">
                    @MRPCalu.Days
                </label>
            </div>
        </div>
        <div class="form-group">
            <div class="col-md-2">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_StartDate">@Resources.Resource.StartDate </label>
            </div>
            <div class="col-md-2" style="margin-bottom: 5px;">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_StartDate">
                    @MRPCalu.StartDate.Value.ToString("yyyy-MM-dd")
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_EndDate">@Resources.Resource.EndDate </label>
            </div>
            <div class="col-md-2" style="margin-bottom: 5px;">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_EndDate">
                    @MRPCalu.EndDate.Value.ToString("yyyy-MM-dd")
                </label>
            </div>
            <div class="col-md-2">
                <button class="btn btn-info" onclick="PrintGreport(@company.comp_num, @MRPCalu.PlanYear,@MRPCalu.PlanNo,'Calculation')">
                    <i class="fa fa-print"></i>
                    @Html.Recource(9565)
                </button>
            </div>
            <div class="col-md-2" style="margin-bottom: 5px;">
                
            </div>
        </div>
        <div class="form-group">
            <div class="col-md-2">
                <label class="unselectable" for="SAVE_ProductionPlanAnalysis_PlanNote">@Resources.Resource.PlanNote </label>
            </div>
            <div class="col-md-10" style="margin-bottom: 5px;">
                <textarea style="width: 100%;height:35px  !important;" id="SAVE_ProductionPlanAnalysis_PlanNote" disabled>@MRPCalu.PlanNote</textarea>
            </div>
        </div>
        <div class="form-group">
            <div class="col-md-12 GroupTitle">
                @Resources.Resource.RequestData :
            </div>
        </div>
        <div class="form-group" style="display:block;height:212px;">
            <div class="col-md-3">
                <table class="table table-hover" id="MRPCalculationTable">
                    <thead>
                        <tr>
                            <th>@Resources.Resource.ItemNo</th>
                            <th>@Resources.Resource.ItemName</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody style="text-align: center;">
                        @{
                            int i = 1;
                        }
                        @foreach (MRP_Calculation MRPC in Model)
                        {
                            if (MRPC.OrderStat == true)
                            {
                                <tr class="OrderStat" data-tooltip="sticky_@i">
                                    <td style="text-align: center !important">@MRPC.ItemNo</td>
                                    <td style="text-align: center !important">@MRPC.ItemDesc</td>
                                    <td></td>
                                </tr>
                            }
                            else
                            {
                                <tr data-tooltip="sticky_@i">
                                    <td style="text-align: center !important">@MRPC.ItemNo</td>
                                    <td style="text-align: center !important">@MRPC.ItemDesc</td>
                                    <td></td>
                                </tr>
                            }
                            i++;
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-md-9" style="overflow-x:auto;display:block;bottom: 5px;">
                <table class="table table-hover MRPCalculation" id="MRPCalculationTable">
                    <thead>
                        <tr>
                            <th>@Resources.Resource.MainUnit</th>
                            <th>@Resources.Resource.QTY</th>
                            <th>@Resources.Resource.QtyPreviousPlan</th>
                            <th>@Resources.Resource.QuantityAva</th>
                            <th>@Resources.Resource.CoverDays</th>
                            <th>@Resources.Resource.OrderQuantity</th>
                            <th>@Resources.Resource.CoverDays</th>
                            <th>@Resources.Resource.TotalQuantityAvailable</th>
                            <th>@Resources.Resource.CoverDays</th>
                            <th>@Resources.Resource.OrderStat</th>
                            <th>@Resources.Resource.Shoratge</th>
                            <th>@Resources.Resource.NumberOrder</th>
                            <th>@Resources.Resource.QuantityToOrder</th>
                            <th>@Resources.Resource.Supplier</th>
                            <th>@Resources.Resource.PurchaseOrderNo</th>
                            <th>
                                <input id="MRP_Calculation_Actionchecked" type="checkbox" onchange="SelectAll(this)" checked>
                            </th>
                        </tr>
                    </thead>
                    <tbody style="text-align: center !important;" id="MRPCalculationTbody">
                        @foreach (MRP_Calculation MRPC in Model)
                        {
                            if (MRPC.OrderStat == true)
                            {
                                <tr class="OrderStat" itemNo="@MRPC.ItemNo">
                                    <td style="text-align: center !important">@MRPC.UnitDesc</td>
                                    <td style="text-align: center !important">@MRPC.TotalReqQty</td>
                                    <td style="text-align: center !important">@MRPC.TotalPrvQty</td>
                                    <td style="text-align: center !important">@MRPC.QtyOH</td>
                                    <td style="text-align: center !important">@MRPC.QtyOHCDays</td>
                                    <td style="text-align: center !important">@MRPC.QtyInOrder</td>
                                    <td style="text-align: center !important">@MRPC.QtyInOrderCDays</td>
                                    <td style="text-align: center !important">@MRPC.TotalAvialbeQty</td>
                                    <td style="text-align: center !important">@MRPC.StockCDays</td>
                                    <td style="text-align:center!important">
                                        @if (MRPC.OrderStat == true)
                                        {
                                            <i class="fa fa-check"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-times"></i>
                                        }
                                    </td>
                                    <td style="text-align: center !important">@MRPC.QtyShoratge</td>
                                    <td style="text-align: center !important">@MRPC.NoOforders</td>
                                    <td style="text-align: center !important">
                                        <input onblur="CheckValue(this)" type="number" style="width: 90px;text-align: center;" id="MRPCalculation_QtyToOrder" required="true" value="@MRPC.QtyToOrder" />
                                    </td>
                                    <td style="text-align: center !important">
                                        <select style="width:75px !important;" class="MRP_Calculation_Vender" required="true">
                                            @foreach (var v in Venders)
                                            {
                                                if (MRPC.Prefvendor == v.VenderId)
                                                {
                                                    <option value="@v.VenderId" selected>@ar(v.DescAr, v.DescEn)</option>
                                                }
                                                else
                                                {
                                                    <option value="@v.VenderId">@ar(v.DescAr, v.DescEn)</option>
                                                }

                                            }
                                        </select>
                                    </td>
                                    <td style="text-align: center !important">@MRPC.PlanPRNo</td>
                                    <td style="text-align:center!important">
                                        <input id="MRP_Calculation_Action" type="checkbox" checked>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                <tr itemNo="@MRPC.ItemNo">
                                    <td style="text-align: center !important">@MRPC.UnitDesc</td>
                                    <td style="text-align: center !important">@MRPC.TotalReqQty</td>
                                    <td style="text-align: center !important">@MRPC.TotalPrvQty</td>
                                    <td style="text-align: center !important">@MRPC.QtyOH</td>
                                    <td style="text-align: center !important">@MRPC.QtyOHCDays</td>
                                    <td style="text-align: center !important">@MRPC.QtyInOrder</td>
                                    <td style="text-align: center !important">@MRPC.QtyInOrderCDays</td>
                                    <td style="text-align: center !important">@MRPC.TotalAvialbeQty</td>
                                    <td style="text-align: center !important">@MRPC.StockCDays</td>
                                    <td style="text-align:center!important">
                                        @if (MRPC.OrderStat == true)
                                        {
                                            <i class="fa fa-check"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-times"></i>
                                        }
                                    </td>
                                    <td style="text-align: center !important">@MRPC.QtyShoratge</td>
                                    <td style="text-align: center !important">@MRPC.NoOforders</td>
                                    <td style="text-align: center !important">
                                        <input onblur="CheckValue(this)" type="number" style="width: 90px;text-align: center;" id="MRPCalculation_QtyToOrder" required="true" value="@MRPC.QtyToOrder" />
                                    </td>
                                    <td style="text-align: center !important">
                                        <select style="width:75px !important;" class="MRP_Calculation_Vender" required="true">
                                            @foreach (var v in Venders)
                                            {
                                                if (MRPC.Prefvendor == v.VenderId)
                                                {
                                                    <option value="@v.VenderId" selected>@ar(v.DescAr, v.DescEn)</option>
                                                }
                                                else
                                                {
                                                    <option value="@v.VenderId">@ar(v.DescAr, v.DescEn)</option>
                                                }

                                            }
                                        </select>
                                    </td>
                                    <td style="text-align: center !important">@MRPC.PlanPRNo</td>
                                    <td style="text-align:center!important">
                                        <input id="MRP_Calculation_Action" type="checkbox" checked>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div id="mystickytooltip" class="stickytooltip">
            <div style="padding:5px">
                @{
                    i = 1;
                }
                @foreach (MRP_Calculation MRPC in Model)
                {
                <div id="sticky_@i" class="atip" style="width:262px;@Html.Translate("direction:rtl","")">

                    @Html.Translate("هدف التغطية بالايام", "Coverage target") : @MRPC.StockCoverage
                    <br />
                    @Html.Translate("مدة التسليم", "Lead time") : @MRPC.LeadTime
                    <br />
                    @Html.Translate("نقطة اعادة الطلب", "Reorder point") : @MRPC.ReOrderPoint
                    <br />
                    @Html.Translate("الحد الادنى للطلب", "MOQ") : @MRPC.MOQ
                    <br />
                    @Html.Translate("مضاعف الطلب", "Order multiple") : @MRPC.OrderMulti
                </div>
                    i++;
                }

            </div>
            <div class="stickystatus"></div>
        </div>

        <div class="form-group">
            <div class="col-md-2">
                <label class="unselectable" for="MRPCalculation_GroupItemBySupplier">
                    <input id="MRPCalculation_GroupItemBySupplier" type="radio" name="MRP_CalculationRadio" checked>
                    @Resources.Resource.GroupItemBySupplier
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="MRPCalculation_PurchaseOrderForEachItem">
                    <input name="MRP_CalculationRadio" type="radio" id="MRPCalculation_PurchaseOrderForEachItem" />
                    @Resources.Resource.PurchaseOrderForEachItem
                </label>
            </div>
            <div class="col-md-2" style="left: 20px;">
                <label class="unselectable" for="MRPCalculation_OnePurchaseOrderForAllItems">
                    <input name="MRP_CalculationRadio" type="radio" id="MRPCalculation_OnePurchaseOrderForAllItems" />
                    @Resources.Resource.OnePurchaseOrderForAllItems
                </label>
            </div>
            <div class="col-md-3"></div>
            <div class="col-md-3">
                <button class="btn btn-primary btn-block" onclick="CreatePurchaseOrders()">
                    @Resources.Resource.CreatePurchaseOrders
                </button>
            </div>
        </div>
    </div>


<script>
    $('.MRP_Calculation_Vender').select2();
    function SelectAll(e) {
        var table = $('.MRPCalculation #MRPCalculationTbody tr');
        var trs = table;
        for (var i = 0; i < trs.length; i++) {
            $(trs[i]).closest('tr').find('#MRP_Calculation_Action')[0].checked = e.checked
        }
    }
    function CheckValue(e) {
        if (e.value < 0) {
            e.focus();
        }
    }
    function CreatePurchaseOrders() {
        var table = $('.MRPCalculation #MRPCalculationTbody tr');
        var trs = table;

        var MRPPlanPRNo = new Array();

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('#MRP_Calculation_Action')[0].checked == true) {
                    MRPPlanPRNo.push({
                        PlanYear :  @MRPCalu.PlanYear,
                        PlanNo : @MRPCalu.PlanNo,
                        ItemNo: trs[i].getAttribute('itemNo'),
                        QtyToOrder: $(trs[i]).closest('tr').find('#MRPCalculation_QtyToOrder')[0].value,
                        venderNo: $(trs[i]).closest('tr').find('.MRP_Calculation_Vender')[0].value,
                        GroupItemBySupplier: MRPCalculation_GroupItemBySupplier.checked,
                        PurchaseOrderForEachItem: MRPCalculation_PurchaseOrderForEachItem.checked,
                        OnePurchaseOrderForAllItems: MRPCalculation_OnePurchaseOrderForAllItems.checked
                    });
            }
        }

        if (MRPPlanPRNo.length == 0) {
            MsgBox('@Resources.Resource.NoItemWasSelected', 'red');
            return false
        }


        if (confirm('@Resources.Resource.ConfirmCreatePurchaseOrders')) {
            wait();
            burn({ lPlanPRNo: MRPPlanPRNo }, '../../../ProductionPlanAnalysis/CreatePurchaseOrders', '', LoadCreatePurchaseOrders, true);
        }
    }
</script>


@functions{
    string ar(string arabic, string english)
    {
        if (Session["language"].ToString() == "en") { return english; } else { return arabic; }
    }
}






