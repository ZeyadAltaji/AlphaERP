<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-8">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="MRP_ShipmentsControl_Date">@Html.Recource(58)</label>
                <input value="@DateTime.Now.ToString("yyyy-MM-dd")" type="date" id="MRP_ShipmentsControl_Date" />
            </div>
            <div class="col-md-2">
                <label class="unselectable"></label>
                <button class="btn btn-success btn-block" onclick="InquiryShipmentsControl()">
                    @Resources.Resource.Search
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="InquiryShipmentsControlDiv">

    </div>
</div>

<script>
    function InquiryShipmentsControl() {
        wait();
        burn({ Date: MRP_ShipmentsControl_Date.value }, '../../../ShipmentsControl/ShipmentsControlList', '', LoadShipmentsControl, true);
    }
    function LoadShipmentsControl(r) {
        InquiryShipmentsControlDiv.innerHTML = "";
        $('#InquiryShipmentsControlDiv').html(r);
        done();
    }
</script>