@using System.Data.SqlClient;
@using AlphaERP.Models

@{
    int OrdYear = ViewBag.OrdYear;
    int OrderNo = ViewBag.OrderNo;
    string TawreedNo = ViewBag.TawreedNo;
    string ShipSer = ViewBag.ShipSer;
    string srl = ViewBag.srl;
    User me = (User)Session["me"];
    Company company = (Company)Session["company"];
    List<int> store = new MDB().InvStoreUsers.Where(x => x.CompNo == company.comp_num && x.UserID == me.UserID && x.AllPerm == true).Select(o => o.StoreNo).ToList();
    List<Ord_OrdReceiptHF> OrdRecHF = new MDB().Ord_OrdReceiptHF.Where(x => x.CompNo == company.comp_num && x.OrderYear == OrdYear
&& x.OrderNo == OrderNo && x.TawreedNo == TawreedNo && x.ShipSer == ShipSer && store.Contains(x.StoreNo.Value)).ToList();
    int Srial = 1;
}


<style>
    tr.details {
        max-height: 0 !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    tr.details {
        background-color: gray !important;
        border-style: solid !important;
    }
</style>

<div id="OrdReceiptTable_@srl">
    <div style="width: 100%; padding: 1px; background: #fff !important ">
        <table class="table table-hover" id="OrdReceiptTable_@srl" style="background:lightgray;width:100%">
            <thead>
                <tr>
                    <th style="word-wrap: break-word; white-space: normal; width: 10%; text-align: center;">@Html.Recource(3229)</th>
                    <th style="word-wrap: break-word; white-space: normal; width: 10%; text-align: center;">@Html.Recource(3230)</th>
                    <th style="width: 10%; text-align: center;">@Html.Recource(696)</th>
                    <th style=" width: 15%; text-align: center;">@Html.Translate("مورد النقل", "Transport Vendor")</th>
                    <th style="width: 15%; text-align: center;">@Html.Recource(1)</th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (Ord_OrdReceiptHF item in OrdRecHF)
                {
                    Ord_OrdReceiptDF df = new MDB().Ord_OrdReceiptDF.Where(x => x.CompNo == company.comp_num && x.OrderYear == item.OrderYear && x.OrderNo == item.OrderNo
                    && x.TawreedNo == item.TawreedNo && x.ShipSer == item.ShipSer && x.RecNo == item.RecNo).FirstOrDefault();

                    Vendor Vend = new MDB().Vendors.Where(x => x.comp == company.comp_num && x.VendorNo == item.VendorNo).FirstOrDefault();
                    InvStoresMF StoreM = new MDB().InvStoresMFs.Where(x => x.CompNo == item.CompNo && x.StoreNo == item.StoreNo).FirstOrDefault();
                    string hult = Vend.IsHalt.Value.ToString();
                    if (df.RecQty == null || df.RecQty == 0)
                    {
                        <tr id="OrdRecHF_@Srial">
                            <td style="word-wrap: break-word; white-space: normal; width: 10%; text-align: center;" id="OrdRecHF_RecNo_@Srial">@item.RecNo</td>
                            <td style="word-wrap: break-word; white-space: normal; width: 10%; text-align: center;" id="OrdRecHF_ReceiptDate_@Srial">@item.RecDate.Value.ToString("yyyy-MM-dd")</td>
                            <td style="direction: ltr; width: 10%; text-align: center;" id="OrdRecHF_ShipSer_@Srial">@item.ShipSer</td>
                            <td style="width: 15%; text-align: center; word-wrap: break-word; white-space: normal; " id="ShipmentsInfo_Vendor_@Srial">@Html.Translate(Vend.Name, Vend.Eng_Name)</td>
                            <td style="width: 15%; text-align: center; word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_Stores_@Srial">@Html.Translate(StoreM.StoreName, StoreM.StoreNameEng)</td>
                            <td style="color: red; word-wrap: break-word; white-space: normal; width: 20%; text-align: center;">@Html.Translate("لم يتم إدخال بيانات الاستلام الفعلي", "The actual receipt data has not been entered")</td>
                            <td>

                                @if (item.IsApproval == false)
                                {
                                    <button onclick="EditOrdReceipt('@item.OrderYear', '@item.OrderNo', '@item.TawreedNo', '@item.ShipSer', '@item.RecNo', '@hult')" type="button" class="btn btn-ed ex" title=" @Html.Translate("تعديل محضر استلام", "Edit Order Receipt")">
                                        <i class="fa fa-pencil-alt"></i>
                                    </button>
                                    <button id="eOrdReceipt" class="btn btn-primary btn-block" href="" target="_blank" style="display:none;">
                                        @Html.Translate("تعديل محضر استلام", "Edit Order Receipt")
                                    </button>
                                    <button class="btn-de" onclick="DeleteOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo','@hult')">
                                        <i class="fa fa-trash-alt" aria-hidden="true"></i>
                                    </button>
                                    <button class="btn btn-primary ex" title="ترحيل" onclick="PostedOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo','@hult')" disabled>
                                        <i style="font-weight:100" class="fa fa-folder"></i>
                                        @Html.Translate("ترحيل", "Posted")
                                    </button>
                                    <button class="btn btn-default ex" title="عرض" href="/OrdReceipt/ViewOrdReceipt?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer&RecNo=@item.RecNo" disabled target="_blank">
                                        <i style="font-weight:100" class="fa fa-folder"></i>
                                        @Html.Translate("عرض", "View")
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-ed ex" href="/OrdReceipt/EditOrdReceipt?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer&RecNo=@item.RecNo" disabled target="_blank">
                                        <i class="fa fa-pencil-alt"></i>
                                    </button>
                                    <button class="btn-de" onclick="DeleteOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo', '@hult')" disabled>
                                        <i class="fa fa-trash-alt" aria-hidden="true"></i>
                                    </button>
                                    <button class="btn btn-primary ex" title="ترحيل" onclick="PostedOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo', '@hult')" disabled>
                                        <i style="font-weight:100" class="fa fa-folder"></i>
                                        @Html.Translate("ترحيل", "Posted")
                                    </button>
                                    <button class="btn btn-default ex" title="عرض" href="/OrdReceipt/ViewOrdReceipt?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer&RecNo=@item.RecNo" target="_blank">
                                        <i style="font-weight:100" class="fa fa-folder"></i>
                                        @Html.Translate("عرض", "View")
                                    </button>
                                }

                                <input type="hidden" id="InputSerial" value="@(Srial++)" />
                            </td>
                        </tr>
                    }
                    else
                    {
            <tr id="OrdRecHF_@Srial" style="background-color:greenyellow !important;">
                <td style="word-wrap: break-word; white-space: normal; width: 10%; text-align: center;" id="OrdRecHF_RecNo_@Srial">@item.RecNo</td>
                <td  style="word-wrap: break-word; white-space: normal; width: 10%; text-align: center;" id="OrdRecHF_ReceiptDate_@Srial">@item.RecDate.Value.ToString("yyyy-MM-dd")</td>
                <td style="direction: ltr; width: 10%; text-align: center;" id="OrdRecHF_ShipSer_@Srial">@item.ShipSer</td>
                <td style="width: 15%; text-align: center; word-wrap: break-word; white-space: normal; " id="OrdRecHF_Vendor_@Srial">@Html.Translate(Vend.Name, Vend.Eng_Name)</td>
                <td style="width: 15%; text-align: center; word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_Stores_@Srial">@Html.Translate(StoreM.StoreName, StoreM.StoreNameEng)</td>
                <td style="color: green; word-wrap: break-word; white-space: normal; width: 20%; text-align: center; ">@Html.Translate("تم إدخال بيانات الاستلام الفعلي", "Actual receipt data has been entered")</td>
                <td>

                    @if (item.IsApproval == false && (df.RecQty != null && df.RecQty != 0))
                    {
                        <button onclick="EditOrdReceipt('@item.OrderYear', '@item.OrderNo', '@item.TawreedNo', '@item.ShipSer', '@item.RecNo', '@hult')" type="button" class="btn btn-ed ex" title=" @Html.Translate("تعديل محضر استلام", "Edit Order Receipt")">
                            <i class="fa fa-pencil-alt"></i>
                        </button>
                        <button id="eOrdReceipt" class="btn btn-primary btn-block" href="" target="_blank" style="display:none;">
                            @Html.Translate("تعديل محضر استلام", "Edit Order Receipt")
                        </button>
                        <button class="btn-de" onclick="DeleteOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo', '@hult')">
                            <i class="fa fa-trash-alt" aria-hidden="true"></i>
                        </button>
                        <button class="btn btn-primary ex" title="ترحيل" onclick="PostedOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo', '@hult')">
                            <i style="font-weight:100" class="fa fa-folder"></i>
                            @Html.Translate("ترحيل", "Posted")
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-ed ex" href="/OrdReceipt/EditOrdReceipt?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer&RecNo=@item.RecNo" disabled target="_blank">
                            <i class="fa fa-pencil-alt"></i>
                        </button>
                        <button class="btn-de" onclick="DeleteOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo', '@hult')" disabled>
                            <i class="fa fa-trash-alt" aria-hidden="true"></i>
                        </button>
                        <button class="btn btn-primary ex" title="ترحيل" onclick="PostedOrdReceipt('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer','@item.RecNo', '@hult')" disabled>
                            <i style="font-weight:100" class="fa fa-folder"></i>
                            @Html.Translate("ترحيل", "Posted")
                        </button>
                    }
                    <button class="btn btn-default ex" title="عرض" href="/OrdReceipt/ViewOrdReceipt?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer&RecNo=@item.RecNo" target="_blank">
                        <i style="font-weight:100" class="fa fa-folder"></i>
                        @Html.Translate("عرض", "View")
                    </button>
                    <input type="hidden" id="InputSerial" value="@(Srial++)" />
                </td>
            </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function EditOrdReceipt(OrdYear, OrdNo, TawreedNo, ShipSer, RecNo, IsHalt) {
        if (IsHalt == "True") {
            alert('@Html.Translate("لا يمكن التعديل المورد موقوف", "Cannot edit vendor suspended")');
            return false;
        }
        $('#eOrdReceipt').attr("href", '/OrdReceipt/EditOrdReceipt?OrdYear=' + OrdYear + '&OrderNo=' + OrdNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer + '&RecNo=' + RecNo +  '')
        $('#eOrdReceipt').click();
    }
</script>


