<script>
    $('#Ord_vOrdReceipt_CboVendorNo').select2();
    $('#Ord_vOrdReceipt_CboStoreNo').select2();

    $('#Ord_vOrdReceipt_CboCurrCode').select2();
    $('#Ord_vOrdReceipt_CboDocType').select2();

    SumTotalQty()
    function SumTotalQty() {
        var table = $('#vOrdRecDFTBody tr');
        var trs = table;
        var vTotalPortQty1 = 0
        var vTotalPortQty2 = 0
        var vTotalRecQty1 = 0
        var vTotalRecQty2 = 0
        var vTotalCantTransport = 0
        var vTotalShortage = 0
        var vTotallostQty = 0
        var vTotalWeightBreaker = 0


        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            vTotalPortQty1 += Number($(trs[i]).closest('tr').find('#vOrdRec_Qty_' + InputSerial)[0].value);
            vTotalPortQty2 += Number($(trs[i]).closest('tr').find('#vOrdRec_Qty2_' + InputSerial)[0].value);

            vTotalRecQty1 += Number($(trs[i]).closest('tr').find('#vOrdRec_RecQty_' + InputSerial)[0].value);
            vTotalRecQty2 += Number($(trs[i]).closest('tr').find('#vOrdRec_RecQty2_' + InputSerial)[0].value);

            $(trs[i]).closest('tr').find('#vOrdRec_lostQty_' + InputSerial)[0].value = Number($(trs[i]).closest('tr').find('#vOrdRec_Qty2_' + InputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#vOrdRec_RecQty2_' + InputSerial)[0].value)

            vTotalCantTransport += Number($(trs[i]).closest('tr').find('#vOrdRec_CantTransport_' + InputSerial)[0].value);
            vTotalShortage += Number($(trs[i]).closest('tr').find('#vOrdRec_Shortage_' + InputSerial)[0].value);
            vTotallostQty += Number($(trs[i]).closest('tr').find('#vOrdRec_lostQty_' + InputSerial)[0].value);
            vTotalWeightBreaker += Number($(trs[i]).closest('tr').find('#vOrdRec_WeightBreaker_' + InputSerial)[0].value);

        }

        $('#vTotalPortQty1').html(Number(vTotalPortQty1).toFixed(3));
        $('#vTotalPortQty2').html(Number(vTotalPortQty2).toFixed(3));

        $('#vTotalRecQty1').html(Number(vTotalRecQty1).toFixed(3));
        $('#vTotalRecQty2').html(Number(vTotalRecQty2).toFixed(3));

        $('#vTotalCantTransport').html(Number(vTotalCantTransport).toFixed(3));
        $('#vTotalShortage').html(Number(vTotalShortage).toFixed(3));
        $('#vTotallostQty').html(Number(vTotallostQty).toFixed(3));
        $('#vTotalWeightBreaker').html(Number(vTotalWeightBreaker).toFixed(3));
    }
</script>