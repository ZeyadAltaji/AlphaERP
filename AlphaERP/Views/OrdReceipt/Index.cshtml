<script>
    $('#Model_OrdReceip').draggable({
        handle: ".modal-header",
    });

    function Checkyear() {
        if (OrdReceipt_OrdYear.value < 2000) {
            OrdReceipt_OrdYear.value = "@DateTime.Now.Year"
            OrdReceipt_OrdYear.focus();
        }
    }

    function SerachOrdReceipt() {
        Ord_OrdReceiptDiv.innerHTML = "";
        $('#Ord_OrdReceiptDiv').load('../../../OrdReceipt/OrdReceiptList?OrdYear=' + OrdReceipt_OrdYear.value );
    }

    function SelectionOrdReceiptInfo(OrdYear, OrderNo, TawreedNo, ShipSer) {
        wait();
        burn({ OrdYear: OrdYear, OrderNo: OrderNo, TawreedNo: TawreedNo, ShipSer: ShipSer }, '../../../OrdReceipt/ChooseOrdReceipt', '', LoadChooseOrdReceipt, true);
    }
    function LoadChooseOrdReceipt(r) {
        Ord_OrdReceiptDiv.innerHTML = "";
        $('#Ord_OrdReceiptDiv').html(r);
        $('#Model_OrdReceip').modal('hide');
        done();
    }

    var _OrdYear = 0;
    var _OrderNo = 0;
    var _TawreedNo = 0;
    var _ShipSer = 0;

    function DeleteOrdReceipt(OrdYear, OrderNo, TawreedNo, ShipSer, RecNo, IsHalt) {
        if (IsHalt == "True") {
            alert('@Html.Translate("لا يمكن التعديل المورد موقوف", "Cannot edit vendor suspended")');
            return false;
        }
        if (confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            _OrdYear = OrdYear;
            _OrderNo = OrderNo;
            _TawreedNo = TawreedNo;
            _ShipSer = ShipSer;
            burn({ OrdYear: OrdYear, OrderNo: OrderNo, TawreedNo: TawreedNo, ShipSer: ShipSer, RecNo: RecNo }, '../../../OrdReceipt/Del_OrdReceipt', '', ReloadDelOrdReceiptInfo, false);
        }
    }
    function ReloadDelOrdReceiptInfo() {
        MsgBox('@Html.Recource(2598)', 'red');
        $('#Ord_OrdReceiptInfoTBody').empty();
        var table = $("#OrdReceiptTable tbody");
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == _OrdYear && $(trs[i])[0].getAttribute('OrderNo') == _OrderNo && $(trs[i])[0].getAttribute('TawreedNo') == _TawreedNo && $(trs[i])[0].getAttribute('ShipSer') == _ShipSer) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = _OrdYear;
                var OrderNo = _OrderNo;
                var TawreedNo = _TawreedNo;
                var ShipSer = _ShipSer;

                $.get("../../../../OrdReceipt/DetailsOrdReceipt?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer, function (data) {
                    OrdReceiptTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }


    function PostedOrdReceipt(OrdYear, OrderNo, TawreedNo, ShipSer, RecNo, IsHalt) {
         if (IsHalt == "True") {
            alert('@Html.Translate("لا يمكن التعديل المورد موقوف", "Cannot edit vendor suspended")');
            return false;
        }
        if (confirm('@Resources.Resource.ApprovalVoucIssue')) {
            _OrdYear = OrdYear;
            _OrderNo = OrderNo;
            _TawreedNo = TawreedNo;
            _ShipSer = ShipSer;

            burn({ OrdYear: OrdYear, OrderNo: OrderNo, TawreedNo: TawreedNo, ShipSer: ShipSer, RecNo: RecNo }, '../../../OrdReceipt/Posted_OrdReceipt', '', ReloadPostedOrdReceiptInfo, false);
        }
    }
    function ReloadPostedOrdReceiptInfo() {
        MsgBox('@Html.Recource(475)', 'green');
        $('#Ord_OrdReceiptInfoTBody').empty();
        var table = $("#OrdReceiptTable tbody");
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == _OrdYear && $(trs[i])[0].getAttribute('OrderNo') == _OrderNo && $(trs[i])[0].getAttribute('TawreedNo') == _TawreedNo && $(trs[i])[0].getAttribute('ShipSer') == _ShipSer) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = _OrdYear;
                var OrderNo = _OrderNo;
                var TawreedNo = _TawreedNo;
                var ShipSer = _ShipSer;

                $.get("../../../../OrdReceipt/DetailsOrdReceipt?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer, function (data) {
                    OrdReceiptTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }

</script>

