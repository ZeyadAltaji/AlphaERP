    SumTotalQty(@RecNo)
    function SumTotalQty(id) {
        var table = $("#eOrdRecDFTBody_" + id);
        var trs = table.find('tr');

        var eTotalPortQty1 = 0;
        var eTotalPortQty2 = 0;
        var eTotalRecQty1 = 0;
        var eTotalRecQty2 = 0;
        var eTotalCantTransport = 0;
        var eTotalShortage = 0;
        var eTotallostQty = 0;
        var eTotalWeightBreaker = 0;
        var eWeightBreaker = 0;

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            eTotalPortQty1 += Number($(trs[i]).closest('tr').find('#eOrdRec_Qty_' + InputSerial)[0].value);
            eTotalPortQty2 += Number($(trs[i]).closest('tr').find('#eOrdRec_Qty2_' + InputSerial)[0].value);

            eTotalRecQty1 += Number($(trs[i]).closest('tr').find('#eOrdRec_RecQty_' + InputSerial)[0].value);
            eTotalRecQty2 += Number($(trs[i]).closest('tr').find('#eOrdRec_RecQty2_' + InputSerial)[0].value);

            $(trs[i]).closest('tr').find('#eOrdRec_lostQty_' + InputSerial)[0].value = Number($(trs[i]).closest('tr').find('#eOrdRec_Qty2_' + InputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#eOrdRec_RecQty2_' + InputSerial)[0].value)
            if (Number($(trs[i]).closest('tr').find('#eOrdRec_RecQty2_' + InputSerial)[0].value) != 0) {
                eWeightBreaker = Number($(trs[i]).closest('tr').find('#eOrdRec_RecQty2_' + InputSerial)[0].value) / Number($(trs[i]).closest('tr').find('#eOrdRec_RecQty_' + InputSerial)[0].value);
            }
            else {
                eWeightBreaker = 0;
            }
            $(trs[i]).closest('tr').find('#eOrdRec_WeightBreaker_' + InputSerial)[0].value = Number(eWeightBreaker).toFixed(3);

            eTotalCantTransport += Number($(trs[i]).closest('tr').find('#eOrdRec_CantTransport_' + InputSerial)[0].value);
            eTotalShortage += Number($(trs[i]).closest('tr').find('#eOrdRec_Shortage_' + InputSerial)[0].value);
            eTotallostQty += Number($(trs[i]).closest('tr').find('#eOrdRec_lostQty_' + InputSerial)[0].value);
            eTotalWeightBreaker += Number($(trs[i]).closest('tr').find('#eOrdRec_WeightBreaker_' + InputSerial)[0].value);

        }

        $('#eTotalPortQty1_'+ id).html(Number(eTotalPortQty1).toFixed(3));
        $('#eTotalPortQty2_'+ id).html(Number(eTotalPortQty2).toFixed(3));

        $('#eTotalRecQty1_' + id).html(Number(eTotalRecQty1).toFixed(3));
        $('#eTotalRecQty2_' + id).html(Number(eTotalRecQty2).toFixed(3));

        $('#eTotalCantTransport_' + id).html(Number(eTotalCantTransport).toFixed(3));
        $('#eTotalShortage_' + id).html(Number(eTotalShortage).toFixed(3));
        $('#eTotallostQty_' + id).html(Number(eTotallostQty).toFixed(3));
        $('#eTotalWeightBreaker_' + id).html(Number(eTotalWeightBreaker).toFixed(3));
    }
