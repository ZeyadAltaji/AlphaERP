    function ExcuteSave_OrdReceiptInfo(id) {

        var table = $("#OrdRecDFTBody_" + id);
        var trs = table.find('tr');


        var OrdReceiptHF = {
            CompNo: '@company.comp_num',
            OrderYear: $('#Ord_OrdReceipt_OrdYear_' + id).val(),
            OrderNo: $('#Ord_OrdReceipt_OrderNo_' + id).val(),
            TawreedNo: $('#Ord_OrdReceipt_TawreedNo_' + id).val(),
            ShipSer: $('#Ord_OrdReceipt_ShipSer_' + id).val(),
            RecNo: 0,
            RecDate: $('#Ord_OrdReceipt_RecDate_' + id).val(),
            CarNo: $('#Ord_OrdReceipt_CarNo_' + id).val(),
            DriverName: $('#Ord_OrdReceipt_DriverName_' + id).val(),
            VendorNo: $('#Ord_OrdReceipt_CboVendorNo_' + id).val(),
            StoreNo: $('#Ord_OrdReceipt_CboStoreNo_' + id).val(),
            Notes: $('#Ord_OrdReceipt_Notes_' + id).val(),
        }

        var OrdReceiptDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            if ($(trs[i]).closest('tr').find('#OrdRec_Qty_' + InputSerial)[0].value > 0) {
                OrdReceiptDF.push({
                    CompNo: '@company.comp_num',
                    OrderYear: $('#Ord_OrdReceipt_OrdYear_' + id).val(),
                    OrderNo: $('#Ord_OrdReceipt_OrderNo_' + id).val(),
                    TawreedNo: $('#Ord_OrdReceipt_TawreedNo_' + id).val(),
                    ShipSer: $('#Ord_OrdReceipt_ShipSer_' + id).val(),
                    RecNo : 0,
                    ItemNo: $(trs[i]).closest('tr').find('#OrdRec_ItemNo')[0].innerHTML,
                    PortQty: $(trs[i]).closest('tr').find('#OrdRec_Qty_' + InputSerial)[0].value,
                    PortTUnit: $(trs[i]).closest('tr').find('.OrdRec_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                    PortUnitSerial: $(trs[i]).closest('tr').find('.OrdRec_ItemNo_Unit')[0].value,
                    PortQty2: $(trs[i]).closest('tr').find('#OrdRec_Qty2_' + InputSerial)[0].value,
                    RecQty: 0,
                    RecQty2:0,
                    CantTransport: 0,
                    Shortage: 0,
                    lostQty: 0,
                    WeightBreaker: 0,
                })
            }
        }

        if (OrdReceiptDF.length == 0) {
            alert('@Html.Translate("يجب إدخال الكميات", "Quantities must be entered")');
            return false;
        }

        var DocumentArchivetable = $("#OrdReceipt_DocumentArchiveTbody_" + id);
        var trsDocumentArchive = DocumentArchivetable.find('tr');

        var DocumentArchive = new Array();

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#OrdReceipt_DocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                OrderYear: $('#Ord_OrdReceipt_OrdYear_' + id).val(),
                OrderNo: $('#Ord_OrdReceipt_OrderNo_' + id).val(),
                TawreedNo: $('#Ord_OrdReceipt_TawreedNo_' + id).val(),
                ShipSer: $('#Ord_OrdReceipt_ShipSer_' + id).val(),
                RecNo: 0,
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#OrdReceipt_DocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#OrdReceipt_DocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#OrdReceipt_DocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ OrdReceiptHF: OrdReceiptHF, OrdReceiptDF: OrdReceiptDF, FileArchive: DocumentArchive }, '../../../OrdReceipt/Save_OrdReceipt', '', ReloadOrdReceiptInfo, false);
    }
    function ReloadOrdReceiptInfo(r) {
        done();
