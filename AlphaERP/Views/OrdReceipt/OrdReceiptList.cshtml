    function CreateOrdReceipt(OrdYear, OrdNo, TawreedNo, ShipSer) {
        $('#AddOrdReceipt').attr("href", '/OrdReceipt/AddOrdReceipt?OrdYear=' + OrdYear + '&OrderNo=' + OrdNo + '&TawreedNo=' + TawreedNo +  '&ShipSer=' + ShipSer + '')
        $('#AddOrdReceipt').click();
    }

    function SelectOrdReceipt(e) {
        var table = $('#OrdReceiptTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function SelectionOrdReceiptDiv() {
        var table = $('#OrdReceiptTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');

        if (trs.length == 0) {
            MsgBox('@Resources.Resource.NoPurchaseOrderWasChosen', 'red');
            done();
            return false
        }

        var OrdYear = trs[0].getAttribute('OrdYear');
        var OrderNo = trs[0].getAttribute('OrderNo');
        var TawreedNo = trs[0].getAttribute('TawreedNo');
        var ShipSer = trs[0].getAttribute('ShipSer');

        SelectionOrdReceiptInfo(OrdYear, OrderNo, TawreedNo, ShipSer);
    }
</script>






