                                @{
                                    foreach (var item in GLDEPMF)
                                    {
                                        <tr onclick="Select_efinGLDEPMFs(this)" ondblclick="Select_eGLDEPMFs(this)" DEP_NUM="@item.DEP_NUM" DepDesc="@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()">
                                            <td style="width: 20%;" id="ePurchOrder_DEPNUM">@item.DEP_NUM</td>
                                            <td style="width: 55%;" id="ePurchOrder_DEPNAME">@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()</td>
                                            <td></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Selecting_eOrdPO_GLDEPMFs('@TawreedNo')" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    var Serial = 0;
    var deptId = 0;
    var GLDEPMFs = $('#Select_eOrd_GLDEPMFsTable_' + @TawreedNo).DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    function Serach_eDept(Id) {
        Serial = Id;
        var table = $("#Select_eOrd_GLDEPMFsTable_" + Id);
        table.find('tr').removeClass("selected");

        $('#Model_eOrdPO_GLDEPMFs_' + Id).draggable({
            handle: ".modal-header",
        });

        $('#Model_eOrdPO_GLDEPMFs_' + Id).modal('show');
    }
    function Select_efinGLDEPMFs(e) {
        var table = $('#Select_eOrd_GLDEPMFsTable_' + Serial);
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Select_eGLDEPMFs(e) {
        $('#Ord_ePurchaseOrder_DeptNo_' + Serial).val(e.getAttribute('DEP_NUM'));
        $('#Ord_ePurchaseOrder_DeptName_' + Serial).val(e.getAttribute('DepDesc'));

        $('#Ord_ePurchaseOrder_OldDeptNo_' + Serial).val(e.getAttribute('DEP_NUM'));

        $('#Ord_ePurchaseOrder_VendorNo_' + Serial).val(null)
        $('#Ord_ePurchaseOrder_VendorName_' + Serial).val(null)
        $('#Ord_ePurchaseOrder_VendorAddress_' + Serial).val(null);

        $('#Model_eOrdPO_GLDEPMFs_' + Serial).modal('hide');
    }
    function Selecting_eOrdPO_GLDEPMFs() {
        var table = $('#Select_eOrd_GLDEPMFsTable_' + Serial);
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار دائرة", "Select one Dept")');
            return;
        }

        $('#Ord_ePurchaseOrder_DeptNo_' + Serial).val(trs[0].getAttribute('DEP_NUM'));
        $('#Ord_ePurchaseOrder_DeptName_' + Serial).val(trs[0].getAttribute('DepDesc'));

        $('#Ord_ePurchaseOrder_OldDeptNo_' + Serial).val(trs[0].getAttribute('DEP_NUM'));
        $('#Ord_ePurchaseOrder_VendorNo_' + Serial).val(null)
        $('#Ord_ePurchaseOrder_VendorName_' + Serial).val(null)

        $('#Model_eOrdPO_GLDEPMFs_' + Serial).modal('hide');
    }
    function GetDeptName(e, id) {
        Serial = id;
        if (CheckValue('Ord_ePurchaseOrder_DeptNo_' + id)) {
            $('#Ord_ePurchaseOrder_DeptNo_' + id).val(null);
            $('#Ord_ePurchaseOrder_DeptName_' + id).val(null);
            $('#Ord_ePurchaseOrder_VendorNo_' + id).val(null);
            $('#Ord_ePurchaseOrder_VendorName_' + id).val(null);
            $('#Ord_ePurchaseOrder_VendorAddress_' + id).val(null);
            return;
        }

        Serial = id;
        if ($('#Ord_ePurchaseOrder_OldDeptNo_' + id).val() != e) {
            $('#Ord_ePurchaseOrder_OldDeptNo_' + id).val(e);
            burn({ DeptNo: e }, '../../../PurchaseOrder/GetDeptName', '', LoadDeptName, true);
        }
    }
    function LoadDeptName(r) {
        if (r.DeptName == "") {
            $('#Ord_ePurchaseOrder_DeptNo_' + Serial).val(null);
            $('#Ord_ePurchaseOrder_DeptName_' + Serial).val(null);
        }
        else {
            $('#Ord_ePurchaseOrder_DeptName_' + Serial).val(r.DeptName);
        }
        $('#Ord_ePurchaseOrder_VendorNo_' + Serial).val(null)
        $('#Ord_ePurchaseOrder_VendorName_' + Serial).val(null)
        $('#Ord_ePurchaseOrder_VendorAddress_' + Serial).val(null);
    }
</script>
