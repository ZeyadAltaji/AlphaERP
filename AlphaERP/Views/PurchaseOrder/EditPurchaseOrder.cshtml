        var table = $("#ePODocumentArchiveTbody_" + Id);
        var trs = table.find('tr');
        Count = trs.length;
    }
    function AddePODocumentArchive(Id) {
        var table = $("#ePODocumentArchiveTbody_" + Id);
        Count++;
        var newarray = [];
        newarray.push('<input id="Ord_ePurchaseOrder_FileId" type="hidden" value="' + Count + '" />')
        newarray.push('<input id="Ord_ePurchaseOrder_Description_' + Count + '" type="text" style="width: 115px !important;text-align: center !important" />')
        newarray.push('<div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="Ord_ePurchaseOrder_File_' + Count + '" onchange="uploadFile(this,' + Count + ',' + Id + ')" /></div>')
        newarray.push('')
        newarray.push('<a id="Ord_ePurchaseOrder_AddDownloadFile_' + Count + '" onclick="DownloadFile()"><span class="glyphicon glyphicon-download"></span></a>')
        newarray.push('<input id="Ord_ePurchaseOrder_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="Ord_ePurchaseOrder_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="Ord_ePurchaseOrder_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="Ord_ePurchaseOrder_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ',' + Id + ')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $(table).append(
            GenRowDocumentArchive(newarray, 'ePODocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        var $td = $(ID).closest("td");
        $($td).find("input[type=file]").click();
    }
    function uploadFile(Elem, Count, Id) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;

        var table = $("#ePODocumentArchiveTbody_" + Id);
        var tr = table.find('#ePODocumentArchive_' + Count);

        var fileName = tr.find("#Ord_ePurchaseOrder_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        tr.find('#Ord_ePurchaseOrder_FileName_' + Count)[0].value = fileName;
        tr.find('#Ord_ePurchaseOrder_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#Ord_ePurchaseOrder_FileSize_' + Count)[0].value = file_size;
        tr.find('#Ord_ePurchaseOrder_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }

            var OrderYear = $('#Ord_ePurchaseOrder_OrdYear_' + Id).val();
            var OrderNo = $('#Ord_ePurchaseOrder_OrdNo_' + Id).val();
            var TawreedNo = $('#Ord_ePurchaseOrder_TawreedNo_' + Id).val();

            $formData.append('Id', Count);
            $formData.append('Ordyear', OrderYear);
            $formData.append('OrdNo', OrderNo);
            $formData.append('TawreedNo', TawreedNo);
        }

        $.ajax({
            url: '@Url.Action("InsertFile", "PurchaseOrder")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function (r) {
                var table = $("#ePODocumentArchiveTbody_" + Id);
                var tr = table.find('#ePODocumentArchive_' + Count);
                tr.find('#Ord_ePurchaseOrder_AddDownloadFile_' + Count)[0].setAttribute('onclick', 'DownloadFile("' + fileName + '","' + r + '")')
            },
            error: function (error) {

            }
        });
    }
    function RemoveRowUpload(e, Count, Id) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            var OrderYear = $('#Ord_ePurchaseOrder_OrdYear_' + Id).val();
            var OrderNo = $('#Ord_ePurchaseOrder_OrdNo_' + Id).val();
            var TawreedNo = $('#Ord_ePurchaseOrder_TawreedNo_' + Id).val();

            $.ajax({
                type: "POST",
                url:'@Url.Action("RemoveFile", "PurchaseOrder")',
                data: { Id: Count, Ordyear: OrderYear, OrdNo: OrderNo, TawreedNo: TawreedNo },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function SaveePODocumentArchive(Id) {
        $('#Model_ePODocumentsArchive_' + Id).modal('hide');
    }
</script>
@*--------------------------------END Model Documents -----------------------------*@


