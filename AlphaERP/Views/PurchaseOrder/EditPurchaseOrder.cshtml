        else{
            $('#Ord_ePurchaseOrder_IsLC_' + Serial).attr("disabled", false);
            $('#Ord_ePurchaseOrder_IsLC_' + Serial)[0].checked = false
        }
    }

    function sumPersTotal(val) {
        if (val == 0) {
            var TotDiscPer = (Number($('#Ord_ePO_DisPersTotal_' + SerialId).val()) / 100) * ($('#Ord_ePO_Amount_' + SerialId).val() - $('#Ord_ePO_Discount_' + SerialId).val());
            $('#Ord_ePO_DisTotal_' + SerialId).val(Number(TotDiscPer));
        }
        else {
            var TotDiscPer = (Number($('#Ord_ePO_DisTotal_' + SerialId).val()) / ($('#Ord_ePO_Amount_' + SerialId).val() - $('#Ord_ePO_Discount_' + SerialId).val())) * 100;
            $('#Ord_ePO_DisPersTotal_' + SerialId).val(Number(TotDiscPer).toFixed(3));
        }
        sumTotalAll(SerialId)
    }

    sumTotalAll('@TawreedNo')
    function sumTotalAll(Id) {
        var table = $("#ePOItemTBody_" + Id);
        var trs = table.find('tr');

        var itemTotal = 0;
        var itemTotalqty = 0;
        var totalAmount = 0;
        var vouDiscountPer = Number($('#Ord_ePO_DisPersTotal_' + Id).val()) / 100;
        var vouDiscountPerItem = 0;
        var itemDiscVal = 0;
        var totalDiscVal = 0;
        var ItemTaxVal = 0;
        var totalTaxVal = 0;
        var TotalNetAmount = 0;
        var Total = 0;
        var FreightCost = 0;
        var ExtraExp = 0;
        var Totals = 0

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value
            itemTotalqty += Number($(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, ''));
            itemTotal = Number($(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, ''));
            itemDiscVal = (Number($(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_DiscPer_' + InputSerial)[0].value.replace(/,/g, ''))) / 100;
            vouDiscountPerItem = (Number(itemTotal) - Number(itemDiscVal)) * Number(vouDiscountPer);
            ItemTaxVal = (Number($(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, '')) - Number(itemDiscVal) - Number(vouDiscountPerItem)) * (Number($(trs[i]).closest('tr').find('#ePODF_STax_Perc_' + InputSerial)[0].value.replace(/,/g, '')) / 100);
            totalAmount += Number(itemTotal)
            totalDiscVal += Number(itemDiscVal);
            totalTaxVal += Number(ItemTaxVal);
            Total = (Number(itemTotal).toFixed(3) - Number(vouDiscountPerItem).toFixed(3) - Number(itemDiscVal).toFixed(3));
            $(trs[i]).closest('tr').find('#ePODF_Total_' + InputSerial)[0].innerHTML = Number(Total).toFixed(3)
            TotalNetAmount += Number($(trs[i]).closest('tr').find('#ePODF_Total_' + InputSerial)[0].innerHTML);
        }

        FreightCost = Number($('#Ord_ePO_FreightCost_' + Id).val());
        ExtraExp = Number($('#Ord_ePO_ExtraExp_' + Id).val());

        TotalNetAmount = Number(TotalNetAmount) + Number(totalTaxVal) + Number(FreightCost) + Number(ExtraExp);
        $('#Ord_ePO_Amount_' + Id).val(Number(totalAmount).toFixed(3));
        $('#Ord_ePO_Discount_' + Id).val(Number(totalDiscVal).toFixed(3));
        $('#Ord_ePO_TaxAmount_' + Id).val(Number(totalTaxVal).toFixed(3));
        $('#Ord_ePO_TotalQty_' + Id).val(Number(itemTotalqty).toFixed(3));
        $('#Ord_ePO_NetAmount_' + Id).val(Number(TotalNetAmount).toFixed(3));

        var TotDiscPer = (Number($('#Ord_ePO_DisPersTotal_' + Id).val()) / 100) * ($('#Ord_ePO_Amount_' + Id).val() - $('#Ord_ePO_Discount_' + Id).val());

        $('#Ord_ePO_DisTotal_' + Id).val(Number(TotDiscPer).toFixed(3));
    }


    function CheckValueGrid(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt == 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
        else {
            if (Amt == '' || Amt == null) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function CheckValueGridTotlal(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt <= 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function ExcuteEdit_PurchOrd(id) {

        if ($('#Ord_ePurchaseOrder_DeptNo_' + id).val() == "") {
            alert('@Html.Translate("يجب إدخال الدائرة", "You Must Enter Dept")');
            return;
        }

        if ($('#Ord_ePurchaseOrder_VendorNo_' + id).val() == "") {
            alert('@Html.Translate("يجب إدخال المورد", "You Must Enter Vendor")');
            return;
        }
        var table = $("#ePOItemTBody_" + id);
        var trs = table.find('tr');

        if (trs.length == 0) {
            alert('@Html.Translate("يجب إدخال مواد الشراء", "Raw Item P.O must be entered")');
            return false;
        }

        var OrdHF = {
            CompNo: '@company.comp_num',
            OrdYear: $('#Ord_ePurchaseOrder_OrdYear_' + id).val(),
            OrderNo: $('#Ord_ePurchaseOrder_OrdNo_' + id).val(),
            TawreedNo: $('#Ord_ePurchaseOrder_TawreedNo_' + id).val(),
            OfferNo: 0,
            Vend_Dept: $('#Ord_ePurchaseOrder_DeptNo_' + id).val(),
            VendorNo: $('#Ord_ePurchaseOrder_VendorNo_' + id).val(),
            EnterDate: '@DateTime.Now.ToShortDateString()',
            ExpShDate: $('#Ord_ePurchaseOrder_ETDate_' + id).val(),
            ConfDate: $('#Ord_ePurchaseOrder_ConfDate_' + id).val(),
            CurType: $('#Ord_ePurchaseOrder_CboCurrCode_' + id).val(),
            PayWay: $('#Ord_ePurchaseOrder_CboPaymentType_' + id).val(),
            ShipWay: $('#Ord_ePurchaseOrder_CboShipMethod_' + id).val(),
            StoreNo: 0,
            DlvryPlace: $('#Ord_ePurchaseOrder_CboDeliveryPlace_' + id).val(),
            Notes: $('#Ord_ePurchaseOrder_Notes_' + id).val(),
            QutationRef: $('#Ord_ePurchaseOrder_QutationRef_' + id).val(),
            DlvDays: $('#Ord_ePurchaseOrder_DeliveryDays_' + id).val(),
            MainPeriod: $('#Ord_ePurchaseOrder_MaintPeriod_' + id).val(),
            Vou_Tax: $('#Ord_ePO_TaxAmount_' + id).val(),
            Per_Tax: 0,
            TotalAmt: $('#Ord_ePO_Amount_' + id).val(),
            NetAmt: $('#Ord_ePO_NetAmount_' + id).val(),
            OrderClose: false,
            DlvState: 0,
            PInCharge: $('#Ord_ePurchaseOrder_ContactPerson_' + id).val(),
            ApprovalDate: $('#Ord_ePurchaseOrder_ConfDate_' + id).val(),
            UnitKind: 'Each',
            LcDept: 0,
            LcAccNo: 0,
            VouDiscount: $('#Ord_ePO_DisTotal_' + id).val().replace(/,/g, ''),
            PerDiscount: $('#Ord_ePO_DisPersTotal_' + id).val(),
            SourceType: $('#Ord_ePurchaseOrder_CboSupplySource_' + id).val(),
            GenNote: $('#Ord_ePurchaseOrder_RequistionNotes' + id).val(),
            Approved: false,
            ETA: $('#Ord_ePurchaseOrder_ETADate_' + id).val(),
            ShipTerms: $('#Ord_ePurchaseOrder_TermsOfShipment_' + id).val(),
            ContactNo: 0,
            Port: $('#Ord_ePurchaseOrder_DestinationPort_' + id).val(),
            IsLC: $('#Ord_ePurchaseOrder_IsLC_' + id)[0].checked,
            FreightExpense: $('#Ord_ePO_FreightCost_' + id).val(),
            ExtraExpenses: $('#Ord_ePO_ExtraExp_' + id).val(),
            LastCost: 0,
            RefNo: $('#Ord_ePurchaseOrder_RefNo_' + id).val(),
        };

        var OrdDF = new Array();
        var Ord_POAttachments = new Array();
        var DocumentArchive = new Array();

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value)) {
                alert('@Html.Translate("يجب إدخال الكمية", "You Must Enter Qty")');
                return;
            }
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, ''))) {
                alert('@Html.Translate("يجب إدخال السعر", "ou Must Enter Price")');
                return;
            }

            if (CheckValueGridTotlal(1, $(trs[i]).closest('tr').find('#ePODF_Total_' + InputSerial)[0].innerHTML)) {
                alert('@Html.Translate("يجب أن يكون المجموع أكبر من صفر", "The Total Must be Greater Than Zero")');
                return;
            }
            
            if($(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, '') > $(trs[i]).closest('tr').find('#ePODF_OldPrice_' + InputSerial)[0].value.replace(/,/g, '')){
                if (!confirm('@Resources.Resource.ConfirmEditPOPrice')) {
                    return;
                }
            }

            var vouDiscountPer = Number($('#Ord_ePO_DisPersTotal_' + id).val()) / 100;
            var vouDiscountPerItem = 0;
            var itemDiscVal = 0;
            var totalDiscVal = 0;
            var ItemTaxVal = 0;
            var itemTotal = 0;

            itemTotal = Number($(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, ''));
            itemDiscVal = (Number($(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_DiscPer_' + InputSerial)[0].value.replace(/,/g, ''))) / 100;
            vouDiscountPerItem = (Number(itemTotal) - Number(itemDiscVal)) * Number(vouDiscountPer);
            ItemTaxVal = (Number($(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, '')) - Number(itemDiscVal) - Number(vouDiscountPerItem)) * (Number($(trs[i]).closest('tr').find('#ePODF_STax_Perc_' + InputSerial)[0].value.replace(/,/g, '')) / 100);

            OrdDF.push({
                CompNo: '@company.comp_num',
                OrdYear: $('#Ord_ePurchaseOrder_OrdYear_' + id).val(),
                OrderNo: $('#Ord_ePurchaseOrder_OrdNo_' + id).val(),
                TawreedNo: $('#Ord_ePurchaseOrder_TawreedNo_' + id).val(),
                ItemNo: $(trs[i]).closest('tr').find('#ePODF_ItemNo')[0].innerHTML,
                ItemSr: $(trs[i]).closest('tr').find('#ePODF_ItemSr')[0].innerHTML,
                PerDiscount: $(trs[i]).closest('tr').find('#ePODF_DiscPer_' + InputSerial)[0].value,
                Bonus: $(trs[i]).closest('tr').find('#ePODF_Bonus_' + InputSerial)[0].value,
                Qty: $(trs[i]).closest('tr').find('#ePODF_Qty_' + InputSerial)[0].value.replace(/,/g, ''),
                Qty2: $(trs[i]).closest('tr').find('#ePODF_Qty2_' + InputSerial)[0].value.replace(/,/g, ''),
                Price: $(trs[i]).closest('tr').find('#ePODF_Price_' + InputSerial)[0].value.replace(/,/g, ''),
                ordamt: $(trs[i]).closest('tr').find('#ePODF_Total_' + InputSerial)[0].innerHTML,
                RefNo: $(trs[i]).closest('tr').find('#ePODF_RefNo_' + InputSerial)[0].value,
                PUnit: $(trs[i]).closest('tr').find('.ePODF_Item_Unit option:Selected')[0].getAttribute('unitCode'),
                ItemTaxVal: ItemTaxVal,
                ItemTaxPer: $(trs[i]).closest('tr').find('#ePODF_STax_Perc_' + InputSerial)[0].value,
                ItemTaxType: 1,
                VouDiscount: vouDiscountPerItem,
                UnitSerial: $(trs[i]).closest('tr').find('.ePODF_Item_Unit')[0].value,
                Note: $(trs[i]).closest('tr').find('#ePODF_ItemNote_' + InputSerial)[0].value,
                NoteDtl: $(trs[i]).closest('tr').find('#ePODF_DetailedNotes_' + InputSerial)[0].value,
                ReqDeliveryDate:$(trs[i]).closest('tr').find('#ePODF_RequestedDeliveryDate_' + InputSerial)[0].value
            });
        }
        var OrdCondsGuaranty = {};
        if ($('#Ord_ePO_txtPaymentCond1_' + id).val() == 0 && $('#Ord_ePO_txtPaymentCond2_' + id).val() == 0 && $('#Ord_ePO_txtPaymentCond3_' + id).val() == 0
            && $('#Ord_ePO_txtPaymentCond4_' + id).val() == 0 && $('#Ord_ePO_txtPaymentCond5_' + id).val() == 0 && $('#Ord_ePO_txtGuaranty1_' + id).val() == 0
            && $('#Ord_ePO_txtGuaranty2_' + id).val() == 0 && $('#Ord_ePO_txtGuaranty3_' + id).val() == 0 && $('#Ord_ePO_txtGuaranty4_' + id).val() == 0 && $('#Ord_ePO_txtGuaranty5_' + id).val() == 0){
            OrdCondsGuaranty = null;
        }
        else{
            var OrdCondsGuaranty = {
                CompNo: '@company.comp_num',
                OrdYear: $('#Ord_ePurchaseOrder_OrdYear_' + id).val(),
                OrderNo: $('#Ord_ePurchaseOrder_OrdNo_' + id).val(),
                TwareedNo: $('#Ord_ePurchaseOrder_TawreedNo_' + id).val(),
                PayCond1: $('#Ord_ePO_txtPaymentCond1_' + id).val(),
                PayCond2: $('#Ord_ePO_txtPaymentCond2_' + id).val(),
                PayCond3: $('#Ord_ePO_txtPaymentCond3_' + id).val(),
                PayCond4: $('#Ord_ePO_txtPaymentCond4_' + id).val(),
                PayCond5: $('#Ord_ePO_txtPaymentCond5_' + id).val(),
                CondPerc1: $('#Ord_ePO_txtPaymentPerc1_' + id).val(),
                CondPerc2: $('#Ord_ePO_txtPaymentPerc2_' + id).val(),
                CondPerc3: $('#Ord_ePO_txtPaymentPerc3_' + id).val(),
                CondPerc4: $('#Ord_ePO_txtPaymentPerc4_' + id).val(),
                CondPerc5: $('#Ord_ePO_txtPaymentPerc5_' + id).val(),
                Guaranty1: $('#Ord_ePO_txtGuaranty1_' + id).val(),
                Guaranty2: $('#Ord_ePO_txtGuaranty2_' + id).val(),
                Guaranty3: $('#Ord_ePO_txtGuaranty3_' + id).val(),
                Guaranty4: $('#Ord_ePO_txtGuaranty4_' + id).val(),
                Guaranty5: $('#Ord_ePO_txtGuaranty5_' + id).val(),
                GuarantyPerc1: $('#Ord_ePO_txtGuarantyPerc1_' + id).val(),
                GuarantyPerc2: $('#Ord_ePO_txtGuarantyPerc2_' + id).val(),
                GuarantyPerc3: $('#Ord_ePO_txtGuarantyPerc3_' + id).val(),
                GuarantyPerc4: $('#Ord_ePO_txtGuarantyPerc4_' + id).val(),
                GuarantyPerc5: $('#Ord_ePO_txtGuarantyPerc5_' + id).val()
            };
        }
     

        var Attachmentstable = $("#ePOAttachmentsTbody_" + id);
        var trsAttachments = Attachmentstable.find('tr');

        for (var i = 0; i < trsAttachments.length; i++) {
            Ord_POAttachments.push({
                CompNo: '@company.comp_num',
                OrdYear: $('#Ord_ePurchaseOrder_OrdYear_' + id).val(),
                OrderNo: $('#Ord_ePurchaseOrder_OrdNo_' + id).val(),
                TawreedNo: $('#Ord_ePurchaseOrder_TawreedNo_' + id).val(),
                Description: $(trsAttachments[i]).closest('tr').find('#Ord_ePO_AttachDescAr')[0].value,
                DescriptionEng: $(trsAttachments[i]).closest('tr').find('#Ord_ePO_AttachDescEn')[0].value
            });
        }


        var DocumentArchivetable = $("#ePODocumentArchiveTbody_" + id);
        var trsDocumentArchive = DocumentArchivetable.find('tr');


        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#Ord_ePurchaseOrder_FileId')[0].value;
            DocumentArchive.push({
                OrderYear: $('#Ord_ePurchaseOrder_OrdYear_' + id).val(),
                OrderNo: $('#Ord_ePurchaseOrder_OrdNo_' + id).val(),
                TawreedNo: $('#Ord_ePurchaseOrder_TawreedNo_' + id).val(),
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#Ord_ePurchaseOrder_Description_' + InputSerial)[0].value ,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#Ord_ePurchaseOrder_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#Ord_ePurchaseOrder_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ BU: $('#Ord_ePurchaseOrder_CboBU_' + id).val(), OrdHF: OrdHF, OrdDF: OrdDF, OrdCondsGuaranty: OrdCondsGuaranty, Ord_POAttachments: Ord_POAttachments, DocumentArchive: DocumentArchive }, '../../../PurchaseOrder/Edit_PurchaseOrder', '', ReloadePurchaseOrder, false);
    }
    function ReloadePurchaseOrder(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        var TawreedNo = r.TawreedNo;
        CloseWindow('/PurchaseOrder/EditPurchaseOrder?OrdYear=' + r.OrdYear + '&OrderNo=' + r.OrdNo + '&TawreedNo=' + TawreedNo + '');
        SerachPurchaseOrderInfo();
    }

</script>

