<script>
    var itemType = 0;
    var frmSatus = 1;
    var SerialItem = 0;

    var RawMaterial = $('#SelectePurchaseOrderItemTable_' + @TawreedNo).DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25,
        "language": {
            search: ' <i class="fa fa-search" aria-hidden="true"></i> '
        }
    });
    function Edit_InvItemsMF(type,Id) {
        itemType = type;
        frmSatus = 1;
        SerialItem = Id;
        var table = $("#SelectePurchaseOrderItemTable_" + Id);
        table.find('tr').removeClass("selected");

        $('#Model_ePurchaseOrder_InvItemsMF_' + Id).draggable({
            handle: ".modal-header",
        });

        $('#Model_ePurchaseOrder_InvItemsMF_' + Id).modal('show');
    }
    function GetItemNo(e, Id) {
        SerialItem = Id;

        if (frmSatus == 1) {
            if (itemType == 1) {
                var table_ = $("#ePOItemTBody_" + Id);
                var item = new Array();
                var Added = false;
                if (table_.find("tr").length != 0) {
                    table_.find("tr").each(function () {

                        var ItemNo_ = $(this).find("#ePODF_ItemNo").text();
                        if (ItemNo_ == e.getAttribute('ItemNo')) {
                            Added = true;
                            return false;
                        }
                        else {
                            Added = false;
                        }
                    });
                    if (!Added) {
                        item.push({
                            ItemNo: e.getAttribute('ItemNo'),
                            ItemDesc: e.getAttribute('ItemDesc')
                        });
                    }
                }
                else {
                    item.push({
                        ItemNo: e.getAttribute('ItemNo'),
                        ItemDesc: e.getAttribute('ItemDesc')
                    });
                }

                if (item.length != 0) {
                    burn({ items: item, srl: table_.find("tr").length, Id: Id}, '../../../PurchaseOrder/ePurchaseOrderItems', '', LoadeItemRawMaterial, true);
                }
                else {
                    $('#Model_ePurchaseOrder_InvItemsMF_' + Id).modal('hide');
                }
            }
        }
    }
    function SelectingePurchaseOrder_InvItemsMF(Id) {
        SerialItem = Id;
        var table = $('#SelectePurchaseOrderItemTable_' + Id);
        var oTable = table.dataTable();
        var data = oTable.$('.selected');

        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة واحدة على الاقل", "Select one item at least")');
            return;
        }
        if (frmSatus == 1) {
            if (itemType == 1) {
                var table_ = $("#ePOItemTBody_" + Id);
                var item = new Array();
                for (var i = 0; i < data.length; i++) {
                    var Added = false;
                    if (table_.find("tr").length != 0) {
                        table_.find("tr").each(function () {
                            var ItemNo_ = $(this).find("#ePODF_ItemNo").text();
                            if (ItemNo_ == data[i].getAttribute('itemno')) {
                                Added = true;
                                return false;
                            }
                            else {
                                Added = false;
                            }
                        });
                        if (!Added) {
                            item.push({
                                ItemNo: data[i].getAttribute('itemno'),
                                ItemDesc: data[i].getAttribute('itemdesc')
                            });
                        }
                    }
                    else {
                        item.push({
                            ItemNo: data[i].getAttribute('itemno'),
                            ItemDesc: data[i].getAttribute('itemdesc')
                        });
                    }
                }
                if (item.length != 0) {
                    burn({ items: item, srl: table_.find("tr").length, Id: Id }, '../../../PurchaseOrder/ePurchaseOrderItems', '', LoadeItemRawMaterial, true);
                }
                else {
                    $('#Model_ePurchaseOrder_InvItemsMF').modal('hide')
                }
            }
        }
    }
    function LoadeItemRawMaterial(r) {
        if (frmSatus == 1) {
            $('#ePOItemTBody_' + SerialItem).append(r);
        }
        else {
            $('#ePOItemTBody_' + SerialItem).append(r);
        }
        $('#Model_ePurchaseOrder_InvItemsMF_' + SerialItem).modal('hide');
    }
    function eGetchangeCost(item, e, srl, Id) {
        SerialItem = Id;
        burn({ itemNo: item, Unitserial: e, srl: srl }, '../../../PurchaseOrder/LoadUnitCost', '', LoadCost, true);
    }
    function LoadCost(r) {
        var table = $("#ePOItemTBody_" + SerialItem);
        var tr = table.find('#ePODF_Serial_' + r.srl);


        tr.find('#ePODF_QtyOH_' + r.srl)[0].value = r.QtyOH;
    }
</script>
