<script>
    function ShowRevisions(btn, itemNo) {
        var url = '/PurchaseOrder/GetItemRevisions';
        window.currentRevisionInput = $(btn).parent().find('input[type="text"]');
        
        $('#RevisionsModalContent').load(url + '?itemNo=' + encodeURIComponent(itemNo), function() {
            $('#Model_Revisions').modal('show');
        });
    }

    function SelectRevision(revNo) {
        if (window.currentRevisionInput) {
            window.currentRevisionInput.val(revNo);
            window.currentRevisionInput.trigger('change');
        }
        $('#Model_Revisions').modal('hide');
    }
</script>
