<script>
    var itemType = 0;
    var frmSatus = 1;
    $('#ModelPurchaseOrder_InvItemsMF').draggable({
        handle: ".modal-header",
    });
    var RawMaterial = $('#SelectPurchaseOrderItemTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25,
        "language": {
            search: ' <i class="fa fa-search" aria-hidden="true"></i> '
        }
    });
    function Add_InvItemsMF(type) {
        itemType = type;
        frmSatus = 1;
        $('#SelectPurchaseOrderItemTable tr').removeClass("selected");
        $('#ModelPurchaseOrder_InvItemsMF').modal('show')
    }
    function GetItemNo(e) {
        if (frmSatus == 1) {
            if (itemType == 1) {
                var table_ = $("#POItemTBody");
                var item = new Array();
                var Added = false;
                if (table_.find("tr").length != 0) {
                    table_.find("tr").each(function () {
                        var ItemNo_ = $(this).find("#PODF_ItemNo").text();
                        if (ItemNo_ == e.getAttribute('ItemNo')) {
                            Added = true;
                            return false;
                        }
                        else {
                            Added = false;
                        }
                    });
                    if (!Added) {
                        item.push({
                            ItemNo: e.getAttribute('ItemNo'),
                            ItemDesc: e.getAttribute('ItemDesc')
                        });
                    }
                }
                else {
                    item.push({
                        ItemNo: e.getAttribute('ItemNo'),
                        ItemDesc: e.getAttribute('ItemDesc')
                    });
                }

                if (item.length != 0) {
                    burn({ items: item, srl: table_.find("tr").length }, '../../../PurchaseOrder/PurchaseOrderItems', '', LoadItemRawMaterial, true);
                }
                else {
                    $('#ModelPurchaseOrder_InvItemsMF').modal('hide')
                }
            }
        }
    }
    function SelectingPurchaseOrder_InvItemsMF() {
        var data = RawMaterial.rows('.selected').data();
        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة واحدة على الاقل", "Select one item at least")');
            return;
        }
        if (frmSatus == 1) {
            if (itemType == 1) {
                var table_ = $("#POItemTBody");
                var item = new Array();
                for (var i = 0; i < data.length; i++) {
                    var Added = false;
                    if (table_.find("tr").length != 0) {
                        table_.find("tr").each(function () {
                            var ItemNo_ = $(this).find("#PODF_ItemNo").text();
                            if (ItemNo_ == data[i][0]) {
                                Added = true;
                                return false;
                            }
                            else {
                                Added = false;
                            }
                        });
                        if (!Added) {
                            item.push({
                                ItemNo: data[i][0],
                                ItemDesc: data[i][1]
                            });
                        }
                    }
                    else {
                        item.push({
                            ItemNo: data[i][0],
                            ItemDesc: data[i][1]
                        });
                    }
                }
                if (item.length != 0) {
                    burn({ items: item, srl: table_.find("tr").length }, '../../../PurchaseOrder/PurchaseOrderItems', '', LoadItemRawMaterial, true);
                }
                else {
                    $('#ModelPurchaseOrder_InvItemsMF').modal('hide')
                }
            }
        }
    }
    function LoadItemRawMaterial(r) {
        if (frmSatus == 1) {
            $('#POItemTBody').append(r);
        }
        else {
            $('#POItemTBody').append(r);
        }
        $('#ModelPurchaseOrder_InvItemsMF').modal('hide')
    }
    function GetchangeCost(item, e, srl) {
        burn({ itemNo: item, Unitserial: e, srl: srl }, '../../../PurchaseOrder/LoadUnitCost', '', LoadCost, true);
    }
    function LoadCost(r) {
        var tr = $('#POItemTBody #PODF_Serial_' + r.srl);
        tr.find('#PODF_QtyOH_' + r.srl)[0].value = r.QtyOH;
    }
</script>
