        $("#POAttachmentsTbody").append(
            GenRowAttach(newarray, 'POAttach_' + Count)
        );
    }
    function GenRowAttach(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function SavePOAttachments() {
        $('#Model_POAttachments').modal('hide')
    }
</script>
