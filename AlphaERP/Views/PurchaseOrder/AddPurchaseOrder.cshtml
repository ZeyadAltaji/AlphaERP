    function sumTotalAll() {
        var table = $('#POItemTBody tr');
        var trs = table;
        var itemTotal = 0;
        var itemTotalqty = 0;
        var totalAmount = 0;
        var vouDiscountPer = Number($('#Ord_PO_DisPersTotal').val()) / 100;
        var vouDiscountPerItem = 0;
        var itemDiscVal = 0;
        var totalDiscVal = 0;
        var ItemTaxVal = 0;
        var totalTaxVal = 0;
        var TotalNetAmount = 0;
        var Total = 0;
        var FreightCost = 0;
        var ExtraExp = 0;
        var Totals = 0

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            itemTotalqty += Number($(trs[i]).closest('tr').find('#PODF_Qty_' + InputSerial)[0].value.replace(/,/g, ''));
            itemTotal = Number($(trs[i]).closest('tr').find('#PODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#PODF_Price_' + InputSerial)[0].value.replace(/,/g, ''));
            itemDiscVal = (Number($(trs[i]).closest('tr').find('#PODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#PODF_Price_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#PODF_DiscPer_' + InputSerial)[0].value.replace(/,/g, ''))) / 100;
            vouDiscountPerItem = (Number(itemTotal) - Number(itemDiscVal)) * Number(vouDiscountPer);
            ItemTaxVal = (Number($(trs[i]).closest('tr').find('#PODF_Qty_' + InputSerial)[0].value.replace(/,/g, '')) * Number($(trs[i]).closest('tr').find('#PODF_Price_' + InputSerial)[0].value.replace(/,/g, '')) - Number(itemDiscVal) - Number(vouDiscountPerItem)) * (Number($(trs[i]).closest('tr').find('#PODF_STax_Perc_' + InputSerial)[0].value.replace(/,/g, '')) / 100);
            totalAmount += Number(itemTotal)
            totalDiscVal += Number(itemDiscVal);
            totalTaxVal += Number(ItemTaxVal);
            Total = (Number(itemTotal).toFixed(3) - Number(vouDiscountPerItem).toFixed(3) - Number(itemDiscVal).toFixed(3));
            $(trs[i]).closest('tr').find('#PODF_Total_' + InputSerial)[0].innerHTML = Number(Total).toFixed(3)
            TotalNetAmount += Number($(trs[i]).closest('tr').find('#PODF_Total_' + InputSerial)[0].innerHTML);
        }

        FreightCost = Number($('#Ord_PO_FreightCost').val())
        ExtraExp = Number($('#Ord_PO_ExtraExp').val())

        TotalNetAmount = Number(TotalNetAmount) + Number(totalTaxVal) + Number(FreightCost) + Number(ExtraExp);
        $('#Ord_PO_Amount').val(Number(totalAmount).toFixed(3));
        $('#Ord_PO_Discount').val(Number(totalDiscVal).toFixed(3));
        $('#Ord_PO_TaxAmount').val(Number(totalTaxVal).toFixed(3));
        $('#Ord_PO_TotalQty').val(Number(itemTotalqty).toFixed(3));
        $('#Ord_PO_NetAmount').val(Number(TotalNetAmount).toFixed(3));

        var TotDiscPer = (Number($('#Ord_PO_DisPersTotal').val()) / 100) * ($('#Ord_PO_Amount').val() - $('#Ord_PO_Discount').val());

        $('#Ord_PO_DisTotal').val(Number(TotDiscPer).toFixed(3));
    }


