@using System.Data.SqlClient;
@using AlphaERP.Models

@{
    int OrdYear = ViewBag.OrdYear;
    int OrderNo = ViewBag.OrderNo;
    string TawreedNo = ViewBag.TawreedNo;

    Company company = (Company)Session["company"];
    List<Ord_OrderShippingHF> ShippingHF = new MDB().Ord_OrderShippingHF.Where(x => x.CompNo == company.comp_num && x.OrderYear == OrdYear && x.OrderNo == OrderNo && x.TawreedNo == TawreedNo).ToList();
    int Srial = 1;
}

<style>
    tr.details {
        max-height: 0 !important;
        padding: 0 !important;
        margin: 0 !important;
    }
    
    tr.details {
        background-color: gray !important;
        border-style: solid !important;
    }
</style>

<div id="PurchaseOrderInfoTable_@TawreedNo">
    <div style="width: 100%; padding: 1px; background: #fff !important ">
        <table class="table table-hover" id="PurchaseOrderInfoTable_@TawreedNo" style="background:lightgray;width:100%">
            <thead>
                <tr>
                    <th>@Html.Recource(696)</th>
                    <th>@Resources.Resource.ClearanceCompany</th>
                    <th>@Resources.Resource.ShippingPolicyNo</th>
                    <th>@Html.Recource(3832)</th>
                    <th>@Html.Recource(3833)</th>
                    <th>@Html.Recource(70)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (Ord_OrderShippingHF item in ShippingHF)
                {

                    Ord_PortInfoHF PortInfoHF = new MDB().Ord_PortInfoHF.Where(x => x.CompNo == company.comp_num && x.OrderYear == item.OrderYear && x.OrderNo == item.OrderNo
               && x.TawreedNo == item.TawreedNo && x.ShipSer == item.ShipSer).FirstOrDefault();
                    Vendor Vend = new MDB().Vendors.Where(x => x.comp == item.CompNo && x.VendorNo.ToString() == item.ClearanceCompany).FirstOrDefault();

            if(PortInfoHF == null)
            {
                <tr id="ShipmentsInfo_@Srial">
                    <td style="direction: ltr;" id="ShipmentsInfo_ShipSer_@Srial">@item.ShipSer</td>
                    <td style="word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_Vendor_@Srial">@Html.Translate(Vend.Name, Vend.Eng_Name)</td>
                    <td style="word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_ShippingPolicyNo_@Srial">@item.ShippingPolicyNo</td>
                    <td id="ShipmentsInfo_ShippingDate_@Srial">@item.ShippingDate.ToString("yyyy-MM-dd")</td>
                    <td id="ShipmentsInfo_ArrivalDate_@Srial">@item.ArrivalDate.Value.ToString("yyyy-MM-dd")</td>
                    <td style="word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_Notes_@Srial">@item.ShippingNotes</td>
                    <td>
                        <button onclick="EditShipments('@item.OrderYear','@item.OrderNo','@item.TawreedNo','@item.ShipSer')" type="button" class="btn btn-ed ex" title="@Html.Translate("تعديل معلومات الشحنة", "Edit shipment Information")">
                            <i class="fa fa-pencil-alt"></i>
                        </button>
                        <button id="eShipments" class="btn btn-primary btn-block" href="" target="_blank" style="display:none;">
                            @Html.Translate("تعديل معلومات الشحنات", "Edit Shipment Info")
                        </button>
                        <button class="btn-de" onclick="DeleteShipmentsInfo('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer')">
                            <i class="fa fa-trash-alt" aria-hidden="true"></i>
                        </button>
                        <button class="btn btn-default ex" title="عرض" href="/ShipmentsInfo/ShipmentsView?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer" target="_blank">
                            <i style="font-weight:100" class="fa fa-folder"></i>
                            @Html.Translate("عرض", "View")
                        </button>
                        <input type="hidden" id="InputSerial" value="@(Srial++)" />
                    </td>
                </tr>
            }
            else
            {
            <tr id="ShipmentsInfo_@Srial">
                <td style="direction: ltr;" id="ShipmentsInfo_ShipSer_@Srial">@item.ShipSer</td>
                <td style="word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_Vendor_@Srial">@Html.Translate(Vend.Name, Vend.Eng_Name)</td>
                <td style="word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_ShippingPolicyNo_@Srial">@item.ShippingPolicyNo</td>
                <td id="ShipmentsInfo_ShippingDate_@Srial">@item.ShippingDate.ToString("yyyy-MM-dd")</td>
                <td id="ShipmentsInfo_ArrivalDate_@Srial">@item.ArrivalDate.Value.ToString("yyyy-MM-dd")</td>
                <td style="word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_Notes_@Srial">@item.ShippingNotes</td>
                <td>
                    @if (PortInfoHF.IsApproval == false)
                    {
                        <button onclick="EditShipments('@item.OrderYear','@item.OrderNo','@item.TawreedNo','@item.ShipSer')" type="button" class="btn btn-ed ex" title=" @Html.Translate("تعديل معلومات الشحنة", "Edit shipment Information")">
                            <i class="fa fa-pencil-alt"></i>
                        </button>
                        <button id="eShipments" class="btn btn-primary btn-block" href="" target="_blank" style="display:none;">
                            @Html.Translate("تعديل معلومات الشحنات", "Edit Shipment Info")
                        </button>
                        <button class="btn-de" onclick="DeleteShipmentsInfo('@item.OrderYear','@item.OrderNo', '@item.TawreedNo','@item.ShipSer')">
                            <i class="fa fa-trash-alt" aria-hidden="true"></i>
                        </button>
                    }
                    else
                    {
                        <button disabled type="button" class="btn btn-ed ex" title="@Html.Translate("تعديل معلومات الشحنة", "Edit shipment Information")">
                            <i class="fa fa-pencil-alt"></i>
                        </button>
                        <button id="eShipments" class="btn btn-primary btn-block" href="" target="_blank" style="display:none;">
                            @Html.Translate("تعديل معلومات الشحنات", "Edit Shipment Info")
                        </button>
                        <button class="btn-de" disabled>
                            <i class="fa fa-trash-alt" aria-hidden="true"></i>
                        </button>
                    }
                    <button class="btn btn-default ex" title="عرض" href="/ShipmentsInfo/ShipmentsView?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer" target="_blank">
                        <i style="font-weight:100" class="fa fa-folder"></i>
                        @Html.Translate("عرض", "View")
                    </button>
                    <input type="hidden" id="InputSerial" value="@(Srial++)" />
                </td>
            </tr>
            }
        }
            </tbody>
        </table>
    </div>
</div>
<script>
    function EditShipments(OrdYear, OrdNo, TawreedNo, ShipSer) {
        $('#eShipments').attr("href", '/ShipmentsInfo/eShipmentsInfo?OrdYear=' + OrdYear + '&OrderNo=' + OrdNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer + '')
        $('#eShipments').click();
    }
</script>
