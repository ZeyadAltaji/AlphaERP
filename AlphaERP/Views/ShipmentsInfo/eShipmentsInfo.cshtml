                                        cn.Open();
                                        SqlDataReader rdr = cmd.ExecuteReader();
                                        if (rdr.HasRows)
                                        {
                                            while (rdr.Read())
                                            {
                                                string ItemDesc = rdr["ItemDesc"].ToString();
                                                string ItemDescEn = rdr["ItemDesc_Ara"].ToString();
                                                string Desc = Html.Translate(ItemDesc, ItemDescEn).ToString();
                                                <tr onclick="eShipmentsInfoItem_InvItems(this,@srl)" ItemNo="@rdr["ItemNo"]" ItemDesc="@Html.Trim(Desc,50)">
                                                    <td style="width: 20%;">@rdr["ItemNo"]</td>
                                                    <td style="width: 55%;" title="@Desc">@Html.Trim(Desc, 50)</td>
                                                    <td style="width: 10%;text-align: center;">@rdr["RefrenceNo"]</td>
                                                    <td style="text-align: center !important;">@rdr["BarCode"]</td>
                                                </tr>
                                            }
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="SelectingeShipmentsInfoItem_InvItems(@srl)" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>

<script>
    $('#MRP_eShipmentsInfo_CboClearanceCompany_' + @srl).select2();


    $('#eShipmentsInfoItem_' + @srl).DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25
    });

    var SerialVal = 0;
    function EditRmCode(val, srl) {
        SerialVal = val;
        var table = $("#eShipmentsInfoItemTbody_" + srl);
        table.find('tr').removeClass("selected");
        $('#Model_eShipmentsInfo_InvItems_' + srl).draggable({
            handle: ".modal-header",
        });
        $('#Model_eShipmentsInfo_InvItems_'+ srl).modal('show')
    }
    function eShipmentsInfoItem_InvItems(e, srl) {
        var table = $("#eShipmentsInfoItemTbody_" + srl);
        var trs = table.find('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function SelectingeShipmentsInfoItem_InvItems(srl) {
        var table = $("#eShipmentsInfoItemTbody_" + srl);
        var trs = table.find('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة", "Select one Item")');
            return;
        }

        var ids = '#eShipmentsInfoDFTBody_' + srl;

        var tr = $(ids + " #eShipmentsInfo_" + SerialVal + "");
        $(tr).find('#eShipmentsInfo_ItemNo_' + SerialVal).html(trs[0].getAttribute('ItemNo'));
        $(tr).find('#eShipmentsInfo_ItemDesc_' + SerialVal).html(trs[0].getAttribute('ItemDesc'));

        burn({ ItemNo: trs[0].getAttribute('ItemNo'), srl: srl }, '../../../ShipmentsInfo/LoadUnitItem', '', LoadUnitByItem, true);

        $('#Model_eShipmentsInfo_InvItems_' + srl).modal('hide')
    }
    function LoadUnitByItem(r) {
        var tr = "";
        var srl = r.Id;

        var id = '#eShipmentsInfoDFTBody_' + srl;
        tr = $(id + " #eShipmentsInfo_" + SerialVal + "");


        tr.find('.eShipmentsInfo_ItemNo_Unit').empty().trigger("change");

        for (var i = 0; i < r.unit.length; i++) {
            var newOption = new Option(r.unit[i].UnitName, r.unit[i].VSUnitCode, false, false);
            tr.find('.eShipmentsInfo_ItemNo_Unit').append(newOption).trigger('change');
        }
    }

    function CheckValueQty(e,srl) {
        if (e.value < 0) {
            alert('@Html.Translate("يجب أن تكون الكمية أكبر من صفر", "The Qty Must be Greater Than Zero")');
            e.value = 0;
            e.focus();
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    function CheckValueQty2(e,srl) {
        if (e.value < 0) {
            alert('@Html.Translate("يجب أن تكون الكمية 2 أكبر من صفر", "The Qty 2 Must be Greater Than Zero")');
            e.value = 0;
            e.focus();
        }
        if (e.value == "") {
            e.value = 0;
        }
        SumTotalQty(srl)
    }
    SumTotalQty(@srl)
    function SumTotalQty(id) {
        var table = $("#eShipmentsInfoDFTBody_" + id);
        var trs = table.find('tr');

        var TotaleShipmentPOQty1 = 0;
        var TotaleShipmentPOQty2 = 0;
        var TotaleShipmentRemainingQty = 0;

        var TotaleShipmentQty1 = 0;
        var TotaleShipmentQty2 = 0;
        var TotaleDiffQty1 = 0;
        var TotaleDiffQty2 = 0;
        var Total1 = 0
        var Total2 = 0

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputItemSerial')[0].value
            TotaleShipmentPOQty1 += Number($(trs[i]).closest('tr').find('#eShipmentsInfoPO_Qty_' + InputSerial)[0].value);
            TotaleShipmentPOQty2 += Number($(trs[i]).closest('tr').find('#eShipmentsInfoPO_Qty2_' + InputSerial)[0].value);
            TotaleShipmentRemainingQty += Number($(trs[i]).closest('tr').find('#eShipmentsInfo_RemainingQty_' + InputSerial)[0].value);

            TotaleShipmentQty1 += Number($(trs[i]).closest('tr').find('#eShipmentsInfo_Qty_' + InputSerial)[0].value);
            TotaleShipmentQty2 += Number($(trs[i]).closest('tr').find('#eShipmentsInfo_Qty2_' + InputSerial)[0].value);

            TotaleDiffQty1 = Number($(trs[i]).closest('tr').find('#eShipmentsInfoPO_Qty_' + InputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#eShipmentsInfo_Qty_' + InputSerial)[0].value);
            TotaleDiffQty2 = Number($(trs[i]).closest('tr').find('#eShipmentsInfoPO_Qty2_' + InputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#eShipmentsInfo_Qty2_' + InputSerial)[0].value);
            if(@CActive.ClientNo != 239){
                $(trs[i]).closest('tr').find('#eShipmentsInfo_Difference1_' + InputSerial)[0].value = Number(TotaleDiffQty1);
                $(trs[i]).closest('tr').find('#eShipmentsInfo_Difference2_' + InputSerial)[0].value = Number(TotaleDiffQty2);
            }

            Total1 = Number(Total1) + Number(TotaleDiffQty1);
            Total2 = Number(Total2) + Number(TotaleDiffQty2);
        }

        $('#eTotalShipmentPOQty1_' + id).html(Number(TotaleShipmentPOQty1));
        $('#eTotalShipmentPOQty2_' + id).html(Number(TotaleShipmentPOQty2));
        $('#eTotalShipmentRemainingQty_' + id).html(Number(TotaleShipmentRemainingQty));
        $('#eTotalShipmentQty1_' + id).html(Number(TotaleShipmentQty1));
        $('#eTotalShipmentQty2_' + id).html(Number(TotaleShipmentQty2));
        $('#eTotalShipmentDifferenceQty1_' + id).html(Number(Total1));
        $('#eTotalShipmentDifferenceQty2_' + id).html(Number(Total2));
    }
    function ExcuteEditMRP_ShipmentsInfo(id) {

        var table = $("#eShipmentsInfoDFTBody_" + id);
        var trs = table.find('tr');

        var OrderShippingHF = {
            CompNo: '@company.comp_num',
            OrderYear: $('#MRP_eShipmentsInfo_OrdYear_' + id).val(),
            OrderNo: $('#MRP_eShipmentsInfo_OrderNo_' + id).val(),
            TawreedNo: $('#MRP_eShipmentsInfo_TawreedNo_' + id).val(),
            ShipSer: $('#MRP_eShipmentsInfo_ShipSer_' + id).val(),
            ShippingDate: $('#MRP_eShipmentsInfo_ShippingDate_' + id).val(),
            ArrivalDate: $('#MRP_eShipmentsInfo_ArrivalDate_' + id).val(),
            ShippingPolicyNo: $('#MRP_eShipmentsInfo_ShippingPolicyNo_' + id).val(),
            ClearanceInvNo: $('#MRP_eShipmentsInfo_ClearanceInvNo_' + id).val(),
            ClearanceCompany: $('#MRP_eShipmentsInfo_CboClearanceCompany_' + id).val(),
            Transporter: $('#MRP_eShipmentsInfo_Transporter_' + id).val(),
            TransportInvNo: $('#MRP_eShipmentsInfo_TransportInvNo_' + id).val(),
            ShippingNotes: $('#MRP_eShipmentsInfo_ShippingNotes_' + id).val(),
        }

        var OrderShippingDF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputItemSerial')[0].value
            if ($(trs[i]).closest('tr').find('#eShipmentsInfo_Qty_' + InputSerial)[0].value > 0) {
                if(@CActive.ClientNo == 239) {
                    OrderShippingDF.push({
                        CompNo: '@company.comp_num',
                        OrderYear: $('#MRP_eShipmentsInfo_OrdYear_' + id).val(),
                        OrderNo: $('#MRP_eShipmentsInfo_OrderNo_' + id).val(),
                        TawreedNo: $('#MRP_eShipmentsInfo_TawreedNo_' + id).val(),
                        ShipSer: $('#MRP_eShipmentsInfo_ShipSer_' + id).val(),
                        ItemNo: $(trs[i]).closest('tr').find('#eShipmentsInfo_ItemNo_' + InputSerial)[0].innerHTML,
                        ShippingQty: $(trs[i]).closest('tr').find('#eShipmentsInfo_Qty_' + InputSerial)[0].value,
                        Qty2: $(trs[i]).closest('tr').find('#eShipmentsInfo_Qty2_' + InputSerial)[0].value,
                        TUnit: $(trs[i]).closest('tr').find('.eShipmentsInfo_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                        UnitSerial: $(trs[i]).closest('tr').find('.eShipmentsInfo_ItemNo_Unit')[0].value,
                        ETA: $(trs[i]).closest('tr').find('#eShipmentsInfo_ETA_' + InputSerial)[0].value,
                        Marketing: $(trs[i]).closest('tr').find('#eShipmentsInfo_Marketing_' + InputSerial)[0].checked,
                        tqm: $(trs[i]).closest('tr').find('#eShipmentsInfo_tqm_' + InputSerial)[0].checked,
                        QualityControl: $(trs[i]).closest('tr').find('#eShipmentsInfo_QualityControl_' + InputSerial)[0].checked,
                        SupplierInvoiceNo: $(trs[i]).closest('tr').find('#eShipmentsInfo_SupplierInvoiceNo_' + InputSerial)[0].value,
                        Amount: $(trs[i]).closest('tr').find('#eShipmentsInfo_Amount_' + InputSerial)[0].value,
                        CurrCode: $(trs[i]).closest('tr').find('.eShipmentsInfo_Currency')[0].value,
                        ShippingDate: $(trs[i]).closest('tr').find('#eShipmentsInfo_ShippingDate_' + InputSerial)[0].value,
                        JFDA: $(trs[i]).closest('tr').find('.eShipmentsInfo_JFDA')[0].value,
                        SampleDate: $(trs[i]).closest('tr').find('#eShipmentsInfo_SampleDate_' + InputSerial)[0].value,
                        JFDAApprovalDate: $(trs[i]).closest('tr').find('#eShipmentsInfo_JFDAApprovalDate_' + InputSerial)[0].value,
                        Declaration: $(trs[i]).closest('tr').find('#eShipmentsInfo_Declaration_' + InputSerial)[0].value,
                        ActualArrivalDate: $(trs[i]).closest('tr').find('#eShipmentsInfo_ActualArrivalDate_' + InputSerial)[0].value,
                        AWBBL: $(trs[i]).closest('tr').find('#eShipmentsInfo_AWBBL_' + InputSerial)[0].value,
                        Transporter: $(trs[i]).closest('tr').find('#eShipmentsInfo_Transporter_' + InputSerial)[0].value,
                        TransporterInvoice: $(trs[i]).closest('tr').find('#eShipmentsInfo_TransporterInvoice_' + InputSerial)[0].value
                    })
                }
                else{
                    OrderShippingDF.push({
                        CompNo: '@company.comp_num',
                        OrderYear: $('#MRP_eShipmentsInfo_OrdYear_' + id).val(),
                        OrderNo: $('#MRP_eShipmentsInfo_OrderNo_' + id).val(),
                        TawreedNo: $('#MRP_eShipmentsInfo_TawreedNo_' + id).val(),
                        ShipSer: $('#MRP_eShipmentsInfo_ShipSer_' + id).val(),
                        ItemNo: $(trs[i]).closest('tr').find('#eShipmentsInfo_ItemNo_' + InputSerial)[0].innerHTML,
                        ShippingQty: $(trs[i]).closest('tr').find('#eShipmentsInfo_Qty_' + InputSerial)[0].value,
                        Qty2: $(trs[i]).closest('tr').find('#eShipmentsInfo_Qty2_' + InputSerial)[0].value,
                        TUnit: $(trs[i]).closest('tr').find('.eShipmentsInfo_ItemNo_Unit option:Selected')[0].getAttribute('unitCode'),
                        UnitSerial: $(trs[i]).closest('tr').find('.eShipmentsInfo_ItemNo_Unit')[0].value,
                        ETA: '@DateTime.Now.ToShortDateString()',
                        Marketing: false,
                        tqm: false,
                        QualityControl: false,
                        SupplierInvoiceNo: '',
                        Amount: 0,
                        CurrCode: 0,
                        ShippingDate: '@DateTime.Now.ToShortDateString()',
                        JFDA: 0,
                        SampleDate: '@DateTime.Now.ToShortDateString()',
                        JFDAApprovalDate: '@DateTime.Now.ToShortDateString()',
                        Declaration: '',
                        ActualArrivalDate: '@DateTime.Now.ToShortDateString()',
                        AWBBL: '',
                        Transporter: '',
                        TransporterInvoice: ''
                    })
                }
            }
        }

        if (OrderShippingDF.length == 0) {
            alert('@Html.Translate("يجب إدخال كمية لمادة واحده على الاقل", "A quantity must be entered for at least one substance")');
            return false;
        }

        var DocumentArchivetable = $("#eShipmentsInfo_DocumentArchiveTbody_" + id);
        var trsDocumentArchive = DocumentArchivetable.find('tr');

        var DocumentArchive = new Array();
        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#eShipmentsInfo_EditDocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                OrderYear: $('#MRP_eShipmentsInfo_OrdYear_' + id).val(),
                OrderNo: $('#MRP_eShipmentsInfo_OrderNo_' + id).val(),
                TawreedNo: $('#MRP_eShipmentsInfo_TawreedNo_' + id).val(),
                ShipSer: $('#MRP_eShipmentsInfo_ShipSer_' + id).val(),
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#eShipmentsInfo_EditDocumentArchive_Description_' + InputSerial)[0].value,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#eShipmentsInfo_EditDocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#eShipmentsInfo_EditDocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ OrderShippingHF: OrderShippingHF, OrderShippingDF: OrderShippingDF, FileArchive: DocumentArchive }, '../../../ShipmentsInfo/Edit_ShipmentsInfo', '', ReloadeShipmentsInfo, false);
    }
    function ReloadeShipmentsInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#ShipmentsInfoTBody').empty();
        var TawreedNo = r.TawreedNo;
        var ShipSer = r.ShipSer;
        CloseWindow('/ShipmentsInfo/eShipmentsInfo?OrdYear=' + r.OrdYear + '&OrderNo=' + r.OrdNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer + '')
        var table = $("#PurchaseOrderInfoTable tbody");
        var trs = table.find('tr');
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrdNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');

                $.get("../../../../ShipmentsInfo/DetailsShipmentsInfo?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo, function (data) {
                    PurchOrdTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }

</script>