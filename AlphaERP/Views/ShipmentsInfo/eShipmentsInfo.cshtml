                                        </td>
                                        <td>
                                            <input type="text" style="width: 115px !important; text-align: center !important" id="eShipmentsInfo_EditDocumentArchive_Description_@Count" value="@row["Description"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="eShipmentsInfo_EditDocumentArchive_File_@Count" onchange="uploadFile(this,@Count,@srl)" /></div>
                                        </td>
                                        <td></td>
                                        <td>
