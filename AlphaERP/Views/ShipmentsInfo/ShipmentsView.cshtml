                            <tbody style="text-align: center;" id="ViewShipmentsInfoDFTBody">
                                    @foreach (Ord_OrderShippingDF DF in OrdShipDF)
                                    {
                                        double ResQty = 0;
                                        {
                                            using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                            {
                                                Dt = new DataTable();
                                                cn.Open();
                                                using (SqlCommand cmd = new SqlCommand())
                                                {
                                                    cmd.Connection = cn;
                                                    cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                    cmd.CommandText = "Ord_GetItemUnitCost";
                                                    cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                    cmd.Parameters.Add(new SqlParameter("@ItemNo", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                    cmd.Parameters.Add(new SqlParameter("@UnitSerial", System.Data.SqlDbType.SmallInt, 4)).Value = DF.UnitSerial.Value;
                                                    using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                    {
                                                        DA.Fill(Dt);
                                                    }
                                                }
                                            }
                                            foreach (DataRow row in Dt.Rows)
                                            {
                                                ResQty = Convert.ToDouble(row["ResQty"]);
                                            }
                                        }
                                        OrderDF OrdDF = new MDB().OrderDFs.Where(x => x.CompNo == company.comp_num && x.OrdYear == DF.OrderYear && x.OrderNo == DF.OrderNo && x.TawreedNo == DF.TawreedNo && x.ItemNo == DF.ItemNo).FirstOrDefault();
                                        double RemainingQty = new MDB().Ord_OrderShippingDF.Where(x => x.CompNo == company.comp_num && x.OrderYear == DF.OrderYear && x.OrderNo == DF.OrderNo && x.TawreedNo == DF.TawreedNo && x.ItemNo == DF.ItemNo).Sum(o => o.ShippingQty).Value;
                                        RemainingQty = OrdDF.Qty.Value - (RemainingQty);
                                        string ItemDesc = Mf.Where(x => x.ItemNo == DF.ItemNo).Select(O => Html.Translate(O.ItemDesc, O.ItemDesc_Ara)).FirstOrDefault().ToString();
                                        InvItemsMF M = Mf.Where(x => x.ItemNo == DF.ItemNo).FirstOrDefault();
                                        string UnitName = "";
                                        switch (DF.UnitSerial)
                                        {
                                            case 1:
                                                UnitName = M.UnitC1;
                                                break;
                                            case 2:
                                                UnitName = M.UnitC2;
                                                break;
                                            case 3:
                                                UnitName = M.UnitC3;
                                                break;
                                            case 4:
                                                UnitName = M.UnitC4;
