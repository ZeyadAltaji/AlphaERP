<div class="modal fade" id="Model_vShipmentsInfo_DocumentsArchive">
    <div class="modal-dialog" style="width:800px; ">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Translate("أرشفة الوثائق", "Archive Documents")</label>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-12" style="overflow-y:auto">
                        <table class="table table-hover" id="vShipmentsInfo_DocumentArchiveTable">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th style="text-align: center !important">@Html.Recource(66)</th>
                                    <th style="text-align: center !important">@Html.Recource(5629)</th>
                                    <th style="text-align: center !important">@Html.Recource(5630)</th>
                                    <th style="text-align: center !important">@Html.Recource(5631)</th>
                                    <th style="text-align: center !important">@Html.Recource(5632)</th>
                                    <th style="text-align: center !important">@Html.Recource(5633)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="vShipmentsInfo_DocumentArchiveTbody" style="border-top: 1px solid #ddd;">
                                @foreach (DataRow row in DtAttachment.Rows)
                                {
                                    DateTime date = Convert.ToDateTime(row["DataUpload"].ToString());
                                    <tr id="vShipmentsInfoDocumentArchive_@Count">
                                        <td>
                                            <input id="vShipmentsInfo_EditDocumentArchive_FileId" type="hidden" value="@Count" />
                                        </td>
                                        <td>
                                            <input type="text" style="width: 115px !important; text-align: center !important" id="vShipmentsInfo_EditDocumentArchive_Description_@Count" value="@row["Description"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <a onclick="DownloadFile('@row["FileName"].ToString()','@Convert.ToBase64String((byte[])row["ArchiveData"])')"><span class="glyphicon glyphicon-download"></span></a>
                                        </td>
                                        <td>
                                            <input id="vShipmentsInfo_EditAttachmentFiles_FileName_@Count" type="text" style="text-align: center !important" value="@row["FileName"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="vShipmentsInfo_EditDocumentArchive_UploadDate_@Count" type="text" style="width: 95px; text-align: center !important" value="@date.ToShortDateString()" disabled />
                                        </td>
                                        <td>
                                            <input id="vShipmentsInfo_EditDocumentArchive_FileSize_@Count" type="text" style="width: 70px; text-align: center !important" value="@row["FileSize"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="vShipmentsInfo_EditDocumentArchive_FileType_@Count" type="text" style="width: 55px; text-align: center !important" value="@row["ContentType"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input type="hidden" id="InputSerial" value="@(Count++)" />
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="ViewShipmentsInfoDocumentArchive()" class="btn btn-primary">@Resources.Resource.Save</button>
            </div>
        </form>
    </div>
</div>
<script>
    var DocumentsArchiveValue = 0;
    $('#Model_vShipmentsInfo_DocumentsArchive').draggable({
        handle: ".modal-header",
    });
    function ViewDocuments(val) {
        DocumentsArchiveValue = val;
        $('#Model_vShipmentsInfo_DocumentsArchive').modal('show')
    }

    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    function ViewShipmentsInfoDocumentArchive() {
        $('#Model_vShipmentsInfo_DocumentsArchive').modal('hide')
    }
</script>
@*--------------------------------END Model Documents -----------------------------*@




<script>
    SumTotalQty()
    function SumTotalQty() {
        var table = $("#ViewShipmentsInfoDFTBody");
        var trs = table.find('tr');

        var TotalvShipmentPOQty1 = 0;
        var TotalvShipmentPOQty2 = 0;
        var TotalvShipmentRemainingQty = 0;

        var TotalvShipmentQty1 = 0;
        var TotalvShipmentQty2 = 0;
        var TotalvDiffQty1 = 0;
        var TotalvDiffQty2 = 0;
        var Total1 = 0
        var Total2 = 0

        for (var i = 0; i < trs.length; i++) {
            
            TotalvShipmentPOQty1 += Number($(trs[i]).closest('tr').find('#ViewShipmentsInfoPO_Qty')[0].innerHTML);
            TotalvShipmentPOQty2 += Number($(trs[i]).closest('tr').find('#ViewShipmentsInfoPO_Qty2')[0].innerHTML);
            TotalvShipmentRemainingQty += Number($(trs[i]).closest('tr').find('#ViewShipmentsInfo_RemainingQty')[0].innerHTML);

            TotalvShipmentQty1 += Number($(trs[i]).closest('tr').find('#ViewShipmentsInfo_Qty')[0].innerHTML);
            TotalvShipmentQty2 += Number($(trs[i]).closest('tr').find('#ViewShipmentsInfo_Qty2')[0].innerHTML);

            TotalvDiffQty1 = Number($(trs[i]).closest('tr').find('#ViewShipmentsInfoPO_Qty')[0].innerHTML) - Number($(trs[i]).closest('tr').find('#ViewShipmentsInfo_Qty')[0].innerHTML);
            TotalvDiffQty2 = Number($(trs[i]).closest('tr').find('#ViewShipmentsInfoPO_Qty2')[0].innerHTML) - Number($(trs[i]).closest('tr').find('#ViewShipmentsInfo_Qty2')[0].innerHTML);
            if(@CActive.ClientNo != 239){
                $(trs[i]).closest('tr').find('#ViewShipmentsInfo_Difference1')[0].innerHTML = Number(TotalvDiffQty1);
                $(trs[i]).closest('tr').find('#ViewShipmentsInfo_Difference2')[0].innerHTML = Number(TotalvDiffQty2);
            }

            Total1 = Number(Total1) + Number(TotalvDiffQty1);
            Total2 = Number(Total2) + Number(TotalvDiffQty2);
        }

        $('#vTotalShipmentPOQty1').html(Number(TotalvShipmentPOQty1));
        $('#vTotalShipmentPOQty2').html(Number(TotalvShipmentPOQty2));
        $('#vTotalShipmentRemainingQty').html(Number(TotalvShipmentRemainingQty));
        $('#vTotalShipmentQty1').html(Number(TotalvShipmentQty1));
        $('#vTotalShipmentQty2').html(Number(TotalvShipmentQty2));
        $('#vTotalShipmentDifferenceQty1').html(Number(Total1));
        $('#vTotalShipmentDifferenceQty2').html(Number(Total2));
    }
</script>