            TotalShipmentQty2 += Number($(trs[i]).closest('tr').find('#ShipmentsInfo_Qty2_' + InputSerial)[0].value);

            TotalDiffQty1 = Number($(trs[i]).closest('tr').find('#ShipmentsInfoPO_Qty_' + InputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#ShipmentsInfo_Qty_' + InputSerial)[0].value);
