                                <tbody style="text-align: center;" id="ShipmentsInfoDFTBody_@srl">
                                    @foreach (OrderDF DF in OrdDF)
                                    {
                                        double ResQty = 0;
                                        {
                                            using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                            {
                                                Dt = new DataTable();
                                                cn.Open();
                                                using (SqlCommand cmd = new SqlCommand())
                                                {
                                                    cmd.Connection = cn;
                                                    cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                    cmd.CommandText = "Ord_GetItemUnitCost";
                                                    cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                    cmd.Parameters.Add(new SqlParameter("@ItemNo", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                    cmd.Parameters.Add(new SqlParameter("@UnitSerial", System.Data.SqlDbType.SmallInt, 4)).Value = DF.UnitSerial.Value;
                                                    using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                    {
                                                        DA.Fill(Dt);
                                                    }
                                                }
                                            }
                                            foreach (DataRow row in Dt.Rows)
                                            {
                                                ResQty = Convert.ToDouble(row["ResQty"]);
                                            }
                                        }
                                        int counts = new MDB().Ord_OrderShippingDF.Where(x => x.CompNo == company.comp_num && x.OrderYear == DF.OrdYear && x.OrderNo == DF.OrderNo && x.TawreedNo == DF.TawreedNo && x.ItemNo == DF.ItemNo).Count();
                                        double RemainingQty;
                                        if (counts == 0)
                                        {
                                            RemainingQty = 0;
                                        }
                                        else
                                        {
                                            RemainingQty = new MDB().Ord_OrderShippingDF.Where(x => x.CompNo == company.comp_num && x.OrderYear == DF.OrdYear && x.OrderNo == DF.OrderNo && x.TawreedNo == DF.TawreedNo && x.ItemNo == DF.ItemNo).Sum(o => o.ShippingQty).Value;
                                        }
                                        RemainingQty = DF.Qty.Value - RemainingQty;
                                        string ItemDesc = Mf.Where(x => x.ItemNo == DF.ItemNo).Select(O => Html.Translate(O.ItemDesc, O.ItemDesc_Ara)).FirstOrDefault().ToString();
                                        string UnitSerial = DF.UnitSerial.Value.ToString();
                                        <tr style="height: 25px;" id="ShipmentsInfo_@Srial">
                                            <td class="second-col" style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="ShipmentsInfo_ItemNo">@DF.ItemNo</td>
                                            <td class="third-col" style="text-align: center !important; word-wrap: break-word; white-space: normal;border-right: 1px solid;" id="PurchOrdDF_ItemDesc">@ItemDesc</td>
                                            <td style="text-align: center;">
                                                <select class="ShipmentsInfo_ItemNo_Unit">
                                                    @{
                                                        using (var cn = new SqlConnection(Html.ConnectionString().ToString()))
                                                        {
                                                            Dt = new DataTable();
                                                            cn.Open();
                                                            using (SqlCommand cmd = new SqlCommand())
                                                            {
                                                                cmd.Connection = cn;
                                                                cmd.CommandType = System.Data.CommandType.StoredProcedure;
                                                                cmd.CommandText = "InvT_LoadItemUnits";
                                                                cmd.Parameters.Add(new SqlParameter("@CompNo", System.Data.SqlDbType.SmallInt)).Value = company.comp_num;
                                                                cmd.Parameters.Add(new SqlParameter("@ItemCode", System.Data.SqlDbType.VarChar, 20)).Value = DF.ItemNo;
                                                                using (SqlDataAdapter DA = new SqlDataAdapter(cmd))
                                                                {
                                                                    DA.Fill(Dt);
                                                                }
                                                            }
                                                        }
                                                    }
                                                    @foreach (DataRow row in Dt.Rows)
                                                    {
                                                        if (UnitSerial == row["UnitSerial"].ToString())
                                                        {
                                                            <option value="@row["UnitSerial"].ToString()" unitCode="@row["UnitCode"].ToString()" selected>
                                                                @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                            </option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@row["UnitSerial"].ToString()" unitCode="@row["UnitCode"].ToString()">
                                                                @Html.Translate(row["UnitName"].ToString(), row["UnitNameEng"].ToString())
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            @if (compMF.UseQty2 == true)
                                            {
                                                <td style="text-align:center !important">
                                                    <input id="ShipmentsInfoPO_Qty_@Srial" value="@DF.Qty" type="number" style="width:75px !important" disabled />
                                                </td>
                                                <td style="text-align:center !important;border-right: 1px solid;">
                                                    <input id="ShipmentsInfoPO_Qty2_@Srial" value="@DF.Qty2" type="number" style="width:75px !important" disabled />
                                                </td>
                                            }
                                            else
                                            {
                                                <td style="text-align:center !important;border-right: 1px solid;">
                                                    <input id="ShipmentsInfoPO_Qty_@Srial" value="@DF.Qty" type="number" style="width:75px !important" disabled />
                                                </td>
                                                <td style="text-align:center !important;border-right: 1px solid;" hidden>
