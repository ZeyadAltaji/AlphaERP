    function SelectPurchaseOrderInfo(e) {
        var table = $('#PurchaseOrderInfoTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function SelectionOrderInfoDiv() {
        var table = $('#PurchaseOrderInfoTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');

        if (trs.length == 0) {
            MsgBox('@Resources.Resource.NoPurchaseOrderWasChosen', 'red');
            done();
            return false
        }

        var OrdYear = trs[0].getAttribute('OrdYear');
        var OrderNo = trs[0].getAttribute('OrderNo');
        var TawreedNo = trs[0].getAttribute('TawreedNo');

        SelectionShipmentsInfo(OrdYear, OrderNo, TawreedNo);
    }


    function CreateShipments(OrdYear, OrdNo, TawreedNo) {
        $('#AddShipments').attr("href", '/ShipmentsInfo/AddShipments?OrdYear=' + OrdYear + '&OrderNo=' + OrdNo + '&TawreedNo=' + TawreedNo + '')
        $('#AddShipments').click();
    }
</script>






