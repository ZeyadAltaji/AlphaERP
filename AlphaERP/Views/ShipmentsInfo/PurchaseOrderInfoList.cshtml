@using System.Data.SqlClient;
@using AlphaERP.Models
@{
    int OrdYear = 0;
    if (ViewBag.OrdYear == null)
    {
        OrdYear = DateTime.Now.Year;
    }
    else
    {
        OrdYear = ViewBag.OrdYear;
    }

    User me = (User)Session["me"];
    Company company = (Company)Session["company"];

    List<PurchaseOrderInfo> lOrderInfo = new MDB().Database.SqlQuery<PurchaseOrderInfo>(string.Format("SELECT OrderHF.OrdYear,OrderHF.OrderNo ,OrderHF.TawreedNo,convert(date,OrderHF.EnterDate) as EnterDate ,OrderHF.VendorNo,OrderHF.RefNo  " +
    "FROM OrderHF " +
    "where (OrderHF.CompNo = '{0}') AND (OrderHF.OrdYear = '{1}') AND (OrderHF.Approved = 1) GROUP BY OrderHF.OrdYear,OrderHF.OrderNo ,OrderHF.TawreedNo,convert(date,OrderHF.EnterDate),OrderHF.VendorNo,OrderHF.RefNo order by OrderHF.OrdYear,OrderHF.OrderNo desc ,OrderHF.TawreedNo desc ", company.comp_num, OrdYear)).ToList();
    List<Vendor> Vend = new MDB().Vendors.Where(x => x.comp == company.comp_num && x.IsHalt == false).ToList();
}

<table class="table" id="PurchaseOrderInfoTable">
    <thead>
        <tr>
            <th>@Html.Recource(3197)</th>
            <th>@Html.Recource(3797)</th>
            <th>@Html.Recource(6315)</th>
            <th>@Html.Recource(517)</th>
            <th>@Html.Recource(96)</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="PurchaseOrderInfoTbody">
        @foreach (PurchaseOrderInfo P in lOrderInfo.OrderByDescending(o => o.TawreedNo))
        {
            Vendor v = new MDB().Vendors.Where(x => x.comp == company.comp_num && x.VendorNo == P.VendorNo).FirstOrDefault();
            <tr OrdYear="@P.OrdYear" OrderNo="@P.OrderNo" TawreedNo="@P.TawreedNo">
                <td>@P.OrderNo</td>
                <td>@P.TawreedNo</td>
                <td>@P.EnterDate.ToString("yyyy-MM-dd")</td>
                <td>@Html.Translate(v.Name,v.Eng_Name)</td>
                <td>@P.RefNo</td>
                <td>
                    <button onclick="btnex(this)" style="background-color:transparent;width:22px;padding:0" type="button" class="btn btn-default ex" title="@Html.Recource(769)">
                        <i style="font-weight:100" class="fa fa-folder"></i>
                    </button>
                    @*<button style="background-color:transparent;width:22px;padding:0" type="button" class="btn btn-default ex" title="@Html.Recource(769)">
                        <i style="font-weight:100" class="fa fa-folder"></i>
                    </button>*@
                    <button onclick="CreateShipments('@P.OrdYear','@P.OrderNo','@P.TawreedNo')"  style="background-color:transparent;width:22px;padding:0" type="button" class="btn btn-default" title=" @Html.Translate("اضافة معلومات الشحنة", "Add shipment Information")">
                        <i class="fa fa-plus"></i>
                    </button>
                    <button id="AddShipments" class="btn btn-primary btn-block" href="" target="_blank" style="display:none;">
                        @Html.Translate("الشحنات", "Shipment")
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>


<script>
    var PurchOrdTable;
    PurchOrdTable = $('#PurchaseOrderInfoTable').dataTable({
        "scrollY": 'calc( 100vh - 270px)',
        "paging": true,
        "pageLength": 25,
        "order": [[1, "desc"]],
        "language": {
            search: ' <i class="fa fa-search" aria-hidden="true"></i> '
        }
    });
    function btnex(e) {
        var nTr = e.parentNode.parentNode;
        if ($(e).attr("opened") == 'details_close') {
            PurchOrdTable.fnClose(nTr);
            $(e).attr("opened", "details_open");
        }
        else {
            wait();
            $(e).attr("opened", "details_close");
            var OrdYear = $(e.parentNode.parentNode).attr("OrdYear");
            var OrderNo = $(e.parentNode.parentNode).attr("OrderNo");
            var TawreedNo = $(e.parentNode.parentNode).attr("TawreedNo");
            $.get("../../../../ShipmentsInfo/DetailsShipmentsInfo?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo, function (data) {
                   PurchOrdTable.fnOpen(nTr, data, 'details');
                   done();
             });
        }
    }
