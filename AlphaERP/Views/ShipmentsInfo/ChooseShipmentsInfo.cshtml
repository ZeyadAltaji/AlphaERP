@using System.Data.SqlClient;
@using AlphaERP.Models

@{
    int OrdYear = ViewBag.OrdYear;
    int OrderNo = ViewBag.OrderNo;
    string TawreedNo = ViewBag.TawreedNo;

    Company company = (Company)Session["company"];
    List<Ord_OrderShippingHF> ShippingHF = new MDB().Ord_OrderShippingHF.Where(x => x.CompNo == company.comp_num && x.OrderYear == OrdYear && x.OrderNo == OrderNo && x.TawreedNo == TawreedNo).ToList();
    int Srial = 1;
}



<div class="box box-primary">
    <div class="box-body box-profile">
        <div class="modal-body row">
            <div class="form-group">
                <div class="col-md-3">
                    <button class="btn btn-primary btn-block" href="/ShipmentsInfo/AddShipments?OrdYear=@OrdYear&OrderNo=@OrderNo&TawreedNo=@TawreedNo">
                        @Html.Translate("اضافة معلومات الشحنة", "Add shipment Information")
                    </button>
                </div>
            </div>
            <div class="form-group">
                <div class="col-md-12 wrapperx" id="MRP_ShipmentsInfo_Div">
                    <table class="table table-hover MRP_ShipmentsInfo" id="ShipmentsInfoTable">
                        <thead>
                            <tr>
                                <th>@Html.Recource(3197)</th>
                                <th>@Html.Recource(3797)</th>
                                <th>@Html.Recource(696)</th>
                                <th>@Html.Recource(3832)</th>
                                <th>@Html.Recource(3833)</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody style="text-align: center;" id="ShipmentsInfoTBody">
                            @foreach (Ord_OrderShippingHF item in ShippingHF)
                            {
                              <tr id="ShipmentsInfo_@Srial">
                                  <td id="ShipmentsInfo_OrderNo_@Srial">@item.OrderNo</td>
                                  <td id="ShipmentsInfo_TawreedNo_@Srial">@item.TawreedNo</td>
                                  <td style="direction: ltr;" id="ShipmentsInfo_ShipSer_@Srial">@item.ShipSer</td>
                                  <td id="ShipmentsInfo_ShippingDate_@Srial">@item.ShippingDate.ToString("yyyy-MM-dd")</td>
                                  <td id="ShipmentsInfo_ArrivalDate_@Srial">@item.ArrivalDate.Value.ToString("yyyy-MM-dd")</td>
                                  <td>
                                      <button class="btn btn-ed ex" title="@Html.Translate("تعديل", "Edit")" href="/ShipmentsInfo/eShipmentsInfo?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer" target="_blank">
                                          <i class="fa fa-pencil-alt"></i>
                                      </button>
                                      <button class="btn btn-default ex" title="عرض" href="/ShipmentsInfo/ShipmentsView?OrdYear=@item.OrderYear&OrderNo=@item.OrderNo&TawreedNo=@item.TawreedNo&ShipSer=@item.ShipSer" target="_blank">
                                          <i style="font-weight:100" class="fa fa-folder"></i>
                                          @Html.Translate("عرض", "View")
                                      </button>
                                      <input type="hidden" id="InputSerial" value="@(Srial++)" />
                                  </td>
                              </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $('#ShipmentsInfoTable').DataTable({
        "scrollY": 300,
        "paging": true,
        "pageLength": 25
    });
</script>


