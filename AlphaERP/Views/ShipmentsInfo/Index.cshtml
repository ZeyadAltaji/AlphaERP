<script>
    $('#Model_PurchaseOrderInfo').draggable({
        handle: ".modal-header",
    });

    function Checkyear() {
        if (MRP_PurchaseOrderInfo_OrdYear.value < 2000) {
            MRP_PurchaseOrderInfo_OrdYear.value = "@DateTime.Now.Year"
            MRP_PurchaseOrderInfo_OrdYear.focus();
        }
    }

    function SerachPurchaseOrderInfo() {
        MRP_PurchaseOrderInfoDiv.innerHTML = "";
        $('#MRP_PurchaseOrderInfoDiv').load('../../../ShipmentsInfo/PurchaseOrderInfoList?OrdYear=' + MRP_PurchaseOrderInfo_OrdYear.value );
    }

    var _OrdYear = 0;
    var _OrderNo = 0;
    var _TawreedNo = 0;
    var _ShipSer = 0;

    function DeleteShipmentsInfo(OrdYear, OrderNo, TawreedNo, ShipSer) {
        if (confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            _OrdYear = OrdYear;
            _OrderNo = OrderNo;
            _TawreedNo = TawreedNo;
            _ShipSer = ShipSer;

            burn({ OrdYear: OrdYear, OrderNo: OrderNo, TawreedNo: TawreedNo, ShipSer: ShipSer }, '../../../ShipmentsInfo/Del_ShipmentsInfo', '', ReloadDelOrdShipmentsInfo, false);
        }
    }
    function ReloadDelOrdShipmentsInfo() {
        MsgBox('@Html.Recource(2598)', 'red');

        var table = $("#PurchaseOrderInfoTable tbody");
        var trs = table.find('tr');
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == _OrdYear && $(trs[i])[0].getAttribute('OrderNo') == _OrderNo && $(trs[i])[0].getAttribute('TawreedNo') == _TawreedNo) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');

                $.get("../../../../ShipmentsInfo/DetailsShipmentsInfo?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo, function (data) {
                    PurchOrdTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }

    //function SelectionShipmentsInfo(OrdYear, OrderNo, TawreedNo) {
