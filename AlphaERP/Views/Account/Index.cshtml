@{
    string lan = (string)Session["language"];
    Layout = null;

}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>@Resources.Resource.title</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="icon" href="~/Images/logo.png" type="image/x-icon">
    <link rel="stylesheet" type="text/css" href="~/Content/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/Content/font-awesome.min.css">
    @if (lan == "en")
    {
        <link rel="stylesheet" type="text/css" href="~/Content/login.css">
    }
    else
    {
        <link rel="stylesheet" type="text/css" href="~/Content/loginAr.css">
    }
    <style>
        .carousel-item {
            height: 250px;
        }
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* Firefox */
        input[type=number] {
            -moz-appearance: textfield;
        }
            input:: -webkit-outer-spin-button, input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* Firefox */
        input[type=number] {
            -moz-appearance: textfield;
        }

        #Logindiv {
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            position: relative;
        }
    </style>



    @if (lan != "en")
    {
        <style>
            body {
                direction: rtl
            }

            .input100 {
                padding: 0 68px 0 30px;
            }

            .symbol-input100 {
                padding-right: 35px;
            }
        </style>
    }
 

    <script>
        function makeid(length) {
            var result = '';
            var characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
            var charactersLength = characters.length;
            for (var i = 0; i < length; i++) {
                result += characters.charAt(Math.floor(Math.random() * charactersLength));
            }
            return result;
        }
    </script>

</head>
<body>
    <script src="~/Scripts/jquery-3.3.1.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <div class="limiter">
        <div class="container-login100">
            <div class="wrap-login100">
                <div class="login100-pic js-tilt" data-tilt="" style="font-family:Poppins-RegularE !important">
                    <div id="carouselExampleIndicators" class="carousel slide" data-ride="carousel">
                        <ol class="carousel-indicators">
                            <li data-target="#carouselExampleIndicators" data-slide-to="0" class="active"></li>
                            <li data-target="#carouselExampleIndicators" data-slide-to="1"></li>
                            <li data-target="#carouselExampleIndicators" data-slide-to="2"></li>
                        </ol>
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <p style="margin-bottom: 10px">
                                    <img src="data:image/png;base64,">
                                </p>
                                Alpha ERP
                                <x style="color:#000">AlphaERP</x>
                                <p>
                                    Design your production plan
                                </p>
                                <p>
                                    calculate all the time and materials needed
                                </p>
                            </div>

                            <div class="carousel-item">
                                <p style="margin-bottom: 10px">
                                    <img src="data:image/png;base64,">
                                </p>
                                Alpha ERP
                                <x style="color:#000">AlphaERP</x>
                                <p>
                                    The plan will go through several stages
                                </p>
                                <p>
                                    where the study and approval took place
                                </p>
                            </div>
                            <div class="carousel-item">
                                <p style="margin-bottom: 10px">
                                    <img src="data:image/png;base64,">
                                </p>
                                Alpha ERP
                                <x style="color:#000">AlphaERP</x>
                                <p>
                                    The most suitable plan of action will be chosen
                                </p>
                                <p>
                                    your business is ready to start
                                </p>
                            </div>
                        </div>

                    </div>
                    
                </div>
                <div class="login100-form validate-form" style="height:100%">
                    <form id="Logindiv" onsubmit="return validateForm()" action="../../../Account/Index" method="post">
                        <div>
                            <span class="login100-form-title">
                                @Html.Translate("تسجيل الدخول","System login")
                            </span>
                            <label style="width: 100% ; text-align: center">
                                @Resources.Resource.TypeLogin
                            </label>
                            <div class="wrap-input100 validate-input" data-validate="Valid email is required: ex@abc.xyz">
                                <input autofocus class="input100" type="text" id="Email" name="UserID" placeholder="@Resources.Resource.UserName"
                                       autocomplete="off">
                                <span class="focus-input100"></span>
                                <span class="symbol-input100">
                                    <i class="fa fa-envelope" aria-hidden="true"></i>
                                </span>
                            </div>

                            <div class="wrap-input100 validate-input" data-validate="Password is required">
                                <input class="input100" type="password" id="password" name="UserPWD" placeholder="@Resources.Resource.Password">
                                <span class="focus-input100"></span>
                                <span class="symbol-input100">
                                    <i class="fa fa-lock" aria-hidden="true"></i>
                                </span>
                            </div>
                            @{
                                string alig = "    background-position-x: left;";
                                if (Session["language"].ToString() == "en")
                                {
                                    alig = "    background-position-x: right;";
                                }
                            }
                            <div hidden style="display:none" class="wrap-input100 validate-input" data-validate="Captcha is required">
                                <input value="000000" autocomplete="off" maxlength="6" style="@alig background-image:url(../../../Account/Captcha);    background-repeat: no-repeat;background-position-y: center; unset;" class="input100" type="number" id="Captcha" name="Captcha" placeholder="@Resources.Resource.Captcha">
                                <span class="focus-input100"></span>
                                <span class="symbol-input100" onclick="alert(0)">
                                    <i style="cursor:default !important" class="fa fa-repeat" aria-hidden="true"></i>
                                </span>
                                <label onclick="RefReshCaptcha()" style="width: 50px;height: 50px;position: absolute;top: 0;">

                                </label>
                            </div>
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            <div class="container-login100-form-btn">
                                <input id="submit" type="submit" class="login100-form-btn" value="@Resources.Resource.Login" />
                            </div>
                            <div class="text-center p-t-12">
                                <a style="font-family:Poppins-RegularE !important" class="txt2" onclick="ChangeLangauge('ar-JO')"> @Resources.Resource.ChangeLan </a>
                            </div>
                            <div class="text-center p-t-12">
                                   <a class="txt2" target="_blank" href="http://gcesoft.com.jo" style="background-color: #666666;
    -webkit-background-clip: text;
    -moz-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: rgba(255, 255, 255, 0.23) -1px 2px 0px;
    pointer-events: none;user-select:none">@Resources.Resource.Copyright</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</body>
</html>
<style>
</style>



<script>
    $("#Captcha").keypress(function (event) {
        var ew = event.which;
        if (ew == 13)
            submit.click();
        if (48 <= ew && ew <= 57)
            return true;
        if (65 <= ew && ew <= 90)
            return true;
        if (97 <= ew && ew <= 122)
            return true;
        return false;
    });
    
    
    function ChangeLangauge(l) {
        $.ajax({
            type: "POST",
            url: '../../../Account/ChangeLanguage',
            data: { lanuage: l },
            success: function (response) {
                $('body').attr('data-lan', l);
                location.reload();
            },
        });
    }
    function validateForm() {
        if (Email.value.toString().trim() == "") {
            Email.focus();
            Email.select();
            return false;
        }
        if (password.value == "") {
            password.focus();
            password.select();
            return false;
        }
        if (Captcha.value.length < 6) {
            Captcha.focus();
            Captcha.select();
            return false;
        }
    }
    function RefReshCaptcha() {
        var rnd = makeid(15)
        Captcha.value = '';
        Captcha.focus();
        Captcha.style.backgroundImage = "url('../../../Account/Captcha?" + rnd + "')";
    }
    //$('.carousel').carousel();

</script>

