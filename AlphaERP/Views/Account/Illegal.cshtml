@{
    Session["language"] = "ar-JO";
    string lan = (string)Session["language"];
    
    Layout = null;

}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>@Resources.Resource.title</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="icon" href="~/Images/logo.png" type="image/x-icon">
    <link rel="stylesheet" type="text/css" href="~/Content/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/Content/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="~/Content/login.css">
    <style>
        #Logindiv {
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            position: relative;
        }
    </style>



    @if (Session["language"].ToString() != "en")
    {
        <style>
            body {
                direction: rtl
            }

            .input100 {
                padding: 0 68px 0 30px;
            }

            .symbol-input100 {
                padding-right: 35px;
            }
        </style>
    }

    <style>
        .myimg {
            background: url('data:image/png;base64,');
            height: 265px;
            width: 100%;
            background-repeat: round;
            border: 0;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    <script src="~/Scripts/jquery-3.3.1.min.js"></script>
    <div class="limiter">
        <div class="container-login100">
            <div class="wrap-login100">
                <div class="login100-pic js-tilt" data-tilt>
                    <p style="margin-bottom: 10px">
                        <img style="width: 140px;height:100px" src="data:image/png;base64,">
                    </p>
                    Alpha ERP
                    <small>SPA 2.2.00</small>
                    <p>
                        Thank you for using our ERP system
                    </p>
                    <p>
                        Full ERP web system
                    </p>
                    <label class="myimg"></label>
                </div>
                <div class="login100-form validate-form" style="height:100%">
                    <form id="Logindiv" onsubmit="return validateForm()" action="../../../Account/Index" method="post">
                        @Html.AntiForgeryToken()



                        <div>
                            <span class="login100-form-title" style="color:red">
                                <i class="fa fa-lock"></i>
                                <i class="fa fa-frown-o"></i>
                                @Resources.Resource.IllegalCopy
                            </span>
                            <label style="width: 100% ; text-align: center">
                                @Resources.Resource.ActivationError
                            </label>
                            


                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</body>
</html>
<style>
</style>


