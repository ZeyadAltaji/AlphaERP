<script>
    var DocumentsArchiveValue = 0;
    var Count = 0;
    $('#Model_DocumentsArchive').draggable({
        handle: ".modal-header",
    });
    function AddDocuments(val) {
        DocumentsArchiveValue = val;
        $('#Model_DocumentsArchive').modal('show')
    }
    function AddDocumentArchive() {
        Count++;
        var newarray = [];
        newarray.push('<input id="DocumentArchive_FileId" type="hidden" value="' + Count + '" />')
        newarray.push('<input id="DocumentArchive_Description_' + Count + '" type="text" style="width: 115px !important;text-align: center !important" />')
        newarray.push('<div class="image-upload"><label for="file-input"><span class="glyphicon glyphicon-upload" onclick="OpenFileUpload(this)"></span></label><input type="file" name="uploadFile_7" style="display:none" id="DocumentArchive_File_' + Count + '" onchange="uploadFile(this,' + Count + ')" /></div>')
        newarray.push('<input id="DocumentArchive_FileName_' + Count + '" type="text" style="text-align: center !important" disabled />')
        newarray.push('<input id="DocumentArchive_UploadDate_' + Count + '" type="text" style="width: 95px;text-align: center !important" disabled />')
        newarray.push('<input id="DocumentArchive_FileSize_' + Count + '" type="text" style="width: 70px;text-align: center !important" disabled />')
        newarray.push('<input id="DocumentArchive_FileType_' + Count + '" type="text" style="width: 55px;text-align: center !important" disabled />')
        newarray.push('<button class="btn-de" onclick="RemoveRowUpload(this,' + Count + ')" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $("#DocumentArchiveTbody").append(
            GenRowDocumentArchive(newarray, 'DocumentArchive_' + Count)
        );
    }
    function GenRowDocumentArchive(tds, Id) {
        var row = '';
        row = '<tr Id = ' + Id + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function OpenFileUpload(ID) {
        var $td = $(ID).closest("td");
        $($td).find("input[type=file]").click();
    }
    function uploadFile(Elem,Count) {
        var uploadDate = new Date($.now());
        var shortDate = moment(uploadDate).format('DD/MM/YYYY');
        var InputID = $(Elem).attr("id");
        var file_size = $(Elem)[0].files[0].size;
        var fileName = $("#DocumentArchive_File_" + Count).val().replace(/C:\\fakepath\\/i, '');
        var filetype = fileName.split('.').pop();

        var tr = $("#DocumentArchiveTbody #DocumentArchive_" + Count + "");
        tr.find('#DocumentArchive_FileName_' + Count)[0].value = fileName;
        tr.find('#DocumentArchive_UploadDate_' + Count)[0].value = shortDate;
        tr.find('#DocumentArchive_FileSize_' + Count)[0].value = file_size;
        tr.find('#DocumentArchive_FileType_' + Count)[0].value = "." + filetype;

        var $file = document.getElementById(InputID);
        $formData = new FormData();
        if ($file.files.length > 0) {
            for (var i = 0; i < $file.files.length; i++) {
                $formData.append('file-' + i, $file.files[i]);
            }
            $formData.append('Id', Count);
        }

        $.ajax({
            url: '@Url.Action("InsertFile", "ConvertToPurchOrd")',
            type: 'POST',
            data: $formData,
            contentType: false,
            processData: false,
            success: function () {
            },
            error: function (error) {
            }
        });
    }
    function RemoveRowUpload(e, Count) {
        if (confirm('@Resources.Resource.DeleteConfirm')) {
            var p = e.parentNode.parentNode;
            p.parentNode.parentNode.deleteRow(p.rowIndex);
            $.ajax({
                type: "POST",
                url:'@Url.Action("RemoveFile", "ConvertToPurchOrd")',
                data: { Id: Count },
                success: function (response) {

                },
            });

            return true;
        }
        return false;
    }
    function SaveDocumentArchive() {
        $('#Model_DocumentsArchive').modal('hide')
    }
</script>
@*--------------------------------END Model Documents -----------------------------*@

