                                <th></th>
                            </tr>
                        </thead>
                        <tbody style="text-align: center;" id="PurchaseOrdItemTBody">
                            @foreach (OrderDF OrdDF in OrdDFs)
                            {
                                InvItemsMF M = MF.Where(x => x.ItemNo == OrdDF.ItemNo).FirstOrDefault();
                                string UnitName = "";
                                switch (OrdDF.UnitSerial)
                                {
                                    case 1:
                                        UnitName = M.UnitC1;
                                        break;
                                    case 2:
                                        UnitName = M.UnitC2;
                                        break;
                                    case 3:
                                        UnitName = M.UnitC3;
                                        break;
                                    case 4:
                                        UnitName = M.UnitC4;
                                        break;

                                }

                            <tr style="height: 25px;" itemNo="@OrdDF.ItemNo" id="PurchOrdDF_Serial_@Srial">
                                <td class="first-col" style="text-align: center !important" id="PurchOrdDF_ItemSr">@OrdDF.ItemSr</td>
                                <td class="second-col" style="text-align: center !important; word-wrap: break-word; white-space: normal; " id="PurchOrdDF_ItemNo">@OrdDF.ItemNo</td>
                                <td class="third-col" style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="PurchOrdDF_ItemDesc">@Html.Translate(M.ItemDesc, M.ItemDesc_Ara)</td>
