<div class="modal fade" id="Model_ROrdPO_GLDEPMFs">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(1867)</label>
            </div>
            <div class="modal-body row">

                <div class="form-group">
                    <div class="col-md-12">
                        <table class="table table-hover" id="Select_ReqOrd_GLDEPMFsTable">
                            <thead>
                                <tr>
                                    <th style="width: 20%;">@Html.Recource(110)</th>
                                    <th style="width: 55%;">@Html.Recource(109)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    foreach (var item in GLDEPMF)
                                    {
                                        <tr onclick="Select_finGLDEPMFs(this)" ondblclick="Select_GLDEPMFs(this)" DEP_NUM="@item.DEP_NUM" DepDesc="@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()">
                                            <td style="width: 20%;">@item.DEP_NUM</td>
                                            <td style="width: 55%;">@Html.Translate(item.DEP_NAME, item.DEP_ENAME).ToString()</td>
                                            <td></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Selecting_OrdPO_GLDEPMFs()" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_ROrdPO_GLDEPMFs').draggable({
        handle: ".modal-header",
    });
    var deptId = 0;
    var GLDEPMFs = $('#Select_ReqOrd_GLDEPMFsTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    function Serach_Dept() {
        $('#Select_ReqOrd_GLDEPMFsTable tr').removeClass("selected");
        $('#Model_ROrdPO_GLDEPMFs').modal('show');
    }
    function Select_finGLDEPMFs(e) {
        var trs = GLDEPMFs.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Select_GLDEPMFs(e) {
        var trs = GLDEPMFs.$('tr[name=selected]');
        MRP_PurchaseReqHF_save_PurchaseReqDeptId.value = trs[0].getAttribute('DEP_NUM');
        MRP_PurchaseReqHF_save_PurchaseReqDeptName.value = trs[0].getAttribute('DepDesc');

        deptId = trs[0].getAttribute('DEP_NUM')
        MRP_PurchaseReqHF_save_PurchaseReqVendorNo.value = null;
        MRP_PurchaseReqHF_save_PurchaseReqVendorName.value = null;

        $('#Model_ROrdPO_GLDEPMFs').modal('hide')
    }
    function Selecting_OrdPO_GLDEPMFs() {
        var trs = GLDEPMFs.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار دائرة", "Select one Dept")');
            return;
        }

        MRP_PurchaseReqHF_save_PurchaseReqDeptId.value = trs[0].getAttribute('DEP_NUM');
        MRP_PurchaseReqHF_save_PurchaseReqDeptName.value = trs[0].getAttribute('DepDesc');

        deptId = trs[0].getAttribute('DEP_NUM')

        MRP_PurchaseReqHF_save_PurchaseReqVendorNo.value = null;
        MRP_PurchaseReqHF_save_PurchaseReqVendorName.value = null;

        $('#Model_ROrdPO_GLDEPMFs').modal('hide')
    }
    function GetDeptName(e) {

        if (deptId != e) {
            deptId = e;
            burn({ DeptNo: e }, '../../../PurchaseOrder/GetDeptName', '', LoadDeptName, true);
        }
    }
    function LoadDeptName(r) {
        if (r.DeptName == "") {
            MRP_PurchaseReqHF_save_PurchaseReqDeptId.value = null;
            MRP_PurchaseReqHF_save_PurchaseReqDeptName.value = null;
        }
        else {
            MRP_PurchaseReqHF_save_PurchaseReqDeptName.value = r.DeptName;
        }
        MRP_PurchaseReqHF_save_PurchaseReqVendorNo.value = null;
        MRP_PurchaseReqHF_save_PurchaseReqVendorName.value = null;
    }

</script>
@*----------------------ENDDept-----------------------*@

