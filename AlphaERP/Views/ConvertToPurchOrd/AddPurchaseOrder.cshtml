                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(1867)</label>
            </div>
            <div class="modal-body row" id="ROrdPO_Accbody">

            </div>
            <div class="modal-footer">
                <button type="button" onclick="Selecting_OrdPO_Acc()" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_ROrdPO_Acc').draggable({
        handle: ".modal-header",
    });
    function CheckValue(ID) {
        if (document.getElementById(ID).getAttribute('required') == 'true') {
            if (document.getElementById(ID).value == '') {
                document.getElementById(ID).focus();
                return true;
            } else {
                return false;
            }
        }
        return false;
    }
    function Serach_Vendor() {
        if (CheckValue('MRP_PurchaseReqHF_save_PurchaseReqDeptId')) {
            alert('@Html.Translate("يجب ادخال الدائرة", "You must enter the Dept")');
            return;
        }
        burn({ DeptId: MRP_PurchaseReqHF_save_PurchaseReqDeptId.value }, '../../../PurchaseOrder/Account', '', ReloadtAcc, true);
    }
    function ReloadtAcc(r) {
        ROrdPO_Accbody.innerHTML = "";
        $('#ROrdPO_Accbody').html(r);
        $('#Model_ROrdPO_Acc').modal('show');
    }
    function Select_finAcc(e) {
        var table = $('#OrdPO_AccTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Selecting_OrdPO_Acc() {
        var table = $('#OrdPO_AccTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حساب", "Select one Acc")');
            return;
        }

        MRP_PurchaseReqHF_save_PurchaseReqVendorNo.value = trs[0].getAttribute('acc_num');
        MRP_PurchaseReqHF_save_PurchaseReqVendorName.value = trs[0].getAttribute('AccDesc');
        $('#Model_ROrdPO_Acc').modal('hide')
    }
    function Select_Acc(e) {
        var table = $('#OrdPO_AccTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');

        MRP_PurchaseReqHF_save_PurchaseReqVendorNo.value = trs[0].getAttribute('acc_num');
        MRP_PurchaseReqHF_save_PurchaseReqVendorName.value = trs[0].getAttribute('AccDesc');

        $('#Model_ROrdPO_Acc').modal('hide')
    }

    function GetVendorName(e) {
        burn({ DeptNo: MRP_PurchaseReqHF_save_PurchaseReqDeptId.value, AccNo: e }, '../../../PurchaseOrder/GetVendorName', '', LoadVendorName, true);
    }
    function LoadVendorName(r) {
        if (r.VendorName == "") {
            alert('@Html.Translate("الحساب غير مربوط بالدائرة", "The Account Is Not Linked To The Department")');
            MRP_PurchaseReqHF_save_PurchaseReqVendorNo.focus();
            MRP_PurchaseReqHF_save_PurchaseReqVendorNo.value = null;
            MRP_PurchaseReqHF_save_PurchaseReqVendorName.value = null;
        }
        else {
            MRP_PurchaseReqHF_save_PurchaseReqVendorName.value = r.VendorName;
        }
    }
</script>
@*----------------------ENDAcc-----------------------*@


