            LcDept: 0,
            LcAccNo: 0,
            VouDiscount: MRP_PurchaseReqHF_save_DisTotal.value,
            PerDiscount: MRP_PurchaseReqHF_save_DisPersTotal.value,
            SourceType: MRP_PurchaseReqHF_save_CboSupplySource.value,
            GenNote: ProdCost_PurchaseReqHF_save_RequistionNotes.value,
            Approved: false,
            ETA: '@DateTime.Now.ToShortDateString()',
            ShipTerms: MRP_PurchaseReqHF_save_TermsOfShipment.value,
            ContactNo: 0,
            Port: MRP_PurchaseReqHF_save_DestinationPort.value,
            IsLC: MRP_PurchaseReqHF_save_IsLC.checked,
            FreightExpense: MRP_PurchaseReqHF_save_FreightCost.value,
            ExtraExpenses: MRP_PurchaseReqHF_save_ExtraExp.value,
            LastCost: 0,
            RefNo: MRP_PurchaseReqHF_save_RefNo.value
        };

        var OrdDF = new Array();
        var Ord_POAttachments = new Array();
        var DocumentArchive = new Array();

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value)) {
                alert('@Html.Translate("يجب إدخال الكمية", "You Must Enter Qty")');
                return;
            }
            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value)) {
                alert('@Html.Translate("يجب إدخال السعر", "You Must Enter Price")');
                return;
            }

            if (CheckValueGrid(1, $(trs[i]).closest('tr').find('#PurchOrdDF_ReqDeliveryDate_' + InputSerial)[0].value)) {
                alert('@Html.Translate("يجب إدخال تاريخ التسليم المطلوب", "You Must Enter Requested Delivery Date")');
                return;
            }

            if (CheckValueGridTotlal(1, $(trs[i]).closest('tr').find('#PurchOrdDF_Totalth_' + InputSerial)[0].innerHTML)) {
                alert('@Html.Translate("يجب أن يكون المجموع أكبر من صفر", "The Total Must be Greater Than Zero")');
                return;
            }

            if($(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value > $(trs[i]).closest('tr').find('#PurchOrdDF_OldPrice_' + InputSerial)[0].value){
                if (!confirm('@Resources.Resource.ConfirmEditPOPrice')) {
                    return;
                }
            }

            var vouDiscountPer = Number($('#MRP_PurchaseReqHF_save_DisPersTotal').val()) / 100;
            var vouDiscountPerItem = 0;
            var itemDiscVal = 0;
            var totalDiscVal = 0;
            var ItemTaxVal = 0;
            var itemTotal = 0;
            debugger;
            itemTotal = Number($(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value);
            itemDiscVal = (Number($(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_DiscPer_' + InputSerial)[0].value)) / 100;
            vouDiscountPerItem = (Number(itemTotal) - Number(itemDiscVal)) * Number(vouDiscountPer);
            ItemTaxVal = (Number($(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value) - Number(itemDiscVal) - Number(vouDiscountPerItem)) * (Number($(trs[i]).closest('tr').find('#PurchOrdDF_STax_Perc_' + InputSerial)[0].value) / 100);
            OrdDF.push({
                CompNo: '@company.comp_num',
                OrdYear: @OrdYear,
                OrderNo: @OrdNo,
                TawreedNo: @TawreedNo,
                ItemNo: $(trs[i]).closest('tr').find('#PurchOrdDF_ItemNo')[0].innerHTML,
                ItemSr: $(trs[i]).closest('tr').find('#PurchOrdDF_ItemSr')[0].innerHTML,
                PerDiscount: $(trs[i]).closest('tr').find('#PurchOrdDF_DiscPer_' + InputSerial)[0].value,
                Bonus: $(trs[i]).closest('tr').find('#PurchOrdDF_Bonus_' + InputSerial)[0].value,
                Qty: $(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value,
                Qty2: $(trs[i]).closest('tr').find('#PurchOrdDF_Qty2_' + InputSerial)[0].value,
                Price: $(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value,
                ordamt: $(trs[i]).closest('tr').find('#PurchOrdDF_Totalth_' + InputSerial)[0].innerHTML,
                RefNo: $(trs[i]).closest('tr').find('#PurchOrdDF_RefNo_' + InputSerial)[0].value,
                PUnit: $(trs[i]).closest('tr').find('#PurchOrdDF_UnitName')[0].innerHTML,
                ItemTaxVal: ItemTaxVal,
                ItemTaxPer: $(trs[i]).closest('tr').find('#PurchOrdDF_STax_Perc_' + InputSerial)[0].value,
                ItemTaxType: 1,
                VouDiscount: vouDiscountPerItem,
                UnitSerial: $(trs[i]).closest('tr').find('#PurchOrdDF_UnitName')[0].getAttribute("unitserial"),
                Note: $(trs[i]).closest('tr').find('#PurchOrdDF_ItemNote_' + InputSerial)[0].value,
                NoteDtl: $(trs[i]).closest('tr').find('#PurchOrdDF_DetailedNotes_' + InputSerial)[0].value,
                ReqDeliveryDate:$(trs[i]).closest('tr').find('#PurchOrdDF_ReqDeliveryDate_' + InputSerial)[0].value,
                ReqYear:@OrdYear,
                ReqNo:@OrdNo
            });
        }

        var OrdCondsGuaranty = {
            CompNo: '@company.comp_num',
            OrdYear: @OrdYear,
            OrderNo: @OrdNo,
            TwareedNo: @TawreedNo,
            PayCond1: MRP_PurchaseReqHF_save_txtPaymentCond1.value,
            PayCond2: MRP_PurchaseReqHF_save_txtPaymentCond2.value,
            PayCond3: MRP_PurchaseReqHF_save_txtPaymentCond3.value,
            PayCond4: MRP_PurchaseReqHF_save_txtPaymentCond4.value,
            PayCond5: MRP_PurchaseReqHF_save_txtPaymentCond5.value,
            CondPerc1: MRP_PurchaseReqHF_save_txtPaymentPerc1.value,
            CondPerc2: MRP_PurchaseReqHF_save_txtPaymentPerc2.value,
            CondPerc3: MRP_PurchaseReqHF_save_txtPaymentPerc3.value,
            CondPerc4: MRP_PurchaseReqHF_save_txtPaymentPerc4.value,
            CondPerc5: MRP_PurchaseReqHF_save_txtPaymentPerc5.value,
            Guaranty1: MRP_PurchaseReqHF_save_txtGuaranty1.value,
            Guaranty2: MRP_PurchaseReqHF_save_txtGuaranty2.value,
            Guaranty3: MRP_PurchaseReqHF_save_txtGuaranty3.value,
            Guaranty4: MRP_PurchaseReqHF_save_txtGuaranty4.value,
            Guaranty5: MRP_PurchaseReqHF_save_txtGuaranty5.value,
            GuarantyPerc1: MRP_PurchaseReqHF_save_txtGuarantyPerc1.value,
            GuarantyPerc2: MRP_PurchaseReqHF_save_txtGuarantyPerc2.value,
            GuarantyPerc3: MRP_PurchaseReqHF_save_txtGuarantyPerc3.value,
            GuarantyPerc4: MRP_PurchaseReqHF_save_txtGuarantyPerc4.value,
            GuarantyPerc5: MRP_PurchaseReqHF_save_txtGuarantyPerc5.value
        }

        var Attachmentstable = $('#AttachmentsTbody tr');
        var trsAttachments = Attachmentstable;
        for (var i = 0; i < trsAttachments.length; i++) {
            Ord_POAttachments.push({
                CompNo: '@company.comp_num',
                OrdYear: @OrdYear,
                OrdNo: @OrdNo,
                TawreedNo: @TawreedNo,
                Description: $(trsAttachments[i]).closest('tr').find('#ProdCost_PurchaseReqHF_save_AttachDescAr')[0].value,
                DescriptionEng: $(trsAttachments[i]).closest('tr').find('#ProdCost_PurchaseReqHF_save_AttachDescEn')[0].value
            })
        }

        var DocumentArchivetable = $('#DocumentArchiveTbody tr');
        var trsDocumentArchive = DocumentArchivetable;

        for (var i = 0; i < trsDocumentArchive.length; i++) {
            var InputSerial = $(trsDocumentArchive[i]).closest('tr').find('#DocumentArchive_FileId')[0].value;
            DocumentArchive.push({
                FileId: InputSerial,
                Description: $(trsDocumentArchive[i]).closest('tr').find('#DocumentArchive_Description_' + InputSerial)[0].value ,
                DateUploded: $(trsDocumentArchive[i]).closest('tr').find('#DocumentArchive_UploadDate_' + InputSerial)[0].value,
                ContentType: $(trsDocumentArchive[i]).closest('tr').find('#DocumentArchive_FileType_' + InputSerial)[0].value
            })
        }

        wait();
        burn({ BU: MRP_PurchaseReqHF_save_BusinessUnit.value, OrdHF: OrdHF, OrdDF: OrdDF, OrdCondsGuaranty: OrdCondsGuaranty, Ord_POAttachments: Ord_POAttachments, DocumentArchive: DocumentArchive }, '../../../ConvertToPurchOrd/CreatePurchaseOrder', '', ReloadPurchaseOrder, false);
    }
    function ReloadPurchaseOrder(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        CloseWindow('/ConvertToPurchOrd/AddPurchaseOrder?vendor=' + r.vendor + '&OrdYear=' + r.OrdYear + '&OrdNo=' + r.OrdNo + '&TawreedNo=' + r.TawreedNo + '');
    }

</script>