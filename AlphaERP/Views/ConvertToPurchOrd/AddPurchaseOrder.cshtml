    sumTotalAll()
    function sumTotalAll() {
        var table = $('#PurchaseOrdItemTBody tr');
        var trs = table;
        var itemTotal = 0;
        var itemTotalqty = 0;
        var totalAmount = 0;
        var vouDiscountPer = Number($('#MRP_PurchaseReqHF_save_DisPersTotal').val()) / 100;
        var vouDiscountPerItem = 0;
        var itemDiscVal = 0;
        var totalDiscVal = 0;
        var ItemTaxVal = 0;
        var totalTaxVal = 0;
        var TotalNetAmount = 0;
        var Total = 0
        var FreightCost = 0
        var ExtraExp = 0
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            itemTotalqty += Number($(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value);
            itemTotal = Number($(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value);
            itemDiscVal = (Number($(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_DiscPer_' + InputSerial)[0].value)) / 100;
            vouDiscountPerItem = (Number(itemTotal) - Number(itemDiscVal)) * Number(vouDiscountPer);
            ItemTaxVal = (Number($(trs[i]).closest('tr').find('#PurchOrdDF_Qtyth_' + InputSerial)[0].value) * Number($(trs[i]).closest('tr').find('#PurchOrdDF_Priceth_' + InputSerial)[0].value) - Number(itemDiscVal) - Number(vouDiscountPerItem)) * (Number($(trs[i]).closest('tr').find('#PurchOrdDF_STax_Perc_' + InputSerial)[0].value) / 100);
            totalAmount += Number(itemTotal)
            totalDiscVal += Number(itemDiscVal);
            totalTaxVal += Number(ItemTaxVal);
            Total = (Number(itemTotal).toFixed(3) - Number(vouDiscountPerItem).toFixed(3) - Number(itemDiscVal).toFixed(3));
            $(trs[i]).closest('tr').find('#PurchOrdDF_Total_' + InputSerial)[0].innerHTML = Number(Total).toFixed(3)
            $(trs[i]).closest('tr').find('#PurchOrdDF_Totalth_' + InputSerial)[0].innerHTML = Number(Total).toFixed(3)
            TotalNetAmount += Number($(trs[i]).closest('tr').find('#PurchOrdDF_Totalth_' + InputSerial)[0].innerHTML);
        }

        FreightCost = Number($('#MRP_PurchaseReqHF_save_FreightCost').val())
        ExtraExp = Number($('#MRP_PurchaseReqHF_save_ExtraExp').val())

        TotalNetAmount = Number(TotalNetAmount) + Number(totalTaxVal) + Number(FreightCost) + Number(ExtraExp);
        
        var ztotalAmount = addCommas(totalAmount.toFixed(3))
        $('#MRP_PurchaseReqHF_save_Amountth').val(Number(totalAmount).toFixed(3));
        $('#MRP_PurchaseReqHF_save_Amount').val(ztotalAmount);
        $('#MRP_PurchaseReqHF_save_Discountth').val(Number(totalDiscVal).toFixed(3));
        $('#MRP_PurchaseReqHF_save_Discount').val(Number(totalDiscVal).toFixed(3));
        var ztotalTaxVal = addCommas(totalTaxVal.toFixed(3))
        $('#MRP_PurchaseReqHF_save_TaxAmountth').val(Number(totalTaxVal).toFixed(3));
        $('#MRP_PurchaseReqHF_save_TaxAmount').val(ztotalTaxVal);
        var zitemTotalqty = addCommas(itemTotalqty.toFixed(3))
        
        $('#MRP_PurchaseReqHF_save_TotalQtyth').val(Number(itemTotalqty).toFixed(3));
        $('#MRP_PurchaseReqHF_save_TotalQty').val(zitemTotalqty);
        var z = addCommas(TotalNetAmount.toFixed(3))
        
        $('#MRP_PurchaseReqHF_save_NetAmountth').val(Number(TotalNetAmount).toFixed(3));
        $('#MRP_PurchaseReqHF_save_NetAmount').val(z);

        var TotDiscPer = (Number($('#MRP_PurchaseReqHF_save_DisPersTotal').val()) / 100) * ($('#MRP_PurchaseReqHF_save_Amountth').val() - $('#MRP_PurchaseReqHF_save_Discountth').val());

        $('#MRP_PurchaseReqHF_save_DisTotal').val(Number(TotDiscPer).toFixed(3));
    }

