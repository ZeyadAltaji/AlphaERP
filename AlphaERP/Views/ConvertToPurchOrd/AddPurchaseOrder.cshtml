                        <table class="table table-hover" id="ShipmentsTable">
                            <thead>
                                <tr>
                                    <th>@Html.Recource(58)</th>
                                    <th>@Html.Recource(49)</th>
                                    <th></th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="ShipmentsTbody" style="border-top: 1px solid #ddd;">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="SaveShipments()" class="btn btn-primary">@Resources.Resource.Save</button>
            </div>
        </form>
    </div>
</div>
<script>
    var ShipmentsValue = 0;
    var ShipmentItemNo = 0;
    var ShipmentItemDesc = 0;
    var ShipmentQty = 0;
    var Count = 0;
    $('#Model_Shipments').draggable({
        handle: ".modal-header",
    });
    function Shipments(val, ItemNo, ItemDesc, Qty) {
        ShipmentsValue = val;
        ShipmentItemNo = ItemNo;
        ShipmentItemDesc = ItemDesc;
        ShipmentQty = Qty;
        $('#TitleShipments')[0].innerHTML = ShipmentItemNo + ' - ' + ShipmentItemDesc + ' ( ' + ShipmentQty + ' ) '
        var trs = $('#ShipmentsTbody tr[ItemNo=' + ShipmentItemNo + ']');
        if (trs.length == 0) {
            AddShipments()
        }
        var table = $('#ShipmentsTbody tr');
        var trs = table;
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('#Shipments_ShipmentsItemNo')[0].value == ShipmentItemNo) {
                $(trs[i]).closest('tr').show();
            }
            else {
                $(trs[i]).closest('tr').hide();
            }
        }
        $('#Model_Shipments').modal('show')
    }
    function AddShipments() {
        Count++;
        var newarray = [];
        newarray.push('<input id="Shipments_ShipmentsDate" type="Date" style="width: 115px !important;text-align: center !important" value="@DateTime.Now.ToString("yyyy-MM-dd")" />')
        newarray.push('<input id="Shipments_ShipmentsQty" type="number" style="width: 65px !important;text-align: center !important" value="' + ShipmentQty + '" />')
        newarray.push('<input id="Shipments_ShipmentsItemNo" type="text" value="' + ShipmentItemNo + '" style="display:none;" />')
        newarray.push('<button class="btn-de" onclick="RemoveRow(this)" type="button"><i class= "fa fa-trash-alt"></i ></button>')
        $("#ShipmentsTbody").append(
            GenRowShipments(newarray, 'trShipments', ShipmentItemNo)
        );
    }
    function GenRowShipments(tds, Id, ItemNo) {
        var row = '';
        row = '<tr Id = ' + Id + '  ItemNo= ' + ItemNo + '>';
        for (var i = 0; i < tds.length; i++) {
            row += '<td>' + tds[i] + '</td>'
        }
        row += '</tr>'
        return row;
    }
    function SaveShipments() {
        var qty = 0
        var table = $('#ShipmentsTbody tr[ItemNo=' + ShipmentItemNo + ']');
        var trs = table;
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('#Shipments_ShipmentsItemNo')[0].value == ShipmentItemNo) {
                qty += parseFloat($(trs[i]).closest('tr').find('#Shipments_ShipmentsQty')[0].value)
            }
        }
        if (qty != ShipmentQty) {
            alert('@Html.Translate("الكمية المطلوبة لا تساوي الكمية المدخلة", "The quantity demanded is not equal to the quantity entered")');
            return false;
        }
        $('#Model_Shipments').modal('hide')
    }
</script>
@*--------------------------------END Model Shipments -----------------------------*@

