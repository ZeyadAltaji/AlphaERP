                    <th style="text-align: center !important;">@Html.Recource(1671)</th>
                    <th style="text-align:center !important">@Html.Recource(215)</th>
                    <th style="text-align:center !important" hidden>@Html.Recource(215)</th>
                    @if (CActive.ClientNo == 239)
