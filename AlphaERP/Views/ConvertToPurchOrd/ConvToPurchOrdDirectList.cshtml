<script>
    $('#ConvertToPurchOrdTable').DataTable({
        "scrollY": 'calc( 100vh - 355px)',
        "paging": false,
        "pageLength": 10,
        "order": [[0, "desc"]],
        "language": {
            search: ' <i class="fa fa-search" aria-hidden="true"></i> '
        },
    });
    $('.MRP_ConvertToPurchOrd_Vender').select2();
    $('.ProdCost_ConvertToPurchOrd_save_CboUnit').select2();
    $('.MRP_ConvertToPurchOrd_PreferredVender').select2();


    var v = $('#ProdCost_ConvertToPurchOrd_save_CboReqBU').val()
    $('#ProdCost_ConvertToPurchOrd_save_txtReqBU').val(v);
    function PurchOrdBUChange() {
        var v = $('#ProdCost_ConvertToPurchOrd_save_txtReqBU').val();
        $('#ProdCost_ConvertToPurchOrd_save_CboReqBU').val(v)
        if (document.getElementById('ProdCost_ConvertToPurchOrd_save_CboReqBU').value == '') {
            ProdCost_ConvertToPurchOrd_save_txtReqBU.value = ''
            document.getElementById('ProdCost_ConvertToPurchOrd_save_txtReqBU').focus();
            return;
        }
    }
    function myActionVendore(e, srial) {
        var table = $('.MRP_ConvertToPurchOrd #MRP_ConvertToPurchOrdTbody tr');
        var trs = table;
        var vendor = $(trs).find('#MRP_ConvertToPurchOrd_Vender_' + srial)[0].value

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('.MRP_ConvertToPurchOrd_Vender')[0].value == vendor) {
                if (e.checked == true) {
                    $(trs[i]).closest('tr').find('#MRP_ConvertToPurchOrd_Action')[0].checked = true
                }
                else {
                    $(trs[i]).closest('tr').find('#MRP_ConvertToPurchOrd_Action')[0].checked = false
                }
            }
            else {
                $(trs[i]).closest('tr').find('#MRP_ConvertToPurchOrd_Action')[0].checked = false
            }
        }
    }
    function myActionVendore_ByVenore(e, srial) {
        var table = $('.MRP_ConvertToPurchOrd #MRP_ConvertToPurchOrdTbody tr');
        var trs = table;
        var vendor = $(trs).find('#MRP_ConvertToPurchOrd_Vender_' + srial)[0].value

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('.MRP_ConvertToPurchOrd_Vender')[0].value == vendor) {
                if (e.checked == true) {
                    $(trs[i]).closest('tr').find('#MRP_ConvertToPurchOrd_Action')[0].checked = true
                }
                else {
                    $(trs[i]).closest('tr').find('#MRP_ConvertToPurchOrd_Action')[0].checked = false
                }
            }
            else {
                $(trs[i]).closest('tr').find('#MRP_ConvertToPurchOrd_Action')[0].checked = false
            }
        }
    }
    function ChangeQty(e,Id) {
        if (Number(e.value) > Number($('#OrdDF_Qtythold_' +Id)[0].value)) {
            alert("لا يجوز ان تكون كمية امر الشراء اكبر من كمية طلب الشراء");
            $('#OrdDF_Qty_'+ Id)[0].value = $('#OrdDF_Qtythold_' + Id)[0].value;
            return false;
        }

        
        $('#OrdDF_Qtyth_' + Id)[0].value = e.value
        var temp = parseFloat(validDigits(e.value));
        var temp1 = addCommas(temp.toFixed(3))
        $('#OrdDF_Qty_'+ Id)[0].value = temp1;

        var Qtyth = parseFloat(validDigits($('#OrdDF_Qtyth_'+ Id)[0].value)) ;
        var Price = parseFloat(validDigits( $('#OrdDF_Priceth_'+ Id)[0].innerHTML)) ;

        var total = Number(Qtyth) *  Number(Price);
        $('#OrdDF_TatalValueth_'+ Id)[0].innerHTML = total;
        var temptotal = addCommas(total.toFixed(3))
        $('#OrdDF_TatalValue_'+ Id)[0].innerHTML = temptotal;
        SumTotal();
    }
    function SumTotal() {
        var table = $('#MRP_ConvertToPurchOrdTbody tr');
        var trs = table;
        var Total = 0
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            if ($(trs[i]).closest('tr').find('#MRP_ConvertToPurchOrd_Action')[0].checked == true) {
                Total += Number($(trs[i]).closest('tr').find('#OrdDF_TatalValueth_' + InputSerial)[0].innerHTML);
            }
        }

        var z = addCommas(Total.toFixed(3));
        $('#MRP_ConvertToPurchOrd_save_Amount').val(z);
    }
    function validDigits(n, dec) {
        n = n.replace(/[^\d\.]+/g, '');
        var ax1 = n.indexOf('.'), ax2 = -1;
        if (ax1 != -1) {
            ++ax1;
            ax2 = n.indexOf('.', ax1);
            if (ax2 > ax1) n = n.substring(0, ax2);
            if (typeof dec === 'number') n = n.substring(0, ax1 + dec);
        }
        return n;
    }
    function addCommas(n) {
        var rx = /(\d+)(\d{3})/;
        return String(n).replace(/^\d+/, function (w) {
            while (rx.test(w)) {
                w = w.replace(rx, '$1,$2');
            }
            return w;
        });
    }
    function CheckValue(ID) {
        if (document.getElementById(ID).getAttribute('required') == 'true') {
            if (document.getElementById(ID).value == '') {
                document.getElementById(ID).focus();
                return true;
            } else {
                return false;
            }
        }
        return false;
    }
    function CreatePurchOrder() {
        if (MRP_ConvertToPurchOrd_PreferredVender.value == "") {
            MRP_ConvertToPurchOrd_PreferredVender.focus();
            alert('@Html.Translate("يجب اختيار المورد", "Vender must be selected")');
            return false;
        }

        if (ProdCost_ConvertToPurchOrd_save_CboReqBU.value == "") {
            ProdCost_ConvertToPurchOrd_save_CboReqBU.focus();
            alert('@Html.Translate("يجب اختيار وحدة العمل", "Work unit must be selected")');
            return false;
        }

        var OrdReqDF = new Array();

        $('.MRP_ConvertToPurchOrd #MRP_ConvertToPurchOrdTbody tr').each(function () {
            var InputSerial = $(this).find('#InputSerial')[0].value;
            if ($(this).find('#MRP_ConvertToPurchOrd_Action').is(':checked') == true) {
                debugger
                var Qty = 0;
                if ('@DivisionPurchaseOrder' == 'True') {
                    Qty = $(this).find('#OrdDF_Qtyth_' + InputSerial)[0].value;
                }
                else {
                    Qty = $(this).find('#OrdDF_Qtyth').html();
                }
                OrdReqDF.push({
                    ReqYear: $(this).find('#OrdDF_ReqYear')[0].value,
                    ReqNo: $(this).find('#OrdDF_ReqNo')[0].value,
                    OrderType: $(this).find('#OrdDF_OrderType')[0].value,
                    prefvendor: MRP_ConvertToPurchOrd_PreferredVender.value,
                    SubItemNo: $(this).find('#OrdDF_ItemNo').html(),
                    ItemSr: $(this).find('#OrdDF_ItemSrl')[0].value,
                    Qty: Qty,
                    Qty2: $(this).find('#OrdDF_Qty2').html(),
                    Price: $(this).find('#OrdDF_Priceth_'+ InputSerial).html(),
                    TotalValue: $(this).find('#OrdDF_TatalValueth_'+ InputSerial).html(),
                    SubUnitSerial: $(this).find('#OrdDF_SubUnitSerial')[0].value,
                    Note: $(this).find('#OrdDF_Note').html(),
                });
            }
        });
        debugger
        if (OrdReqDF.length == 0) {
            MsgBox('@Resources.Resource.NoItemWasSelected', 'red');
            return false
        }

        wait();
        if (confirm('@Resources.Resource.ConfirmCreatePurchaseOrder')) {
            burn({ BU: ProdCost_ConvertToPurchOrd_save_CboReqBU.value, OrdReqDF: OrdReqDF }, '../../../ConvertToPurchOrd/CreatePurchOrder', '', ReloadCreatePurchOrder, false);
        }
        else {
            done();
        }
    }
    function ReloadCreatePurchOrder(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        $('#Ordvendor').val(r.vendor);
        $('#orderyear').val(r.OrdYear);
        $('#OrdNo').val(r.OrdNo);
        $('#TawreedNo').val(r.TawreedNo);
        $('#AddPurchaseOrder').attr("href", '/ConvertToPurchOrd/AddPurchaseOrder?vendor=' + $('#Ordvendor').val() + '&OrdYear=' + $('#orderyear').val() + '&OrdNo=' + $('#OrdNo').val() + '&TawreedNo=' + $('#TawreedNo').val() + '')
        $('#AddPurchaseOrder').click();
        ConvertToPurchOrdSerach()
    }


</script>


<div class="modal fade" id="Model_PO_RejectReason">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-12">
                        <div class="col-md-3">
                            <label class="unselectable" for="ProdCost_PurchaseReqHF_save_ReturnReason">@Html.Translate("سبب الارجاع", "Return Reason")</label>
                        </div>
                        <div class="col-md-4" style="margin-bottom: 5px;">
                            <input required="false" style="width:410px !important;" type="text" id="ProdCost_PurchaseReqHF_save_ReturnReason" placeholder="@Html.Translate("سبب الارجاع", "Return Reason")" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="ExcuteSaveProd_ReturnReason()" class="btn btn-danger">@Html.Translate("الغاء", "Reject")</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>

<script>
    $('#Model_PO_RejectReason').draggable({
        handle: ".modal-header",
    });

    var _ReqYear = 0;
    var _ReqNo = 0;
    var _ItemNo = 0;
    function Cancelling_PurchaseRequest(ReqYear, ReqNo, ItemNo) {
        _ReqYear = ReqYear;
        _ReqNo = ReqNo;
        _ItemNo = ItemNo;
        if (confirm('@Resources.Resource.CancelPurchaseOrders')) {
            ProdCost_PurchaseReqHF_save_ReturnReason.value = ''
            $('#Model_PO_RejectReason').modal('show')
        }
    }
    function ExcuteSaveProd_ReturnReason() {
        if (ProdCost_PurchaseReqHF_save_ReturnReason.value == '') {
            alert('@Html.Translate("يجب إدخال سبب الارجاع", "Return reason must be entered")');
            return false;
        }
        wait();
        burn({ ReqYear: _ReqYear, ReqNo: _ReqNo, ItemNo: _ItemNo, ReturnReason: $('#ProdCost_PurchaseReqHF_save_ReturnReason')[0].value }, '../../../ConvertToPurchOrd/Return_PurchaseRequest', '', ReloadReturnPurchaseRequest, false);
    }
    function ReloadReturnPurchaseRequest() {
        done();
        $('#Model_PO_RejectReason').modal('hide')
        ConvertToPurchOrdSerach()
    }
</script>


<div class="modal fade" id="Model_ConvertToPurchOrd_DocumentsArchive">
    <div class="modal-dialog" style="width:800px; ">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Translate("أرشفة الوثائق", "Archive Documents")</label>
            </div>
            <div class="modal-body row">
                <div class="form-group">
                    <div class="col-md-12" style="overflow-y:auto" id="ConvertToPurchOrd_DocumentsArchiveDiv">
                        
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_ConvertToPurchOrd_DocumentsArchive').draggable({
        handle: ".modal-header",
    });
    function Attach_PurchaseRequest(ReqYear,ReqNo) {
        ConvertToPurchOrd_DocumentsArchiveDiv.innerHTML = "";
        $('#ConvertToPurchOrd_DocumentsArchiveDiv').load('../../../ConvertToPurchOrd/AttachPurchaseRequest?ReqYear=' + ReqYear + '&ReqNo=' + ReqNo);
        $('#Model_ConvertToPurchOrd_DocumentsArchive').modal('show');
    }
   
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    }
    
</script>



