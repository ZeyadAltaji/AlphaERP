                    double? Qty = Orddf == null ? 0 : new MDB().Ord_LinkRquestDFAndPO.Where(x => x.CompNo == company.comp_num && x.ReqYear == OrdDF.ReqYear && x.ReqNo == OrdDF.ReqNo
                     && x.ItemNo == OrdDF.SubItemNo).Sum(o => o.Qty).Value;

                    double? TotalQty = OrdDF.Qty - Qty;

                    switch (OrdDF.SubUnitSerial)
                    {
                        case 1:
                            UnitName = M.UnitC1;
                            break;
                        case 2:
                            UnitName = M.UnitC2;
                            break;
                        case 3:
                            UnitName = M.UnitC3;
                            break;
                        case 4:
                            UnitName = M.UnitC4;
                            break;

                    }
                    switch (HF.OrderPriority)
                    {
                        case 0:
                            OrderPriorityDeesc = Html.Translate("عادي", "Normal").ToString();
                            break;
                        case 1:
