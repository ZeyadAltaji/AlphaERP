                    }
                    else
                    {
                        PrdType = new MDB().Database.SqlQuery<PayCodes>(string.Format("select MinCode as sys_minor ,CodeDesc as DescAr,isnull(CodeDescEng,'No Desc.') as DescEn from InvCodes where (CompNo = '{0}') AND (MajCode = 'PrdType') AND  (MinCode = '{1}')", company.comp_num, HF.OrderType)).FirstOrDefault();
                    }
                    <tr style="height: 25px;" itemNo="@OrdDF.SubItemNo">
                        <td style="text-align: center !important" data-tooltip="sticky_@i">@HF.ReqNo</td>
                        <td style="text-align: center !important">
                            <input type="hidden" value="@HF.OrderType" id="OrdDF_OrderType" />
                            @Html.Translate(PrdType.DescAr, PrdType.DescEn)
                        </td>
                        <td style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="OrdDF_RefNo">@HF.RefNo</td>
                        <td style="text-align: center !important; word-wrap: break-word; white-space: normal;" id="OrdDF_ItemNo">@OrdDF.SubItemNo</td>
                        <td style="text-align: center !important;word-wrap: break-word;white-space: normal;" title="@ItemDesc">@ItemDesc</td>
                        <td style="text-align: center !important">@OrdDF.ReqDeliveryDate.ToShortDateString()</td>
                        <td style="text-align: center !important" SubUnitSerial="@OrdDF.SubUnitSerial">@UnitName</td>
                         @if (ordCompMF.IsDivisionPurchaseOrder == true)
                         {
                            <td style="text-align: center !important">
                                <input id="OrdDF_Qty_@i" value="@TotalQty.Value.ToString("n2")" type="text" style="width:75px !important" onblur="ChangeQty(this,@i)" />
                            </td>
                            <td hidden>
                                <input id="OrdDF_Qtythold_@i" value="@TotalQty.Value" type="text" style="width:75px !important" hidden />
                                <input id="OrdDF_Qtyth_@i" value="@TotalQty.Value" type="text" style="width:75px !important" hidden />
                            </td>
                         }
                         else
                         {
                            <td style="text-align: center !important" id="OrdDF_Qty">@TotalQty.Value.ToString("n2")</td>
                            <td style="text-align: center !important" id="OrdDF_Qtyth" hidden>@TotalQty.Value</td>
                         }
                        
                        @if (compMF.UseQty2 == true)
                        {
                            <td style="text-align: center !important" id="OrdDF_Qty2">@OrdDF.Qty2</td>
                        }
                        else
                        {
                            <td style="text-align: center !important" id="OrdDF_Qty2" hidden>@OrdDF.Qty2</td>
                        }
                        <td style="text-align:center !important">@Html.Translate(Currency.DescAr, Currency.DescEn)</td>
                        <td style="text-align: center !important" id="OrdDF_Price_@i">@OrdDF.Price.Value.ToString("n2")</td>
                        <td style="text-align: center !important" id="OrdDF_Priceth_@i" hidden>@OrdDF.Price.Value</td>
                        @if (CActive.ClientNo == 239)
                        {
                            <td style="text-align: center !important;word-wrap: break-word;white-space: normal;" title="@OrdDF.Note" id="OrdDF_Note">@OrdDF.Note</td>
                        }
                        else
                        {
                            <td style="text-align: center !important;word-wrap: break-word;white-space: normal;">
                               @Html.Translate(BUDESC.DescAr, BUDESC.DescEn)
                            </td>
                        }
                        <td style="text-align: center !important" id="OrdDF_TatalValue_@i">@TatalValue.Value.ToString("n2")</td>
                        <td style="text-align: center !important" id="OrdDF_TatalValueth_@i" hidden>@TatalValue</td>
                        <td style="text-align:center!important">
                            <input id="MRP_ConvertToPurchOrd_Action" type="checkbox" onchange="SumTotal()">
                            <button class="btn-de" onclick="Cancelling_PurchaseRequest('@OrdDF.ReqYear','@OrdDF.ReqNo','@OrdDF.SubItemNo')" title=@Html.Translate("إرجاع","Return")>
                                <i class="fa fa-times-circle"></i>
                            </button>
                            <button class="btn btn-ed ex" onclick="Attach_PurchaseRequest('@OrdDF.ReqYear','@OrdDF.ReqNo')" title=@Html.Translate("إرجاع","Return")>
                                <i class="fa fa-paperclip" aria-hidden="true"></i>
                            </button>
                            <input type="hidden" id="InputSerial" value="@(i++)" />
                            <input type="hidden" id="OrdDF_ReqYear" value="@OrdDF.ReqYear" />
                            <input type="hidden" id="OrdDF_SubUnitSerial" value="@OrdDF.SubUnitSerial" />
                            <input type="hidden" id="OrdDF_ReqNo" value="@OrdDF.ReqNo" />
                            <input type="hidden" id="OrdDF_ItemSrl" value="@OrdDF.ItemSr" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



