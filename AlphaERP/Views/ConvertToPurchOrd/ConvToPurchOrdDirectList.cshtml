@{
    int i = 1;
}
<div class="form-group">
    <div class="col-md-12 wrapperx" id="MRP_ConvertToPurchOrd_DIV">
        <table class="table table-hover MRP_ConvertToPurchOrd" id="ConvertToPurchOrdTable">
            <thead>
                <tr>
                    <th style="text-align: center !important;">@Html.Recource(3197)</th>
                    <th style="text-align: center !important;">@Html.Recource(3265)</th>
                    <th style="text-align: center !important;">@Html.Recource(96)</th>
                    <th style="text-align: center !important;">@Html.Recource(44)</th>
                    <th style="text-align: center !important; ">@Html.Recource(74)</th>
                    <th style="text-align: center !important;">@Html.Translate("تاريخ التسليم المطلوب", "Requested Delivery Date")</th>
                    <th>@Html.Recource(67)</th>
                    @if (CActive.ClientNo == 335)
                    {
                        <th>@Html.Recource(5693)</th>
                    }
                    else
                    {
                        <th>@Html.Recource(49)</th>
                        <th hidden>@Html.Recource(49)</th>

                    }
                    @if (compMF.UseQty2 == true)
                    {
                        if (CActive.ClientNo == 335)
                        {
                            <th>@Html.Recource(442)</th>
                        }
                        else
                        {
                            <th>@Html.Recource(72)</th>
                        }
