<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-6">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="MRP_ConvertToPurchOrd_DirectPurchaseOrder">
                    <input id="MRP_ConvertToPurchOrd_DirectPurchaseOrder" type="radio" name="MRP_ConvertToPurchOrdRadio" checked onchange="GetConvertToPurchOrd()">
                    @Resources.Resource.Direct
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="MRP_ConvertToPurchOrd_InDirectPurchaseOrder">
                    <input name="MRP_ConvertToPurchOrdRadio" type="radio" id="MRP_ConvertToPurchOrd_InDirectPurchaseOrder" onchange="GetConvertToPurchOrd()" />
                    @Resources.Resource.InDirect
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable"></label>
                <button class="btn btn-success btn-block" onclick="ConvertToPurchOrdSerach()">
                    @Resources.Resource.Search
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="ConvertToPurchOrdDirectDiv" style="display:none">

    </div>
    <div class="box-body box-profile" id="ConvertToPurchOrdInDirectDiv" style="display:none">

    </div>
</div>


<div class="modal fade" id="Model_ConvertToPurchOrdInDirectInfo">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="box-body box-profile" id="ConvertToPurchOrdInDirectInfoDiv">

            </div>
        </form>
    </div>
</div>


<script>
    ConvertToPurchOrdSerach()
    function ConvertToPurchOrdSerach() {
        if (MRP_ConvertToPurchOrd_DirectPurchaseOrder.checked == true) {
            ConvertToPurchOrdDirectDiv.innerHTML = "";
            ConvertToPurchOrdInDirectDiv.innerHTML = "";
            $("#ConvertToPurchOrdInDirectDiv").css("display", "none");
            $("#ConvertToPurchOrdDirectDiv").css("display", "block");
            $('#ConvertToPurchOrdDirectDiv').load('../../../ConvertToPurchOrd/GetPurchOrd?PurchOrd=0');
        }
        if (MRP_ConvertToPurchOrd_InDirectPurchaseOrder.checked == true) {
            $("#ConvertToPurchOrdDirectDiv").css("display", "none");
            $("#ConvertToPurchOrdInDirectDiv").css("display", "block");
            ConvertToPurchOrdInDirectInfoDiv.innerHTML = "";
            ConvertToPurchOrdInDirectDiv.innerHTML = "";
            $('#ConvertToPurchOrdInDirectInfoDiv').load('../../../ConvertToPurchOrd/PurchOrdList');
            $('#Model_ConvertToPurchOrdInDirectInfo').modal('show');
        }
    }
    function AddPurchOrdInDirect(ReqYear, ReqNo) {
        wait();
        burn({ ReqYear: ReqYear, ReqNo: ReqNo }, '../../../ConvertToPurchOrd/PurchOrdInDirect', '', LoadPurchOrdInDirect, true);
    }
    function LoadPurchOrdInDirect(r) {
        ConvertToPurchOrdInDirectDiv.innerHTML = "";
        $('#ConvertToPurchOrdInDirectDiv').html(r);
        $('#Model_ConvertToPurchOrdInDirectInfo').modal('hide');
        done();
    }
    function GetConvertToPurchOrd() {
        ConvertToPurchOrdSerach()
    }
    function PurchOrdDirect(r) {
       
    }
    function PurchOrdInDirect(r) {
        ConvertToPurchOrdDirectDiv.innerHTML = "";
        ConvertToPurchOrdInDirectDiv.innerHTML = "";
        $("#ConvertToPurchOrdDirectDiv").css("display", "none");
        $("#ConvertToPurchOrdInDirectDiv").css("display", "block");
        $('#ConvertToPurchOrdInDirectDiv').html(r);
        done();
    }

</script>