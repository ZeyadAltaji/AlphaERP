        <Name>MRP_GeneralPlanInfoH</Name>
        <NameInSource>MS SQL</NameInSource>
        <Parameters isList="true" count="3">
          <value>_x0040_CompNo,CompNo,16,0</value>
          <value>_x0040_PlanYear,PlanYear,16,0</value>
          <value>_x0040_PlanNo,PlanNo,8,0</value>
        </Parameters>
        <SqlCommand>select *,DATEDIFF(DAY,StartDate , EndDate) as Difference from MRP_GeneralPlanInfoH where CompNo=@CompNo and PlanYear = @PlanYear and PlanNo = @PlanNo</SqlCommand>
