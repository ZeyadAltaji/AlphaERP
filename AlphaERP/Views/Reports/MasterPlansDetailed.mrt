          <value>FormulaCode,System.String</value>
          <value>FromDate,System.DateTime</value>
          <value>ToDate,System.DateTime</value>
          <value>Qty,System.Decimal</value>
          <value>Sr,System.Int32</value>
        </Columns>
        <CommandTimeout>30</CommandTimeout>
        <Dictionary isRef="1" />
        <Key>c9cfb3b879004d75af70b5ec92561664</Key>
        <Name>SubDetails</Name>
        <NameInSource>MS SQL</NameInSource>
        <Parameters isList="true" count="3">
          <value>CompNo,CompNo,8,20</value>
          <value>PlanYear,PlanYear,8,20</value>
          <value>PlanNo,PlanNo,8,20</value>
        </Parameters>
        <SqlCommand>SELECT        CompNo, PlanYear, PlanNo, Sr, FormulaCode, ItemNo, FromDate, ToDate, Qty
	FROM            MRP_GeneralPlanSubDtls
	WHERE        (CompNo = @CompNo) AND (PlanYear = @PlanYear) AND (PlanNo = @PlanNo)
ORDER BY ItemNo,Sr 
</SqlCommand>
      </SubDetails>
    </DataSources>
