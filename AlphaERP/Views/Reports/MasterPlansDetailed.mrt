    <DataSources isList="true" count="4">
      <header Ref="3" type="Stimulsoft.Report.Dictionary.StiSqlSource" isKey="true">
        <Alias>header</Alias>
        <Columns isList="true" count="8">
          <value>CompNo,System.Int32</value>
          <value>PlanYear,System.Int32</value>
          <value>PlanNo,System.Int32</value>
          <value>StartDate,System.DateTime</value>
          <value>EndDate,System.DateTime</value>
          <value>PlanNotes,System.String</value>
          <value>daysNo,System.Int32</value>
          <value>PlanActive,System.String</value>
        </Columns>
        <CommandTimeout>30</CommandTimeout>
        <Dictionary isRef="1" />
        <Key>060fa079c56240c7b534c3655a88b703</Key>
        <Name>header</Name>
        <NameInSource>MS SQL</NameInSource>
        <Parameters isList="true" count="3">
          <value>CompNo,CompNo,8,20</value>
          <value>PlanYear,PlanYear,8,20</value>
          <value>PlanNo,PlanNo,8,20</value>
        </Parameters>
        <SqlCommand>SELECT        CompNo, PlanYear, PlanNo,convert(date,StartDate) as StartDate,convert(date,EndDate) as EndDate, PlanNotes,DATEDIFF(DD, CONVERT(date,StartDate), convert(date,EndDate)) AS daysNo,
	case when PlanActive = 1 then 'فعال' else 'غير فعال' end as PlanActive
FROM          MRP_GeneralPlanInfoH
WHere        (MRP_GeneralPlanInfoH.CompNo = @CompNo) AND (MRP_GeneralPlanInfoH.PlanYear = @PlanYear) AND (MRP_GeneralPlanInfoH.PlanNo = @PlanNo)</SqlCommand>
      </header>
      <Details Ref="4" type="Stimulsoft.Report.Dictionary.StiSqlSource" isKey="true">
        <Alias>Details</Alias>
        <Columns isList="true" count="9">
          <value>CompNo,System.Int32</value>
          <value>PlanYear,System.Int32</value>
          <value>PlanNo,System.Int32</value>
          <value>ItemNo,System.String</value>
          <value>FormulaCode,System.String</value>
          <value>UnitCode,System.String</value>
          <value>ItemDesc,System.String</value>
          <value>formula_desc,System.String</value>
          <value>PQty,System.Decimal</value>
        </Columns>
        <CommandTimeout>30</CommandTimeout>
        <Dictionary isRef="1" />
        <Key>b3caa58f1ede4fa1b33af889a44fb2b5</Key>
        <Name>Details</Name>
        <NameInSource>MS SQL</NameInSource>
        <Parameters isList="true" count="3">
          <value>CompNo,CompNo,8,20</value>
          <value>PlanYear,PlanYear,8,20</value>
          <value>PlanNo,PlanNo,8,20</value>
        </Parameters>
        <SqlCommand>SELECT        MRP_GeneralPlanInfoD.CompNo, MRP_GeneralPlanInfoD.PlanYear, MRP_GeneralPlanInfoD.PlanNo, MRP_GeneralPlanInfoD.FormulaCode, MRP_GeneralPlanInfoD.ItemNo, MRP_GeneralPlanInfoD.PQty, 
	CASE WHEN isnull(prod_formula_header_info_1.comp_no, 0) 
                         = 0 THEN UnitC4 ELSE CASE WHEN prod_formula_header_info.UnitSerial = 1 THEN InvItemsMF.UnitC1 ELSE CASE WHEN prod_formula_header_info.UnitSerial = 2 THEN InvItemsMF.UnitC2 ELSE CASE WHEN prod_formula_header_info.UnitSerial
                          = 3 THEN InvItemsMF.UnitC3 ELSE InvItemsMF.UnitC1 END END END END AS UnitCode, InvItemsMF.ItemDesc, InvItemsMF.ItemDesc_Ara, prod_formula_header_info.formula_desc
FROM            MRP_GeneralPlanInfoD INNER JOIN
                         InvItemsMF ON MRP_GeneralPlanInfoD.CompNo = InvItemsMF.CompNo AND MRP_GeneralPlanInfoD.ItemNo = InvItemsMF.ItemNo INNER JOIN
                         prod_formula_header_info ON MRP_GeneralPlanInfoD.CompNo = prod_formula_header_info.comp_no AND MRP_GeneralPlanInfoD.FormulaCode = prod_formula_header_info.formula_code INNER JOIN
                         MRP_GeneralPlanInfoH ON MRP_GeneralPlanInfoD.CompNo = MRP_GeneralPlanInfoH.CompNo AND MRP_GeneralPlanInfoD.PlanYear = MRP_GeneralPlanInfoH.PlanYear AND 
                         MRP_GeneralPlanInfoD.PlanNo = MRP_GeneralPlanInfoH.PlanNo LEFT OUTER JOIN
                         prod_formula_header_info AS prod_formula_header_info_1 ON MRP_GeneralPlanInfoD.ItemNo = prod_formula_header_info_1.formula_code AND 
                         MRP_GeneralPlanInfoD.CompNo = prod_formula_header_info_1.comp_no
WHERE        (MRP_GeneralPlanInfoD.CompNo = @CompNo) AND (MRP_GeneralPlanInfoD.PlanYear = @PlanYear) AND (MRP_GeneralPlanInfoD.PlanNo = @PlanNo)</SqlCommand>
      </Details>
      <Company Ref="5" type="Stimulsoft.Report.Dictionary.StiSqlSource" isKey="true">
        <Alias>Company</Alias>
        <Columns isList="true" count="9">
          <value>comp_num,System.Int32</value>
          <value>comp_name,System.String</value>
          <value>comp_ename,System.String</value>
          <value>comp_logo,System.Drawing.Image</value>
          <value>comp_logo1,System.Drawing.Image</value>
          <value>comp_logo2,System.Drawing.Image</value>
          <value>comp_logo3,System.Drawing.Image</value>
          <value>DateNow,System.DateTime</value>
          <value>TimeNow,System.String</value>
        </Columns>
        <CommandTimeout>30</CommandTimeout>
        <Dictionary isRef="1" />
        <Key>811d6d27c557445cbf5f93bcefc90343</Key>
        <Name>Company</Name>
        <NameInSource>MS SQL</NameInSource>
        <Parameters isList="true" count="1">
          <value>CompNo,CompNo,8,20</value>
        </Parameters>
        <SqlCommand>SELECT     COMPANY.comp_num, COMPANY.comp_name, COMPANY.comp_ename,
	COMPANY.comp_logo  As comp_logo
	, COMPANY.comp_logo1 As comp_logo1
	, COMPANY.comp_logo2 As comp_logo2
	, COMPANY.comp_logo3 As comp_logo3
	, Convert(date,GETDATE()) as DateNow
    ,Convert(varchar,GETDATE(),108) as TimeNow
	

				
	FROM         COMPANY LEFT OUTER JOIN
                      GLCOMMF ON COMPANY.comp_num = GLCOMMF.GLCOM_COMNUM LEFT OUTER JOIN
                      ClientsActive ON COMPANY.comp_num = ClientsActive.CompNo LEFT OUTER JOIN
                      CurrType ON GLCOMMF.CurrType = CurrType.CurrType LEFT OUTER JOIN
                      InvCompMF ON COMPANY.comp_num = InvCompMF.CompNo
WHERE     (COMPANY.comp_num = @CompNo)</SqlCommand>
      </Company>
      <SubDetails Ref="6" type="Stimulsoft.Report.Dictionary.StiSqlSource" isKey="true">
        <Alias>SubDetails</Alias>
        <Columns isList="true" count="9">
          <value>CompNo,System.Int32</value>
