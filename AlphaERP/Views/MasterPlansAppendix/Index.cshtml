<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-8">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="SAVE_MasterPlansAppendix_Year">@Resources.Resource.Year </label>
                <input style="width:165px !important;" oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);" required="true" type="number" id="SAVE_MasterPlansAppendix_Year" value="@DateTime.Now.Year" placeholder="@Resources.Resource.Year" onblur="Checkyear()" maxLength="4" />
            </div>
            <div class="col-md-2">
                <label class="unselectable"></label>
                <button class="btn btn-success btn-block" onclick="SerachAllProductionPlan()">
                    @Resources.Resource.Search
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="AllProductionPlanAppendixDiv">

    </div>
</div>
<div class="modal fade" id="Model_AllProductionPlan">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="box-body box-profile" id="AllProductionPlanDiv">

            </div>

        </form>
    </div>
</div>
<div class="modal fade" id="Model_ProductionPlanAppendix">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="box-body box-profile" id="ProductionPlanAppendixDiv">

            </div>

        </form>
    </div>
</div>

<script>
    $('#Model_AllProductionPlan').draggable({
        handle: ".modal-header",
    });
    $('#Model_ProductionPlanAppendix').draggable({
        handle: ".modal-header",
    });
    function CheckValue(ID) {
        if (document.getElementById(ID).getAttribute('required') == 'true') {
            if (document.getElementById(ID).value == '') {
                document.getElementById(ID).focus();
                return true;
            } else {
                return false;
            }
        }
        return false;
    }
    function Checkyear() {
        if (SAVE_MasterPlansAppendix_Year.value < 2000) {
            SAVE_MasterPlansAppendix_Year.value = "@DateTime.Now.Year"
            SAVE_MasterPlansAppendix_Year.focus();
        }
    }
    function SerachAllProductionPlan() {
        if (CheckValue('SAVE_MasterPlansAppendix_Year')) { return; }
        AllProductionPlanDiv.innerHTML = "";
        AllProductionPlanAppendixDiv.innerHTML = "";
        $('#AllProductionPlanDiv').load('../../../MasterPlansAppendix/AllProductionPlan?year=' + SAVE_MasterPlansAppendix_Year.value);
        $('#Model_AllProductionPlan').modal('show');
    }
    function AddProdPlanDetialsisDiv(PlanYear, PlanNo) {
        wait();
        burn({ Planyear: PlanYear, PlanNo: PlanNo }, '../../../MasterPlansAppendix/ProdPlanDetails', '', LoadSpecificPlan, true);
    }
    function LoadSpecificPlan(r) {
        AllProductionPlanAppendixDiv.innerHTML = "";
        $('#AllProductionPlanAppendixDiv').html(r);
        $('#Model_AllProductionPlan').modal('hide');
        done();
    }
    function AddSubDetalis(PlanYear, PlanNo, ItemNo, ItemDesc, FormulaCode, FormulaDesc, Unit, qty, StartDate, EndDate) {
        var Item = {
            PlanYear: PlanYear,
            PlanNo: PlanNo,
            ItemNo: ItemNo,
            ItemDesc: ItemDesc,
            FormulaCode: FormulaCode,
            formula_desc: FormulaDesc,
            UnitDesc: Unit,
            PQty: qty,
            StartDate: StartDate,
            EndDate: EndDate
        }

        wait();
        burn({ SubDetails: Item }, '../../../MasterPlansAppendix/ProductionPlanAppendix', '', LoadProductionPlanAppendix, true);
    }
    function LoadProductionPlanAppendix(r) {
        ProductionPlanAppendixDiv.innerHTML = "";
        $('#ProductionPlanAppendixDiv').html(r);
        $('#Model_ProductionPlanAppendix').modal('show');
        done();
    }
    function LoadGeneralPlanSub() {
        ProductionPlanAppendixDiv.innerHTML = "";
        $('#Model_ProductionPlanAppendix').modal('hide');
        MsgBox('@Html.Recource(475)', 'green');
        done();
    }
</script>