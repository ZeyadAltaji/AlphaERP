    function eSelectOption(e){
        debugger
        var val = e.value;
        var row = e.closest('tr');

        var toNoInput = row.querySelector('input[name="ToNo"]');
        var alertToNoInput = row.querySelector('input[name="AlertToNo"]');
        var FromNoInput = row.querySelector('input[name="FromNo"]');
        var AlertFromNoNoInput = row.querySelector('input[name="AlertFromNo"]');

        if (val == 1 || val == 2 || val == 4) {
            toNoInput.value = FromNoInput.value;
            alertToNoInput.value = AlertFromNoNoInput.value
            toNoInput.disabled = true;
            alertToNoInput.disabled = true;
        } else {
            toNoInput.value = "";
            alertToNoInput.value = "";
            toNoInput.disabled = false;
            alertToNoInput.disabled = false;
        }
        if (val == 4) {
            toNoInput.type = "text";
            alertToNoInput.type = "text";
            FromNoInput.type = "text";
            AlertFromNoNoInput.type = "text";
        } else {
            toNoInput.type = "number";
            alertToNoInput.type = "number";
            FromNoInput.type = "number";
            AlertFromNoNoInput.type = "number";
        }
    }
