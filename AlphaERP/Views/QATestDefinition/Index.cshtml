    function formatToNo(e) {
        debugger
        var row = e.closest('tr');

        var GroupQAselectVal = row.querySelector('#RangeType');
        var GroupQAselect = GroupQAselectVal.value;
        if (GroupQAselect == "1" || GroupQAselect == "2" || GroupQAselect == "4") {
            if(GroupQAselect == "4"){
                var val = e.value;
                var parentRow = $(e).closest('tr');
                var NewtoNoInput = parentRow.find('input[name="NewToNo"]');
                if(val != ''){
                    NewtoNoInput.val(val);
                }else{
                    NewtoNoInput.val();
                }
            }
            else{
                var val = parseFloat(e.value).toFixed(4);
                var parentRow = $(e).closest('tr');
                var NewtoNoInput = parentRow.find('input[name="NewToNo"]');
                if(!isNaN(val)){
                    NewtoNoInput.val(val);
                }else{
                    NewtoNoInput.val();
                }
            }

        }

    }
    function formatAlertToNo(e) {
        debugger
        var row = e.closest('tr');

        var GroupQAselectVal = row.querySelector('#RangeType');
        var GroupQAselect = GroupQAselectVal.value;
        if (GroupQAselect == "1" || GroupQAselect == "2" || GroupQAselect == "4") {
            if( GroupQAselect == "4"){
                var val = e.value;
                var parentRow = $(e).closest('tr');
                var NewalertToNoInput = parentRow.find('input[name="NewAlertToNo"]');
                if(val != ''){
                    NewalertToNoInput.val(val);
                }else{
                    NewalertToNoInput.val();
                }
            }else{
                var val = parseFloat(e.value).toFixed(4);
                var parentRow = $(e).closest('tr');
                var NewalertToNoInput = parentRow.find('input[name="NewAlertToNo"]');
                if(!isNaN(val)){
                    NewalertToNoInput.val(val);
                }else{
                    NewalertToNoInput.val();
                }
            }

        }

    }


