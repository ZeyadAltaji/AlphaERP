<script>
    $('#AlertBUSelect').select2()
    var mCData = @Html.Raw(mCJson);

    function SelectedFiles() {
        var fileInput = document.getElementById('Attachments');
        document.getElementById('SelectedAttachments').innerHTML = '';
        for (var i = 0; i < fileInput.files.length; i++) {
            var filename = fileInput.files[i].name;
            document.getElementById('SelectedAttachments').innerHTML += filename.toLowerCase() + ", ";
        }
    }

    var TestsTable = $('#SelectTestTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    var TestsTableadd = $('#SelectTestTableNew').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 100,
        "scrollX": true,
        "autoWidth": false
    });
    $('#AlertBU').select2();

    var FormNo_ = 0;
    function InsertTest() {
        debugger
        var data = TestsTable.rows('.selected').data();
        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار فحص واحد على الاقل", "Select one test at least")');
            return;
        }
        var table_ = $("#eMainTestTableBD");
        for (var i = 0; i < data.length; i++) {
            var Added = false;
            table_.find("tr").each(function () {
                var TestNo_ = $(this).find("td:first-child").text();
                if (TestNo_ == data[i][0]) {
                    Added = true;
                }
            });

            if (!Added) {
                debugger;
                var newarray = [];
                newarray.push(data[i][0])
                newarray.push(data[i][1])
                newarray.push(data[i][2])
                newarray.push('<select onchange="eSelectOption(this)" id="eGroupQAselect"  style="width:89px !important"><option value="3">@Html.Translate("بين", "Between")</option><option value="1">@Html.Translate("اكبر من ", "Greater Than")</option><option value="2">@Html.Translate("اقل من", "Less Than")</option><option value="4">@Html.Translate("نص", "Text")</option></select>');
                newarray.push('<input onblur="eformatToNo(this)"  name="FromNo"  type="number" style="width:89px !important" />')
                newarray.push('<input onblur="eformat(this)"  name="ToNo" type="number" style="width:89px !important" />')
                newarray.push('<input onblur="eformatAlertToNo(this)" name="AlertFromNo"  type="number" style="width:89px !important" />')
                newarray.push('<input onblur="eformat(this)" name="AlertToNo" type="number" style="width:89px !important" />')
                newarray.push('<button class="btn-de" onclick="RemoveRow(this)"><i class= "fa fa-trash-alt"></i ></button>')
                $("#eMainTestTableBD").append(
                    GenRow(newarray)
                );
            }

        }
        $('#Test_edit_Test').modal('hide')

    }
    function SelectOption(e){
        debugger
        var val = e.value;
        var row = e.closest('tr');

        var NewtoNoInput = row.querySelector('input[name="NewToNo"]');
        var NewalertToNoInput = row.querySelector('input[name="NewAlertToNo"]');
        var NewFromNoInput = row.querySelector('input[name="NewFromNo"]');
        var NewAlertFromNoNoInput = row.querySelector('input[name="NewAlertFromNo"]');

        if (val == 1 || val == 2 || val == 4) {
            NewtoNoInput.value = NewFromNoInput.value;
            NewalertToNoInput.value = NewAlertFromNoNoInput.value
            NewtoNoInput.disabled = true;
            NewalertToNoInput.disabled = true;
        } else {
            NewtoNoInput.value = "";
            NewalertToNoInput.value = "";
            NewtoNoInput.disabled = false;
            NewalertToNoInput.disabled = false;
        }
        if (val == 4) {
            NewtoNoInput.type = "text";
            NewalertToNoInput.type = "text";
            NewFromNoInput.type = "text";
            NewAlertFromNoNoInput.type = "text";
        } else {
            NewtoNoInput.type = "number";
            NewalertToNoInput.type = "number";
            NewFromNoInput.type = "number";
            NewAlertFromNoNoInput.type = "number";
        }
    }
    function InsertTestforadd() {
        debugger
        var data = TestsTableadd.rows('.selected').data();
        if (data.length == 0) {
            alert('@Html.Translate("يرجى اختيار فحص واحد على الاقل", "Select one test at least")');
            return;
        }
        var table_ = $("#MainTestTable");
        for (var i = 0; i < data.length; i++) {
            var Added = false;
            table_.find("tr").each(function () {
                var TestNo_ = $(this).find("td:first-child").text();
                if (TestNo_ == data[i][0]) {
                    Added = true;
                }
            });

            if (!Added) {
                debugger;
                var newarray = [];
                newarray.push(data[i][0])
                newarray.push(data[i][1])
                newarray.push(data[i][2])
                newarray.push('<select onchange="SelectOption(this)"  id="RangeType" style="width:89px !important"><option value="3">@Html.Translate("بين", "Between")</option><option value="1">@Html.Translate("اكبر من ", "Greater Than")</option><option value="2">@Html.Translate("اقل من", "Less Than")</option><option value="4">@Html.Translate("نص", "Text")</option></select>');

                newarray.push('<input onblur="formatToNo(this)"  name="NewFromNo"  type="number" style="width:89px !important" />')
                newarray.push('<input onblur="format(this)" name="NewToNo" type="number" style="width:89px !important" />')
                newarray.push('<input onblur="formatAlertToNo(this)" name="NewAlertFromNo" type="number" style="width:89px !important" />')
                newarray.push('<input  onblur="format(this)"  name="NewAlertToNo" type="number" style="width:89px !important" />')
                newarray.push('<button class="btn-de" onclick="RemoveRow(this)"><i class= "fa fa-trash-alt"></i ></button>')
                $("#MainTestTableBD").append(
                    GenRow(newarray)
                );
            }

        }
        $('#Test_Add_Test').modal('hide')

    }
    $('#Test_Add_Test').draggable({
        handle: '.modal-header'
    });
    $('#PordCost_FormTest_save_PordCost_FormTest').draggable({
        handle: '.modal-header'
    });
    $('#PordCost_FormTest_add_PordCost_FormTest').draggable({
        handle: '.modal-header'
    });
    $('#Test_edit_Test').draggable({
        handle: '.modal-header'
    });
    $('#PordCost_FormTest_save_PordCost_FormTest').on('shown.bs.modal', function () {
        $('#PordCost_FormTest_save_FormDesc').focus();
        $('#PordCost_FormTest_save_FormDesc').select();
    });

    function CreateNewPordCost_FormTest() {
        $('#addQAtestProd').load("../../../QATestDefinition/LoadAddNewQC");

        $('#PordCost_FormTest_add_PordCost_FormTest').modal('show')
        $('.div-overlay-background').css('opacity', '0.3');


    }

    function ExcutePordCost_FormTest_save_PordCost_FormTestadd() {
        debugger
        if (document.getElementById('PordCost_FormTest_save_FormDesc').value == '') { document.getElementById('PordCost_FormTest_save_FormDesc').focus(); return; }
        var trs = document.getElementById('MainTestTableBD').getElementsByTagName("tr");
        if (trs.length == 0) {
            alert('@Html.Translate("اضف فحص واحد على الاقل","Add one test at least")');
            return;
        }
        for (var i = 0; i < trs.length; i++) {
            var v1 = 0; var v2 = 0;
            var inpt = trs[i].cells[4].children[0]
            v1 = Number(inpt.value);
            if (Number(inpt.value) <= 0) { inpt.focus(); return; }
            inpt = trs[i].cells[5].children[0]
            v2 = Number(inpt.value);
            if (Number(inpt.value) <= 0) { inpt.focus(); return; }

            if (v1 > v2) {
                inpt.focus();
                MsgBox('@Html.Translate("-إلى رقم- يجب ان يكون اكبر من -من رقم-","-To No- must be greater than -From No-")', 'red');
                return;
            }
            var inpt = trs[i].cells[6].children[0]
            v3 = Number(inpt.value);
            if (Number(inpt.value) <= 0) { inpt.focus(); return; }
            inpt = trs[i].cells[7].children[0]
            v4 = Number(inpt.value);
            if (Number(inpt.value) <= 0) { inpt.focus(); return; }

            if (v3 > v4) {
                inpt.focus();
                var message = '@Html.Translate("في التنبيه يجب ان يكون الى الرقم اكبر من الرقم", "In Alert -To No- must be greater than -From No-")';

                displayNotification("warning", message);

                return;
            }


        }






        var fileUpload = $("#Attachments").get(0);
        var files = fileUpload.files;
        var formData = new FormData();
        for (var i = 0; i < files.length; i++) {
            formData.append('files', files[i]);
        }
        for (var i = 0; i < trs.length; i++) {
            debugger
            var inpt = trs[i].cells[4].children[0]
            var inpt2 = trs[i].cells[5].children[0]
            var inptAlertFromNo = trs[i].cells[6].children[0]
            var inptAlertToNo = trs[i].cells[7].children[0]
            var RangType = trs[i].cells[3].children[0]

            formData.append('Forms[' + i + '].TestNo', trs[i].cells[0].innerHTML);
            formData.append('Forms[' + i + '].FormDesc', document.getElementById('PordCost_FormTest_save_Notes').value);
            formData.append('Forms[' + i + '].Notes', trs[i].cells[1].innerHTML);
            formData.append('Forms[' + i + '].AlertBU', document.getElementById('AlertBU').value);
            formData.append('Forms[' + i + '].RangType', RangType.value);

            formData.append('Forms[' + i + '].FromNo', inpt.value);
            formData.append('Forms[' + i + '].ToNo', inpt2.value);
            formData.append('Forms[' + i + '].AlertFromNo', inptAlertFromNo.value);
            formData.append('Forms[' + i + '].AlertToNo', inptAlertToNo.value);
        }
        formData.append('FormNo', FormNo_);
        wait();
        $.ajax({
            type: 'POST',
            url: '../../../QATestDefinition/Action',
            data: formData,
            processData: false,
            contentType: false,
            success: function (data) {
                done();
                if (data.ok == 'ok') {
                    done();
                    LoadPordCost_FormTest()
                } else {
                    done(); alert(data.error)
                }
            }
        });
    }
