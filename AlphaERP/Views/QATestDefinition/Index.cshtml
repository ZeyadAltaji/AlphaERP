@model IEnumerable<AlphaERP.Models.PordCost_FormTestView>
@using AlphaERP.Models
@{
    Company company = (Company)Session["company"];

    List<ProdCost_Parameter> parameters = new MDB().ProdCost_Parameters.Where(x => x.CompNo == company.comp_num && x.ParmID == 5).ToList();
    List<ProdCost_Parameter> Groupparameters = new MDB().ProdCost_Parameters.Where(x => x.CompNo == company.comp_num && x.ParmID == 9).ToList();

    List<Alpha_BusinessUnitDef> M_C = new MDB().Alpha_BusinessUnitDef.Where(x => x.CompNo == company.comp_num).ToList();
    string mCJson = new System.Web.Script.Serialization.JavaScriptSerializer().Serialize(M_C);
    Alpha_BusinessUnitDef get = new MDB().Alpha_BusinessUnitDef.Where(x => x.CompNo == company.comp_num).FirstOrDefault();
    ProdCost_FormTest ProdCost_FormTest = new MDB().ProdCost_FormTest.Where(x => x.CompNo == company.comp_num).FirstOrDefault();
    short getAlertBU = 0;
    if (ProdCost_FormTest != null)
    {
        getAlertBU = new MDB().ProdCost_FormTest.Where(x => x.CompNo == company.comp_num && ProdCost_FormTest.AlertBU == get.BusUnitID).Select(x => x.AlertBU.Value).FirstOrDefault();
    }

}
