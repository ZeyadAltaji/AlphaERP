    function EditingPorsssdCost_FormTest(r) {
        debugger
        if (r && r.files) {
            document.getElementById('SelectedAttachments').innerHTML = r.files;
        } else {
            document.getElementById('SelectedAttachments').innerHTML = '';
        }
        $.each(r.f, function (i, item) {
            document.getElementById('PordCost_FormTest_save_FormDesc').value = item.FormDesc;
            document.getElementById('PordCost_FormTest_save_Notes').value = item.Notes;
            document.getElementById('getAlertBU').value = item.AlertBU;

        });
        var getdata = document.getElementById('getAlertBU').value;
        var select = document.getElementById('AlertBUSelect');
        select.innerHTML = ''; // Clear existing options
        var getdataNumber = parseInt(getdata);
        var translatedText  = '@Html.Translate("BusUnitDescAr_", "BusUnitDescEng_")';

        $.each(mCData, function (i, item) {
            var option = document.createElement("option");
            option.value = item.BusUnitID;
            option.text = translatedText.replace("BusUnitDescAr_", item.BusUnitDescAr).replace("BusUnitDescEng_", item.BusUnitDescEng);

            if (item.BusUnitID ===getdataNumber) {
                option.selected = true;
            }

            select.appendChild(option);
        });

        $.each(r.l, function (i, item) {
            var newarray = [];
            r.l
            newarray.push(item.ParmCode)
            newarray.push(ar())
            //newarray.push(ar(item.LocalDesc, item.EngDesc))

            var selectOptions = '<select onchange="SelectOption(this)" id="RangeType" style="width:89px !important">';
            selectOptions += '<option value="1" ' + (r.f[i].Rangtype == 1 ? 'selected' : '') + '>@Html.Translate("اكبر من ", "Greater Than")</option>';
            selectOptions += '<option value="2" ' + (r.f[i].Rangtype == 2 ? 'selected' : '') + '>@Html.Translate("اقل من", "Less Than")</option>';
            selectOptions += '<option value="3" ' + (r.f[i].Rangtype == 3 ? 'selected' : '') + '>@Html.Translate("بين", "Between")</option>';
            selectOptions += '<option value="4" ' + (r.f[i].Rangtype == 4 ? 'selected' : '') + '>@Html.Translate("قيمة الاختبار", "Test Value")</option>';
            selectOptions += '</select>';

            newarray.push(selectOptions);
            newarray.push('<input onblur="format(this, 4)" type="number" style="width:89px !important" value="' + Number(r.f[i].FromNo).toFixed(4) + '" />')
            newarray.push('<input onblur="format(this, 4)" type="number" style="width:89px !important" value="' + Number(r.f[i].ToNo).toFixed(4) + '" />')
            newarray.push('<input onblur="format(this, 4)" type="number" style="width:89px !important" value="' + Number(r.f[i].AlertFromNo).toFixed(4) + '" />')
            newarray.push('<input onblur="format(this, 4)" type="number" style="width:89px !important" value="' + Number(r.f[i].AlertToNo).toFixed(4) + '" />')
            newarray.push('<button class="btn-de" onclick="RemoveRow(this)"><i class= "fa fa-trash-alt"></i ></button>')
            $("#eMainTestTableBD").append(
                GenRow(newarray)
            );
        });
        debugger;
        $('#PordCost_FormTest_save_PordCost_FormTest').modal('show')
        $(".box-primary").addClass('Overlay');

    }
    function format(e, x) {
        if (x == null) {
            e.value = Number(e.value).toFixed(3);
        } else {
            e.value = Number(e.value).toFixed(Number(x));
        }
    }
    function eformat(e, x) {
