<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-6">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="Ord_EvalVendors_OrdYear">@Resources.Resource.Year </label>
            </div>
            <div class="col-md-2">
                <input onblur="Checkyear()" type="number" id="Ord_EvalVendors_OrdYear" value="@DateTime.Now.Year" oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);" maxlength="4" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-success btn-block" onclick="SerachOrdEvalVendors()">
                    @Resources.Resource.Search
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="Ord_EvalVendorsDiv">

    </div>
</div>

<script>
    function Checkyear() {
        if (Ord_EvalVendors_OrdYear.value < 2000) {
            Ord_EvalVendors_OrdYear.value = "@DateTime.Now.Year"
            Ord_EvalVendors_OrdYear.focus();
        }
    }
    SerachOrdEvalVendors()
    function SerachOrdEvalVendors() {
        Ord_EvalVendorsDiv.innerHTML = "";
        $('#Ord_EvalVendorsDiv').load('../../../EvalVendors/EvalVendorsList?OrdYear=' + Ord_EvalVendors_OrdYear.value);
    }

    function Delete_EvalVenodrs(OrdYear, OrdNo, TawreedNo, EvalVendId) {
        if (confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            burn({ OrdYear: OrdYear, OrderNo: OrdNo, TawreedNo: TawreedNo, EvalVendId: EvalVendId }, '../../../EvalVendors/Del_EvalVendors', '', ReloadDelEvalVendors, false);
        }
    }
    function ReloadDelEvalVendors() {
        MsgBox('@Html.Recource(2598)', 'red');
        SerachOrdEvalVendors();
    }
</script>