@*----------------------Vendor-----------------------*@
<div class="modal fade wide" id="Model_EvalVendors_OrdNo" style="inset: 35px auto auto 75px;">
    <div class="modal-dialog">
        <form class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <label class="modal-title">@Html.Recource(3795)</label>
            </div>
            <div class="modal-body row" id="OrdEvalVendors_OrdNobody">

            </div>
            <div class="modal-footer">
                <button type="button" onclick="Selecting_EvalVendors_OrdNo()" class="btn btn-primary">@Html.Recource(4599)</button>
                <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
            </div>
        </form>
    </div>
</div>
<script>
    $('#Model_EvalVendors_OrdNo').draggable({
        handle: ".modal-header",
    });
    function CheckValue(ID) {
        if (document.getElementById(ID).getAttribute('required') == 'true') {
            if (document.getElementById(ID).value == '') {
                document.getElementById(ID).focus();
                return true;
            } else {
                return false;
            }
        }
        return false;
    }
    function Serach_OrdNo() {
        if (CheckValue('Ord_EvalVendors_OrderYear')) {
            alert('@Html.Translate("يجب ادخال السنة", "You must enter the Year")');
            return;
        }

        burn({ OrdYear: Ord_EvalVendors_OrderYear.value }, '../../../EvalVendors/PR', '', ReloadtPR, true);
    }
    function ReloadtPR(r) {
        OrdEvalVendors_OrdNobody.innerHTML = "";
        $('#OrdEvalVendors_OrdNobody').html(r);
        $('#Model_EvalVendors_OrdNo').modal('show');
    }
    function Select_finPROrder(e) {
        var table = $('#Ord_PROrderTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function Selecting_EvalVendors_OrdNo() {
        var table = $('#Ord_PROrderTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار امر شراء", "Select one PR")');
            return;
        }

        Ord_EvalVendors_OrdNo.value = trs[0].getAttribute('OrderNo');
        Ord_EvalVendors_TawreedNo.value = trs[0].getAttribute('TawreedNo');
        Ord_EvalVendors_VendorNo.value = trs[0].getAttribute('VendorNo');
        Ord_EvalVendors_VendorName.value = trs[0].getAttribute('VenName');

        $('#Model_EvalVendors_OrdNo').modal('hide')
    }
    function Select_PROrder(e) {
        var table = $('#Ord_PROrderTable');
        var oTable = table.dataTable();
        var trs = oTable.$('tr[name=selected]');

        Ord_EvalVendors_OrdNo.value = trs[0].getAttribute('OrderNo');
        Ord_EvalVendors_TawreedNo.value = trs[0].getAttribute('TawreedNo');
        Ord_EvalVendors_VendorNo.value = trs[0].getAttribute('VendorNo');
        Ord_EvalVendors_VendorName.value = trs[0].getAttribute('VenName');

        $('#Model_EvalVendors_OrdNo').modal('hide')
    }
</script>

<script>
    var OrderYear = Ord_EvalVendors_OrderYear.value;
    function Checkyear(e) {
        if (Ord_EvalVendors_OrderYear.value < 2000) {
            Ord_EvalVendors_OrderYear.value = "@DateTime.Now.Year"
            Ord_EvalVendors_OrderYear.focus();
        }
        if (Ord_EvalVendors_OrderYear.value != OrderYear) {
            Ord_EvalVendors_OrdNo.value = "";
            Ord_EvalVendors_TawreedNo.value = "";
            Ord_EvalVendors_VendorNo.value = "";
            Ord_EvalVendors_VendorName.value = "";
            OrderYear = Ord_EvalVendors_OrderYear.value;
        }
        else {
            OrderYear = Ord_EvalVendors_OrderYear.value;
        }
    }
    function CheckValueGridTotlal(NotEqualZero, Amt) {
        if (NotEqualZero == '1') {
            if (Amt == '' || Amt == null || Amt <= 0) {
                return true;
            }
            else {
                return false;
            }
            return false;
        }
    }
    function ExcuteSaveOrd_EvalVendors() {
        if (Ord_EvalVendors_OrderYear.value == "") {
            alert('@Html.Translate("يجب إدخال السنة", "You Must Enter Year")');
            return;
        }
        if (Ord_EvalVendors_OrdNo.value == "") {
            alert('@Html.Translate("يجب إدخال رقم طلب الشراء", "You Must Enter P.O.No")');
            return;
        }
        if (Ord_EvalVendors_TawreedNo.value == "") {
            alert('@Html.Translate("يجب إدخال رقم امر الشراء", "You Must Enter P.R.No")');
            return;
        }
        if (Ord_EvalVendors_VendorNo.value == "") {
            alert('@Html.Translate("يجب إدخال المورد", "You Must Enter Vendor")');
            return;
        }

        var table = $('#Ord_EvalVendorsTBody tr');
        var trs = table;


        var EvalVenodrsHF = {
            CompNo: '@company.comp_num',
            Orderyear: Ord_EvalVendors_OrderYear.value,
            OrderNo: Ord_EvalVendors_OrdNo.value,
            TawreedNo: Ord_EvalVendors_TawreedNo.value,
            EvalVendId: 0,
            VendorNo: Ord_EvalVendors_VendorNo.value,
            doc: Ord_EvalVendors_Documents.value,
            recdate: Ord_EvalVendors_AgreementDate.value,
            realdate: Ord_EvalVendors_RealDeliveryDate.value,
            catdate: Ord_EvalVendors_ClassificationDate.value
        };

        var EvalVenodrsDF = new Array();
        var Count = 0;
        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i]).closest('tr').find('#EvalVendors_Mark')[0].value > 0) {
                Count = Count + 1;
            }
            EvalVenodrsDF.push({
                CompNo: '@company.comp_num',
                EvalVendId: 0,
                CodeId: $(trs[i]).closest('tr').find('#EvalVendors_CodeId')[0].innerHTML,
                Marks: $(trs[i]).closest('tr').find('#EvalVendors_Mark')[0].value
            });
        }
        if (Count < 1) {
            alert('@Html.Translate("يجب إدخال العلامة", "You Must Enter Mark")');
            return;
        }
        wait();
        burn({ EvalVenodrsHF: EvalVenodrsHF, EvalVenodrsDF: EvalVenodrsDF }, '../../../EvalVendors/Save_EvalVendors', '', ReloadEvalVendors, false);
    }
    function ReloadEvalVendors(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        CloseWindow('/EvalVendors/AddEvalVendors');
        SerachOrdEvalVendors();
    }
</script>