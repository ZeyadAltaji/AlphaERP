<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-8" style="padding:0">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
        </div>
    </div>
    <div class="box-body box-profile">
        <div class="modal-body row" style="height: calc(100vh - 210px) !important;">
            <div class="form-group">
                <div class="col-md-12">
                    <div class="col-md-2">
                        <label class="unselectable" for="Ord_EvalVendors_OrderYear">@Html.Recource(3196)</label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <input onblur="Checkyear(this.value)" type="number" id="Ord_EvalVendors_OrderYear" value="@DateTime.Now.Year" oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);" maxlength="4" />
                    </div>
                    <div class="col-md-2">
                        <label class="unselectable" for="Ord_EvalVendors_OrdNo">@Html.Recource(3197)</label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <input required="false" style="width: 125px !important;" type="text" id="Ord_EvalVendors_OrdNo" value="" disabled />
