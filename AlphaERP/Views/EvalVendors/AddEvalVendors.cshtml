                            <i class="fa fa-search" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="col-md-2">
                        <label class="unselectable" for="Ord_EvalVendors_TawreedNo">@Html.Recource(3797) </label>
                    </div>
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <input required="false" style="width: 150px !important;" type="text" id="Ord_EvalVendors_TawreedNo" value="" disabled />
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="col-md-12">
                    <div class="col-md-2" style="margin-bottom: 5px;">
                        <label class="unselectable" for="Ord_EvalVendors_VendorNo">@Html.Recource(3087)</label>
                    </div>
                    <div class="col-md-10" style="margin-bottom: 5px;">
                        <input required="false" style="width: 125px !important;" type="text" id="Ord_EvalVendors_VendorNo" value="" disabled />
