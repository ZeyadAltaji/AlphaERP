<script>
    sumTotalAll()
    function sumTotalAll() {
        var table = $('#InqPurchOrdDirectTBody tr');
        var trs = table;
        var itemTotal = 0;
        var itemTotalqty = 0;
        var totalAmount = 0;
        var vouDiscountPer = Number($('#MRP_InqPurchOrdDirect_DisPersTotal').val()) / 100;
        var vouDiscountPerItem = 0;
        var itemDiscVal = 0;
        var totalDiscVal = 0;
        var ItemTaxVal = 0;
        var totalTaxVal = 0;
        var TotalNetAmount = 0;
        var Total = 0;
        var FreightCost = 0;
        var ExtraExp = 0;
    
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            itemTotalqty += Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Qty_' + InputSerial)[0].innerHTML);
            itemTotal = Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Qty_' + InputSerial)[0].innerHTML) * Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Price_' + InputSerial)[0].innerHTML);
            itemDiscVal = (Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Qty_' + InputSerial)[0].innerHTML) * Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Price_' + InputSerial)[0].innerHTML) * Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_PerDiscount_' + InputSerial)[0].innerHTML)) / 100;
            vouDiscountPerItem = (Number(itemTotal) - Number(itemDiscVal)) * Number(vouDiscountPer);
            ItemTaxVal = (Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Qty_' + InputSerial)[0].innerHTML) * Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Price_' + InputSerial)[0].innerHTML) - Number(itemDiscVal) - Number(vouDiscountPerItem)) * (Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_ItemTaxPer_' + InputSerial)[0].innerHTML) / 100);
            //if ($(trs[i]).closest('tr').find('#InqPurchOrdDirect_ItemTaxType_' + InputSerial)[0].value == true) {
            //    ItemTaxVal = (Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Qty_' + InputSerial)[0].innerHTML) * Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Price_' + InputSerial)[0].innerHTML) - Number(itemDiscVal) - Number(vouDiscountPerItem)) * (Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_ItemTaxPer_' + InputSerial)[0].innerHTML) / 100);
            //}
            //else {
            //    ItemTaxVal = (Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Qty_' + InputSerial)[0].innerHTML) * Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_ItemTaxPer_' + InputSerial)[0].innerHTML));
            //}
            totalAmount += Number(itemTotal)
            totalDiscVal += Number(itemDiscVal);
            totalTaxVal += Number(ItemTaxVal);
            Total = (Number(itemTotal).toFixed(3) - Number(vouDiscountPerItem).toFixed(3) - Number(itemDiscVal).toFixed(3));
            $(trs[i]).closest('tr').find('#InqPurchOrdDirect_Total_' + InputSerial)[0].innerHTML = Number(Total).toFixed(3)
            TotalNetAmount += Number($(trs[i]).closest('tr').find('#InqPurchOrdDirect_Total_' + InputSerial)[0].innerHTML);
        }

        FreightCost = Number($('#MRP_InqPurchOrdDirect_FreightCost').val())
        ExtraExp = Number($('#MRP_InqPurchOrdDirect_ExtraExp').val())
        TotalNetAmount = Number(TotalNetAmount) + Number(totalTaxVal) + Number(FreightCost) + Number(ExtraExp);
        $('#MRP_InqPurchOrdDirect_Amount').val(Number(totalAmount).toFixed(3));
        $('#MRP_InqPurchOrdDirect_Discount').val(Number(totalDiscVal).toFixed(3));
        $('#MRP_InqPurchOrdDirect_TaxAmount').val(Number(totalTaxVal).toFixed(3));
        $('#MRP_InqPurchOrdDirect_TotalQty').val(Number(itemTotalqty).toFixed(3));
        $('#MRP_InqPurchOrdDirect_NetAmount').val(Number(TotalNetAmount).toFixed(3));

        var TotDiscPer = (Number($('#MRP_InqPurchOrdDirect_DisPersTotal').val()) / 100) * ($('#MRP_InqPurchOrdDirect_Amount').val() - $('#MRP_InqPurchOrdDirect_Discount').val());

        $('#MRP_InqPurchOrdDirect_DisTotal').val(Number(TotDiscPer).toFixed(3));
    }
</script>