                        <table class="table table-hover" id="InqPurchOrdDirectDocumentArchiveTable">
                            <thead>
                                <tr>
                                    <th style="text-align: center !important">@Html.Recource(66)</th>
                                    <th style="text-align: center !important">@Html.Recource(5629)</th>
                                    <th style="text-align: center !important">@Html.Recource(5630)</th>
                                    <th style="text-align: center !important">@Html.Recource(5631)</th>
                                    <th style="text-align: center !important">@Html.Recource(5632)</th>
                                    <th style="text-align: center !important">@Html.Recource(5633)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="InqPurchOrdDirectDocumentArchiveTbody" style="border-top: 1px solid #ddd;">
                                @foreach (DataRow row in DtAttachment.Rows)
                                {
                                    DateTime date = Convert.ToDateTime(row["DateUploded"].ToString());
                                    <tr>
                                        <td>
                                            <input type="text" style="text-align: center !important" id="InqPurchOrdDirect_AttachmentFiles_AttachDescAr" value="@row["Description"].ToString()" disabled />
                                        </td>
                                        <td>

                                            <a onclick="DownloadFile('@row["FileName"].ToString()','@Convert.ToBase64String((byte[])row["FileData"])')"><span class="glyphicon glyphicon-download"></span></a>
                                        </td>
                                        <td>
                                            <input id="InqPurchOrdDirectAttachmentFiles_FileName" type="text" style="text-align: center !important" value="@row["FileName"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="InqPurchOrdDirectDocumentArchive_UploadDate" type="text" style="text-align: center !important" value="@date.ToShortDateString()" disabled />
                                        </td>
                                        <td>
                                            <input id="InqPurchOrdDirectDocumentArchive_FileSize" type="text" style="text-align: center !important" value="@row["FileSize"].ToString()" disabled />
                                        </td>
                                        <td>
                                            <input id="InqPurchOrdDirectDocumentArchive_FileType" type="text" style="text-align: center !important" value="@row["ContentType"].ToString()" disabled />
                                        </td>
                                        <td></td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="CloseDocumentArchive()" class="btn btn-primary">@Resources.Resource.Close</button>
            </div>
        </form>
    </div>
</div>
<script>
    var DocumentsArchiveValue = 0;
    var Count = 0;
    $('#Model_InqPurchOrdDirectDocumentsArchive').draggable({
        handle: ".modal-header",
    });
    function AddInqPurchOrdDirectDocuments(val) {
        DocumentsArchiveValue = val;
        $('#Model_InqPurchOrdDirectDocumentsArchive').modal('show')
    }
    function DownloadFile(FileName, base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        saveByteArray(FileName, bytes)
    }
    function saveByteArray(reportName, byte) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        var fileName = reportName;
        link.download = fileName;
        link.click();
    };
    function CloseDocumentArchive() {
        $('#Model_InqPurchOrdDirectDocumentsArchive').modal('hide')
    }
</script>
@*--------------------------------END Model Documents -----------------------------*@

