                                <td class="four-col" style="text-align: center !important" id="InqPurchOrdDirect_RequestedDeliveryDate_@Srial">@OrdDF.ReqDeliveryDate.Value.ToString("yyyy-MM-dd")</td>

                                <td style="width: 45%;text-align: center;">
                                    <button onclick="InqPurchOrdDirectItemNote(@Srial)" type="button" class="btn btn-primary">@Html.Recource(3799)</button>
                                    <input type="text" id="InqPurchOrdDirect_ItemNote_@Srial" value="@OrdDF.Note" style="display:none;" />
                                </td>
