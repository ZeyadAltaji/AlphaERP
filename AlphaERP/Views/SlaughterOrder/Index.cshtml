
<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-8" style="padding:0">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="Invt_SlaughterOrderListDiv">
        @Html.Partial("~/Views/SlaughterOrder/SlaughterOrderList.cshtml")
    </div>
</div>

<script>
    function serachlaughterOrder() {
        $('#Invt_SlaughterOrderListDiv').load('../../../SlaughterOrder/SlaughterOrderList');
    }

    function DeleteSlaughterOrder(SlaughterOrderNo) {
        if (confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            burn({ SlaughterOrderNo: SlaughterOrderNo }, '../../../SlaughterOrder/Del_SlaughterOrder', '', ReloadDelSlaughterOrderInfo, false);
        }
    }
    function ReloadDelSlaughterOrderInfo() {
        MsgBox('@Html.Recource(2598)', 'red');
        serachlaughterOrder();
    }

    function PostedSlaughterOrder(SlaughterOrderNo) {
        if (confirm('@Resources.Resource.ApprovalVoucIssue')) {
            burn({ SlaughterOrderNo: SlaughterOrderNo }, '../../../SlaughterOrder/Posted_SlaughterOrder', '', ReloadPostedSlaughterOrder, false);
        }
    }
    function ReloadPostedSlaughterOrder() {
        MsgBox('@Html.Recource(475)', 'green');
        serachlaughterOrder();
    }

</script>