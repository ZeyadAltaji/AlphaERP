<script>
    $('.nav-tabs a[href="#SlaughterOrderInfo"]').tab('show')
    $('.Invt_SlaughterOrder_CboSubUnit').select2();
    $('#Invt_SlaughterOrder_CboStoreNo').select2();
    $('#Invt_SlaughterOrder_CboOutStoreNo').select2();


    $('#SelectSlaughterOrderDFBatchTable').DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25
    });

    $('#Model_SlaughterOrder_InvItemsMF').draggable({
        handle: ".modal-header",
    });
    $('#Model_SlaughterOrderDF_Batch').draggable({
        handle: ".modal-header",
    });
    $('#Model_SlaughterOrder_Batch').draggable({
        handle: ".modal-header",
    });

    function changeStoreNo(e) {
        Invt_SlaughterOrder_ItemNo.value = "";
        Invt_SlaughterOrder_ItemDesc.value = "";
        Invt_SlaughterOrder_BatchNo.value = "";
        $(".Invt_SlaughterOrder_CboSubUnit").empty().trigger("change");
        $('#SlaughterOrderDFTBody').empty();
    }
    function Add_InvItemsMF() {
        $('#SlaughterOrder_ItemsMF').empty();
        $('#SelectSlaughterOrderItemTable tr').removeClass("selected");
        $('#SlaughterOrder_ItemsMF').load('../../../SlaughterOrder/SlaughterOrderItemsList?StoreNo=' + Invt_SlaughterOrder_CboStoreNo.value);
        $('#Model_SlaughterOrder_InvItemsMF').modal('show');
    }
    function SelectSlaughterOrder_InvItems(e) {
        var trs = $('#SelectSlaughterOrderItemTable tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function GetItemNo(e) {
        var trs = $('#SelectSlaughterOrderItemTable tr[name=selected]');
        Invt_SlaughterOrder_ItemNo.value = trs[0].getAttribute('ItemNo');
        Invt_SlaughterOrder_ItemDesc.value = trs[0].getAttribute('ItemDesc');

        burn({ ItemNo: trs[0].getAttribute('ItemNo'), storeNo: Invt_SlaughterOrder_CboStoreNo.value }, '../../../SlaughterOrder/LoadUnitItem', '', LoadBatchAndUnitItem, true);
    }
    function SelectingSlaughterOrder_InvItemsMF() {
        var trs = $('#SelectSlaughterOrderItemTable tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة", "Select one Item")');
            return;
        }
        Invt_SlaughterOrder_ItemNo.value = trs[0].getAttribute('ItemNo');
        Invt_SlaughterOrder_ItemDesc.value = trs[0].getAttribute('ItemDesc');

        burn({ ItemNo: trs[0].getAttribute('ItemNo'), storeNo: Invt_SlaughterOrder_CboStoreNo.value }, '../../../SlaughterOrder/LoadUnitItem', '', LoadBatchAndUnitItem, true);


    }
    function LoadBatchAndUnitItem(r) {
        $(".Invt_SlaughterOrder_CboSubUnit").empty().trigger("change");
        for (var i = 0; i < r.unit.length; i++) {
            var newOption = new Option(r.unit[i].UnitName, r.unit[i].VSUnitCode, false, false);
            newOption.setAttribute("unitCode", r.unit[i].UnitCode)
            $(".Invt_SlaughterOrder_CboSubUnit").append(newOption).trigger('change');
        }

        Invt_SlaughterOrder_BatchNo.value = r.Batch

        burn({ ItemNo: Invt_SlaughterOrder_ItemNo.value, storeNo: Invt_SlaughterOrder_CboOutStoreNo.value, Batch: Invt_SlaughterOrder_BatchNo.value }, '../../../SlaughterOrder/LoadItemKits', '', LoadItemKits, true);

        $('#Model_SlaughterOrder_InvItemsMF').modal('hide')
    }
    function LoadItemKits(r) {
        $('#SlaughterOrderDFTBody').empty();
        $('#SlaughterOrderDFTBody').append(r);
        $('#Model_SlaughterOrder_InvItemsMF').modal('hide');
        SumTotal();
    }
    function SumTotalCostPercent(e) {
        if (e.value < 0) {
            alert('@Html.Translate("لا يجوز ان نسبة الكلفة اقل من 0", "The value of the Cost Percent may not be less than 0")');
            e.value = 0;
            e.focus()
            return false;
        }
        SumTotal()
    }
    function SumTotal(){
        var table = $('#SlaughterOrderDFTBody tr');
        var trs = table;
        var TotalCostPercent = 0;

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value
            if ($(trs[i]).closest('tr').find('#SlaughterOrderDF_Qty_' + InputSerial)[0].value > 0) {
                TotalCostPercent += Number($(trs[i]).closest('tr').find('#SlaughterOrderDF_CostPercent_' + InputSerial)[0].value);
            }
        }
        $('#Invt_SlaughterOrder_TotalCostPercent').val(Number(TotalCostPercent));
    }
    var thisValue = 0;
    function AddBatchNo(e, srl) {
        thisValue = srl;
        var trs = $('#SlaughterOrderDFTBody #SlaughterOrderDF_' + srl);

        $('#SelectSlaughterOrderDFBatchTable tr').removeClass("selected");
        $('#SelectSlaughterOrderDFBatchTbody').empty();
        $('#SelectSlaughterOrderDFBatchTbody').load('../../../SlaughterOrder/LoadItemBatch?ItemNo=' + trs.find('#SlaughterOrderDFItemNo_' + srl)[0].innerHTML +'&storeNo=' + Invt_SlaughterOrder_CboOutStoreNo.value);
        $('#Model_SlaughterOrderDF_Batch').modal('show');
    }
    function SelectSlaughterOrderDF_BatchNo(e) {
        var trs = $('#SelectSlaughterOrderDFBatchTable tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function SelectingSlaughterOrderDFBatch() {
        var trs = $('#SelectSlaughterOrderDFBatchTable tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حزمة", "Select one Batch")');
            return;
        }

        var tr = $("#SlaughterOrderDFTBody #SlaughterOrderDF_" + thisValue + "");
        tr.find('#SlaughterOrderDF_Batch_' + thisValue)[0].value = trs[0].getAttribute('BatchNo');

        $('#Model_SlaughterOrderDF_Batch').modal('hide')
    }

    function Add_BatchNo() {
        if (Invt_SlaughterOrder_ItemNo.value != "") {
            $('#SelectSlaughterOrderBatchTable tr').removeClass("selected");
            $('#SlaughterOrderBatch').empty();
            $('#SlaughterOrderBatch').load('../../../SlaughterOrder/LoadItemBatchhf?ItemNo=' + Invt_SlaughterOrder_ItemNo.value + '&storeNo=' + Invt_SlaughterOrder_CboStoreNo.value);
            $('#Model_SlaughterOrder_Batch').modal('show');
        }
    }
    function SelectSlaughterOrder_BatchNo(e) {
        var trs = $('#SelectSlaughterOrderBatchTable tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function SelectingSlaughterOrderBatch() {
        var trs = $('#SelectSlaughterOrderBatchTable tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حزمة", "Select one Batch")');
            return;
        }

        Invt_SlaughterOrder_BatchNo.value = trs[0].getAttribute('BatchNo');

        var table = $('#SlaughterOrderDFTBody tr');
        var trs = table;

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value;
            $(trs[i]).closest('tr').find('#SlaughterOrderDF_Batch_' + InputSerial)[0].value = Invt_SlaughterOrder_BatchNo.value;
        }
        $('#Model_SlaughterOrder_Batch').modal('hide')
    }
