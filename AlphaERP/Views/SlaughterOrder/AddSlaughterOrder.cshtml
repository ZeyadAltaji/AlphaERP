    function ExcuteSave_SlaughterOrder() {
        if (Invt_SlaughterOrder_ItemNo.value == "") {
            alert('@Html.Translate("يجب إدخال المادة", "You Must Enter Item")');
            return;
        }
        if (Invt_SlaughterOrder_BatchNo.value == "") {
            alert('@Html.Translate("يجب إدخال الحزمة", "You Must Enter Batch")');
            return;
        }
        if (Invt_SlaughterOrderQty.value == "" || Invt_SlaughterOrderQty.value <= 0) {
            Invt_SlaughterOrderQty.focus();
            if (@CActive.ClientNo == 335) {
                alert('@Html.Translate("يجب إدخال العدد", "You Must Enter Number")');
            }
            else {
                alert('@Html.Translate("يجب إدخال الكمية", "You Must Enter Qty")');
            }
            return;
        }

        var table = $('#SlaughterOrderDFTBody tr');
        var trs = table;

        if (trs.length == 0) {
            alert('@Html.Translate("يجب إدخال المواد", "Raw Items must be entered")');
            return false;
        }

        var SlaughterOrder = {
            CompNo: '@company.comp_num',
            SlaughterOrderNo: 0,
            SlaughterOrderDate: Invt_SlaughterOrder_Date.value,
            StoreNo: Invt_SlaughterOrder_CboStoreNo.value,
            ItemNo: Invt_SlaughterOrder_ItemNo.value,
            Batch: Invt_SlaughterOrder_BatchNo.value,
            Qty: Invt_SlaughterOrderQty.value,
            TUnit: $('.Invt_SlaughterOrder_CboSubUnit option:Selected')[0].getAttribute('unitCode'),
            UnitSerial: $('.Invt_SlaughterOrder_CboSubUnit')[0].value,
            Qty2: Invt_SlaughterOrderQty2.value,
            Notes: Invt_SlaughterOrder_Notes.value
        };

        var CountQty = 0
        var TotalCostPercent = 0

        var SlaughterOrderF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#InputSerial')[0].value;
            if ($(trs[i]).closest('tr').find('#SlaughterOrderDF_Qty_' + InputSerial)[0].value > 0) {
                if (Number($(trs[i]).closest('tr').find('#SlaughterOrderDF_CostPercent_' + InputSerial)[0].value) <= 0) {
                    alert('@Html.Translate("يجب إدخال نسبة الكلفة", "You Must Enter Cost Percentage")');
                    return false;
                }
                CountQty = CountQty + 1;
                TotalCostPercent = Number(TotalCostPercent) +  Number($(trs[i]).closest('tr').find('#SlaughterOrderDF_CostPercent_' + InputSerial)[0].value);
            }
            SlaughterOrderF.push({
                CompNo: '@company.comp_num',
                SlaughterOrderNo: 0,
                StoreNo: Invt_SlaughterOrder_CboOutStoreNo.value,
                ItemNo: $(trs[i]).closest('tr').find('#SlaughterOrderDFItemNo_' + InputSerial)[0].innerHTML,
                Batch: $(trs[i]).closest('tr').find('#SlaughterOrderDF_Batch_' + InputSerial)[0].value,
                Qty: $(trs[i]).closest('tr').find('#SlaughterOrderDF_Qty_' + InputSerial)[0].value,
                TUnit: $(trs[i]).closest('tr').find('.SlaughterOrderDFItems_Unit option:Selected')[0].getAttribute('unitCode'),
                UnitSerial: $(trs[i]).closest('tr').find('.SlaughterOrderDFItems_Unit')[0].value,
                Qty2: $(trs[i]).closest('tr').find('#SlaughterOrderDF_Qty2_' + InputSerial)[0].value,
                CostPercent: $(trs[i]).closest('tr').find('#SlaughterOrderDF_CostPercent_' + InputSerial)[0].value
            })
        }
        if (CountQty == 0) {
            alert('@Html.Translate("يجب إدخال كميات للمخرجات", "You Must Enter Qty Output")');
            return false;
        }

        if (TotalCostPercent != 100) {
            alert('@Html.Translate("يجب ان يكون مجموع نسبة الكلفة يساوي 100 %", "The total cost percentage must be equal to 100%.")');
            return false;
        }

        var CountAmount = 0;
        var ExpensesDetailstable = $('#ExpensesDetailsTBody tr');
        var trsExpensesDetails = ExpensesDetailstable;
        var OutlaySlaugh = new Array();
        for (var i = 0; i < trsExpensesDetails.length; i++) {
            if ($(trsExpensesDetails[i]).closest('tr').find('#ExpensesDetails_Amount')[0].value > 0) {
                CountAmount = CountAmount + 1;
            }
            OutlaySlaugh.push({
                CompNo: '@company.comp_num',
                SlaughterOrderNo: 0,
                DocEspCode: $(trsExpensesDetails[i]).closest('tr').find('#ExpensesDetailsItemNo')[0].getAttribute("itemcode"),
                DocEspVal: $(trsExpensesDetails[i]).closest('tr').find('#ExpensesDetails_Amount')[0].value
            })
        }
        @*if (CountAmount == 0) {
            alert('@Html.Translate("يجب إدخال القيم للمصاريف", "You Must Enter Amount Expenses")');
            $('.nav-tabs a[href="#ExpensesDetails"]').tab('show')
            return false;
        }*@
        wait();

        burn({ SlaughterOrderHF: SlaughterOrder, SlaughterOrderDF: SlaughterOrderF, OutlaySlaughter: OutlaySlaugh }, '../../../SlaughterOrder/Save_SlaughterOrder', '', ReloadSlaughterOrderInfo, false);
    }
    function ReloadSlaughterOrderInfo() {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        Invt_SlaughterOrderListDiv.innerHTML = "";
        CloseWindow('/SlaughterOrder/AddSlaughterOrder')
        serachlaughterOrder();
    }
</script>

