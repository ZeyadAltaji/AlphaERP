@using AlphaERP.Models
@using System.Data.SqlClient;
@using System.Data;
@using System.Collections.Generic;
@{
    User me = (User)Session["me"];
    Company company = (Company)Session["company"];
    long SlaughterOrderNo = ViewBag.SlaughterOrderNo;

    List<int> store = new MDB().InvStoreUsers.Where(x => x.CompNo == company.comp_num && x.UserID == me.UserID && x.AllPerm == true).Select(o => o.StoreNo).ToList();
    List<InvStoresMF> lStores = new MDB().InvStoresMFs.Where(x => x.CompNo == company.comp_num && store.Contains(x.StoreNo)).ToList();

    Invt_SlaughterOrderHF SlaughterOrderHF = new MDB().Invt_SlaughterOrderHF.Where(x => x.CompNo == company.comp_num && x.SlaughterOrderNo == SlaughterOrderNo).FirstOrDefault();
    InvItemsMF M = new MDB().InvItemsMFs.Where(x => x.CompNo == company.comp_num && x.ItemNo == SlaughterOrderHF.ItemNo).FirstOrDefault();
    List<Invt_SlaughterOrderDF> SlaughterOrderDF = new MDB().Invt_SlaughterOrderDF.Where(x => x.CompNo == company.comp_num && x.SlaughterOrderNo == SlaughterOrderNo).ToList();

    List<Invt_OutlaySlaughter> OutlaySlaughter = new MDB().Invt_OutlaySlaughter.Where(x => x.CompNo == company.comp_num && x.SlaughterOrderNo == SlaughterOrderNo).ToList();

    int Srial = 1;
    List<InvKit> Mf = new MDB().InvKits.Where(x => x.CompNo == company.comp_num).ToList();
    var litem = Mf.GroupBy(x => x.Kit_ItemNo).ToList();
    DataTable Dt = new DataTable();
    InvCompMF compMF = new MDB().InvCompMFs.Where(x => x.CompNo == company.comp_num).FirstOrDefault();
    if (compMF.UseQty2 == null)
    {
        compMF.UseQty2 = false;
    }
    List<OutlaySlaugCode> Exp = new MDB().Database.SqlQuery<OutlaySlaugCode>(string.Format("select Invt_OutlaySlaughter.DocEspCode as MinCode,InvCodes.CodeDesc,InvCodes.CodeDescEng,Invt_OutlaySlaughter.DocEspVal " +
"from Invt_OutlaySlaughter inner join InvCodes on InvCodes.CompNo = Invt_OutlaySlaughter.CompNo AND  Invt_OutlaySlaughter.DocEspCode = InvCodes.MinCode and (MajCode='DocEsp') AND (InvCodes.MinCode <> 0) " +
"where (Invt_OutlaySlaughter.CompNo = '{0}') AND (Invt_OutlaySlaughter.SlaughterOrderNo = '{1}') union all SELECT InvCodes.MinCode as MinCode,InvCodes.CodeDesc, InvCodes.CodeDescEng, 0 as DocEspVal " +
"from InvCodes LEFT OUTER JOIN Invt_OutlaySlaughter ON InvCodes.CompNo = Invt_OutlaySlaughter.CompNo AND Invt_OutlaySlaughter.DocEspCode = InvCodes.MinCode " +
"where (InvCodes.CompNo = '{0}') AND (InvCodes.MajCode = 'DocEsp')  AND (InvCodes.MinCode <> 0)  AND (Invt_OutlaySlaughter.id IS NULL) ", company.comp_num, SlaughterOrderHF.SlaughterOrderNo)).ToList();
    ClientsActive CActive = new MDB().ClientsActives.Where(x => x.CompNo == company.comp_num).FirstOrDefault();


}

