                    <button class="btn btn-default pull-left" data-dismiss="modal">@Html.Recource(15)</button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    $('.nav-tabs a[href="#eSlaughterOrderInfo_"]' + @SlaughterOrderNo).tab('show')
    $('.Invt_eSlaughterOrder_CboSubUnit_' + @SlaughterOrderNo).select2();
    $('#Invt_eSlaughterOrder_CboStoreNo_' + @SlaughterOrderNo).select2();
    $('#Invt_eSlaughterOrder_CboOutStoreNo_' + @SlaughterOrderNo).select2();
    $('#eSelectSlaughterOrderDFBatchTable_' + @SlaughterOrderNo).DataTable({
        "scrollY": 200,
        "paging": true,
        "pageLength": 25
    });

    SumTotal(@SlaughterOrderNo)
    function changeStoreNo(e, srl) {
        $("#Invt_eSlaughterOrder_ItemNo_" + srl).val("");
        $("#Invt_eSlaughterOrder_ItemDesc_" + srl).val("");
        $("#Invt_eSlaughterOrder_BatchNo_" + srl).val("");

        $(".Invt_eSlaughterOrder_CboSubUnit_" + srl).empty().trigger("change");
        $('#eSlaughterOrderDFTBody_' + srl).empty();
    }

    function Add_InvItemsMF(srl) {
        $('#eSlaughterOrder_ItemsMF_' + srl).empty();
        var table = $("#eSelectSlaughterOrderItemTable_" + srl);
        table.find('tr').removeClass("selected");

        $('#Model_eSlaughterOrder_InvItemsMF_' + srl).draggable({
            handle: ".modal-header",
        });

        $('#eSlaughterOrder_ItemsMF_' + srl).load('../../../SlaughterOrder/eSlaughterOrderItemsList?StoreNo=' + $('#Invt_eSlaughterOrder_CboStoreNo_' + srl).val() + '&SlaughterOrderNo=' + srl);

        $('#Model_eSlaughterOrder_InvItemsMF_' + srl).modal('show');
    }
    var trlength = 0;
    var id = 0;

    function GetItemNo(e, srl) {
        id = srl;
        trlength = 0;

        var table = $("#eSelectSlaughterOrderItemTable_" + srl);
        var trs = table.find('tr[name=selected]');

        $('#Invt_eSlaughterOrder_ItemNo_' + srl).val(trs[0].getAttribute('ItemNo'));
        $('#Invt_eSlaughterOrder_ItemDesc_' + srl).val(trs[0].getAttribute('ItemNo'));

        trlength = trs.length;

        burn({ ItemNo: trs[0].getAttribute('ItemNo'), storeNo: $('#Invt_eSlaughterOrder_CboStoreNo_' + srl).val() }, '../../../SlaughterOrder/LoadUnitItem', '', LoadBatchAndUnitItem, true);
    }
    function eSelectSlaughterOrder_InvItems(e, srl) {
        var table = $("#eSelectSlaughterOrderItemTable_" + srl);
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function eSelectingSlaughterOrder_InvItemsMF(srl) {
        id = srl;
        trlength = 0;
        var table = $("#eSelectSlaughterOrderItemTable_" + srl);
        var trs = table.find('tr[name=selected]');

        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار مادة", "Select one Item")');
            return;
        }

        $('#Invt_eSlaughterOrder_ItemNo_' + srl).val(trs[0].getAttribute('ItemNo'));
        $('#Invt_eSlaughterOrder_ItemDesc_' + srl).val(trs[0].getAttribute('ItemNo'));

        trlength = trs.length;
        burn({ ItemNo: trs[0].getAttribute('ItemNo'), storeNo: $('#Invt_eSlaughterOrder_CboStoreNo_' + srl).val() }, '../../../SlaughterOrder/LoadUnitItem', '', LoadBatchAndUnitItem, true);


    }
    function LoadBatchAndUnitItem(r) {
        $(".Invt_eSlaughterOrder_CboSubUnit_" + id).empty().trigger("change");
        for (var i = 0; i < r.unit.length; i++) {
            var newOption = new Option(r.unit[i].UnitName, r.unit[i].VSUnitCode, false, false);
            newOption.setAttribute("unitCode", r.unit[i].UnitCode)
            $(".Invt_eSlaughterOrder_CboSubUnit_" + id).append(newOption).trigger('change');
        }

        $('#Invt_eSlaughterOrder_BatchNo_' + id).val(r.Batch);

        burn({ Serial: trlength, ItemNo: $('#Invt_eSlaughterOrder_ItemNo_' + id).val(), storeNo: $('#Invt_eSlaughterOrder_CboOutStoreNo_' + id).val(), Batch: r.Batch, SlaughterOrderNo: id }, '../../../SlaughterOrder/eLoadItemKits', '', LoadeItemKits, true);

        $('#Model_eSlaughterOrder_InvItemsMF_' + id).modal('hide');
    }
    function LoadeItemKits(r) {
        $('#eSlaughterOrderDFTBody_' + id).empty();
        $('#eSlaughterOrderDFTBody_' + id).append(r);
        $('#Model_eSlaughterOrder_InvItemsMF_' + id).modal('hide');
        SumTotal(id);
    }
    function SumTotalCostPercent(e,srl) {
        if (e.value < 0) {
            alert('@Html.Translate("لا يجوز ان نسبة الكلفة اقل من 0", "The value of the Cost Percent may not be less than 0")');
            e.value = 0;
            e.focus()
            return false;
        }
        SumTotal(srl);
    }

    function SumTotal(id){
        var table = $('#eSlaughterOrderDFTBody_' + id).find('tr');
        var trs = table;

        var TotalCostPercent = 0;

        for (var i = 0; i < trs.length; i++) {
            var eInputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value;
            if ($(trs[i]).closest('tr').find('#eSlaughterOrderDF_Qty_' + eInputSerial)[0].value > 0) {
                TotalCostPercent += Number($(trs[i]).closest('tr').find('#eSlaughterOrderDF_CostPercent_' + eInputSerial)[0].value);
            }
        }
        $('#eInvt_SlaughterOrder_TotalCostPercent').val(Number(TotalCostPercent));
    }


    var thisValue = 0;
    function AddBatchNo(e, srl,id) {
        thisValue = srl;
        var table = $("#eSlaughterOrderDFTBody_" + id);
        var trs = table.find('#eSlaughterOrderDF_' + srl);

        $('#Model_eSlaughterOrderDF_Batch_' + id).draggable({
            handle: ".modal-header",
        });

        var storeNo = $('#Invt_eSlaughterOrder_CboOutStoreNo_' + id).val();

        $('#eSelectSlaughterOrderDFBatchTable_' + id).find('tr').removeClass("selected");
        $('#eSelectSlaughterOrderDFBatchTbody_' + id).empty();
        $('#eSelectSlaughterOrderDFBatchTbody_' + id).load('../../../SlaughterOrder/eLoadItemBatch?ItemNo=' + trs.find('#eSlaughterOrderDFItemNo_' + srl)[0].innerHTML + '&storeNo=' + storeNo + '&SlaughterOrderNo=' + id);
        $('#Model_eSlaughterOrderDF_Batch_' + id).modal('show');
    }
    function SelecteSlaughterOrderDF_BatchNo(e, srl) {
        var table = $("#eSelectSlaughterOrderDFBatchTable_" + srl);
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function SelectingeSlaughterOrderDFBatch(e,srl) {
        var table = $("#eSelectSlaughterOrderDFBatchTable_" + srl);
        var trs = table.find('tr[name=selected]');

        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حزمة", "Select one Batch")');
            return;
        }

        var table = $("#eSlaughterOrderDFTBody_" + srl);
        var tr = table.find('#eSlaughterOrderDF_' + thisValue);

        tr.find('#eSlaughterOrderDF_Batch_' + thisValue)[0].value = trs[0].getAttribute('BatchNo');

        $('#Model_eSlaughterOrderDF_Batch_' + srl).modal('hide')
    }

    function Add_BatchNo(srl) {
        var ItemNo = $('#Invt_eSlaughterOrder_ItemNo_' + srl).val();
        var storeNo = $('#Invt_eSlaughterOrder_CboStoreNo_' + srl).val();
        if (ItemNo != "") {


            $('#Model_eSlaughterOrder_Batch_' + srl).draggable({
                handle: ".modal-header",
            });
            $('#eSelectSlaughterOrderBatchTable_' + srl).find('tr').removeClass("selected");
            $('#eSlaughterOrderBatch_' + srl).empty();
            $('#eSlaughterOrderBatch_' + srl).load('../../../SlaughterOrder/eLoadItemBatchhf?ItemNo=' + ItemNo + '&storeNo=' + storeNo + '&SlaughterOrderNo=' + srl);
            $('#Model_eSlaughterOrder_Batch_' + srl).modal('show');
        }
    }
    function eSelectSlaughterOrder_BatchNo(e,srl) {
        var trs = $('#eSelectSlaughterOrderBatchTable_' + srl).find('tr');
        for (var i = 0; i < trs.length; i++) {
            trs[i].setAttribute('name', '');
            $(trs[i]).removeClass('selected');
        }
        e.setAttribute('name', 'selected');
        $(e).addClass('selected');
    }
    function eSelectingSlaughterOrderBatch(srl) {
        var trs = $('#eSelectSlaughterOrderBatchTable_' + srl).find('tr[name=selected]');
        if (trs.length == 0) {
            alert('@Html.Translate("يرجى اختيار حزمة", "Select one Batch")');
            return;
        }

        $('#Invt_eSlaughterOrder_BatchNo_' + srl).val(trs[0].getAttribute('BatchNo'));

        var table = $('#eSlaughterOrderDFTBody_' + srl).find('tr');
        var trs = table;

        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value;
            $(trs[i]).closest('tr').find('#eSlaughterOrderDF_Batch_' + InputSerial)[0].value = $('#Invt_eSlaughterOrder_BatchNo_' + srl).val();
        }

        $('#Model_eSlaughterOrder_Batch_' + srl).modal('hide')
    }
     function GetValueqty(e) {
        if (e.value < 0) {
            if (@CActive.ClientNo == 335) {
                alert('@Html.Translate("يجب أن تكون العدد أكبر من صفر", "The Number Must be Greater Than Zero")');
            }
            else {
                alert('@Html.Translate("يجب أن تكون الكمية أكبر من صفر", "The Qty Must be Greater Than Zero")');
            }
            e.value = 0;
            e.focus()
            return false;
        }
    }
    function GetValueqty2(e) {
        if (e.value < 0) {
            if (@CActive.ClientNo == 335) {
                alert('@Html.Translate("يجب أن تكون الوزن أكبر من صفر", "The Weight Must be Greater Than Zero")');
            }
            else {
                alert('@Html.Translate("يجب أن تكون الكمية 2 أكبر من صفر", "The Qty 2 Must be Greater Than Zero")');
            }
            e.value = 0;
            e.focus()
            return false;
        }
    }
    function CheckValueAmount(e) {
        if (e.value < 0) {
            alert('@Html.Translate("لا يجوز ان تكون القيمة اقل من 0", "The value of the Amount may not be less than 0")');
            e.value = 0;
            e.focus()
            return false;
        }
    }
    function ExcuteEdit_SlaughterOrder(srl) {

        if ($('#Invt_eSlaughterOrder_ItemNo_' + srl).val() == "") {
            alert('@Html.Translate("يجب إدخال المادة", "You Must Enter Item")');
            return;
        }
        if ($('#Invt_eSlaughterOrder_BatchNo_' + srl).val() == "") {
            alert('@Html.Translate("يجب إدخال الحزمة", "You Must Enter Batch")');
            return;
        }
        if ($('#Invt_eSlaughterOrderQty_' + srl).val() == "" || $('#Invt_eSlaughterOrderQty_' + srl).val() <= 0) {
            $('#Invt_eSlaughterOrderQty_' + srl).focus();
            if (@CActive.ClientNo == 335) {
                alert('@Html.Translate("يجب إدخال العدد", "You Must Enter Number")');
            }
            else {
                alert('@Html.Translate("يجب إدخال الكمية", "You Must Enter Qty")');
            }

            return;
        }

        var table = $('#eSlaughterOrderDFTBody_' + srl).find('tr');
        var trs = table;

        if (trs.length == 0) {
            alert('@Html.Translate("يجب إدخال المواد", "Raw Items must be entered")');
            return false;
        }

        var SlaughterOrder = {
            CompNo: '@company.comp_num',
            SlaughterOrderNo: $('#Invt_eSlaughterOrder_SlaughterOrdNo_' + srl).val(),
            SlaughterOrderDate: $('#Invt_eSlaughterOrder_Date_' + srl).val(),
            StoreNo: $('#Invt_eSlaughterOrder_CboStoreNo_' + srl).val(),
            ItemNo: $('#Invt_eSlaughterOrder_ItemNo_' + srl).val(),
            Batch: $('#Invt_eSlaughterOrder_BatchNo_' + srl).val(),
            Qty: $('#Invt_eSlaughterOrderQty_' + srl).val(),
            TUnit: $('.Invt_eSlaughterOrder_CboSubUnit_' + srl).find('option:Selected')[0].getAttribute('unitCode'),
            UnitSerial: $('.Invt_eSlaughterOrder_CboSubUnit_' + srl)[0].value,
            Qty2: $('#Invt_eSlaughterOrderQty2_' + srl).val(),
            Notes: $('#Invt_eSlaughterOrder_Notes_' + srl).val()
        };

        var CountQty = 0
        var TotalCostPercent = 0

        var SlaughterOrderF = new Array();
        for (var i = 0; i < trs.length; i++) {
            var InputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value;
            if ($(trs[i]).closest('tr').find('#eSlaughterOrderDF_Qty_' + InputSerial)[0].value > 0) {
                if (Number($(trs[i]).closest('tr').find('#eSlaughterOrderDF_CostPercent_' + InputSerial)[0].value) <= 0) {
                    alert('@Html.Translate("يجب إدخال نسبة الكلفة", "You Must Enter Cost Percentage")');
                    return false;
                }
                CountQty = CountQty + 1;
                TotalCostPercent = Number(TotalCostPercent) +  Number($(trs[i]).closest('tr').find('#eSlaughterOrderDF_CostPercent_' + InputSerial)[0].value);
            }
            SlaughterOrderF.push({
                CompNo: '@company.comp_num',
                SlaughterOrderNo: $('#Invt_eSlaughterOrder_SlaughterOrdNo_' + srl).val(),
                StoreNo: $('#Invt_eSlaughterOrder_CboOutStoreNo_' + srl).val(),
                ItemNo: $(trs[i]).closest('tr').find('#eSlaughterOrderDFItemNo_' + InputSerial)[0].innerHTML,
                Batch: $(trs[i]).closest('tr').find('#eSlaughterOrderDF_Batch_' + InputSerial)[0].value,
                Qty: $(trs[i]).closest('tr').find('#eSlaughterOrderDF_Qty_' + InputSerial)[0].value,
                TUnit: $(trs[i]).closest('tr').find('.eSlaughterOrderDFItems_Unit option:Selected')[0].getAttribute('unitCode'),
                UnitSerial: $(trs[i]).closest('tr').find('.eSlaughterOrderDFItems_Unit')[0].value,
                Qty2: $(trs[i]).closest('tr').find('#eSlaughterOrderDF_Qty2_' + InputSerial)[0].value,
                CostPercent: $(trs[i]).closest('tr').find('#eSlaughterOrderDF_CostPercent_' + InputSerial)[0].value
            })
        }
        if (CountQty == 0) {
            alert('@Html.Translate("يجب إدخال كميات للمخرجات", "You Must Enter Qty Output")');
            return false;
        }

        if (TotalCostPercent != 100) {
            alert('@Html.Translate("يجب ان يكون مجموع نسبة الكلفة يساوي 100 %", "The total cost percentage must be equal to 100%.")');
            return false;
        }

        var CountAmount = 0;
        var ExpensesDetailstable = $('#eExpensesDetailsTBody_' + srl).find('tr');
        var trsExpensesDetails = ExpensesDetailstable;
        var OutlaySlaugh = new Array();
        for (var i = 0; i < trsExpensesDetails.length; i++) {
            if ($(trsExpensesDetails[i]).closest('tr').find('#eExpensesDetails_Amount')[0].value > 0) {
                CountAmount = CountAmount + 1;
            }
            OutlaySlaugh.push({
                CompNo: '@company.comp_num',
                SlaughterOrderNo: $('#Invt_eSlaughterOrder_SlaughterOrdNo_' + srl).val(),
                DocEspCode: $(trsExpensesDetails[i]).closest('tr').find('#eExpensesDetailsItemNo')[0].getAttribute("itemcode"),
                DocEspVal: $(trsExpensesDetails[i]).closest('tr').find('#eExpensesDetails_Amount')[0].value
            })
        }
        @*if (CountAmount == 0) {
            alert('@Html.Translate("يجب إدخال القيم للمصاريف", "You Must Enter Amount Expenses")');
            return false;
        }*@

        wait();

        burn({ SlaughterOrderHF: SlaughterOrder, SlaughterOrderDF: SlaughterOrderF, OutlaySlaughter: OutlaySlaugh }, '../../../SlaughterOrder/Edit_SlaughterOrder', '', ReloadSelaughterOrderInfo, false);
    }
    function ReloadSelaughterOrderInfo(r) {
        done();
        MsgBox('@Html.Recource(475)', 'green');
        Invt_SlaughterOrderListDiv.innerHTML = "";
        CloseWindow('/SlaughterOrder/EditSlaughterOrder?SlaughterOrderNo=' + r.SlaughterOrderNo + '')
        serachlaughterOrder();
    }
</script>

