    function CreateWeightRate(OrdYear, OrdNo, TawreedNo, ShipSer) {
        $('#AddWeightRate').attr("href", '/WeightChangeRate/AddWeightChangeRate?OrdYear=' + OrdYear + '&OrderNo=' + OrdNo + '&TawreedNo=' + TawreedNo +  '&ShipSer=' + ShipSer + '')
        $('#AddWeightRate').click();
    }
    
</script>






