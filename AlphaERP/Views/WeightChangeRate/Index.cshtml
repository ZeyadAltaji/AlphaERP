<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-6">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa MYICON" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <label class="unselectable" for="WeightChangeRate_OrdYear">@Resources.Resource.Year </label>
            </div>
            <div class="col-md-2">
                <input onblur="Checkyear()" type="number" id="WeightChangeRate_OrdYear" value="@DateTime.Now.Year" oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);" maxlength="4" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-success btn-block" onclick="SerachShipments()">
                    @Resources.Resource.Search
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile" id="Ord_ShipmentsDiv">
        @Html.Partial("~/Views/WeightChangeRate/ShipmentsList.cshtml")
    </div>
</div>


<script>
     function Checkyear() {
         if (WeightChangeRate_OrdYear.value < 2000) {
             WeightChangeRate_OrdYear.value = "@DateTime.Now.Year"
             WeightChangeRate_OrdYear.focus();
        }
    }

    function SerachShipments() {
        Ord_OrdReceiptDiv.innerHTML = "";
        $('#Ord_OrdReceiptDiv').load('../../../WeightChangeRate/ShipmentsList?OrdYear=' + WeightChangeRate_OrdYear.value );
    }

    function DeleteWeightRate(OrdYear, OrderNo, TawreedNo, ShipSer, Ser) {
        if (confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            burn({ OrdYear: OrdYear, OrderNo: OrderNo, TawreedNo: TawreedNo, ShipSer: ShipSer, Ser: Ser }, '../../../WeightChangeRate/Del_WeightChangeRate', '', ReloadDelWeightChangeRate, false);
        }
    }
    function ReloadDelWeightChangeRate(r) {
        MsgBox('@Html.Recource(2598)', 'red');

        var TawreedNo = r.TawreedNo;
        var ShipSer = r.ShipSer;

        var table = $("#WeightRateTable tbody");
        var trs = table.find('tr');

        for (var i = 0; i < trs.length; i++) {
            if ($(trs[i])[0].getAttribute('OrdYear') == r.OrdYear && $(trs[i])[0].getAttribute('OrderNo') == r.OrdNo && $(trs[i])[0].getAttribute('TawreedNo') == TawreedNo && $(trs[i])[0].getAttribute('ShipSer') == ShipSer) {
                var nTr = $(trs[i])[0];
                wait();
                $(this).attr("opened", "details_close");
                var OrdYear = $(trs[i])[0].getAttribute('OrdYear');
                var OrderNo = $(trs[i])[0].getAttribute('OrderNo');
                var TawreedNo = $(trs[i])[0].getAttribute('TawreedNo');
                var ShipSer = $(trs[i])[0].getAttribute('ShipSer');

                $.get("../../../../WeightChangeRate/DetailsWeightChangeRate?OrdYear=" + OrdYear + '&OrderNo=' + OrderNo + '&TawreedNo=' + TawreedNo + '&ShipSer=' + ShipSer, function (data) {
                    WeightRateTable.fnOpen(nTr, data, 'details');
                    done();
                });
            }
        }
    }

</script>