<script>
    SumDifferenceQty()
    function SumDifferenceQty() {
        var table = $('#ViewPortInfo_ShipmentsInfoTBody tr');
        var trs = table;
        var ViewTotalShipmentQty1 = 0
        var ViewTotalShipmentQty2 = 0
        var ViewTotalShipment1Qty1 = 0
        var ViewTotalShipment1Qty2 = 0
        var ViewTotalDifferenceQty1 = 0
        var ViewTotalDifferenceQty2 = 0
        var Total1 = 0
        var Total2 = 0


        for (var i = 0; i < trs.length; i++) {
            var eInputSerial = $(trs[i]).closest('tr').find('#eInputSerial')[0].value
            ViewTotalShipmentQty1 += Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo_Qty_' + eInputSerial)[0].value);
            ViewTotalShipmentQty2 += Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo_Qty2_' + eInputSerial)[0].value);
            ViewTotalShipment1Qty1 += Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo1_Qty_' + eInputSerial)[0].value);
            ViewTotalShipment1Qty2 += Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo1_Qty2_' + eInputSerial)[0].value);

            ViewTotalDifferenceQty1 = Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo_Qty_' + eInputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo1_Qty_' + eInputSerial)[0].value);
            ViewTotalDifferenceQty2 = Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo_Qty2_' + eInputSerial)[0].value) - Number($(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo1_Qty2_' + eInputSerial)[0].value);

            $(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo1_difference1_' + eInputSerial)[0].value = Number(ViewTotalDifferenceQty1).toFixed(3);
            $(trs[i]).closest('tr').find('#ViewPortInfo_ShipmentsInfo1_difference2_' + eInputSerial)[0].value = Number(ViewTotalDifferenceQty2).toFixed(3);

            Total1 = Number(Total1) + Number(ViewTotalDifferenceQty1);
            Total2 = Number(Total2) + Number(ViewTotalDifferenceQty2);

        }

        $('#ViewTotalShipmentQty1').html(Number(ViewTotalShipmentQty1).toFixed(3));
        $('#ViewTotalShipmentQty2').html(Number(ViewTotalShipmentQty2).toFixed(3));
        $('#ViewTotalShipment1Qty1').html(Number(ViewTotalShipment1Qty1).toFixed(3));
        $('#ViewTotalShipment1Qty2').html(Number(ViewTotalShipment1Qty2).toFixed(3));
        $('#ViewTotalDifferenceQty1').html(Number(Total1).toFixed(3));
        $('#ViewTotalDifferenceQty2').html(Number(Total2).toFixed(3));
    }
</script>