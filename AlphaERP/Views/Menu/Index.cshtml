<script type="text/javascript">
    function FormatNumberLength(num, length) {
        var r = "" + num;
        while (r.length < length) {
            r = "0" + r;
        }
        return r;
    }
    var Collection = new Array();
    $('.dd').nestable();
    var Ce = null;
    function ms() {
        Collection = new Array();

        var LiS = document.getElementById('mainOL').getElementsByTagName('li');
        for (var i = 0; i < LiS.length; i++) {
            if (LiS[i].getAttribute('mine') == "true") {
                getMyLvL(LiS[i], FormatNumberLength(i, 6))
            }
        }
        Ready()
        function getMyLvL(e, sort) {
            if (e.parentNode.id == 'mainOL') {
                var Block = {
                    sort: sort,
                    entry: e.getAttribute('entry'),
                    inquiry: e.getAttribute('inquiry'),
                    report: e.getAttribute('report'),
                    addButton: e.getAttribute('add'),
                    updateButton: e.getAttribute('mod'),
                    deleteButton: e.getAttribute('del'),
                    ProgID: e.getAttribute('ProgID'),
                    ProgArName: e.getAttribute('AR'),
                    ProgEnName: e.getAttribute('EN'),
                    SourceForm: e.getAttribute('SFORM'),
                    Icon: e.getAttribute('mIcon'),
                    ParentID: 0
                };
                Collection.push(Block);
            } else {
                if (e.parentNode.parentNode.parentNode.id == "mainOL") {
                    var Block = {
                        sort: sort,
                        entry: e.getAttribute('entry'),
                        inquiry: e.getAttribute('inquiry'),
                        report: e.getAttribute('report'),
                        addButton: e.getAttribute('add'),
                        updateButton: e.getAttribute('mod'),
                        deleteButton: e.getAttribute('del'),
                        ProgID: e.getAttribute('ProgID'),
                        ProgArName: e.getAttribute('AR'),
                        ProgEnName: e.getAttribute('EN'),
                        SourceForm: e.getAttribute('SFORM'),
                        Icon: e.getAttribute('mIcon'),
                        ParentID: e.parentNode.parentNode.getAttribute('ProgID')
                    };
                    Collection.push(Block);
                } else {
                    var Block = {
                        sort: sort,
                        entry: e.getAttribute('entry'),
                        inquiry: e.getAttribute('inquiry'),
                        report: e.getAttribute('report'),
                        addButton: e.getAttribute('add'),
                        updateButton: e.getAttribute('mod'),
                        deleteButton: e.getAttribute('del'),
                        ProgID: e.getAttribute('ProgID'),
                        ProgArName: e.getAttribute('AR'),
                        ProgEnName: e.getAttribute('EN'),
                        SourceForm: e.getAttribute('SFORM'),
                        Icon: e.getAttribute('mIcon'),
                        ParentID: e.parentNode.parentNode.getAttribute('ProgID')
                    };
                    Collection.push(Block);
                }
            }
        }
    }


    function Ready() {

        var token = $('[name=__RequestVerificationToken]').val();
        var url = 'Menu/UpdateOrder';
        var settings = {
            "async": true,
            "crossDomain": true,
            "url": url,
            "method": "POST",
            "data": {
                __RequestVerificationToken: token,
                ids: Collection,
            }
        }
        $.ajax(settings).done(function (response) {
            if (response) {
                alert(response)
                reloadMenu()
            } else {
                reloadMenu()
            }
        });
    }
    var ProgIdc = "";
    function SetOptions(e, id) {
        ProgIdc = id;
        Ce = e;
        document.getElementById('mIcon').value = e.parentNode.parentNode.getAttribute('mIcon');
        document.getElementById('EditIcon').setAttribute('class', 'fa ' + e.parentNode.parentNode.getAttribute('mIcon'))
        document.getElementById('SFORM').value = e.parentNode.parentNode.getAttribute('SFORM');
        document.getElementById('AR').value = e.parentNode.parentNode.getAttribute('AR');
        document.getElementById('EN').value = e.parentNode.parentNode.getAttribute('EN');
        
        if (e.parentNode.parentNode.getAttribute('entry') == 'true') {
            document.getElementById('Menu_Type').value = 1;
        }
        if (e.parentNode.parentNode.getAttribute('inquiry') == 'true') {
            document.getElementById('Menu_Type').value = 2;
        }
        if (e.parentNode.parentNode.getAttribute('report') == 'true') {
            document.getElementById('Menu_Type').value = 3;
        }
        var add_ = false;
        var mod_ = false;
        var del_ = false;
        if (e.parentNode.parentNode.getAttribute('add') == 'true') { add_ = true;}
        if (e.parentNode.parentNode.getAttribute('mod') == 'true') { mod_ = true;}
        if (e.parentNode.parentNode.getAttribute('del') == 'true') { del_ = true;}
        $("#Menu_Add").prop("checked", add_);
        $("#Menu_Mod").prop("checked", mod_);
        $("#Menu_Del").prop("checked", del_);




        $('#MenuOptions').modal('show');
    }
    function DeleteMe() {
        if (!confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            return;
        }
        if (!confirm('@Resources.Resource.ConfirmDeleteDialog')) {
            return;
        }
        var token = $('[name=__RequestVerificationToken]').val();
        var url = '../../../Menu/DeleteMe';
        var settings = {
            "async": true,
            "crossDomain": true,
            "url": url,
            "method": "POST",
            "data": {
                __RequestVerificationToken: token,
                ProgId: ProgIdc,
            }
        }
        $.ajax(settings).done(function (response) {
            if (response) {
                reloadMenu();
            } else {
                reloadMenu();
            }
        });
    }
    function save() {
        //document.getElementById(0).childNodes
        if (document.getElementById('mIcon').value == "") { document.getElementById('mIcon').focus(); return }
        if (document.getElementById('SFORM').value == "") { document.getElementById('SFORM').focus(); return }
        if (document.getElementById('AR').value == "") { document.getElementById('AR').focus(); return }
        if (document.getElementById('EN').value == "") { document.getElementById('EN').focus(); return }

        var entry = false;
        var inquiry = false;
        var report = false;
        if (document.getElementById('Menu_Type').value == 1) {
            entry = true;
        }
        if (document.getElementById('Menu_Type').value == 2) {
            inquiry = true;
        }
        if (document.getElementById('Menu_Type').value == 3) {
            report = true;
        }

        var dd = Ce.parentNode.parentNode;
        dd.setAttribute('mIcon', document.getElementById('mIcon') .value);
        dd.setAttribute('SFORM', document.getElementById('SFORM').value);
        dd.setAttribute('AR', document.getElementById('AR').value);
        dd.setAttribute('EN', document.getElementById('EN').value);

        dd.setAttribute('entry', entry);
        dd.setAttribute('inquiry', inquiry);
        dd.setAttribute('report', report);

        dd.setAttribute('add', document.getElementById('Menu_Add').checked);
        dd.setAttribute('mod', document.getElementById('Menu_Mod').checked);
        dd.setAttribute('del', document.getElementById('Menu_Del').checked);



        dd.querySelectorAll('li div')[1].innerHTML = document.getElementById('AR').value + ' <> ' + document.getElementById('EN').value
        $('#MenuOptions').modal('hide');
    }
    function Add() {
        var token = $('[name=__RequestVerificationToken]').val();
        var settings = {
            "async": true,
            "crossDomain": true,
            "url": '../../../Menu/GetLastMENU',
            "method": "POST",
            "data": {
                __RequestVerificationToken: token
            },
            beforeSend: function () {
            },
            complete: function () {
            }
        }
        $.ajax(settings)
            .done(function (response) {
                if (response) {
                    document.getElementById('ProgID').value = response.last;
                    $('#ADD_S_RFQ_Menu').modal('show');
                } else {
                    alert('error')
                }
            });
    }
</script>

