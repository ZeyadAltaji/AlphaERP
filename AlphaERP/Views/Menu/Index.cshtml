<script>

    function AddToMenu() {
        if (document.getElementById('ProgArName').value == "") { document.getElementById('ProgArName').focus(); return }
        if (document.getElementById('ProgArName').value == "") { document.getElementById('ProgArName').focus(); return }
        if (document.getElementById('ProgEnName').value == "") { document.getElementById('ProgEnName').focus(); return }
        if (document.getElementById('SourceForm').value == "") { document.getElementById('SourceForm').focus(); return }
        var entry = false;
        var inquiry = false;
        var report = false;
        if (document.getElementById('Menu_Type0').value == 1) {
            entry = true;
        }
        if (document.getElementById('Menu_Type0').value == 2) {
            inquiry = true;
        }
        if (document.getElementById('Menu_Type0').value == 3) {
            report = true;
        }
        var token = $('[name=__RequestVerificationToken]').val();
        var Menu = {
            ModuleID:10,
            ProgID: document.getElementById('ProgID').value,
            ProgArName: document.getElementById('ProgArName').value,
            ProgEnName: document.getElementById('ProgEnName').value,
            SourceForm: document.getElementById('SourceForm').value,
            Icon: document.getElementById('Icon').value,
            ParentID: document.getElementById('ParentID').value,
            entry: entry,
            inquiry: inquiry,
            report: report,
            addButton: document.getElementById('Menu_Add0').checked,
            updateButton: document.getElementById('Menu_Mod0').checked,
            deleteButton: document.getElementById('Menu_Del0').checked,
        };

        var settings = {
            "async": true,
            "crossDomain": true,
            "url": '../../../Menu/AddToMenu',
            "method": "POST",
            "data": {
                __RequestVerificationToken: token,
                Menu: Menu
            },
            beforeSend: function () {
                wait();
            },
            complete: function () {
            }
        }
        $.ajax(settings)
            .done(function (response) {
                if (response) {
                    done(); $('#ADD_S_RFQ_Menu').modal('hide');
                    reloadMenu();
                } else {
                    done(); $('#ADD_S_RFQ_Menu').modal('hide');
                    reloadMenu();
                }
            });
    }

    function reloadMenu() {
        RefreshMe();
        wait();

        $('#sidebar').load('../../../Menu/ReloadMenu', function () {
            done();
        });
    }

    $('#MenuOptions').draggable({
        handle: '.modal-header'
    });

    $('#ADD_S_RFQ_Menu').draggable({
        handle: '.modal-header'
    });

</script>
