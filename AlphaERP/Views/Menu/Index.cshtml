<link href="~/Content/Menu.css" rel="stylesheet" />
@using AlphaERP.Models;
@{
    List<Menu> ListMenu = new MDB().Menus.OrderBy(x => x.sort).Where(x => x.ProgID != 9097 && x.ModuleID == 10).ToList();
}
<style>
    .divClass {
        width: 20px;
        float: right;
        margin-top: 2px;
    }

    .btnClass {
        width: 20px !important;
        height: 20px;
        font-size: 20px;
        margin-top: 8px;
    }

    .dd-list {
        max-width: max-content
    }
</style>

<style>
    ol li {
        text-align: right !important;
        direction: rtl
    }
</style>

<div class="box box-primary">
    <div class="box-body box-profile slim">
        <div>
            <div class="col-md-8" style="padding:0">
                <label style="margin:0" class="profile-username text-center">
                    <i style="margin:0 10px" class="fa fa-list" aria-hidden="true"></i>
                    MyTilTle
                </label>
            </div>
            <div class="col-md-2">
                <button class="btn btn-success btn-block" onclick="ms()">
                    <i class="fa fa-save"></i> @Resources.Resource.Update
                </button>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-block" onclick="Add()">
                    <i class="fa fa-plus"></i> @Html.Recource(32)
                </button>
            </div>
        </div>
    </div>
    <div class="box-body box-profile slim">
        <div class="dd shadowed" style="height:70vh; overflow-y:auto;width:100% !important;min-width:100% !important">
